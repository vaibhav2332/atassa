{
  "name": "atassa-md",
  "version": "5.0.0",
  "description": "Atassa, a Multi Device Whatsapp Bot built by Gifted Tech to Enhance Whatsapp Communication Experience",
  "logo": "https://files.giftedtech.co.ke/image/u90mimage.jpg",
  "keywords": ["atassa", "gifted-baileys", "gifted-btns", "gifted-api"],
  "env": {
    "SESSION_ID": {
      "description": "Put your SESSION_ID here",
      "value": "",
      "required": true
    },
    "MODE": {
      "description": "Bot mode (private or public)",
      "value": "public",
      "required": false
    },
    "TIME_ZONE": {
      "description": "Timezone",
      "value": "Africa/Nairobi",
      "required": true
    },
    "AUTO_LIKE_STATUS": {
      "description": "Auto like WhatsApp status (true/false)",
      "value": "true",
      "required": false
    },
    "AUTO_READ_STATUS": {
      "description": "Auto view WhatsApp status (true/false)",
      "value": "true",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "stack": "heroku-24"
}
