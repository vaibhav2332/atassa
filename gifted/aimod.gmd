        if (isNaN(num)) return reply('📝 `.aisettings maxhist <number>`');
        CFG.MAX_HIST = num;
        return reply(`✅ *MAX_HIST* updated to ${num} messages.`);
    }

    return reply(
        `⚙️ *AI Global Settings*\n\n` +
        `• *Max History:* ${CFG.MAX_HIST} (pruning threshold)\n` +
        `• *Auto-Enhance:* ${State.autoEnhance ? 'ON' : 'OFF'}\n` +
        `• *Rate Limit:* ${CFG.MAX_RPM} rpm / ${CFG.MAX_RPH} rph\n\n` +
        `_Usage: .aisettings <param> <value>_`
    );
});
// ==============================================================================
// 23. COMMAND: .gem — PERSONA VAULT (.gem)
// ==============================================================================

gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['gems', 'persona', 'personality'],
    category: 'ai',
    desc: 'AI persona vault. Create, list, remix, and use specialized AI personalities.',
    react: '💎'
}, async (from, Gifted, conText) => {
    const { mek, q, isSuperUser, reply } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Elite Senior Developer access required.');

    const args = q.trim().split(/\s+/);
    const sub = args[0]?.toLowerCase();
    const params = args.slice(1);

    if (sub === 'create') {
        const name = params[0]?.toLowerCase();
        const prompt = params.slice(1).join(' ');
        if (!name || !prompt) return reply('📝 *Usage:* `.gem create <name> <system_prompt>`');
        const success = Gems.save(name, prompt);
        return reply(success ? `✅ *Gem Created:* \`${name}\` is now stored in the vault.` : '❌ *Error:* Failed to save gem to database.');
    }

    if (sub === 'gen') {
        const topic = params.join(' ');
        if (!topic) return reply('📝 *Usage:* `.gem gen <topic>` (e.g., `.gem gen sarcastic gamer`)');
        const stub = await thinking(Gifted, from, mek, '🔮 *Forging Persona...*');
        const { text, err } = await askAI(`Generate a high-quality WhatsApp system prompt for an AI persona based on: ${topic}. Include specific speech patterns, emoji usage, and character traits. Return ONLY the raw system prompt text.`);
        if (err) return editMsg(Gifted, stub, `❌ *Error:* ${text}`);
        const gemName = (params[0] || 'gem').toLowerCase().slice(0, 10) + '_ai';
        Gems.save(gemName, text);
        return editMsg(Gifted, stub, `✨ *Gem Forged:* \`${gemName}\`\n\n*System Prompt Preview:*\n_${text.slice(0, 250)}..._\n\nActivate with: \`.gem use ${gemName}\``);
    }

    if (sub === 'analyze' || sub === 'clone') {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!quoted) return reply('📝 *Instruction:* Reply to a message with `.gem analyze` to clone that user\'s writing style.');
        const sample = quoted.conversation || quoted.extendedTextMessage?.text || quoted.imageMessage?.caption;
        if (!sample) return reply('❌ *Error:* No text found in the replied message.');
        const stub = await thinking(Gifted, from, mek, '🕵️ *Analyzing Style...*');
        const { text, err } = await askAI(`Analyze the following text sample and create a system prompt that perfectly replicates this user's writing style, tone, slang, and formatting.\n\nSample: "${sample}"\n\nReturn ONLY the system prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ *Error:* ${text}`);
        const gemName = 'clone_' + Date.now().toString(36);
        Gems.save(gemName, text);
        return editMsg(Gifted, stub, `🧬 *Style Cloned:* \`${gemName}\`\n\n_This AI will now mimic the replied message's vibe._\n\nUse: \`.gem use ${gemName}\``);
    }

    if (sub === 'remix') {
        const baseName = params[0]?.toLowerCase();
        const instruction = params.slice(1).join(' ');
        if (!baseName || !instruction) return reply('📝 *Usage:* `.gem remix <existing_gem> <change_instruction>`');
        const basePrompt = Gems.get(baseName);
        if (!basePrompt) return reply(`❌ *Error:* Gem \`${baseName}\` not found.`);
        const stub = await thinking(Gifted, from, mek, `🔀 *Remixing \`${baseName}\`...*`);
        const { text, err } = await askAI(`Take this existing system prompt and modify it according to the instructions. Return ONLY the new prompt.\n\nBase Prompt: ${basePrompt}\n\nInstruction: ${instruction}`);
        if (err) return editMsg(Gifted, stub, `❌ *Error:* ${text}`);
        const newName = `${baseName}_remix`;
        Gems.save(newName, text);
        return editMsg(Gifted, stub, `🔀 *Gem Remixed:* \`${newName}\` created based on \`${baseName}\`.`);
    }

    if (sub === 'list') {
        const list = Gems.list();
        if (!list.length) return reply('📭 *Vault Empty:* No custom gems found. Create one with `.gem gen`.');
        let out = '📚 *AIGems Vault*\n\n';
        list.forEach((g, i) => { out += `${i + 1}. 💎 \`${g}\`\n`; });
        out += '\n_Use `.gem view <name>` for details or `.gem use <name>` to set active persona._';
        return reply(out);
    }

    if (sub === 'view') {
        const name = params[0]?.toLowerCase();
        if (!name) return reply('📝 *Usage:* `.gem view <name>`');
        const prompt = Gems.get(name);
        if (!prompt) return reply('❌ *Error:* Gem not found.');
        return reply(`💎 *Gem Details: \`${name}\`*\n\n${prompt}`);
    }

    if (sub === 'use') {
        const name = params[0]?.toLowerCase();
        if (!name) return reply('📝 *Usage:* `.gem use <name>`');
        const prompt = Gems.get(name);
        if (!prompt) return reply('❌ *Error:* Gem not found.');
        State.dmGem = prompt;
        return reply(`✅ *Active Persona:* \`${name}\` set for Auto-Pilot.`);
    }

    if (sub === 'delete' || sub === 'del') {
        const name = params[0]?.toLowerCase();
        if (!name) return reply('📝 *Usage:* `.gem delete <name>`');
        const success = Gems.del(name);
        return reply(success ? `🗑️ *Gem Deleted:* \`${name}\` removed.` : '❌ *Error:* Gem not found.');
    }

    return reply(
        `💎 *AIGems Persona Vault*\n\n` +
        `• \`.gem list\` — View all personas\n` +
        `• \`.gem gen <topic>\` — AI generates a new persona\n` +
        `• \`.gem analyze\` — Clone style from replied msg\n` +
        `• \`.gem remix <n> <t>\` — Modify existing gem\n` +
        `• \`.gem use <name>\` — Set as active persona\n\n` +
        `_Sub-commands: create, list, gen, analyze, remix, view, use, delete_`
    );
});

// ==============================================================================
// 24. COMMAND: .gai — AI CONTROL CENTER (.gai)
// ==============================================================================

gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain', 'control'],
    category: 'ai',
    desc: 'Advanced AI control: Target, Stalk, DM mode, and Session Status.',
    react: '🧠'
}, async (from, Gifted, conText) => {
    const { mek, q, isSuperUser, reply } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Authorized Controller status required.');

    const args = q.trim().split(/\s+/);
    const sub = args[0]?.toLowerCase();
    const params = args.slice(1);

    if (sub === 'dm') {
        const toggle = params[0]?.toLowerCase();
        if (toggle === 'on') {
            State.dmActive = true;
            return reply(`📨 *DM Auto-Pilot: ✅ ENABLED*\nPersona: ${State.dmGem ? 'Custom Gem' : 'Default'}`);
        }
        if (toggle === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot: ❌ DISABLED*');
        }
        return reply(`📨 *DM Auto-Pilot:* ${State.dmActive ? '✅ ACTIVE' : '❌ INACTIVE'}`);
    }

    if (sub === 'chat') {
        const gemName = params[0]?.toLowerCase() || 'default';
        const prompt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.chats.set(from, { gem: prompt, history: [], gemName });
        return reply(`⚔️ *Chat AI Active:* Using \`${gemName}\` persona for this chat.`);
    }

    if (sub === 'target') {
        let num = params[0]?.replace(/[^0-9]/g, '');
        const gemName = params[1]?.toLowerCase() || 'default';
        
        if (!num && mek.message?.extendedTextMessage?.contextInfo?.participant) {
            num = mek.message.extendedTextMessage.contextInfo.participant.split('@')[0];
        }
        
        if (!num) return reply('📝 *Usage:* `.gai target <number> [gem]` or reply to someone.');
        
        const tjid = num + '@s.whatsapp.net';
        const prompt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.targets.set(tjid, { gem: prompt, history: [], chatId: from, gemName });
        return reply(`🤖 *Target Locked:* @${num}\n*Mode:* Local (This chat only)\n*Gem:* \`${gemName}\``, { mentions: [tjid] });
    }

    if (sub === 'stalk') {
        let num = params[0]?.replace(/[^0-9]/g, '');
        const gemName = params[1]?.toLowerCase() || 'default';
        
        if (!num && mek.message?.extendedTextMessage?.contextInfo?.participant) {
            num = mek.message.extendedTextMessage.contextInfo.participant.split('@')[0];
        }
        
        if (!num) return reply('📝 *Usage:* `.gai stalk <number> [gem]` or reply to someone.');
        
        const tjid = num + '@s.whatsapp.net'; // Normalization Fix
        const prompt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.stalkers.set(tjid, { gem: prompt, history: [], gemName });
        return reply(`🌍 *Global Stalker Active:* @${num}\n*Mode:* Global (All chats)\n*Gem:* \`${gemName}\``, { mentions: [tjid] });
    }

    if (sub === 'status') {
        const stats = Limiter.stats();
        const cbStatus = CB.open() ? `🛑 *TRIPPED*` : `🟢 *HEALTHY*`;
        
        let report = `📊 *AI System Status*\n\n` +
                     `• *DM Auto-Pilot:* ${State.dmActive ? '✅' : '❌'}\n` +
                     `• *Active Chats:* ${State.chats.size}\n` +
                     `• *Targeted Users:* ${State.targets.size}\n` +
                     `• *Global Stalkers:* ${State.stalkers.size}\n\n` +
                     `🛰️ *Load Monitor*\n` +
                     `• *Circuit:* ${cbStatus} (${CB.fails}/${CB.THRESH})\n` +
                     `• *Traffic:* ${stats.rpm} RPM | ${stats.rph} RPH\n` +
                     `• *Today:* AI:${stats.ai} | Img:${stats.img} | Err:${stats.err}\n`;
        
        return reply(report);
    }

    if (sub === 'summary') {
        const sess = State.chats.get(from) || [...State.targets.values()].find(t => t.chatId === from);
        if (!sess || !sess.history.length) return reply('❌ *Error:* No active history to summarize in this chat.');
        
        const stub = await thinking(Gifted, from, mek, '📝 *Generating Summary...*');
        const historyData = sess.history.join('\n');
        const { text, err } = await askAI(`Summarize this chat history in concise bullet points. Focus on key topics and sentiment.\n\nHistory:\n${historyData}`);
        
        return editMsg(Gifted, stub, err ? `❌ *Summary Failed:* ${text}` : `📝 *Chat Summary*\n\n${text}`);
    }

    if (sub === 'stop') {
        const type = params[0]?.toLowerCase();
        if (type === 'all') {
            State.chats.clear(); State.targets.clear(); State.stalkers.clear(); State.dmActive = false;
            return reply('☢️ *Global Stop:* All AI sessions and stalking terminated.');
        }
        State.chats.delete(from);
        return reply('🛑 *Stop:* AI session ended for this chat.');
    }

    if (sub === 'wipe') {
        if (State.chats.has(from)) {
            State.chats.get(from).history = [];
            return reply('🧹 *Memory Wiped:* Local session history cleared.');
        }
        return reply('ℹ️ No active session here to wipe.');
    }

    return reply(
        `🧠 *GAI Controller*\n\n` +
        `• \`.gai status\` — Network health & stats\n` +
        `• \`.gai dm <on/off>\` — Auto-private reply\n` +
        `• \`.gai chat [gem]\` — Reply to everyone here\n` +
        `• \`.gai target <num>\` — Auto-reply to user here\n` +
        `• \`.gai stalk <num>\` — Auto-reply to user everywhere\n` +
        `• \`.gai summary\` — Summarize current context\n` +
        `• \`.gai stop [all]\` — Terminate AI processes\n` +
        `• \`.gai wipe\` — Clear session memory`
    );
});
/**
 * .img — Advanced Image Studio
 * Sub-commands: gen, chaos, surprise, enhance, models, config
 */
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'genimg', 'drawai'],
    category: 'ai',
    desc: 'Creative AI Image Studio. Use .img help for details.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Creative tools restricted to authorized users.');

    const args = q.trim().split(/\s+/);
    const sub = args[0]?.toLowerCase();
    const promptText = args.slice(1).join(' ');

    const processGen = async (p, label, stub) => {
        const urls = await generateImage(p);
        if (!urls || !urls.length) return editMsg(Gifted, stub, '❌ *Generation Failed:* Check API status or model config.');
        await del(Gifted, stub.key);
        await sendImg(Gifted, from, urls[0], `🎨 *Vision Output*\n💭 _${p.slice(0, 150)}..._\n⚙️ \`${CFG.IMG_MODEL}\``, mek);
        if (urls.length > 1) {
            for (let i = 1; i < urls.length; i++) {
                await sendImg(Gifted, from, urls[i], `✨ *Variation ${i + 1}*`, mek);
            }
        }
    };

    if (sub === 'gen' || (!sub && q && !['chaos', 'surprise', 'enhance', 'models', 'config', 'setup', 'cache', 'help'].includes(sub))) {
        const finalPrompt = sub === 'gen' ? promptText : q;
        if (!finalPrompt) return reply('📝 *Format:* \`.img gen <detailed prompt>\`');
        await react('🎨');
        const stub = await thinking(Gifted, from, mek, '🎨 *Synthesizing Imagery...*');
        return processGen(finalPrompt, 'gen', stub);
    }

    if (sub === 'chaos') {
        const models = Object.keys(CFG.IMG_MDLS).filter(m => CFG.IMG_MDLS[m].tier === 'free');
        CFG.IMG_MODEL = models[Math.floor(Math.random() * models.length)];
        CFG.IMG_SIZE = ['1024x1024', '1792x1024', '1024x1792'][Math.floor(Math.random() * 3)];
        CFG.IMG_QUALITY = Math.random() > 0.5 ? 'hd' : 'standard';
        CFG.IMG_STYLE = Math.random() > 0.5 ? 'vivid' : 'natural';
        
        const stub = await thinking(Gifted, from, mek, '🌪️ *Initiating Chaos Protocol...*');
        const { text: chaosPrompt } = await askAI('Generate a surreal, abstract, and highly detailed image prompt that defies physics. Return ONLY the prompt.');
        await editMsg(Gifted, stub, `🌪️ *Chaos Configuration:*\nModel: \`${CFG.IMG_MODEL}\`\nSize: \`${CFG.IMG_SIZE}\`\nStyle: \`${CFG.IMG_STYLE}\``);
        return processGen(chaosPrompt || 'surreal abstract glitch art 8k', 'chaos', stub);
    }

    if (sub === 'surprise') {
        const theme = promptText || 'random masterpiece';
        const stub = await thinking(Gifted, from, mek, `🎲 *Dreaming:* "${theme}"...`);
        const { text: aiPrompt, err } = await askAI(`Create a professional, descriptive image prompt for: ${theme}. Enhance it with lighting and style keywords. Return ONLY the prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ *Dream Error:* ${aiPrompt}`);
        return processGen(aiPrompt, 'surprise', stub);
    }

    if (sub === 'enhance') {
        if (!promptText) return reply('📝 *Format:* \`.img enhance <basic prompt>\`');
        const stub = await thinking(Gifted, from, mek, '✨ *Polishing Prompt...*');
        const { text: enhanced, err } = await askAI(`Expand this image prompt into a high-quality professional version: "${promptText}". Add artistic details. Return ONLY the prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ *Enhance Error:* ${enhanced}`);
        await editMsg(Gifted, stub, `✨ *Refined Prompt:*\n\n_${enhanced}_\n\n*Generating...*`);
        return processGen(enhanced, 'enhance', stub);
    }

    if (sub === 'models') {
        const list = Object.entries(CFG.IMG_MDLS).map(([id, meta]) => `${meta.tier === 'pro' ? '👑' : '🆓'} \`${id}\` — ${meta.desc}`).join('\n');
        return reply(`📋 *Available Vision Engines*\n\n${list}\n\n*Switch:* \`.img config <engine>\``);
    }

    if (sub === 'config') {
        const [engine, res, qly] = args.slice(1);
        if (engine && CFG.IMG_MDLS[engine]) CFG.IMG_MODEL = engine;
        if (res) CFG.IMG_SIZE = res;
        if (qly) CFG.IMG_QUALITY = qly;
        return reply(`⚙️ *Vision Config Updated*\n• Engine: \`${CFG.IMG_MODEL}\`\n• Size: \`${CFG.IMG_SIZE}\`\n• Quality: \`${CFG.IMG_QUALITY}\``);
    }

    if (sub === 'setup') {
        const stub = await thinking(Gifted, from, mek, '🔧 *Validating API Keys...*');
        _iOk = false;
        const ok = await ensureInfip();
        return editMsg(Gifted, stub, ok ? `✅ *Infip Link Verified*\nActive Key: \`${_iKey.slice(0, 15)}...\`` : `❌ *Key Authentication Failed.*`);
    }

    return reply(
        `🎨 *Creative Vision Studio*\n\n` +
        `• \`.img <prompt>\` — Quick generate\n` +
        `• \`.img surprise [topic]\` — AI dreams for you\n` +
        `• \`.img chaos\` — Randomized engine/parameters\n` +
        `• \`.img enhance <prompt>\` — Better detail generation\n` +
        `• \`.img models\` — List available engines\n` +
        `• \`.img config <model> [size]\` — Adjust settings\n` +
        `• \`.img setup\` — Re-auth API keys`
    );
});

/**
 * .aitranslate — Multi-language Engine
 */
gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['gitrans', 'aitrans', 'translate'],
    category: 'ai',
    desc: 'Advanced AI Translation.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');

    const args = q.trim().split(/\s+/);
    const lang = args[0];
    const content = args.slice(1).join(' ');

    if (!lang || !content) return reply('📝 *Usage:* \`.aitranslate <language> <text>\`');

    const stub = await thinking(Gifted, from, mek, `🌐 *Translating to ${lang}...*`);
    const { text, err } = await askAI(`Translate the following text to ${lang}. Return ONLY the translated text, no conversational filler.\n\nText: ${content}`);
    
    if (err) return editMsg(Gifted, stub, `❌ *Translation Error:* ${text}`);
    return editMsg(Gifted, stub, `🌐 *Translation: ${lang}*\n\n*Original:* ${content}\n*Result:* ${text}`);
});

/**
 * .aiwrite — Content Generation Engine
 */
gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['giwrite', 'compose', 'draft'],
    category: 'ai',
    desc: 'Creative content generator (roasts, stories, emails, etc.)',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');

    const args = q.trim().split(/\s+/);
    const preset = args[0]?.toLowerCase();
    const topic = args.slice(1).join(' ');

    const prompts = {
        roast: `Write a savage, funny, but friendly WhatsApp roast about: ${topic}.`,
        story: `Write a short, engaging story (max 200 words) about: ${topic}.`,
        email: `Draft a professional email regarding: ${topic}. Include a clear subject line.`,
        caption: `Generate 5 creative social media captions with emojis for: ${topic}.`,
        bio: `Write a clever and punchy bio for: ${topic}.`,
        tweet: `Write a viral-style tweet thread about: ${topic}.`,
        apology: `Write a sincere but natural apology about: ${topic}.`,
        lyrics: `Write a short song verse and chorus about: ${topic}.`
    };

    if (!prompts[preset]) {
        return reply(`✍️ *AI Content Writer*\n\n*Presets:* \`${Object.keys(prompts).join('`, `')}\`\n\n*Usage:* \`.aiwrite <preset> <topic>\``);
    }
    if (!topic) return reply(`📝 *Format:* \`.aiwrite ${preset} <what to write about>\``);

    const stub = await thinking(Gifted, from, mek, `✍️ *Drafting ${preset}...*`);
    const { text, err } = await askAI(prompts[preset]);
    
    if (err) return editMsg(Gifted, stub, `❌ *Drafting Failed:* ${text}`);
    return editMsg(Gifted, stub, `✍️ *Result: ${preset.toUpperCase()}*\n\n${text}`);
});

/**
 * .aidecode — Vision & Context Analyzer
 */
gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['gianalyze', 'explain', 'vision'],
    category: 'ai',
    desc: 'Context-heavy explanation or vision analysis.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    let imgUrls = [];

    if (quoted?.imageMessage) {
        await react('👁️');
        const path = await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage, `dec_${Date.now()}`);
        const url = await uploadImgBB(path);
        if (url) imgUrls.push(url);
        try { if (fs.existsSync(path)) fs.unlinkSync(path); } catch(e) {}
    }

    const context = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    if (!context && !imgUrls.length && !q) return reply('🔍 *Context Missing:* Reply to a message or image with \`.aidecode [focus]\`');

    const stub = await thinking(Gifted, from, mek, '🔍 *Analyzing Context...*');
    const prompt = imgUrls.length 
        ? `Analyze this image in depth. ${q ? 'Specific question: ' + q : 'Explain what is happening and identify key elements.'}`
        : `Deeply analyze and explain this message: "${context}". ${q ? 'Focus on: ' + q : 'Break down the meaning, tone, and intent.'}`;

    const { text, err } = await askAI(prompt, imgUrls);
    if (err) return editMsg(Gifted, stub, `❌ *Analysis Failed:* ${text}`);
    return editMsg(Gifted, stub, `🔍 *AI Insights*\n\n${text}`);
});
// ==============================================================================
// 18.  EVENT WATCHER — AUTO-REPLY, STALK & AUTO-ENHANCE
// ==============================================================================
let _isWatching = false;

/**
 * @function attachWatcher
 * @description Main event loop for AI automation. Manages stalking, targeting, and DMs.
 */
const attachWatcher = (Gifted) => {
    if (_isWatching || !Gifted?.ev) return;
    _isWatching = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.remoteJid === 'status@broadcast') continue;

                const fromMe  = msg.key.fromMe;
                const chatId  = msg.key.remoteJid || '';
                const sender  = msg.key.participant || msg.key.remoteJid || '';
                const isGrp   = chatId.endsWith('@g.us');
                const body    = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';
                
                // Normalize sender ID for stalking/targeting lookups
                const cleanSender = sender.split(':')[0].split('@')[0] + '@s.whatsapp.net';

                // --- 1. AUTO-ENHANCE OWN MESSAGES ---
                if (fromMe && State.autoEnhance && body.length > 10 && !body.startsWith('.')) {
                    // Delay slightly to allow the message to land first
                    setTimeout(async () => {
                        try {
                            const { text: improved, err } = await askAI(
                                "Act as a text refiner. Fix grammar, spelling, and flow while keeping the intent and language identical. " +
                                "Return ONLY the corrected text. No quotes, no intro, no chatter.\n\nText: " + body
                            );
                            if (!err && improved.trim() && improved.trim().toLowerCase() !== body.trim().toLowerCase()) {
                                await Gifted.sendMessage(chatId, { text: improved.trim(), edit: msg.key });
                            }
                        } catch (e) { /* silent fail for edit errors */ }
                    }, 1500);
                    continue;
                }

                // If message is from me or a command, ignore for auto-reply
                if (fromMe || body.startsWith('.') || body.startsWith('/') || body.startsWith('!')) continue;

                // --- 2. LOGIC SELECTION: STALK -> TARGET -> CHAT -> DM ---
                let sess = null;

                // Priority 1: Global Stalker (User is tracked in every chat)
                if (State.stalkers.has(cleanSender)) {
                    sess = State.stalkers.get(cleanSender);
                } 
                // Priority 2: Specific Target (User tracked in current chat or globally)
                else if (State.targets.has(cleanSender)) {
                    const targetData = State.targets.get(cleanSender);
                    if (!targetData.chatId || targetData.chatId === chatId) {
                        sess = targetData;
                    }
                } 
                // Priority 3: Chat AI (Everyone in this specific chat triggers AI)
                else if (State.chats.has(chatId)) {
                    sess = State.chats.get(chatId);
                } 
                // Priority 4: DM Auto-Pilot
                else if (!isGrp && State.dmActive) {
                    if (!State.dmSessions.has(cleanSender)) {
                        State.dmSessions.set(cleanSender, { 
                            gem: State.dmGem || State.PERSONA, 
                            history: [], 
                            gemName: 'dm_autopilot' 
                        });
                    }
                    sess = State.dmSessions.get(cleanSender);
                }

                if (!sess) continue;

                // --- 3. EXECUTE AI RESPONSE ---
                setImmediate(async () => {
                    try {
                        let imgUrls = [];
                        const inputTxt = body || (msg.message.imageMessage ? '[User sent an image]' : '[Unsupported Message]');

                        // Handle vision if message is an image
                        if (msg.message.imageMessage) {
                            const tmpPath = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, `watch_${Date.now()}`);
                            if (tmpPath) {
                                const url = await uploadImgBB(tmpPath);
                                if (url) imgUrls.push(url);
                                try { fs.unlinkSync(tmpPath); } catch (_) {}
                            }
                        }

                        // Update session history
                        State.addHist(sess, 'User', inputTxt);

                        // Human-like delay simulation
                        const typingTime = Math.min(inputTxt.length * 30, 3000) + 800;
                        await sleep(typingTime);
                        
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}

                        const prompt = State.buildPrompt(sess.gem, sess.history, inputTxt);
                        const { text: aiResponse, err } = await askAI(prompt, imgUrls);

                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (_) {}

                        if (err || !aiResponse.trim()) return;

                        State.addHist(sess, 'AI', aiResponse);

                        // Construct quoted message for response
                        const quotedMsg = {
                            key: {
                                remoteJid: chatId,
                                fromMe: false,
                                id: msg.key.id,
                                participant: isGrp ? sender : undefined
                            },
                            message: msg.message
                        };

                        await Gifted.sendMessage(chatId, { text: aiResponse }, { quoted: quotedMsg });

                    } catch (e) {
                        console.error(`[AIGems] Watcher Reply Error (${cleanSender}):`, e.message);
                    }
                });

            } catch (e) {
                console.error('[AIGems] Global Watcher Exception:', e.message);
            }
        }
    });

    console.log('✅ [AIGems] Watcher: Live and monitoring events.');
};

// ==============================================================================
// 19.  BOOT LOGIC & EXPORTS
// ==============================================================================

/**
 * Boot interval to ensure the watcher attaches to the global connection
 * even if this module loads before the connection is established.
 */
const bootInterval = setInterval(() => {
    const G = global.conn || global.client || global.Gifted;
    if (G) {
        attachWatcher(G);
        clearInterval(bootInterval);
    }
}, 3000);

// Immediate check on load
const G = global.conn || global.client || global.Gifted;
if (G) {
    attachWatcher(G);
    clearInterval(bootInterval);
}

console.log('🚀 [AIGems] Module fully initialized.');

module.exports = {
    AIGems: {
        State,
        Gems,
        Limiter,
        CB,
        askAI,
        generateImage,
        uploadImgBB,
        config: CFG,
        attach: attachWatcher
    }
};
