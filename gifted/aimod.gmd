gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'draw', 'genimg'],
    category: 'ai',
    desc: 'Generate high-quality AI images.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const prompt = q.trim();
    if (!prompt) return reply('*📝 Usage:* `.img <detailed_prompt>`\n_Try: .img a neon cyberpunk city in the rain, 8k_');

    await react('⏳');
    const stub = await thinking(Gifted, from, mek, `*🎨 Visualizing:* _"${prompt.slice(0, 50)}..."_`);

    const urls = await generateImage(prompt, {
        model: CFG.IMG_MODEL,
        size: CFG.IMG_SIZE,
        quality: CFG.IMG_QUALITY,
        style: CFG.IMG_STYLE
    });

    if (!urls || urls.length === 0) {
        return editMsg(Gifted, stub, '*❌ Generation failed. The neural engine is busy or the prompt was blocked.*');
    }

    await del(Gifted, stub.key);
    await react('✨');

    const caption = `*🎨 AI GENERATION*\n\n*Prompt:* _${prompt}_\n*Model:* \`${CFG.IMG_MODEL}\`\n*Dimensions:* \`${CFG.IMG_SIZE}\``;
    
    return sendImg(Gifted, from, urls[0], caption, mek);
});

// ==============================================================================
// 22. ADVANCED IMAGE SUITE — EXTENDED INFIP CAPABILITIES
// ==============================================================================

gmd({
    pattern: 'imgbatch',
    cmdname: 'imgbatch',
    aliases: ['batchimg', 'multiimg'],
    category: 'ai',
    desc: 'Generate up to 4 variations of an image at once.',
    react: '🎴',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const parts = q.trim().split(/\s+/);
    let count = parseInt(parts[0]);
    let prompt = parts.slice(1).join(' ');

    if (isNaN(count) || count < 1 || count > 4) {
        count = 4;
        prompt = q.trim();
    }

    if (!prompt) return reply('*📝 Usage:* `.imgbatch <1-4> <prompt>`');

    await react('⏳');
    const stub = await thinking(Gifted, from, mek, `*🎴 Generating batch of ${count}...*`);

    const urls = await generateImage(prompt, {
        count: count,
        model: CFG.IMG_MODEL,
        size: CFG.IMG_SIZE
    });

    if (!urls || urls.length === 0) {
        return editMsg(Gifted, stub, '*❌ Batch generation failed.*');
    }

    await del(Gifted, stub.key);
    for (let i = 0; i < urls.length; i++) {
        const cap = i === 0 ? `*🎴 Batch Result (1/${urls.length})*\n_Prompt: ${prompt}_` : `*Variation ${i + 1}*`;
        await sendImg(Gifted, from, urls[i], cap, mek);
        await sleep(500); 
    }
});

gmd({
    pattern: 'imgaspect',
    cmdname: 'imgaspect',
    aliases: ['ratio', 'resize'],
    category: 'ai',
    desc: 'Set the aspect ratio for image generation.',
    react: '📐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const ratio = q.trim().toLowerCase();
    const map = {
        'sq': '1024x1024',
        'square': '1024x1024',
        'port': '1024x1792',
        'portrait': '1024x1792',
        'land': '1792x1024',
        'landscape': '1792x1024',
        'wide': '1792x1024'
    };

    if (!map[ratio]) {
        return reply(`*📐 Aspect Ratios*\n\n` +
                     `• \`.imgaspect sq\` — Square (1024x1024)\n` +
                     `• \`.imgaspect port\` — Portrait (1024x1792)\n` +
                     `• \`.imgaspect land\` — Landscape (1792x1024)\n\n` +
                     `*Current:* \`${CFG.IMG_SIZE}\``);
    }

    CFG.IMG_SIZE = map[ratio];
    return reply(`*✅ Image ratio set to:* \`${CFG.IMG_SIZE}\` (${ratio})`);
});

gmd({
    pattern: 'imgvary',
    cmdname: 'imgvary',
    category: 'ai',
    desc: 'Generate a creative variation of a prompt.',
    react: '🌀',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    let basePrompt = q.trim();
    if (!basePrompt) {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        basePrompt = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    }

    if (!basePrompt) return reply('*📝 Usage:* Reply to a prompt or text with `.imgvary`');

    const stub = await thinking(Gifted, from, mek, '*🌀 Reimagining prompt...*');
    const { text: newPrompt, err } = await askAI(`Rewrite this image prompt to be a unique variation while keeping the same core subject. Add different lighting or artistic style. Return ONLY the new prompt:\n\n"${basePrompt}"`);

    if (err) return editMsg(Gifted, stub, `*❌ AI Error:* ${newPrompt}`);

    await editMsg(Gifted, stub, `*🌀 New Perspective:* _"${newPrompt.slice(0, 100)}..."_`);
    const urls = await generateImage(newPrompt);

    if (!urls || urls.length === 0) return editMsg(Gifted, stub, '*❌ Failed to generate variation.*');

    await del(Gifted, stub.key);
    return sendImg(Gifted, from, urls[0], `*🌀 Variation*\n\n*Original:* _${basePrompt.slice(0, 50)}..._\n*New:* _${newPrompt}_`, mek);
});

