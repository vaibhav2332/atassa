// ==============================================================================
// 13.  .apimon  — API MONITOR & SYSTEM DIAGNOSTICS
// ==============================================================================

gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    aliases: ['apistat', 'aihealth', 'diag'],
    category: 'ai',
    desc: 'Monitor AI API health, usage stats, and circuit status.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'status';

    if (cmd === 'status' || !q.trim()) {
        const s = Limiter.stats();
        const cbStatus = CB.open() ? '🔴 *TRIPPED* (Cooldown)' : `🟢 *ACTIVE* (${CB.fails}/${CB.THRESH})`;
        const bar = (v, max, l = 10) => {
            const filled = Math.min(l, Math.round((v / max) * l));
            return '🟩'.repeat(filled) + '⬜'.repeat(Math.max(0, l - filled));
        };

        return reply(
            `📊 *AI SYSTEM MONITORING*\n\n` +
            `*Circuit Breaker:* ${cbStatus}\n` +
            `*RPM (1m):* ${bar(s.rpm, CFG.MAX_RPM)} \`${s.rpm}/${CFG.MAX_RPM}\` \n` +
            `*RPH (1h):* ${bar(s.rph, CFG.MAX_RPH)} \`${s.rph}/${CFG.MAX_RPH}\` \n\n` +
            `*Daily Consumption:* \n` +
            `• 🧠 AI Text: \`${s.ai}\` reqs\n` +
            `• 🎨 AI Image: \`${s.img}\` reqs\n` +
            `• ⚠️ API Errors: \`${s.err}\` \n\n` +
            `*Resources:*\n` +
            `• Active Sessions: \`${State.chats.size + State.dmSessions.size}\` \n` +
            `• Tracked Targets: \`${State.targets.size + State.stalkers.size}\` \n` +
            `• DB Gems: \`${Gems.list().length}\``
        );
    }

    if (cmd === 'health') {
        const stub = await thinking(Gifted, from, mek, '🔍 _Running Deep Health Check..._');
        const results = [];
        
        // 1. Check QuillBot
        const { text: qCheck, err: qErr } = await askAI('Respond ONLY with: OK');
        results.push( (!qErr && qCheck.includes('OK')) ? '✅ *AI Text:* Reachable' : '❌ *AI Text:* Critical/Blocked' );

        // 2. Check Infip
        const iOk = await ensureInfip();
        results.push( iOk ? '✅ *AI Image:* Connected' : '❌ *AI Image:* Keys Exhausted' );

        // 3. Check DB
        try { 
            db.prepare('SELECT 1').get(); 
            results.push('✅ *Database:* SQLite Responsive'); 
        } catch(e) { results.push('❌ *Database:* Locked/Corrupt'); }

        return editMsg(Gifted, stub, `🔍 *SYSTEM DIAGNOSTICS*\n\n${results.join('\n')}\n\n_Checked at: ${new Date().toLocaleTimeString()}_`);
    }

    if (cmd === 'reset') {
        const type = parts[1]?.toLowerCase();
        if (type === 'circuit') { CB.reset(); return reply('✅ Circuit breaker manually reset.'); }
        if (type === 'stats') { Limiter.daily = { ai: 0, img: 0, err: 0, day: new Date().toDateString() }; return reply('✅ Daily usage stats wiped.'); }
        return reply('📝 `.apimon reset <circuit|stats>`');
    }

    return reply(`📊 *APIMON SUB-COMMANDS*\n\n• \`.apimon status\` — View load and limits\n• \`.apimon health\` — Live API ping test\n• \`.apimon reset\` — Clear errors/stats`);
});

