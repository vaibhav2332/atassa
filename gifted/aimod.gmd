gmd({
    pattern:'autoenhance', cmdname:'autoenhance', category:'ai', desc:'Toggle AI auto-correction.', react:'✍️', filename:__filename
}, async (from, Gifted, conText) => {
    const { q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const a=q.trim().toLowerCase();
    if(a==='on')  { State.autoEnhance=true;  return reply('✍️ *Auto-Enhance: ON*'); }
    if(a==='off') { State.autoEnhance=false; return reply('✍️ *Auto-Enhance: OFF*'); }
    return reply(`✍️ *Status:* ${State.autoEnhance?'✅ ON':'❌ OFF'}`);
});

