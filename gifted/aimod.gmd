// ==============================================================================
// 3. WHATSAPP MARKDOWN UTILITY (WAMarkdown)
// ==============================================================================
/**
 * @class WAMarkdown
 * @description Enforces and cleans WhatsApp-specific formatting to ensure AI 
 * responses are compatible with the WhatsApp UI.
 */
class WAMarkdown {
    /**
     * @static
     * @property {string} STRICTURE
     * @description The system instruction that forces the AI to output WA-compatible markdown.
     */
    static STRICTURE = 'Your response MUST use WhatsApp markdown: *bold* for emphasis, _italics_ for tone, ```code``` for technical parts, and - for bullet points. Do not use LaTeX-style delimiters like \\( or \\).';

    /**
     * @method injectFormattingInstruction
     * @param {string} prompt - The original user or system prompt.
     * @returns {string} The prompt with strict formatting rules appended.
     */
    static injectFormattingInstruction(prompt) {
        if (!prompt) return this.STRICTURE;
        return `${prompt}\n\n[SYSTEM CONSTRAINT]: ${this.STRICTURE}`;
    }

    /**
     * @method sanitize
     * @param {string} text - Raw AI output.
     * @returns {string} Text cleaned of LaTeX, Markdown-V2 artifacts, and unnecessary escapes.
     */
    static sanitize(text) {
        if (typeof text !== 'string') return '';

        return text
            // Remove common LaTeX delimiters often hallucinated by LLMs
            .replace(/\\\(|\\\)/g, '') 
            .replace(/\\\[|\\\]/g, '')
            // Remove markdown headers (# Title) which WA doesn't support (replace with Bold)
            .replace(/^#+\s+(.*)$/gm, '*$1*')
            // Fix escaped characters that AI might produce (\_ becoming _)
            .replace(/\\([_!*`#\-\[\]])/g, '$1')
            // Ensure lists use hyphens (common AI issue with * in lists)
            .replace(/^\s*[\*\+]\s+/gm, '- ')
            .trim();
    }
}

