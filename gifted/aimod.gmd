//  .caption — AI CAPTION GENERATOR (NEW)
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'caption',
        aliases : ['aicaption', 'postcaption', 'igcaption'],
        category: 'ai',
        react   : '📝',
        desc    : 'AI generates social media captions for an image',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        await editOrReply(Gifted, from, mek, '📝 *Writing captions...*');

        let imgUrl = await getQuotedImageUrl(mek, Gifted);
        const context = q || '';
        const basePrompt = imgUrl
            ? `Generate 3 creative social media captions for this image. ${context ? `Context: ${context}` : ''}`
            : `Generate 3 creative social media captions for: "${context||'a post'}"`;

        const r = await qbRequest(basePrompt, imgUrl ? [imgUrl] : []);
        return editOrReply(Gifted, from, mek, `📝 *Captions*\n\n${r}`);
    }
);



// ═══════════════════════════════════════════════════════════════════════════
//  .aidesk — MULTI-UTILITY AI COMMAND CENTER
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'aidesk',
        aliases : ['aihub', 'aicontrol', 'gptdesk'],
        category: 'ai',
        react   : '🧩',
        desc    : '20+ AI utility actions from one command',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        const parts = (q || '').trim().split(/\s+/);
        const action = (parts.shift() || '').toLowerCase();
        const input = parts.join(' ').trim();
        if (!action) return editOrReply(Gifted, from, mek, 'Usage: *.aidesk <summarize|rewrite|plan|email|tweet|translate|json|table|regex|sql|debug|review|prompt|compare|interview|study|todo|decision|caption|explain|brainstorm> <text>*');

        const actions = {
            summarize:'Summarize into bullet points.', rewrite:'Rewrite in better natural English preserving meaning.',
            plan:'Create a step-by-step practical plan.', email:'Write a professional email.',
            tweet:'Write 3 tweet options.', translate:'Translate to English unless target language specified in request.',
            json:'Return structured JSON only.', table:'Return markdown table.', regex:'Generate regex with explanation.',
            sql:'Write SQL query and brief notes.', debug:'Debug this issue and provide fix strategy.',
            review:'Do a code review style critique.', prompt:'Turn this into a strong AI prompt.',
            compare:'Compare options with pros/cons.', interview:'Generate interview Q&A set.',
            study:'Create a study guide.', todo:'Convert into prioritized TODO list.',
            decision:'Provide decision matrix and recommendation.', caption:'Generate 5 catchy captions.',
            explain:'Explain simply with analogy.', brainstorm:'Generate 10 creative ideas.'
        };
        if (!actions[action]) return editOrReply(Gifted, from, mek, `Unknown action: *${action}*`);
        if (!input) return editOrReply(Gifted, from, mek, `Please provide input text for *${action}*.`);

        await editOrReply(Gifted, from, mek, `🧩 Working on *${action}*...`);
        const resp = await smartAI(`${actions[action]}\n\nInput:\n${input}`, [], conText);
        return editOrReply(Gifted, from, mek, `🧩 *AIDesk · ${action}*\n\n${resp}`);
    }
);
