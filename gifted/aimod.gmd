// ==============================================================================
// 18.  EVENT WATCHER — THE AUTO-PILOT & REACTIVE ENGINE
// ==============================================================================

/**
 * @section Reactive Watcher
 * @description Background listener for stalking, auto-reply, and auto-enhance.
 */

let _watchDone = false;

/**
 * Attaches the main message listener to the Gifted instance.
 * @param {Object} Gifted - The Baileys/Gifted client socket.
 */
const attachWatcher = (Gifted) => {
    if (_watchDone || !Gifted?.ev) return;
    _watchDone = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.id.startsWith('BAE5')) continue;

                const fromMe = msg.key.fromMe;
                const chatId = msg.key.remoteJid || '';
                const sender = (msg.key.participant || msg.key.remoteJid || '').split(':')[0].split('@')[0] + '@s.whatsapp.net';
                const isGrp = chatId.endsWith('@g.us');
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                // --- 1. OWNER AUTO-ENHANCE ---
                if (fromMe && State.autoEnhance && body.length > 8 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        try {
                            const { text: enhanced, err } = await askAI(`Strictly fix grammar and spelling. Keep tone. Markdown only. Text: "${body}"`);
                            if (!err && enhanced && enhanced.trim().toLowerCase() !== body.trim().toLowerCase()) {
                                await sleep(1500);
                                await Gifted.sendMessage(chatId, { text: enhanced.trim(), edit: msg.key });
                            }
                        } catch (e) {}
                    });
                    continue;
                }

                if (fromMe || body.startsWith('.')) continue;

                // --- 2. SESSION RESOLVER ---
                let activeSession = null;
                if (State.stalkers.has(sender)) {
                    activeSession = State.stalkers.get(sender);
                } else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (!targetData.chatId || targetData.chatId === chatId) activeSession = targetData;
                } else if (State.chats.has(chatId)) {
                    activeSession = State.chats.get(chatId);
                } else if (!isGrp && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { gem: State.dmGem || State.PERSONA, history: [], gemName: 'dm_auto' });
                    }
                    activeSession = State.dmSessions.get(sender);
                }

                if (!activeSession) continue;

                // --- 3. NEURAL REPLY ---
                setImmediate(async () => {
                    try {
                        let attachedImages = [];
                        if (msg.message.imageMessage) {
                            const tempPath = path.join(__dirname, `tmp_w_${Date.now()}.jpg`);
                            try {
                                const localFile = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, tempPath);
                                const imageUrl = await uploadImgBB(localFile);
                                if (imageUrl) attachedImages.push(imageUrl);
                                if (fs.existsSync(localFile)) fs.unlinkSync(localFile);
                            } catch (e) {}
                        }

                        const input = body || "[image]";
                        State.addHist(activeSession, 'User', input);

                        const finalPrompt = State.buildPrompt(activeSession.gem, activeSession.history, input);
                        
                        await sleep(2000 + Math.random() * 2000);
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}

                        const { text: response, err } = await askAI(finalPrompt, attachedImages);
                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (_) {}

                        if (err && CB.open()) return;

                        State.addHist(activeSession, 'AI', response);
                        await Gifted.sendMessage(chatId, { text: response }, { quoted: msg });
                    } catch (e) { console.error('[AIGems] Watcher Error:', e.message); }
                });
            } catch (e) { console.error('[AIGems] Global Watcher Failure:', e.message); }
        }
    });
    console.log('[AIGems] ⚡ Watcher Logic Hooked to Socket');
};

