    autoEnhance: false,
    DEFAULT_PERSONA: 'You are an Elite AI Assistant. Respond concisely. Never mention you are an AI.' + CFG.MARKDOWN_REQ,
    
    /**
     * Context History Handler
     */
    addHist(ctx, role, txt) { 
        if (!ctx.history) ctx.history = []; 
        const timestamp = new Date().toLocaleTimeString('en', { hour12: false, hour: '2-digit', minute: '2-digit' }); 
        ctx.history.push(`[${timestamp}] ${role}: ${txt}`); 
        if (ctx.history.length > CFG.MAX_HIST) ctx.history = ctx.history.slice(-CFG.MAX_HIST); 
    },
    
    /**
     * Prompt Assembler
     */
    buildPrompt(sys, hist, input) { 
        return `SYSTEM_INSTRUCTION:\n${sys}\n\n--- CONVERSATION_HISTORY ---\n${hist.join('\n')}\n---\nLATEST_USER_INPUT: ${input}\nASSISTANT_RESPONSE:`; 
    }
};

// ==============================================================================
// 7. RATE LIMITING & CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q:[], hr_q:[], daily:{ai:0, img:0, err:0, day:new Date().toDateString()},
    check() {
        const n = Date.now();
        this.min_q = this.min_q.filter(t => n - t < 60000);
        this.hr_q = this.hr_q.filter(t => n - t < 3600000);
        return this.min_q.length < CFG.MAX_RPM && this.hr_q.length < CFG.MAX_RPH;
    },
    hit(type = 'ai') {
        const n = Date.now(); this.min_q.push(n); this.hr_q.push(n);
        const d = new Date().toDateString();
        if (d !== this.daily.day) this.daily = {ai:0, img:0, err:0, day:d};
        if (type === 'ai') this.daily.ai++;
        if (type === 'img') this.daily.img++;
    },
    err() { this.daily.err++; }
};

const CircuitBreaker = {
    fails: 0, lastFail: 0, THRESHOLD: 5, TTL: 300000,
    isOpen() { return this.fails >= this.THRESHOLD && Date.now() - this.lastFail < this.TTL; },
    recordFailure() { this.fails++; this.lastFail = Date.now(); Limiter.err(); },
    recordSuccess() { this.fails = 0; }
};
// ==============================================================================
// 8. GEM PERSONA VAULT ACCESSORS
// ==============================================================================
const Gems = {
    get: (name) => {
        try {
            return db?.prepare('SELECT content FROM gems WHERE name=?').get(name.toLowerCase().trim())?.content ?? null;
        } catch (e) {
            console.error('[AIGems] DB Get Error:', e.message);
            return null;
        }
    },
    save: (name, content) => {
        try {
            return !!db?.prepare('INSERT OR REPLACE INTO gems(name, content) VALUES(?, ?)').run(name.toLowerCase().trim(), content)?.changes;
        } catch (e) {
            console.error('[AIGems] DB Save Error:', e.message);
            return false;
        }
    },
    del: (name) => {
        try {
            return (db?.prepare('DELETE FROM gems WHERE name=?').run(name.toLowerCase().trim())?.changes ?? 0) > 0;
        } catch (e) {
            console.error('[AIGems] DB Delete Error:', e.message);
            return false;
        }
    },
    list: () => {
        try {
            return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r => r.name) ?? [];
        } catch (e) {
            return [];
        }
    }
};

// ==============================================================================
// 9. CORE AI ENGINE (QuillBot SSE Integration)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

/**
 * Communicates with QuillBot's Raven AI Chat via Server-Sent Events.
 */
const askAI = async (prompt, imgUrls = []) => {
    if (CircuitBreaker.isOpen()) return { text: "_[Signal Interference: Neural Link Unstable. Please retry in 5 mins.]_", err: true };
    if (!Limiter.check()) return { text: "⚠️ *Rate limit exceeded.* Cool down for a minute.", err: true };

    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: prompt + CFG.MARKDOWN_REQ,
            files: imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'vision_input.jpg' }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat' },
        tools: []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');
            const response = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout: CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const resultText = await new Promise((resolve, reject) => {
                let buffer = '';
                const timer = setTimeout(() => resolve(buffer), CFG.TIMEOUT - 5000);
                response.data.on('data', chunk => {
                    const lines = chunk.toString().split('\n');
                    for (const line of lines) {
                        const trimmed = line.trim();
                        if (trimmed.startsWith('data: {') && trimmed.includes('"chunk"')) {
                            try {
                                const parsed = JSON.parse(trimmed.slice(6));
                                if (parsed.chunk) buffer += parsed.chunk;
                            } catch (e) {}
                        }
                    }
                });
                response.data.on('end', () => { clearTimeout(timer); resolve(buffer); });
                response.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            if (!resultText.trim()) {
                if (attempt < CFG.RETRIES - 1) {
                    await sleep(2000 * (attempt + 1));
                    continue;
                }
                CircuitBreaker.recordFailure();
                return { text: "❌ *API Error:* Received empty response. Possible cookie expiration.", err: true };
            }

            CircuitBreaker.recordSuccess();
            // Sanitize potential LaTeX or escaped chars common in raw AI outputs
            const cleanText = resultText
                .replace(/\\\(|\\\)/g, '')
                .replace(/\\\[|\\\]/g, '')
                .replace(/\\([a-zA-Z])/g, '$1')
                .trim();

            return { text: cleanText, err: false };

        } catch (error) {
            console.error(`[AIGems] AI Attempt ${attempt + 1} Failed:`, error.message);
            if (attempt < CFG.RETRIES - 1) {
                await sleep(1500 * (attempt + 1));
            } else {
                CircuitBreaker.recordFailure();
                return { text: `⚠️ *Connection Error:* ${error.message}`, err: true };
            }
        }
    }
    return { text: "_[Unable to establish neural uplink.]_", err: true };
};

// ==============================================================================
// 10. IMAGE PROCESSING & GENERATION
// ==============================================================================

/**
 * Uploads media to ImgBB for AI Vision capability.
 */
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, 
            { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch (e) {
        console.error('[AIGems] Media Upload Failed:', e.message);
        return null;
    }
};

/**
 * Generates images via Infip API pool.
 */
let currentInfipKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
const generateImage = async (prompt, opts = {}) => {
    if (!Limiter.check()) return [];
    Limiter.hit('img');

    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;

    try {
        const response = await axios.post(
            'https://api.infip.pro/v1/images/generations',
            {
                model,
                prompt,
                n: 1,
                size,
                response_format: 'url'
            },
            {
                headers: { 
                    'Authorization': `Bearer ${currentInfipKey}`,
                    'Content-Type': 'application/json' 
                },
                timeout: CFG.TIMEOUT
            }
        );

        if (response.status === 200 && response.data?.data?.length) {
            return response.data.data.map(d => d.url);
        }
    } catch (e) {
        Limiter.err();
        console.error('[AIGems] Image Gen Error:', e.message);
        // Swap key on failure
        currentInfipKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
    }
    return [];
};

// ==============================================================================
// 11. COMMAND REGISTRATION: AI CONTROLS & PERSONALITY
// ==============================================================================

// Helper for UI thinking status
const thinking = async (sock, chatId, m, text = "⏳ _Processing request..._") => {
    try {
        return await sock.sendMessage(chatId, { text }, { quoted: m });
    } catch (e) {
        return null;
    }
};

// Helper for message editing (Baileys)
const editMsg = async (sock, originalMsg, newText) => {
    if (!originalMsg?.key) return;
    try {
        await sock.sendMessage(originalMsg.key.remoteJid, { text: newText, edit: originalMsg.key });
    } catch (e) {
        // Fallback if edit is not supported or fails
        await sock.sendMessage(originalMsg.key.remoteJid, { text: newText });
    }
};

// Define Command Logic
const handleGai = async (m, sock, q, isSuperUser) => {
    if (!isSuperUser) return m.reply("❌ *Access Denied:* This command is restricted to the bot owner.");

    const args = q.trim().split(/\s+/);
    const subCmd = args[0]?.toLowerCase();
    const chatId = m.chat || m.from;

    // --- Sub-Command: Target (Lock AI onto specific user in this chat) ---
    if (subCmd === 'target') {
        const targetNum = args[1]?.replace(/[^0-9]/g, '');
        if (!targetNum) return m.reply("📝 *Usage:* `.gai target 234xxx [gem_name]`");
        
        const targetJid = targetNum + '@s.whatsapp.net';
        const gemName = args[2] || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.DEFAULT_PERSONA;

        State.targets.set(targetJid, {
            gem: persona,
            history: [],
            chatId: chatId,
            gemName: gemName
        });

        return m.reply(`🎯 *Target Locked*\n*User:* @${targetNum}\n*Chat:* Current\n*Persona:* \`${gemName}\`\n\n_I will now auto-reply to this user only in this chat._`, { mentions: [targetJid] });
    }

    // --- Sub-Command: Stalk (Lock AI onto user globally) ---
    if (subCmd === 'stalk') {
        const targetNum = args[1]?.replace(/[^0-9]/g, '');
        if (!targetNum) return m.reply("📝 *Usage:* `.gai stalk 234xxx [gem_name]`");

        const targetJid = targetNum + '@s.whatsapp.net';
        const gemName = args[2] || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.DEFAULT_PERSONA;

        State.stalkers.set(targetJid, {
            gem: persona,
            history: [],
            gemName: gemName
        });

        return m.reply(`🕵️ *Global Stalker Active*\n*User:* @${targetNum}\n*Scope:* Everywhere\n*Persona:* \`${gemName}\``, { mentions: [targetJid] });
    }

    // --- Sub-Command: Stop ---
    if (subCmd === 'stop') {
        if (args[1] === 'all') {
            State.targets.clear();
            State.stalkers.clear();
            State.chats.delete(chatId);
            return m.reply("🛑 *AI System Halted:* All active sessions, targets, and stalkers cleared.");
        }
        State.chats.delete(chatId);
        return m.reply("⏹️ *AI Session ended for this chat.*");
    }

    // --- Default AI Interaction ---
    const prompt = q.trim();
    if (!prompt) return m.reply("❓ *No input provided.* Try `.gai help` for more options.");

    const stub = await thinking(sock, chatId, m);
    let visionUrls = [];

    // Vision Support: Check if message is a quoted image
    const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quoted?.imageMessage) {
        const mediaPath = await sock.downloadAndSaveMediaMessage(quoted.imageMessage, `vision_${Date.now()}`);
        const url = await uploadImgBB(mediaPath);
        if (url) visionUrls.push(url);
        try { fs.unlinkSync(mediaPath); } catch(e) {}
    }

    const response = await askAI(prompt, visionUrls);
    return await editMsg(sock, stub, response.text);
};

// Command Registration
if (typeof commandRegister === 'function') {
    
    commandRegister({
        pattern: "gai",
        cmdname: "gai",
        alias: ["ai", "ask", "brain"],
        category: "ai",
        desc: "Advanced AI controller with WhatsApp Markdown integration.",
        react: "🧠",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ") || (m.body ? m.body.split(" ").slice(1).join(" ") : "");
        const isSuperUser = m.isOwner || global.owner?.includes(m.sender?.split('@')[0]);
        await handleGai(m, sock, q, isSuperUser);
    });

    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "identity"],
        category: "ai",
        desc: "Manage Gem Persona Vault for the AI.",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const isSuperUser = m.isOwner || global.owner?.includes(m.sender?.split('@')[0]);
        if (!isSuperUser) return m.reply("❌ *Owner only.*");

        const parts = q.trim().split(/\s+/);
        const sub = parts[0]?.toLowerCase();
        
        if (sub === 'save') {
            const name = parts[1];
            const content = parts.slice(2).join(' ');
            if (!name || !content) return m.reply("📝 `.gem save <name> <system_prompt>`");
            const success = Gems.save(name, content);
            return m.reply(success ? `✅ *Gem Saved:* \`${name}\`` : "❌ *Failed to save to database.*");
        }

        if (sub === 'list') {
            const list = Gems.list();
            if (!list.length) return m.reply("📭 *Vault is empty.*");
            return m.reply(`💎 *Gem Persona Vault*\n\n` + list.map(g => `• \`${g}\``).join('\n'));
        }

        if (sub === 'delete') {
            const name = parts[1];
            if (!name) return m.reply("📝 `.gem delete <name>`");
            const deleted = Gems.del(name);
            return m.reply(deleted ? `🗑️ *Gem Removed:* \`${name}\`` : "❌ *Gem not found.*");
        }

        return m.reply(`💎 *GEM SYSTEM*\n\n• \`.gem save <name> <prompt>\`\n• \`.gem list\`\n• \`.gem delete <name>\``);
    });
}
if (typeof commandRegister === 'function') {

    // ==============================================================================
    // 5. IMAGE GENERATION COMMAND (.img)
    // ==============================================================================
    commandRegister({
        pattern: "img",
        cmdname: "img",
        alias: ["imagine", "genimg", "draw"],
        category: "ai",
        desc: "Generate high-quality AI images using rotating Infip keys.",
        react: "🎨",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const chatId = m.chat || m.from || m.jid || m.key.remoteJid;
        const isSuperUser = m.isOwner || global.owner?.includes(m.sender?.split('@')[0]);

        if (!isSuperUser) return m.reply("❌ *Owner only.*");

        const parts = q.trim().split(/\s+/);
        const subCmd = parts[0]?.toLowerCase();

        // Sub-Command: Models
        if (subCmd === 'models') {
            const list = Object.entries(CFG.IMG_MDLS)
                .map(([id, meta]) => `• *${id}* - _${meta.desc}_ (${meta.tier === 'pro' ? '👑' : '🆓'})`)
                .join('\n');
            return m.reply(`🎨 *AI Image Models*\n\n${list}\n\n_Use_ \`.img config <model_id>\` _to switch._`);
        }

        // Sub-Command: Config
        if (subCmd === 'config') {
            const newModel = parts[1];
            if (!newModel || !CFG.IMG_MDLS[newModel]) return m.reply(`📝 *Usage:* \`.img config <model_id>\`\n_Check_ \`.img models\` _for list._`);
            CFG.IMG_MODEL = newModel;
            return m.reply(`⚙️ *Configuration Updated*\n*Active Model:* \`${CFG.IMG_MODEL}\``);
        }

        // Sub-Command: Setup/Key Rotation
        if (subCmd === 'setup') {
            const stub = await thinking(sock, chatId, m, "🔧 *Verifying API cluster...*");
            const success = await ensureInfip();
            return editMsg(sock, stub, success ? "✅ *API Resilience:* All keys rotated and validated." : "⚠️ *API Alert:* Failed to rotate keys. Circuit breaker may trigger.");
        }

        // Default: Generate
        const prompt = subCmd === 'gen' ? parts.slice(1).join(" ") : q;
        if (!prompt) return m.reply("📝 *Provide a prompt:* `.img gen a cybernetic lion in neon city` ");

        const stub = await thinking(sock, chatId, m, "🎨 *Visualizing your request...*");
        const urls = await generateImage(prompt);

        if (!urls || urls.length === 0) {
            return editMsg(sock, stub, "❌ *Generation Failed.* The API is currently under heavy load or keys are exhausted.");
        }

        await sock.sendMessage(chatId, { delete: stub.key });
        return await sendImg(sock, chatId, urls[0], `🎨 *Prompt:* _${prompt}_\n⚙️ *Model:* \`${CFG.IMG_MODEL}\``, m);
    });

    // ==============================================================================
    // 6. API MONITOR COMMAND (.apimon)
    // ==============================================================================
    commandRegister({
        pattern: "apimon",
        cmdname: "apimon",
        alias: ["aihealth", "stats"],
        category: "ai",
        desc: "Monitor AI health, Rate Limits (RPM/RPH), and Circuit Breaker status.",
        react: "📊",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const isSuperUser = m.isOwner || global.owner?.includes(m.sender?.split('@')[0]);
        if (!isSuperUser) return m.reply("❌ *Access Denied.*");

        const sub = q.trim().toLowerCase();
        const s = Limiter.stats();
        const cbStatus = CB.open() ? "🔴 *TRIPPED* (Open)" : "🟢 *STABLE* (Closed)";

        if (sub === 'health') {
            const stub = await thinking(sock, m.chat, m, "🔍 *Running deep diagnostics...*");
            const { text: testAi } = await askAI("Respond with only 'OK'");
            const aiOk = testAi.includes('OK') ? "✅" : "❌";
            const imgOk = _iOk ? "✅" : "❌";
            
            return editMsg(sock, stub, 
                `🔍 *System Health Check*\n\n` +
                `• *QuillBot SSE:* ${aiOk}\n` +
                `• *Infip Cluster:* ${imgOk}\n` +
                `• *Rate Limiter:* 🟢\n` +
                `• *Circuit Breaker:* ${cbStatus}\n` +
                `• *DB Persistence:* ✅`
            );
        }

        if (sub === 'reset') {
            CB.reset();
            return m.reply("🔄 *Circuit Breaker Reset.* Signal flow restored.");
        }

        const bar = (v, max) => {
            const len = 10;
            const filled = Math.min(len, Math.round((v / max) * len));
            return "▣".repeat(filled) + "▢".repeat(len - filled);
        };

        return m.reply(
            `📊 *AI Engine Metrics*\n\n` +
            `*Circuit Breaker:* ${cbStatus}\n` +
            `*RPM (1m):* \`${bar(s.rpm, CFG.MAX_RPM)}\` [${s.rpm}/${CFG.MAX_RPM}]\n` +
            `*RPH (1h):* \`${bar(s.rph, CFG.MAX_RPH)}\` [${s.rph}/${CFG.MAX_RPH}]\n\n` +
            `*Daily Usage:* \n` +
            `• AI Requests: \`${s.ai}\` \n` +
            `• Image Gens: \`${s.img}\` \n` +
            `• API Errors: \`${s.err}\` \n\n` +
            `_Use_ \`.apimon health\` _for diagnostics._`
        );
    });

    // ==============================================================================
    // 7. AUTO-ENHANCE COMMAND (.autoenhance)
    // ==============================================================================
    commandRegister({
        pattern: "autoenhance",
        cmdname: "autoenhance",
        alias: ["smartedit"],
        category: "ai",
        desc: "Automatically fix grammar and spelling of your own messages.",
        react: "✍️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m } = resolveContext(arg1, args);
        const q = args.join(" ").toLowerCase();
        const isSuperUser = m.isOwner || global.owner?.includes(m.sender?.split('@')[0]);
        if (!isSuperUser) return m.reply("❌ *Owner only.*");

        if (q === 'on') {
            State.autoEnhance = true;
            return m.reply("✍️ *Auto-Enhance:* ✅ *Enabled*\n_I will now silently improve your outgoing messages._");
        } else if (q === 'off') {
            State.autoEnhance = false;
            return m.reply("✍️ *Auto-Enhance:* ❌ *Disabled*");
        }

        return m.reply(`✍️ *Auto-Enhance Status:* ${State.autoEnhance ? '✅ *ON*' : '❌ *OFF*'}\n\n_Usage:_ \`.autoenhance on/off\``);
    });

    // ==============================================================================
    // 8. TRANSLATE & WRITE (.aitranslate / .aiwrite)
    // ==============================================================================
    commandRegister({
        pattern: "aitranslate",
        cmdname: "aitranslate",
        alias: ["aitrans"],
        category: "ai",
        desc: "Translate text to any language using AI.",
        react: "🌐",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const lang = args[0];
        const text = args.slice(1).join(" ");
        if (!lang || !text) return m.reply("📝 *Usage:* \`.aitranslate <lang> <text>\`\n_Example:_ \`.aitranslate French How are you? \` ");

        const stub = await thinking(sock, m.chat, m, `🌐 *Translating to ${lang}...*`);
        const { text: result, err } = await askAI(`Translate the following text to ${lang}. Provide ONLY the translation:\n\n"${text}"`);
        return editMsg(sock, stub, err ? `❌ *Error:* ${result}` : `🌐 *Translation (${lang})*\n\n${result}`);
    });

    commandRegister({
        pattern: "aiwrite",
        cmdname: "aiwrite",
        alias: ["compose", "roast"],
        category: "ai",
        desc: "Creative writing: stories, roasts, emails, and more.",
        react: "📝",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const type = args[0]?.toLowerCase();
        const topic = args.slice(1).join(" ");
        
        const types = {
            roast: "Write a savage but funny WhatsApp roast about: ",
            story: "Write a short, engaging thriller story about: ",
            email: "Write a professional email regarding: ",
            poem: "Write a deep, meaningful poem about: ",
            apology: "Write a sincere and touching apology for: "
        };

        if (!types[type] || !topic) {
            return m.reply(`📝 *AI Creative Writer*\n\n*Types:* \`${Object.keys(types).join(", ")}\`\n\n*Usage:* \`.aiwrite <type> <topic>\``);
        }

        const stub = await thinking(sock, m.chat, m, `✍️ *Drafting your ${type}...*`);
        const { text: result, err } = await askAI(`${types[type]} ${topic}. Format with WhatsApp markdown.`);
        return editMsg(sock, stub, err ? `❌ *Error:* ${result}` : `📝 *AI ${type.toUpperCase()}*\n\n${result}`);
    });

    // ==============================================================================
    // 9. VISION & DECODE (.aidecode)
    // ==============================================================================
    commandRegister({
        pattern: "aidecode",
        cmdname: "aidecode",
        alias: ["explain"],
        category: "ai",
        desc: "Explain complex text or analyze images.",
        react: "🔍",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;

        let visionUrls = [];
        if (quoted?.imageMessage) {
            const media = await sock.downloadAndSaveMediaMessage(quoted.imageMessage, `dec_${Date.now()}`);
            const url = await uploadImgBB(media);
            if (url) visionUrls.push(url);
            try { fs.unlinkSync(media); } catch(e) {}
        }

        const targetText = q || quoted?.conversation || quoted?.extendedTextMessage?.text;
        if (!targetText && visionUrls.length === 0) return m.reply("📝 *Reply to an image or text* with \`.aidecode\` to analyze it.");

        const stub = await thinking(sock, m.chat, m, "🔍 *Analyzing context...*");
        const prompt = visionUrls.length > 0 
            ? `Analyze this image in depth. ${q ? `Focus on: ${q}` : ""}`
            : `Explain the following text in simple terms, highlighting key points:\n\n"${targetText}"`;

        const { text: result, err } = await askAI(prompt, visionUrls);
        return editMsg(sock, stub, err ? `❌ *Analysis Error:* ${result}` : `🔍 *AI Analysis*\n\n${result}`);
    });

}

// ==============================================================================
// 10. RESILIENCE ENGINE: EVENT WATCHER
// Handles Stalkers, Targets, DMs, and Auto-Enhance.
// ==============================================================================
let watcherAttached = false;
const attachResilienceWatcher = (sock) => {
    if (watcherAttached || !sock?.ev) return;
    watcherAttached = true;

    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;
        
        for (const msg of messages) {
            try {
                if (!msg.message) continue;
                const chatId = msg.key.remoteJid;
                const sender = msg.key.participant || chatId;
                const isMe = msg.key.fromMe;
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || "";

                // 1. Auto-Enhance Feature (Self-Correction)
                if (isMe && State.autoEnhance && body.length > 15 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        const { text: improved, err } = await askAI(`Fix only grammar/spelling. Keep tone same. Respond ONLY with fixed text:\n\n${body}`);
                        if (!err && improved.trim() !== body.trim()) {
                            await sock.sendMessage(chatId, { text: improved.trim(), edit: msg.key });
                        }
                    });
                    continue;
                }

                if (isMe) continue;
                if (body.startsWith('.') || body.startsWith('!')) continue;

                // 2. Identify Active Session
                let session = null;
                const senderNum = sender.split('@')[0];

                // Priority 1: Global Stalker
                if (State.stalkers.has(sender)) {
                    session = State.stalkers.get(sender);
                } 
                // Priority 2: Targeted Bot in specific chat
                else if (State.targets.has(sender)) {
                    const t = State.targets.get(sender);
                    if (!t.chatId || t.chatId === chatId) session = t;
                } 
                // Priority 3: Chat-wide AI
                else if (State.chats.has(chatId)) {
                    session = State.chats.get(chatId);
                } 
                // Priority 4: Private DM Auto-Pilot
                else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { gem: State.dmGem || State.DEFAULT_PERSONA, history: [], gemName: 'dm_auto' });
                    }
                    session = State.dmSessions.get(sender);
                }

                if (!session) continue;

                // 3. Process Automatic Reply
                setImmediate(async () => {
                    try {
                        State.addHist(session, 'User', body || '[Media/Action]');
                        const finalPrompt = `SYSTEM: ${session.gem}\n\nFORMAT INSTRUCTION: Always use WhatsApp markdown (*bold*, _italic_, \`monospace\`) for emphasis. Never mention you are an AI.\n\n${session.history.join('\n')}\nAI:`;

                        await sock.sendPresenceUpdate('composing', chatId);
                        const { text: aiResponse, err } = await askAI(finalPrompt);
                        await sock.sendPresenceUpdate('paused', chatId);

                        if (err && CB.open()) return; // Silent fail if CB is open

                        State.addHist(session, 'AI', aiResponse);
                        
                        const safeQuote = {
                            quoted: {
                                key: { remoteJid: chatId, fromMe: false, id: msg.key.id, participant: msg.key.participant },
                                message: msg.message
                            }
                        };

                        await sock.sendMessage(chatId, { text: aiResponse }, safeQuote);
                    } catch (e) {
                        console.error(`[Resilience Watcher] Reply Error: ${e.message}`);
                    }
                });

            } catch (err) {
                console.error(`[Resilience Watcher] Loop Error: ${err.message}`);
            }
        }
    });
    console.log("🛡️ [Resilience Engine] Watcher attached successfully.");
};

// Auto-Boot Watcher
const bootInterval = setInterval(() => {
    const activeSock = global.conn || global.client || global.sock;
    if (activeSock) {
        attachResilienceWatcher(activeSock);
        clearInterval(bootInterval);
    }
}, 5000);

// ==============================================================================
// 11. EXPORT MODULE (Framework Compatibility)
// ==============================================================================
module.exports = {
    askAI,
    generateImage,
    Limiter,
    CB,
    State,
    Gems
};
// ==============================================================================
// 12. THE PERSONA VAULT (.gem) - COMMAND SUITE
// ==============================================================================

/**
 * Command: .gem
 * Purpose: Advanced management of AI personas (Gems).
 */
if (typeof gmd === 'function') {
    gmd({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "gems", "vault"],
        category: "ai",
        desc: "Persona Vault: create, gen, analyze, remix, view, list, use, delete.",
        react: "💎",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ *Unauthorized:* This command is reserved for the Elite Developer.");

        const args = q.trim().split(/\s+/);
        const subCommand = args[0]?.toLowerCase();
        const param = args.slice(1).join(" ");

        // Mandatory Instruction to be injected into every Gem
        const MD_DIRECTIVE = "\n\n[SYSTEM_REPLY_FORMAT]: Always use WhatsApp Markdown (*bold*, _italic_, ~strikethrough~, \`monospace\`). Never use LaTeX or complex code blocks unless requested. Keep responses human-like and concise.";

        try {
            switch (subCommand) {
                case "create": {
                    const name = args[1]?.toLowerCase();
                    const prompt = args.slice(2).join(" ");
                    if (!name || !prompt) return reply("📝 *Usage:* `.gem create <name> <system_prompt>`");
                    
                    const saved = Gems.save(name, prompt + MD_DIRECTIVE);
                    return reply(saved ? `✅ *Gem Locked:* \`${name}\` has been initialized in the vault.` : "⚠️ *Vault Error:* Failed to write to the Gem Database.");
                }

                case "gen": {
                    if (!param) return reply("📝 *Usage:* `.gem gen <topic/character_description>`");
                    const stub = await sock.sendMessage(from, { text: "🔮 *Neural Forge:* Generating persona architecture..." }, { quoted: mek });
                    
                    const genQuery = `Write a professional, detailed system prompt for a WhatsApp AI persona based on this theme: "${param}". Focus on personality traits, speech patterns, and interaction style. Return ONLY the system prompt text.`;
                    const { text: generatedPrompt, err } = await askAI(genQuery);
                    
                    if (err) return sock.sendMessage(from, { text: `❌ *Forge Failure:* ${generatedPrompt}`, edit: stub.key });

                    const safeName = param.split(/\s+/)[0].toLowerCase().replace(/[^a-z0-9]/g, "") + "_ai";
                    Gems.save(safeName, generatedPrompt + MD_DIRECTIVE);
                    
                    return sock.sendMessage(from, { 
                        text: `✨ *Persona Synthesized!*\n*Name:* \`${safeName}\`\n*Preview:* _${generatedPrompt.slice(0, 200)}..._\n\n_Activate with \`.gem use ${safeName}\`_`, 
                        edit: stub.key 
                    });
                }

                case "analyze": {
                    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
                    if (!quoted) return reply("🕵️ *Cloning Protocol:* Reply to a message with `.gem analyze` to clone that style.");
                    
                    const content = quoted.conversation || quoted.extendedTextMessage?.text || "";
                    if (!content) return reply("⚠️ *Error:* No textual data found to analyze.");

                    const stub = await sock.sendMessage(from, { text: "🕵️ *Style Parsing:* Extracting linguistic markers..." }, { quoted: mek });
                    const { text: clonePrompt, err } = await askAI(`Analyze the following text and write a system prompt to perfectly clone this writing style, tone, and vocabulary. Return ONLY the system prompt:\n\n"${content}"`);
                    
                    if (err) return sock.sendMessage(from, { text: `❌ *Analysis Failure:* ${clonePrompt}`, edit: stub.key });

                    const cloneName = "clone_" + Math.random().toString(36).substring(7);
                    Gems.save(cloneName, clonePrompt + MD_DIRECTIVE);
                    
                    return sock.sendMessage(from, { text: `🧬 *Clone Successful:* \`${cloneName}\` added.\n_Activate via \`.gem use ${cloneName}\`_`, edit: stub.key });
                }

                case "remix": {
                    const [target, ...instruction] = args.slice(1);
                    const remixCmd = instruction.join(" ");
                    if (!target || !remixCmd) return reply("📝 *Usage:* `.gem remix <gem_name> <change_instructions>`");

                    const original = Gems.get(target);
                    if (!original) return reply(`❌ *Error:* Gem \`${target}\` not found in registry.`);

                    const stub = await sock.sendMessage(from, { text: "🔀 *Logic Remix:* Recalibrating weights..." }, { quoted: mek });
                    const { text: remixedPrompt, err } = await askAI(`Modify the following system prompt according to these instructions. Return ONLY the full updated prompt:\n\nOriginal: ${original}\n\nUpdate: ${remixCmd}`);

                    if (err) return sock.sendMessage(from, { text: `❌ *Remix Failure:* ${remixedPrompt}`, edit: stub.key });

                    const newName = `${target}_remix`;
                    Gems.save(newName, remixedPrompt); // MD_DIRECTIVE already preserved from original
                    
                    return sock.sendMessage(from, { text: `🔀 *Remix Complete:* \`${newName}\` is now live.`, edit: stub.key });
                }

                case "view": {
                    if (!param) return reply("📝 *Usage:* `.gem view <name>`");
                    const data = Gems.get(param);
                    if (!data) return reply("❌ *Error:* Gem not found.");
                    return reply(`💎 *Gem Vault Record: ${param}*\n\n${data}`);
                }

                case "list": {
                    const allGems = Gems.list();
                    if (!allGems.length) return reply("📚 *Vault Status:* Empty. Create gems with `.gem gen`.");
                    return reply(`📚 *Persona Vault Database*\n\n${allGems.map((g, i) => `${i + 1}. 💎 \`${g}\``).join("\n")}\n\n_Use \`.gem use <name>\` to set as DM handler._`);
                }

                case "use": {
                    if (!param) return reply("📝 *Usage:* `.gem use <name>`");
                    const targetGem = Gems.get(param);
                    if (!targetGem) return reply("❌ *Error:* Gem not found.");
                    State.dmGem = targetGem;
                    return reply(`✅ *Active DM Persona:* \`${param}\` has been deployed.`);
                }

                case "del":
                case "delete": {
                    if (!param) return reply("📝 *Usage:* `.gem delete <name>`");
                    const deleted = Gems.del(param);
                    return reply(deleted ? `🗑️ *Purged:* Gem \`${param}\` wiped from database.` : "❌ *Error:* Gem not found.");
                }

                default:
                    return reply("💎 *PERSONA VAULT CONTROL*\n\n" +
                        "• `.gem create <n> <p>` - Manual Save\n" +
                        "• `.gem gen <topic>` - AI Forge\n" +
                        "• `.gem analyze` - Style Clone (quoted msg)\n" +
                        "• `.gem remix <n> <tweak>` - Modify Gem\n" +
                        "• `.gem list` | `.gem view <n>`\n" +
                        "• `.gem use <n>` | `.gem delete <n>`");
            }
        } catch (error) {
            console.error(`[Gem Engine Error]: ${error.message}`);
            return reply("⚠️ *Critical Failure:* The Persona Vault is unresponsive.");
        }
    });

    // ==============================================================================
    // 13. AI CONTROL CENTER (.gai) - ENHANCED STALK & TARGET
    // ==============================================================================

    gmd({
        pattern: "gai",
        cmdname: "gai",
        alias: ["ai", "bot", "assistant"],
        category: "ai",
        desc: "Master AI controls: DM auto-pilot, Target lock, and Global Stalker.",
        react: "🧠",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ *Restriction:* AI system overrides are owner-only.");

        const args = q.trim().split(/\s+/);
        const sub = args[0]?.toLowerCase();
        const body = args.slice(1).join(" ");

        switch (sub) {
            case "dm": {
                if (args[1] === "on") {
                    State.dmActive = true;
                    return reply(`📨 *DM Auto-Pilot:* ✅ DEPLOYED\nPersona: ${State.dmGem ? "Active Gem" : "System Default"}`);
                }
                if (args[1] === "off") {
                    State.dmActive = false;
                    return reply("📨 *DM Auto-Pilot:* ❌ RECALLED");
                }
                return reply(`📨 *DM Auto-Pilot Status:* ${State.dmActive ? "ACTIVE" : "INACTIVE"}`);
            }

            case "target": {
                const targetNum = args[1]?.replace(/[^0-9]/g, "");
                if (!targetNum) return reply("🎯 *Target Protocol:* `.gai target <number> [gem_name]`");
                
                const targetJid = `${targetNum}@s.whatsapp.net`;
                const gemSelection = args[2] || "default";
                const gemContent = (gemSelection !== "default" ? Gems.get(gemSelection) : null) || State.DEFAULT_PERSONA;

                // Targeted bots respond specifically in the chat where they were locked
                State.targets.set(targetJid, {
                    gem: gemContent,
                    history: [],
                    chatId: from,
                    gemName: gemSelection
                });

                return reply(`🎯 *Target Locked:* @${targetNum}\n🤖 *Persona:* \`${gemSelection}\`\n📍 *Bound To:* This chat session.`);
            }

            case "stalk": {
                const stalkNum = args[1]?.replace(/[^0-9]/g, "");
                if (!stalkNum) return reply("🕵️ *Stalker Protocol:* `.gai stalk <number> [gem_name]`");

                const stalkJid = `${stalkNum}@s.whatsapp.net`;
                const stalkGem = args[2] || "default";
                const stalkContent = (stalkGem !== "default" ? Gems.get(stalkGem) : null) || State.DEFAULT_PERSONA;

                // Stalkers respond to the user across ALL chats (Global)
                State.stalkers.set(stalkJid, {
                    gem: stalkContent,
                    history: [],
                    gemName: stalkGem
                });

                return reply(`🌍 *Global Stalker Active:* @${stalkNum}\n🤖 *Persona:* \`${stalkGem}\`\n📍 *Scope:* Monitoring every interaction.`);
            }

            case "stop": {
                if (args[1] === "all") {
                    State.targets.clear();
                    State.stalkers.clear();
                    State.chats.delete(from);
                    State.dmActive = false;
                    return reply("☢️ *Total Shutdown:* All targeting, stalking, and DM bots deactivated.");
                }
                State.chats.delete(from);
                return reply("🛑 *AI Halted:* Passive chat monitoring disabled here.");
            }

            case "status": {
                const s = Limiter.stats();
                const circ = CB.open() ? "🔴 TRIPPED" : "🟢 STABLE";
                return reply(`📊 *AI CORE ANALYTICS*\n\n` +
                    `• Active Targets: ${State.targets.size}\n` +
                    `• Global Stalkers: ${State.stalkers.size}\n` +
                    `• DM Auto-Pilot: ${State.dmActive ? "ON" : "OFF"}\n` +
                    `• Performance: ${s.rpm}rpm / ${s.rph}rph\n` +
                    `• Circuit Breaker: ${circ}`);
            }

            default: {
                if (!q) return reply("🧠 *AI Assistance:* `.gai <your question>`\n_Use \`.gai help\` for advanced command modes._");
                
                const stub = await sock.sendMessage(from, { text: "🧠 *Processing logic...*" }, { quoted: mek });
                const { text: response, err } = await askAI(q + "\n\n(Respond using WhatsApp Markdown only)");
                
                return sock.sendMessage(from, { text: err ? `⚠️ *Neural Link Error:* ${response}` : response, edit: stub.key });
            }
        }
    });

    // ==============================================================================
    // 14. IMAGE ENGINE (.img) - CREATIVE GENERATION
    // ==============================================================================

    gmd({
        pattern: "img",
        cmdname: "img",
        alias: ["imagine", "draw", "paint"],
        category: "ai",
        desc: "AI Image Generation: gen, models, config, surprise, chaos.",
        react: "🎨",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ *Restriction:* Image core is owner-only.");

        const args = q.trim().split(/\s+/);
        const sub = args[0]?.toLowerCase();
        const prompt = args.slice(1).join(" ");

        const triggerGen = async (p, msg) => {
            const urls = await generateImage(p);
            if (!urls.length) return sock.sendMessage(from, { text: "❌ *Render Error:* Could not generate image.", edit: msg.key });
            
            await sock.sendMessage(from, { delete: msg.key });
            return sock.sendMessage(from, { 
                image: { url: urls[0] }, 
                caption: `🎨 *Render Complete*\n💭 _${p.slice(0, 200)}..._\n⚙️ \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\`` 
            }, { quoted: mek });
        };

        switch (sub) {
            case "models": {
                const list = Object.entries(CFG.IMG_MDLS).map(([id, m]) => `• \`${id}\` - ${m.desc}`).join("\n");
                return reply(`📋 *Available Engines*\n\n${list}\n\n*Active:* \`${CFG.IMG_MODEL}\``);
            }

            case "config": {
                if (!args[1]) return reply(`⚙️ *Current Config:* \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\``);
                if (CFG.IMG_MDLS[args[1]]) CFG.IMG_MODEL = args[1];
                if (args[2]?.includes("x")) CFG.IMG_SIZE = args[2];
                return reply(`✅ *Config Updated:* \`${CFG.IMG_MODEL}\` at \`${CFG.IMG_SIZE}\``);
            }

            case "surprise": {
                const stub = await sock.sendMessage(from, { text: "🎲 *Dreaming...* AI is inventing a prompt." }, { quoted: mek });
                const { text: idea } = await askAI("Write a high-detail creative image prompt for a masterpiece artwork. Return ONLY the prompt.");
                return triggerGen(idea, stub);
            }

            case "chaos": {
                const stub = await sock.sendMessage(from, { text: "🌪️ *Chaos Mode:* Randomized parameters engaged." }, { quoted: mek });
                const models = Object.keys(CFG.IMG_MDLS);
                CFG.IMG_MODEL = models[Math.floor(Math.random() * models.length)];
                CFG.IMG_SIZE = ["1024x1024", "1792x1024", "1024x1792"][Math.floor(Math.random() * 3)];
                const { text: chaosIdea } = await askAI("Write an absurd, surreal, and complex image prompt. Return ONLY the prompt.");
                return triggerGen(chaosIdea, stub);
            }

            case "gen":
            default: {
                const finalPrompt = sub === "gen" ? prompt : q;
                if (!finalPrompt) return reply("📝 *Usage:* `.img <description>`");
                const stub = await sock.sendMessage(from, { text: "🎨 *Visualizing:* Initiating render..." }, { quoted: mek });
                return triggerGen(finalPrompt, stub);
            }
        }
    });
}

