/**
 * AI Response Formatter for WhatsApp Markdown
 * @param {string} rawText 
 * @returns {string}
 */
const formatWA = (rawText) => {
    return rawText
        .replace(/\*\*(.*?)\*\*/g, '*$1*') // Convert MD Bold to WA Bold
        .replace(/__(.*?)__/g, '_$1_')   // Convert MD Italic to WA Italic
        .replace(/`(.*?)`/g, '```$1```') // Ensure code blocks are clean
        .trim();
};
// ==============================================================================
// 19. UPDATED STATE MANAGEMENT (PHASE 4: STALKING & HISTORY FIX)
// ==============================================================================
/**
 * State redesign to handle global stalking, chat-specific targeting, 
 * and DM automation with memory pruning and precise JID identification.
 */
const State = {
    dmActive: false,
    dmGem: null,
    autoEnhance: false,
    PERSONA: 'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Never say you are an AI. Use context.',

    // Core Registries
    sessions: new Map(), // key: remoteJid (Group/DM), val: { gem, history, gemName }
    targets:  new Map(), // key: senderJid, val: { gem, history, gemName, chatJid }
    stalkers: new Map(), // key: senderJid, val: { gem, history, gemName }
    dmSessions: new Map(), // key: senderJid, val: { gem, history, gemName }

    /**
     * Fixes the 'stalk' logic by correctly identifying the participant JID.
     * Handles both Group chats (participant) and Private DMs (remoteJid).
     */
    getSenderJid(msg) {
        const raw = msg.key.participant || msg.key.remoteJid || '';
        return raw.split(':')[0].split('@')[0] + '@s.whatsapp.net';
    },

    /**
     * Adds an entry to conversation history with ISO-based timestamping
     * and dynamic pruning based on CFG.MAX_HIST.
     */
    addHist(sess, role, text) {
        if (!sess.history) sess.history = [];
        const timestamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        const entry = `[${timestamp}] ${role}: ${text}`;
        sess.history.push(entry);

        // Advanced Pruning: Keep only the most recent context
        if (sess.history.length > CFG.MAX_HIST) {
            sess.history = sess.history.slice(-CFG.MAX_HIST);
        }
    },

    /**
     * Constructs a formatted AI prompt including system persona and chat context.
     */
    buildPrompt(sess, input) {
        const sys = sess.gem || this.PERSONA;
        const hist = sess.history || [];
        return `SYSTEM_INSTRUCTIONS:\n${sys}\n\n--- CHAT_HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nAI_REPLY:`;
    }
};

