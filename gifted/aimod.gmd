// 16. .gai — MASTER AI CONTROL CENTER (PHASE 6)
// ==============================================================================
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain', 'stalk', 'target'],
    category: 'ai',
    desc: 'Master AI Control: Manage Stalking, Targeted Botting, and DM Auto-pilot.',
    react: '⚙️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('❌ *Owner Access Required.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const arg1 = parts[1];
    const arg2 = parts[2];

    // --- Sub-Command: DM Auto-Pilot ---
    if (cmd === 'dm') {
        if (arg1 === 'on') {
            State.dmActive = true;
            return reply('📨 *DM Auto-Pilot:* ✅ *ENABLED*\n_The AI will now respond to all incoming private messages._');
        }
        if (arg1 === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot:* ❌ *DISABLED*');
        }
        return reply(`📨 *DM Auto-Pilot Status:* ${State.dmActive ? '✅ ACTIVE' : '❌ INACTIVE'}\n_Toggle with_ \`.gai dm on/off\``);
    }

    // --- Sub-Command: Stalk (Global User Tracking) ---
    if (cmd === 'stalk') {
        const num = arg1?.replace(/[^0-9]/g, '');
        if (!num) return reply('🕵️ *Usage:* \`.gai stalk <number> [gem_name]\`\n_Tracks this user across ALL shared chats._');
        
        const jid = num + '@s.whatsapp.net';
        const gemName = arg2 || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.stalkers.set(jid, { gem: persona, history: [], gemName, lastActive: Date.now() });
        return reply(`🕵️ *Global Stalker Activated*\n*Target:* @${num}\n*Persona:* \`${gemName}\`\n_Monitoring every move..._`, { mentions: [jid] });
    }

    // --- Sub-Command: Target (Local Chat Tracking) ---
    if (cmd === 'target' || cmd === 'bot') {
        const num = arg1?.replace(/[^0-9]/g, '');
        if (!num) return reply('🎯 *Usage:* \`.gai target <number> [gem_name]\`\n_AI will only respond to this user in THIS chat._');
        
        const jid = num + '@s.whatsapp.net';
        const gemName = arg2 || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.targets.set(jid, { gem: persona, history: [], chatId: from, gemName, lastActive: Date.now() });
        return reply(`🎯 *Target Locked*\n*User:* @${num}\n*Scope:* Current Chat Only\n*Persona:* \`${gemName}\``, { mentions: [jid] });
    }

    // --- Sub-Command: Chat (Group Wide Session) ---
    if (cmd === 'chat' || cmd === 'group') {
        const gemName = arg1 || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.chats.set(from, { gem: persona, history: [], gemName, lastActive: Date.now() });
        return reply(`⚔️ *Group AI Session:* ✅ *ACTIVE*\n*Persona:* \`${gemName}\`\n_AI will now reply to all non-command messages here._`);
    }

    // --- Sub-Command: Stop / Terminate ---
    if (cmd === 'stop') {
        if (arg1 === 'all') {
            State.dmActive = false;
            State.stalkers.clear();
            State.targets.clear();
            State.chats.clear();
            State.dmSessions.clear();
            return reply('☢️ *Total Shutdown:* All AI tracking and sessions terminated.');
        }
        if (State.chats.has(from)) {
            State.chats.delete(from);
            return reply('🛑 *AI Session stopped in this chat.*');
        }
        return reply('ℹ️ *No active session found here.* Use \`.gai stop all\` to clear global stalkers.');
    }

    // --- Sub-Command: Status ---
    if (cmd === 'status') {
        const s = Limiter.stats();
        const cb = CB.open() ? '🔴 *TRIPPED* (Cooldown)' : '🟢 *NOMINAL*';
        return reply(
            `📊 *AI SYSTEM STATUS (Phase 6)*\n\n` +
            `• *DM Pilot:* ${State.dmActive ? '✅' : '❌'}\n` +
            `• *Stalkers:* \`${State.stalkers.size}\` active\n` +
            `• *Targets:* \`${State.targets.size}\` users\n` +
            `• *Group Sessions:* \`${State.chats.size}\` chats\n\n` +
            `*API Metrics:*\n` +
            `• Circuit:* ${cb}\n` +
            `• Load (1m):* ${s.rpm}/${CFG.MAX_RPM} RPM\n` +
            `• Queries (24h):* ${s.ai} Text | ${s.img} Img`
        );
    }

    // --- Sub-Command: Help ---
    if (cmd === 'help') {
        return reply(
            `🧠 *GAI MASTER CONTROL HELP*\n\n` +
            `• \`.gai <question>\` — Quick AI query\n` +
            `• \`.gai dm <on/off>\` — Auto-reply to all DMs\n` +
            `• \`.gai stalk <num> [gem]\` — Global user stalking\n` +
            `• \`.gai target <num> [gem]\` — Local chat targeting\n` +
            `• \`.gai chat [gem]\` — AI responses for everyone here\n` +
            `• \`.gai stop [all]\` — Terminate AI activities\n` +
            `• \`.gai summary\` — Summarize current conversation\n` +
            `• \`.gai status\` — View health and usage statistics`
        );
    }

    // --- One-Shot Ask (Default) ---
    if (!q.trim()) return reply('📝 *Usage:* \`.gai <question>\` or \`.gai help\`');
    
    await react('🧠');
    const stub = await thinking(Gifted, from, mek, '🧠 _thinking..._');
    
    // Add strict instruction to avoid LaTeX and use WhatsApp Markdown
    const markdownInstruction = "\n\n*IMPORTANT*: Always respond using WhatsApp Markdown (*bold*, _italics_, ```code blocks```). Never use LaTeX formulas or headers (###). Keep the tone casual and use emojis.";
    const { text, err } = await askAI(q + markdownInstruction);
    
    return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
});

// ==============================================================================
// 17. SESSION MAINTENANCE — STALKER PERSISTENCE (PHASE 6)
// ==============================================================================

/**
 * Periodically cleans up inactive sessions to prevent memory bloat.
 * In Phase 7, this will be linked to SQLite for cold persistence.
 */
setInterval(() => {
    const now = Date.now();
    const EXPIRY = 7200000; // 2 hours of inactivity
    
    State.chats.forEach((sess, id) => {
        if (sess.lastActive && (now - sess.lastActive > EXPIRY)) {
            State.chats.delete(id);
            console.log(`[AIGems] Group session pruned for inactivity: ${id}`);
        }
    });
    
    // Auto-reset circuit breaker after 15 minutes of silence
    if (CB.fails > 0 && (now - CB.lastFail > 900000)) {
        CB.reset();
        console.log('[AIGems] Circuit breaker auto-reset initiated.');
    }
}, 1800000);

// ==============================================================================
// 18. PROCESS FINALIZATION
// ==============================================================================

console.log('[AIGems] Phase 6 (.gai Control Center) successfully deployed.');
console.log('[AIGems] Redundant logic cleaned. Markdown enforcement active.');

// End of Phase 6 text stream. No trailing braces added here.
// ==============================================================================
// 19. .img — ADVANCED IMAGE STUDIO (PHASE 7)
// ==============================================================================
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'art', 'draw', 'genimg'],
    category: 'ai',
    desc: 'Advanced Image Studio. Type .img help for sub-commands.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const rest = parts.slice(1).join(' ');

    /**
     * Internal helper to execute image generation and handle media responses.
     */
    const executeGen = async (prompt, label = '🎨 _Processing visual data…_') => {
        await react('⏳');
        const stub = await thinking(Gifted, from, mek, label);
        
        const urls = await generateImage(prompt, {
            model: CFG.IMG_MODEL,
            size: CFG.IMG_SIZE,
            quality: CFG.IMG_QUALITY,
            style: CFG.IMG_STYLE,
            count: CFG.IMG_COUNT
        });

        if (!urls || urls.length === 0) {
            await react('❌');
            return editMsg(Gifted, stub, '❌ *Engine Stalled.* Failed to generate. Try \`.img setup\` to verify API keys or check your prompt for restricted terms.');
        }

        await del(Gifted, stub.key);
        await react('✨');

        const caption = `*🎨 IMAGE STUDIO*\n\n*Prompt:* _${prompt}_\n*Engine:* \`${CFG.IMG_MODEL}\`\n*Ratio:* \`${CFG.IMG_SIZE}\``;
        
        // Send primary image
        await sendImg(Gifted, from, urls[0], caption, mek);
        
        // Send variations if count > 1
        if (urls.length > 1) {
            for (let i = 1; i < urls.length; i++) {
                await sendImg(Gifted, from, urls[i], `*🎨 Variation ${i + 1}*`, mek);
                await sleep(400);
            }
        }
    };

    // --- Sub-command: HELP ---
    if (cmd === 'help') {
        return reply(
            `🎨 *IMAGE STUDIO MENU*\n\n` +
            `• \`.img gen <prompt>\` — Standard generation\n` +
            `• \`.img surprise [topic]\` — AI-engineered creative prompt\n` +
            `• \`.img chaos\` — Random settings + bizarre scene\n` +
            `• \`.img enhance <prompt>\` — Expand for realism\n\n` +
            `*Settings:*\n` +
            `• \`.img models\` — List available engines\n` +
            `• \`.img set <model>\` — Set default engine\n` +
            `• \`.img ratio <sq|port|land>\` — Aspect ratio\n` +
            `• \`.img setup\` — API diagnostic check\n\n` +
            `*Active Engine:* \`${CFG.IMG_MODEL}\` (\`${CFG.IMG_SIZE}\`)`
        );
    }

    // --- Sub-command: MODELS ---
    if (cmd === 'models' || cmd === 'list') {
        const list = Object.entries(CFG.IMG_MDLS).map(([id, m]) => 
            `${m.tier === 'pro' ? '👑' : '🆓'} \`${id}\` — ${m.desc}`
        ).join('\n');
        return reply(`📋 *AVAILABLE ENGINES*\n\n${list}\n\n*Current:* \`${CFG.IMG_MODEL}\``);
    }

    // --- Sub-command: SET / CONFIG ---
    if (cmd === 'set' || cmd === 'config') {
        const target = parts[1]?.toLowerCase();
        if (!target || !CFG.IMG_MDLS[target]) {
            return reply(`📝 *Usage:* \`.img set <model_id>\`\n_Use_ \`.img models\` _to see valid IDs._`);
        }
        CFG.IMG_MODEL = target;
        return reply(`✅ *Default engine updated to:* \`${CFG.IMG_MODEL}\``);
    }

    // --- Sub-command: RATIO ---
    if (cmd === 'ratio') {
        const r = parts[1]?.toLowerCase();
        const map = { sq: '1024x1024', port: '1024x1792', land: '1792x1024' };
        if (!map[r]) return reply('📝 *Usage:* \`.img ratio <sq|port|land>\`');
        CFG.IMG_SIZE = map[r];
        return reply(`✅ *Dimensions updated:* \`${CFG.IMG_SIZE}\` (${r})`);
    }

    // --- Sub-command: SURPRISE ---
    if (cmd === 'surprise') {
        const topic = rest || 'anything visually stunning and bizarre';
        const stub = await thinking(Gifted, from, mek, '🎲 _Dreaming up concepts…_');
        const { text: dream, err } = await askAI(`Generate a highly creative, vivid, cinematic, and detailed image generation prompt for: ${topic}. Focus on lighting, art style, and composition. Return ONLY the prompt text. Use *bold* for emphasis but NO LaTeX formulas.`);
        if (err) return editMsg(Gifted, stub, `❌ ${dream}`);
        await editMsg(Gifted, stub, `🔮 _Visualizing:_ "${dream.slice(0, 100)}…"`);
        return executeGen(dream, '🎨 _Surprise Generation…_');
    }

    // --- Sub-command: CHAOS ---
    if (cmd === 'chaos') {
        const freeOnes = Object.keys(CFG.IMG_MDLS).filter(k => CFG.IMG_MDLS[k].tier === 'free');
        const randM = freeOnes[Math.floor(Math.random() * freeOnes.length)];
        const randS = ['1024x1024', '1792x1024', '1024x1792'][Math.floor(Math.random() * 3)];
        
        const stub = await thinking(Gifted, from, mek, '🌪️ *Initiating Chaos Mode…*');
        const { text: chaosP } = await askAI("Generate an impossible, surreal, and bizarre image prompt. Be weird. Return ONLY the prompt without any notes or LaTeX.");
        
        const oldM = CFG.IMG_MODEL; const oldS = CFG.IMG_SIZE;
        CFG.IMG_MODEL = randM; CFG.IMG_SIZE = randS;
        
        await executeGen(chaosP || 'melting digital void neon static', `🌪️ _Chaos @ ${randM}…_`);
        
        CFG.IMG_MODEL = oldM; CFG.IMG_SIZE = oldS;
        return;
    }

    // --- Sub-command: ENHANCE ---
    if (cmd === 'enhance') {
        if (!rest) return reply('📝 *Usage:* \`.img enhance <prompt>\`');
        const stub = await thinking(Gifted, from, mek, '🧠 _Prompt Engineering…_');
        const { text: expanded, err } = await askAI(`Rewrite and expand this basic image prompt into a professional, hyper-realistic masterpiece description. Include details about camera settings, lighting effects, and art movements. Return ONLY the expanded prompt: "${rest}"`);
        if (err) return editMsg(Gifted, stub, `❌ ${expanded}`);
        return editMsg(Gifted, stub, `✨ *Hyper-Enhanced Prompt:*\n\n${expanded}\n\n_Use_ \`.img gen\` _to visualize this design._`);
    }

    // --- Sub-command: SETUP ---
    if (cmd === 'setup') {
        const stub = await thinking(Gifted, from, mek, '🔧 _Running diagnostics…_');
        _iOk = false;
        const status = await ensureInfip();
        return editMsg(Gifted, stub, status ? `✅ *Infip Ready:* Connection established and keys validated.` : '❌ *Infip Offline:* All keys in the pool are invalid or exhausted.');
    }

    // --- Default: GENERATION ---
    const prompt = (cmd === 'gen') ? rest : q;
    if (!prompt.trim()) return reply('📝 *Usage:* \`.img <prompt>\` or \`.img help\`');
    return executeGen(prompt);
});

