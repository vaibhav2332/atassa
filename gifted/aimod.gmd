 * Phase 10: Performance Profiling, Advanced Vision, and Final Stabilization coming next.
 */
// ==============================================================================
// 21.  .aidecode  — MULTIMODAL VISION DECODER
// ==============================================================================

/**
 * Advanced vision and text analysis command.
 * Allows users to reply to images or text for AI-powered explanation.
 */
gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'whatis', 'analyze', 'aianalyze'],
    category: 'ai',
    desc: 'Analyze a quoted image or text using neural vision.',
    react: '👁️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImg = quoted?.imageMessage || mek.message?.imageMessage;

    await react('🔍');
    const stub = await thinking(Gifted, from, mek, '👁️ _Decoding visual/textual data…_');

    let imgUrls = [];
    if (hasImg) {
        try {
            const target = quoted?.imageMessage ? quoted.imageMessage : mek.message.imageMessage;
            const tmpPath = path.join(__dirname, `tmp_dec_${Date.now()}.jpg`);
            await Gifted.downloadAndSaveMediaMessage(target, tmpPath);
            const url = await uploadImgBB(tmpPath);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
        } catch (e) {
            console.error('[AIGems] Decoder Vision Error:', e.message);
        }
    }

    const contextText = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    let userPrompt = q.trim();
    
    if (!userPrompt && !hasImg && !contextText) {
        return editMsg(Gifted, stub, '📝 *Usage:* Reply to an image or text block with `.aidecode [instruction]`');
    }

    const finalPrompt = imgUrls.length 
        ? `${userPrompt || 'Analyze this image in detail and describe what you see.'}`
        : `Deeply analyze, explain, and provide insights on the following content:\n\n"${contextText || userPrompt}"`;

    const { text, err } = await askAI(finalPrompt, imgUrls);
    
    if (err) return editMsg(Gifted, stub, `❌ *Analysis Error:* ${text}`);
    
    return editMsg(Gifted, stub, `👁️ *NEURAL DECODER*\n\n${text}`);
});

