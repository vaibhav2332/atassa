    const { text, err } = await askAI(`Translate the following text into ${targetLang}. 
    Maintain the original tone (formal/informal). 
    Original Text: "${textToTranslate}"
    
    *Format:* Output ONLY the translated text without quotes.`);

    return sock.sendMessage(from, { text: err ? `⚠️ *Translation Error:* ${text}` : `🌐 *TRANSLATION [${targetLang.toUpperCase()}]*\n\n${text}`, edit: stub.key });
});

/**
 * .img: Advanced Image Generation Engine
 * Supports: Phoenix, Flux-Schnell, Flux2-Dev, SDXL
 */
gmd({
    pattern: "img",
    cmdname: "img",
    alias: ["imagine", "gen", "draw", "flux", "sdxl"],
    category: "ai",
    desc: "Generate high-quality images using Phoenix, Flux, or SDXL engines.",
    react: "🎨",
    filename: __filename
}, async (from, sock, context) => {
    const { q, reply, mek, isSuperUser } = context;
    if (!isSuperUser) return reply("❌ Owner only.");
    if (!q) return reply("🎨 *Usage:* `.img <prompt>`\n*Advanced:* `.img model:flux | size:1024x1792 | <prompt>`");

    // Parsing advanced parameters
    let model = CFG.IMG_MODEL;
    let size = CFG.IMG_SIZE;
    let prompt = q;

    if (q.includes("|")) {
        const segments = q.split("|");
        prompt = segments.pop().trim();
        segments.forEach(seg => {
            const [k, v] = seg.split(":").map(s => s.trim().toLowerCase());
            if (k === "model" && CFG.IMG_MDLS[v]) model = v;
            if (k === "size") size = v;
        });
    }

    const stub = await sock.sendMessage(from, { text: `🎨 *Neural Rendering...*\n*Engine:* \`${model}\`\n*Prompt:* _${prompt.slice(0, 50)}..._` }, { quoted: mek });

    try {
        const urls = await generateImage(prompt, { model, size });
        if (!urls || urls.length === 0) throw new Error("API returned no image data.");

        await sock.sendMessage(from, { delete: stub.key });
        return await sock.sendMessage(from, { 
            image: { url: urls[0] }, 
            caption: `✨ *AI GENERATION*\n\n*Prompt:* ${prompt}\n*Engine:* \`${model}\`\n*Resolution:* \`${size}\`\n\n_Generated via Gifted-Gems Engine_`
        }, { quoted: mek });

    } catch (e) {
        console.error(`[AIGems] ImgGen Error: ${e.message}`);
        return sock.sendMessage(from, { text: `❌ *Generation Failed:* ${e.message}`, edit: stub.key });
    }
});

