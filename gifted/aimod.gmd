// ==============================================================================
// 21. CORE WATCHER: ROBUST JID IDENTIFICATION
// ==============================================================================

/**
 * The Advanced Watcher handles the logic for triggering AI replies based on
 * Global Stalkers, Local Targets, Active Chat sessions, and DM Auto-Pilot.
 */
const attachPhase4Watcher = (Gifted) => {
    if (!Gifted?.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;

                const chatId = msg.key.remoteJid;
                const senderJid = State.getSenderJid(msg);
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';
                const isGrp = chatId.endsWith('@g.us');

                // Determine session context
                let activeSess = null;

                // 1. Check Global Stalkers (Highest Priority - follows user everywhere)
                if (State.stalkers.has(senderJid)) {
                    activeSess = State.stalkers.get(senderJid);
                } 
                // 2. Check Targeted Users (Middle Priority - chat-specific lock)
                else if (State.targets.has(senderJid)) {
                    const t = State.targets.get(senderJid);
                    if (!t.chatId || t.chatId === chatId) activeSess = t;
                }
                // 3. Check Chat-wide AI (Everyone in this group/DM)
                else if (State.sessions.has(chatId)) {
                    activeSess = State.sessions.get(chatId);
                }
                // 4. DM Auto-Pilot (Lowest Priority - only in private chats)
                else if (!isGrp && State.dmActive) {
                    if (!State.dmSessions.has(senderJid)) {
                        State.dmSessions.set(senderJid, { gem: State.dmGem || State.PERSONA, history: [], gemName: 'dm_auto' });
                    }
                    activeSess = State.dmSessions.get(senderJid);
                }

                if (!activeSess) continue;

                // Ignore commands
                if (body.startsWith('.') || body.startsWith('/') || body.startsWith('!')) continue;

                // Execute Reply Logic
                setImmediate(async () => {
                    try {
                        let mediaUrls = [];
                        if (msg.message.imageMessage) {
                            const path = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, `watch_${Date.now()}`);
                            const url = await uploadImgBB(path);
                            if (url) mediaUrls.push(url);
                            if (fs.existsSync(path)) fs.unlinkSync(path);
                        }

                        // Update Memory
                        State.addHist(activeSess, 'User', body || '[Media/Image]');

                        // Generate Response
                        const prompt = State.buildPrompt(activeSess, body || 'Analyse this image');
                        
                        // Simulation of human typing
                        await Gifted.sendPresenceUpdate('composing', chatId);
                        await sleep(Math.max(1000, Math.min(body.length * 50, 4000)));

                        const { text, err } = await askAI(prompt, mediaUrls);
                        await Gifted.sendPresenceUpdate('paused', chatId);

                        if (err && CB.open()) return;

                        const finalReply = formatWA(text);
                        State.addHist(activeSess, 'AI', finalReply);

                        // Send message with quotation context
                        await Gifted.sendMessage(chatId, { text: finalReply }, { quoted: msg });

                    } catch (e) {
                        console.error('[Phase4Watcher] Session Error:', e.message);
                    }
                });

            } catch (err) {
                console.error('[Phase4Watcher] Loop Error:', err.message);
            }
        }
    });
};

// Initialize the upgraded watcher
const _initWatcher = setInterval(() => {
    const G = global.conn || global.client;
    if (G) {
        attachPhase4Watcher(G);
        clearInterval(_initWatcher);
        console.log('[Phase 4] Advanced State & Stalking Watcher Online');
    }
}, 5000);

