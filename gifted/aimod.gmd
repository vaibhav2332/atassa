/**
 * AI Response Wrapper for WhatsApp Markdown
 * This constant is appended to system prompts to ensure rigid formatting.
 */
const MD_REQ = "\n\n*CRITICAL:* Use WhatsApp Markdown (*bold*, _italic_, ~strike~, `code`). Use bullet points for lists. Be concise and conversational.";

// ==============================================================================
// 17. REFINED MESSAGE INTERCEPTOR (Watcher Logic)
// ==============================================================================

const processAutoReply = async (sock, m, body, sess, chatId) => {
    try {
        // Build the neural context
        const prompt = `SYSTEM: ${sess.gem}${MD_REQ}\n\n--- HISTORY ---\n${sess.history.slice(-10).join("\n")}\n---\nUSER: ${body}\nAI:`;
        
        // Signal typing
        await sock.sendPresenceUpdate('composing', chatId);
        
        const { text, err } = await askAI(prompt);
        if (err) return; // Silent fail for watchers to avoid spamming errors

        // Update session history
        const timestamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        sess.history.push(`[${timestamp}] User: ${body}`);
        sess.history.push(`[${timestamp}] AI: ${text}`);
        if (sess.history.length > CFG.MAX_HIST) sess.history.shift();
        sess.lastActive = Date.now();

        // Send with proper quoting
        const quote = {
            quoted: {
                key: {
                    remoteJid: chatId,
                    fromMe: false,
                    id: m.key.id,
                    participant: m.key.participant || m.sender
                },
                message: m.message
            }
        };

        await sock.sendMessage(chatId, { text: text }, quote);
        await sock.sendPresenceUpdate('paused', chatId);

    } catch (error) {
        console.error(`[AIGems Watcher] Error: ${error.message}`);
    }
};

/**
 * Main Event Linker
 */
const initializeWatcher = (sock) => {
    if (!sock) return;

    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        const m = messages[0];
        if (!m.message || m.key.fromMe) return;

        const from = m.key.remoteJid;
        const sender = m.key.participant || m.key.remoteJid;
        const body = m.message.conversation || m.message.extendedTextMessage?.text || "";

        // Skip command triggers
        if (body.startsWith(".") || body.startsWith("/") || body.startsWith("!")) return;

        let activeSession = null;

        // 1. Check Global Stalkers
        if (State.stalkers.has(sender)) {
            activeSession = State.stalkers.get(sender);
        } 
        // 2. Check Targeted Users (Chat specific)
        else if (State.targets.has(sender)) {
            const target = State.targets.get(sender);
            if (target.chatId === from) activeSession = target;
        }
        // 3. Check Active Group Chats
        else if (State.chats.has(from)) {
            activeSession = State.chats.get(from);
        }
        // 4. Check DM Auto-Pilot
        else if (!from.endsWith('@g.us') && State.dmActive) {
            if (!State.dmSessions.has(sender)) {
                State.dmSessions.set(sender, {
                    gem: State.dmGem || State.PERSONA,
                    history: [],
                    gemName: "dm_auto",
                    lastActive: Date.now()
                });
            }
            activeSession = State.dmSessions.get(sender);
        }

        if (activeSession && body.length > 0) {
            await processAutoReply(sock, m, body, activeSession, from);
        }
    });
};

// Hook into existing lifecycle if global client exists
if (global.conn || global.client) {
    initializeWatcher(global.conn || global.client);
}
/**
 * Media Handler for Vision Tasks in Watcher
 * Downloads content from message buffers and uploads to ImgBB for AI analysis.
 */
const downloadAndUpload = async (sock, m) => {
    try {
        const messageType = Object.keys(m.message)[0];
        if (messageType !== 'imageMessage') return null;
        
        // Baileys dynamic content downloader
        const stream = await sock.downloadContentFromMessage(m.message.imageMessage, 'image');
        let buffer = Buffer.from([]);
        for await (const chunk of stream) {
            buffer = Buffer.concat([buffer, chunk]);
        }
        
        // Write to temporary local storage before cloud processing
        const tmpPath = path.join(__dirname, `../vision_tmp_${Date.now()}.jpg`);
        fs.writeFileSync(tmpPath, buffer);
        
        const url = await uploadImgBB(tmpPath);
        
        // Cleanup local storage immediately
        if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
        return url;
    } catch (e) {
        console.error(`[Vision Watcher] Failed to process media: ${e.message}`);
        return null;
    }
};

/**
 * Auto-Enhance Logic: Fixes grammar and tone of outgoing owner messages.
 */
const performAutoEnhance = async (sock, m, chatId) => {
    const text = m.message.conversation || m.message.extendedTextMessage?.text || "";
    if (text.length < 15 || text.startsWith('.') || text.startsWith('/') || text.startsWith('!')) return;

    try {
        const prompt = `Correction Task: Improve grammar, spelling, and professional tone. Keep it natural. Use WhatsApp markdown (*bold* for emphasis). Return ONLY the corrected text.\n\nText: "${text}"`;
        const { text: improved, err } = await askAI(prompt);
        
        if (!err && improved.trim().toLowerCase() !== text.trim().toLowerCase()) {
            // Native message edit protocol
            await sock.sendMessage(chatId, { text: `✨ ${improved.trim()}`, edit: m.key });
        }
    } catch (e) {
        // Silently fail to maintain flow
    }
};

/**
 * Enhanced initializeWatcher - Now supports AI Vision and Auto-Enhance
 */
const startIntelligentWatcher = (sock) => {
    if (!sock) return;

    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;
        const m = messages[0];
        if (!m.message) return;

        const from = m.key.remoteJid;
        const sender = m.key.participant || m.key.remoteJid;
        const isFromMe = m.key.fromMe;
        const body = m.message.conversation || m.message.extendedTextMessage?.text || m.message.imageMessage?.caption || "";

        // 1. Owner's Auto-Enhance Feature
        if (isFromMe && State.autoEnhance) {
            return await performAutoEnhance(sock, m, from);
        }

        // 2. Incoming Logic (Block commands from triggering AI)
        if (isFromMe || body.startsWith(".") || body.startsWith("/")) return;

        let activeSession = null;
        let imageUrl = null;

        // 3. Resolve Active Session Type
        if (State.stalkers.has(sender)) {
            activeSession = State.stalkers.get(sender);
        } else if (State.targets.has(sender)) {
            const target = State.targets.get(sender);
            if (target.chatId === from) activeSession = target;
        } else if (State.chats.has(from)) {
            activeSession = State.chats.get(from);
        } else if (!from.endsWith('@g.us') && State.dmActive) {
            if (!State.dmSessions.has(sender)) {
                State.dmSessions.set(sender, {
                    gem: State.dmGem || State.PERSONA,
                    history: [],
                    gemName: "dm_auto",
                    lastActive: Date.now()
                });
            }
            activeSession = State.dmSessions.get(sender);
        }

        // 4. Execution with Vision Support
        if (activeSession) {
            // Download image if present for Vision-enabled responses
            if (m.message.imageMessage) {
                imageUrl = await downloadAndUpload(sock, m);
            }

            if (body.length > 0 || imageUrl) {
                const imgList = imageUrl ? [imageUrl] : [];
                const prompt = `SYSTEM: ${activeSession.gem}${MD_REQ}\n\n--- HISTORY ---\n${activeSession.history.slice(-10).join("\n")}\n---\nUSER: ${body || "[Image Attached]"}\nAI:`;
                
                await sock.sendPresenceUpdate('composing', from);
                const { text, err } = await askAI(prompt, imgList);
                
                if (!err) {
                    const timestamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                    activeSession.history.push(`[${timestamp}] User: ${body || "[Sent Image]"}`);
                    activeSession.history.push(`[${timestamp}] AI: ${text}`);
                    if (activeSession.history.length > CFG.MAX_HIST) activeSession.history.shift();
                    
                    const quote = {
                        quoted: {
                            key: { remoteJid: from, fromMe: false, id: m.key.id, participant: sender },
                            message: m.message
                        }
                    };
                    await sock.sendMessage(from, { text: text }, quote);
                }
                await sock.sendPresenceUpdate('paused', from);
            }
        }
    });
};

// Auto-boot sequence for the watcher
if (global.conn || global.client) {
    startIntelligentWatcher(global.conn || global.client);
}

// ==============================================================================
// 19. REFINED MODULEBASE COMMANDS
// ==============================================================================

if (typeof commandRegister === 'function') {

    // Vision Analysis Command
    commandRegister({ 
        pattern: "vision", 
        cmdname: "vision", 
        alias: ["describe", "see"], 
        type: "ai", 
        category: "ai", 
        desc: "High-level AI image analysis and text extraction.", 
        react: "👁️", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const chatId = m.chat || m.from || m.jid || m.key.remoteJid;
        const sendOptions = buildSafeQuote(m);
        
        const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage || m.message;
        if (!quoted?.imageMessage) {
            return await sock.sendMessage(chatId, { text: "❌ *Error:* You must reply to an image with `.vision` to analyze it." }, sendOptions);
        }

        const stub = await sock.sendMessage(chatId, { text: "👁️‍🗨️ _Processing visual data..._" }, sendOptions);
        const url = await downloadAndUpload(sock, { message: quoted });
        
        if (!url) {
            return await sock.sendMessage(chatId, { text: "❌ *Error:* Image uplink failed.", edit: stub.key });
        }

        const { text, err } = await askAI("Explain this image in depth and translate any text you see." + MD_REQ, [url]);
        await sock.sendMessage(chatId, { text: err ? "⚠️ *AI Error:* Could not decode vision stream." : text, edit: stub.key });
    });

    // Global Stalker Command (Refined)
    commandRegister({ 
        pattern: "stalk", 
        cmdname: "stalk", 
        alias: ["spy", "follow"], 
        type: "ai", 
        category: "ai", 
        desc: "Follow a user across all groups and respond as them.", 
        react: "🕵️", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const parts = q.split(" ");
        const num = parts[0]?.replace(/[^0-9]/g, '');
        const gemName = parts[1] || "default";

        if (!num) return await sock.sendMessage(m.chat, { text: "📝 *Correct Usage:* `.stalk <number> [gem_name]`" });

        const tjid = `${num}@s.whatsapp.net`;
        const persona = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;

        State.stalkers.set(tjid, {
            gem: persona,
            history: [],
            gemName: gemName,
            lastActive: Date.now()
        });

        const reply = `👣 *Global Stalker Activated*\n\n*Target:* @${num}\n*Behavior:* AI will reply to this user in every chat.\n*Persona:* \`${gemName}\`\n*Status:* Running in Background`;
        await sock.sendMessage(m.chat, { text: reply, mentions: [tjid] }, buildSafeQuote(m));
    });

    // Target Locked Command (Chat Specific)
    commandRegister({ 
        pattern: "target", 
        cmdname: "target", 
        alias: ["lockon"], 
        type: "ai", 
        category: "ai", 
        desc: "Force AI to only respond to a specific user in THIS chat.", 
        react: "🎯", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const chatId = m.chat || m.from || m.jid || m.key.remoteJid;
        const parts = q.split(" ");
        const num = parts[0]?.replace(/[^0-9]/g, '');
        const gemName = parts[1] || "default";

        if (!num) return await sock.sendMessage(chatId, { text: "📝 *Usage:* `.target <number> [gem]`" });

        const tjid = `${num}@s.whatsapp.net`;
        const persona = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;

        State.targets.set(tjid, {
            gem: persona,
            history: [],
            gemName: gemName,
            chatId: chatId,
            lastActive: Date.now()
        });

        const reply = `🎯 *Target Locked*\n\n*User:* @${num}\n*Chat:* This Chat Only\n*Persona:* \`${gemName}\`\n\n_AI will now counter-reply to every message from this user here._`;
        await sock.sendMessage(chatId, { text: reply, mentions: [tjid] }, buildSafeQuote(m));
    });

    // AI Status Dashboard
    commandRegister({ 
        pattern: "aistatus", 
        cmdname: "aistatus", 
        alias: ["stats", "sessions"], 
        type: "ai", 
        category: "ai", 
        desc: "View all active AI sessions and stalkers.", 
        react: "📊", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const chatId = m.chat || m.from || m.jid || m.key.remoteJid;
        
        let report = `🧠 *AI COGNITIVE ENGINE STATUS*\n\n`;
        report += `🛰️ *Global Stalkers:* ${State.stalkers.size}\n`;
        report += `🎯 *Targeted Users:* ${State.targets.size}\n`;
        report += `💬 *Active Group Chats:* ${State.chats.size}\n`;
        report += `📨 *DM Auto-Pilot:* ${State.dmActive ? "✅ ENABLED" : "❌ DISABLED"}\n`;
        report += `✍️ *Auto-Enhance:* ${State.autoEnhance ? "✅ ENABLED" : "❌ DISABLED"}\n\n`;
        
        if (State.stalkers.size > 0) {
            report += `*Current Stalk List:*\n`;
            State.stalkers.forEach((v, k) => { report += `• @${k.split('@')[0]} [${v.gemName}]\n`; });
        }

        await sock.sendMessage(chatId, { text: report, mentions: Array.from(State.stalkers.keys()) }, buildSafeQuote(m));
    });
}

// ==============================================================================
// 20. EXPORT LOGIC
// ==============================================================================
module.exports = {
    State,
    askAI,
    Gems,
    CFG,
    startIntelligentWatcher
};
if (typeof commandRegister === 'function') {

    // ── AI PERSONA SYSTEM ──────────────────────────────────────────────────
    commandRegister({ 
        pattern: "gem", 
        cmdname: "gem", 
        alias: ["gems", "persona"], 
        type: "ai", 
        category: "ai", 
        desc: "AI persona vault for creating and managing custom personalities.", 
        react: "💎", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const chatId = m.chat || m.from;
        const parts = q.trim().split(/\s+/);
        const cmd = parts[0]?.toLowerCase() || 'help';
        const rest = parts.slice(1);

        try {
            if (cmd === 'create') {
                if (rest.length < 2) return await sock.sendMessage(chatId, { text: "📝 *Usage:* `.gem create <name> <persona_prompt>`" }, buildSafeQuote(m));
                const [name, ...pArr] = rest;
                const content = pArr.join(' ');
                Gems.save(name, content);
                return await sock.sendMessage(chatId, { text: `✅ *Gem Saved:* \`${name}\`\n\n_${content.slice(0, 100)}..._` }, buildSafeQuote(m));
            }

            if (cmd === 'gen') {
                const topic = rest.join(' ');
                if (!topic) return await sock.sendMessage(chatId, { text: "📝 *Usage:* `.gem gen <topic>`" }, buildSafeQuote(m));
                await sock.sendMessage(chatId, { text: "🔮 _Forging new persona..._" }, buildSafeQuote(m));
                const { text, err } = await askAI(`Create a detailed WhatsApp persona prompt for: ${topic}. Speak in WhatsApp markdown.`);
                if (err) return await sock.sendMessage(chatId, { text: `⚠️ *Error:* ${text}` });
                const name = (rest[0] || 'gem').toLowerCase().slice(0, 10) + '_ai';
                Gems.save(name, text);
                return await sock.sendMessage(chatId, { text: `✨ *New Gem:* \`${name}\`\n\n${text}\n\n_Use with:_ \`.gem use ${name}\`` }, buildSafeQuote(m));
            }

            if (cmd === 'list') {
                const list = Gems.list();
                if (!list.length) return await sock.sendMessage(chatId, { text: "📚 *No gems found.* Create one with `.gem gen`" });
                return await sock.sendMessage(chatId, { text: `📚 *Available Gems:*\n\n${list.map(g => `• \`${g}\``).join('\n')}` }, buildSafeQuote(m));
            }

            if (cmd === 'use') {
                const name = rest[0];
                if (!name) return await sock.sendMessage(chatId, { text: "📝 *Usage:* `.gem use <name>`" });
                const persona = Gems.get(name);
                if (!persona) return await sock.sendMessage(chatId, { text: "❌ *Gem not found.*" });
                State.dmGem = persona;
                return await sock.sendMessage(chatId, { text: `✅ *DM Persona set to:* \`${name}\`` }, buildSafeQuote(m));
            }

            // Default Help
            const help = `💎 *GEM PERSONA SYSTEM*\n\n• \`.gem list\` - View all personas\n• \`.gem gen <topic>\` - AI creates a persona\n• \`.gem create <n> <p>\` - Manual creation\n• \`.gem use <n>\` - Set as active DM persona\n• \`.gem view <n>\` - See prompt details\n• \`.gem delete <n>\` - Remove a persona`;
            await sock.sendMessage(chatId, { text: help }, buildSafeQuote(m));

        } catch (e) {
            console.error(e);
        }
    });

    // ── ONE-SHOT AI SYSTEM ────────────────────────────────────────────────
    commandRegister({ 
        pattern: "gai", 
        cmdname: "gai", 
        alias: ["ai", "ask"], 
        type: "ai", 
        category: "ai", 
        desc: "Advanced AI assistant with vision and context awareness.", 
        react: "🧠", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const chatId = m.chat || m.from;
        
        if (!q && !m.quoted) return await sock.sendMessage(chatId, { text: "❓ *What is your question?*" });

        const parts = q.trim().split(/\s+/);
        const sub = parts[0]?.toLowerCase();

        // Sub-commands for control
        if (sub === 'dm') {
            State.dmActive = parts[1] === 'on';
            return await sock.sendMessage(chatId, { text: `📨 *DM Auto-Pilot:* ${State.dmActive ? "✅ ON" : "❌ OFF"}` });
        }
        if (sub === 'stop') {
            State.chats.delete(chatId);
            return await sock.sendMessage(chatId, { text: "🛑 *AI Session Terminated.*" });
        }
        if (sub === 'chat') {
            const gemName = parts[1] || 'default';
            const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            State.chats.set(chatId, { gem: persona, history: [], gemName });
            return await sock.sendMessage(chatId, { text: `⚔️ *Live Chat Session Active* [${gemName}]` });
        }

        // Logic for answering
        let imgUrls = [];
        const quoted = m.msg?.contextInfo?.quotedMessage || m.quoted;
        if (quoted?.imageMessage) {
            const path = await sock.downloadAndSaveMediaMessage(quoted.imageMessage);
            const url = await uploadImgBB(path);
            if (url) imgUrls.push(url);
        }

        const prompt = `INSTRUCTION: Provide response in WhatsApp markdown. Use bold for emphasis. If code is provided, use triple backticks. \n\nQUESTION: ${q}`;
        const { text, err } = await askAI(prompt, imgUrls);
        
        await sock.sendMessage(chatId, { text: err ? `⚠️ *API Error:* ${text}` : text }, buildSafeQuote(m));
    });

    // ── IMAGE GENERATION ──────────────────────────────────────────────────
    commandRegister({ 
        pattern: "img", 
        cmdname: "img", 
        alias: ["imagine", "draw"], 
        type: "ai", 
        category: "ai", 
        desc: "Generate high-quality AI images with various models.", 
        react: "🎨", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        const chatId = m.chat || m.from;

        if (!q) return await sock.sendMessage(chatId, { text: "📝 *Usage:* `.img <prompt>` or `.img config`" });

        if (q === 'config') {
            return await sock.sendMessage(chatId, { text: `⚙️ *IMG CONFIG*\nModel: \`${CFG.IMG_MODEL}\`\nSize: \`${CFG.IMG_SIZE}\`\nQuality: \`${CFG.IMG_QUALITY}\`` });
        }

        await sock.sendMessage(chatId, { text: "🎨 _Generating image, please wait..._" }, buildSafeQuote(m));
        const urls = await generateImage(q);
        
        if (!urls || urls.length === 0) return await sock.sendMessage(chatId, { text: "❌ *Failed to generate image.*" });

        await sock.sendMessage(chatId, { 
            image: { url: urls[0] }, 
            caption: `🎨 *Generated:* _${q.slice(0, 50)}..._\n🤖 *Model:* \`${CFG.IMG_MODEL}\`` 
        }, buildSafeQuote(m));
    });

    // ── API MONITOR ───────────────────────────────────────────────────────
    commandRegister({ 
        pattern: "apimon", 
        cmdname: "apimon", 
        alias: ["health"], 
        type: "admin", 
        category: "admin", 
        desc: "Monitor AI API health and rate limits.", 
        react: "📊", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const stats = Limiter.stats();
        const status = `📊 *SYSTEM MONITOR*\n\n` +
                       `📈 *RPM:* ${stats.rpm}/${CFG.MAX_RPM}\n` +
                       `📉 *RPH:* ${stats.rph}/${CFG.MAX_RPH}\n` +
                       `🤖 *AI Calls:* ${stats.ai}\n` +
                       `🎨 *Images:* ${stats.img}\n` +
                       `⚠️ *Errors:* ${stats.err}\n` +
                       `🛡️ *Circuit:* ${CB.open() ? "🔴 TRIPPED" : "🟢 CLOSED"}`;
        
        await sock.sendMessage(m.chat, { text: status }, buildSafeQuote(m));
    });

    // ── AUTO ENHANCE TOGGLE ───────────────────────────────────────────────
    commandRegister({ 
        pattern: "autoenhance", 
        cmdname: "autoenhance", 
        alias: ["ae"], 
        type: "ai", 
        category: "ai", 
        desc: "Automatically fix grammar/spelling in your messages.", 
        react: "✍️", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const mode = args[0]?.toLowerCase();
        
        if (mode === 'on') State.autoEnhance = true;
        else if (mode === 'off') State.autoEnhance = false;
        
        await sock.sendMessage(m.chat, { text: `✍️ *Auto-Enhance:* ${State.autoEnhance ? "✅ ENABLED" : "❌ DISABLED"}` });
    });

    // ── AI TRANSLATE ──────────────────────────────────────────────────────
    commandRegister({ 
        pattern: "aitranslate", 
        cmdname: "aitranslate", 
        alias: ["translate", "tr"], 
        type: "ai", 
        category: "ai", 
        desc: "Translate text to any language using AI.", 
        react: "🌐", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const lang = args[0];
        const text = args.slice(1).join(" ");
        
        if (!lang || !text) return await sock.sendMessage(m.chat, { text: "📝 *Usage:* `.tr <language> <text>`" });

        const { text: result, err } = await askAI(`Translate the following to ${lang}. Provide only the translation in WhatsApp markdown:\n\n${text}`);
        await sock.sendMessage(m.chat, { text: err ? "❌ *Translation Failed*" : `🌐 *Translation (${lang}):*\n\n${result}` }, buildSafeQuote(m));
    });

    // ── AI WRITE ──────────────────────────────────────────────────────────
    commandRegister({ 
        pattern: "aiwrite", 
        cmdname: "aiwrite", 
        alias: ["write", "compose"], 
        type: "ai", 
        category: "ai", 
        desc: "Compose professional or creative text.", 
        react: "📝", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const topic = args.join(" ");
        if (!topic) return await sock.sendMessage(m.chat, { text: "📝 *Provide a topic to write about.*" });

        const { text, err } = await askAI(`Write a detailed, well-formatted piece about: ${topic}. Use WhatsApp markdown bolding for headers.`);
        await sock.sendMessage(m.chat, { text: err ? "❌ *Writing Failed*" : text }, buildSafeQuote(m));
    });

    // ── AI DECODE ─────────────────────────────────────────────────────────
    commandRegister({ 
        pattern: "aidecode", 
        cmdname: "aidecode", 
        alias: ["explain"], 
        type: "ai", 
        category: "ai", 
        desc: "Analyze and explain images or complex text.", 
        react: "🔍", 
        filename: __filename 
    }, async (arg1, ...args) => { 
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(" ");
        
        let imgUrls = [];
        const quoted = m.msg?.contextInfo?.quotedMessage || m.quoted;
        if (quoted?.imageMessage) {
            const path = await sock.downloadAndSaveMediaMessage(quoted.imageMessage);
            const url = await uploadImgBB(path);
            if (url) imgUrls.push(url);
        }

        const prompt = `Explain and analyze this ${imgUrls.length > 0 ? "image" : "text"} in detail. Focus: ${q || "General overview"}. Use WhatsApp markdown.`;
        const { text, err } = await askAI(prompt, imgUrls);
        
        await sock.sendMessage(m.chat, { text: err ? "⚠️ *Analysis Failed*" : `🔍 *AI DECODE*\n\n${text}` }, buildSafeQuote(m));
    });
}
