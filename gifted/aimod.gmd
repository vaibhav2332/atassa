// ==============================================================================
// 3. DATABASE
// ==============================================================================
let db = null;
if (Database) {
    try {
        const dbDir = path.dirname(CFG.DB_PATH);
        if (!fs.existsSync(dbDir)) fs.mkdirSync(dbDir, { recursive: true });
        
        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        console.log('[AIGems] Database ready');
    } catch(e) { console.error('[AIGems] DB error:', e.message); db = null; }
}

const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT content FROM gems WHERE name=?').get(n.toLowerCase().trim())?.content ?? null; } catch(e){ return null; } },
    save : (n, c) => { try { return !!db?.prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(n.toLowerCase().trim(), c)?.changes; } catch(e){ return false; } },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};

// ==============================================================================
// 4. RATE LIMITER + CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q:[], hr_q:[], daily:{ai:0,img:0,err:0,day:new Date().toDateString()},
    check() {
        const n=Date.now();
        this.min_q=this.min_q.filter(t=>n-t<60000);
        this.hr_q=this.hr_q.filter(t=>n-t<3600000);
        return this.min_q.length<CFG.MAX_RPM && this.hr_q.length<CFG.MAX_RPH;
    },
    hit(type='ai'){
        const n=Date.now(); this.min_q.push(n); this.hr_q.push(n);
        const d=new Date().toDateString();
        if(d!==this.daily.day) this.daily={ai:0,img:0,err:0,day:d};
        if(type==='ai') this.daily.ai++;
        if(type==='img') this.daily.img++;
    },
    err(){ this.daily.err++; },
    stats(){
        const n=Date.now();
        return {rpm:this.min_q.filter(t=>n-t<60000).length, rph:this.hr_q.filter(t=>n-t<3600000).length, ...this.daily};
    }
};

const CB = {
    fails:0, lastFail:0, THRESH:5, TTL:300000,
    open()  { return this.fails>=this.THRESH && Date.now()-this.lastFail<this.TTL; },
    fail()  { this.fails++; this.lastFail=Date.now(); Limiter.err(); },
    ok()    { this.fails=0; },
    reset() { this.fails=0; this.lastFail=0; },
    msg()   { return ['neural link glitchy rn','signal weak on my end','connection hiccupped','brain.exe crashed lol'][Math.floor(Math.random()*4)]; }
};
};
// ==============================================================================
// 5. CORE AI — QuillBot SSE streaming (responseType: 'stream' for proper SSE)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const systemInstruction = "Strictly adhere to WhatsApp Markdown in all outputs: use *bold* for emphasis, _italics_ for subtle notes, and structured bullet points with emojis where appropriate. Never use markdown headers (###).";
    const finalPrompt = `${systemInstruction}\n\nUser: ${prompt}`;

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: finalPrompt,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { 
                        const o = JSON.parse(l.slice(6)); 
                        if (o.chunk) full += o.chunk; 
                    } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1500 * (attempt + 1)); continue; }
                CB.fail();
                return { text: 'empty response — api connection jittery', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] askAI attempt ${attempt+1}:`, e.message);
            if (attempt < CFG.RETRIES - 1) await sleep(1500 * (attempt + 1));
            else { 
                CB.fail(); 
                return { text: `Neural link unstable — ${e.message}`, err: true }; 
            }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 6. IMGBB UPLOADER
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch(e) { 
        console.error('[AIGems] ImgBB Upload Error:', e.message); 
        return null; 
    }
};

// ==============================================================================
// 7. IMAGE GENERATOR — Infip API (key pool)
// ==============================================================================
let _iKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
let _iOk  = false;
const _iCache = new Map();
const _iHdr = () => ({ Authorization: `Bearer ${_iKey}`, 'Content-Type': 'application/json' });

const ensureInfip = async () => {
    if (_iOk) return true;
    try { 
        const r = await axios.get(`${CFG.INFIP_URL}/v1/models`, { headers: _iHdr(), timeout: 10000 }); 
        if (r.status === 200) { _iOk = true; return true; } 
    } catch(e){}
    try { 
        const r = await axios.post(`${CFG.INFIP_URL}/v1/api-keys`, {}, { timeout: 10000 }); 
        if (r.data?.api_key) { _iKey = r.data.api_key; _iOk = true; return true; } 
    } catch(e){}
    _iOk = true; 
    return false;
};

const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL, 
          size  = opts.size  || CFG.IMG_SIZE,
          n     = Math.min(opts.count || CFG.IMG_COUNT, 4), 
          quality = opts.quality || CFG.IMG_QUALITY, 
          style = opts.style || CFG.IMG_STYLE;
          
    const cacheKey = `${model}|${size}|${prompt.slice(0, 100)}`;
    const hit = _iCache.get(cacheKey);
    if (hit && Date.now() - hit.ts < 3600000) return hit.urls;
    
    if (!Limiter.check()) return [];
    await ensureInfip(); 
    Limiter.hit('img');

    for (let i = 0; i < CFG.RETRIES; i++) {
        try {
            const r = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`,
                { model, prompt, n, size, response_format: 'url', quality, style },
                { headers: _iHdr(), timeout: CFG.TIMEOUT }
            );
            if (r.status === 200 && r.data?.data?.length) { 
                const urls = r.data.data.map(d => d.url); 
                _iCache.set(cacheKey, { urls, ts: Date.now() }); 
                return urls; 
            }
        } catch(e) { 
            Limiter.err(); 
            if (i < CFG.RETRIES - 1) await sleep(2000 * (i + 1)); 
        }
    }
    return [];
};

// ==============================================================================
// 8. RUNTIME STATE
// ==============================================================================
const State = {
    dmActive: false, 
    dmGem: null,
    chats: new Map(), 
    targets: new Map(), 
    stalkers: new Map(), 
    dmSessions: new Map(),
    autoEnhance: false,
    PERSONA: 'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Never say you are an AI. Use conversation history to stay consistent. Always use WhatsApp Markdown: *bold*, _italics_, and structured bullet points.',
    
    addHist(ctx, role, txt) { 
        if (!ctx.history) ctx.history = []; 
        const t = new Date().toLocaleTimeString('en', { hour12: false, hour: '2-digit', minute: '2-digit' }); 
        ctx.history.push(`[${t}] ${role}: ${txt}`); 
        if (ctx.history.length > CFG.MAX_HIST) ctx.history = ctx.history.slice(-CFG.MAX_HIST); 
    },
    
    buildPrompt(sys, hist, input) { 
        return `SYSTEM:\n${sys}\n\n--- HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nREPLY:`; 
    }
};
// ==============================================================================
// 5. CORE AI — QuillBot SSE streaming (responseType: 'stream' for proper SSE)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

/**
 * Communicates with QuillBot AI using the SSE stream endpoint.
 * Includes fixed SSE parsing logic to handle "chunk" extraction accurately.
 */
const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const systemInstruction = "Strictly adhere to WhatsApp Markdown in all outputs: use *bold* for emphasis, _italics_ for subtle notes, and structured bullet points with emojis where appropriate. Never use markdown headers (###).";
    const finalPrompt = `${systemInstruction}\n\nUser: ${prompt}`;

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: finalPrompt,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            // Collect SSE chunks into full text
            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            // Parse SSE: extract all "chunk" values from QuillBot's Raven stream
            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { 
                        const o = JSON.parse(l.slice(6)); 
                        if (o.chunk) full += o.chunk; 
                    } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1500 * (attempt + 1)); continue; }
                CB.fail();
                return { text: 'empty response — service may be temporarily throttled', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] askAI attempt ${attempt+1}:`, e.message);
            if (attempt < CFG.RETRIES - 1) await sleep(1500 * (attempt + 1));
            else { 
                CB.fail(); 
                return { text: `Neural link unstable — ${e.message}`, err: true }; 
            }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 9. MESSAGE HELPERS
// ==============================================================================

/**
 * Sends a temporary "thinking" label to provide user feedback.
 */
const thinking = async (Gifted, from, mek, label = '⏳ _thinking…_') => {
    try {
        return await Gifted.sendMessage(from, { text: label }, { quoted: mek });
    } catch (e) {
        return null;
    }
};

/**
 * Edits an existing message if possible, or falls back to delete/resend.
 */
const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText, edit: sentMsg.key });
        return;
    } catch (e) {}
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { delete: sentMsg.key });
    } catch (e) {}
    await sleep(400);
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText });
    } catch (e) {
        console.error('[AIGems] editMsg Error:', e.message);
    }
};

/**
 * Deletes a message by its key.
 */
const del = async (Gifted, key) => {
    try {
        await Gifted.sendMessage(key.remoteJid, { delete: key });
    } catch (_) {}
};

/**
 * Sends an image via URL; provides text link fallback on failure.
 */
const sendImg = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { image: { url }, caption }, { quoted: mek });
        return true;
    } catch (e) {
        try {
            await Gifted.sendMessage(from, { text: `🎨 ${caption}\n\n🔗 ${url}` }, { quoted: mek });
        } catch (_) {}
        return false;
    }
};

// ==============================================================================
// 10.  .gem  — PERSONA VAULT SYSTEM
// ==============================================================================
gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['gems', 'persona'],
    category: 'ai',
    desc: 'AI persona vault. .gem help for all sub-commands.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');
    const parts = q.trim().split(/\s+/),
        cmd = parts[0]?.toLowerCase() || 'help',
        rest = parts.slice(1);

    if (cmd === 'create') {
        if (rest.length < 2) return reply('📝 `.gem create <name> <persona prompt>`');
        const [name, ...pArr] = rest, content = pArr.join(' ');
        return Gems.save(name, content) ?
            reply(`💎 *Gem Saved*\n\n*Name:* \`${name}\`\n*Preview:* _${content.slice(0, 120)}_`) :
            reply('❌ *Database error.*');
    }
    if (cmd === 'gen') {
        const topic = rest.join(' ');
        if (!topic) return reply('📝 `.gem gen <topic>`  e.g. `.gem gen sarcastic gamer`');
        const stub = await thinking(Gifted, from, mek, `🔮 _Forging "${topic}"…_`);
        const { text, err } = await askAI(`Create a detailed WhatsApp persona system prompt for: ${topic}.\nInclude personality, speaking style, slang, emoji habits.\nInstructions: Always use WhatsApp Markdown (*bold*, _italics_). Return ONLY the raw system prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const name = (rest[0] || 'gem').toLowerCase().slice(0, 12) + '_ai';
        Gems.save(name, text);
        return editMsg(Gifted, stub, `✨ *Gem Created*\n\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0, 150)}_\n\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd === 'analyze') {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!quoted) return reply('📝 *Reply to a message* then run `.gem analyze`');
        const sample = quoted.conversation || quoted.extendedTextMessage?.text || '[no text]';
        const stub = await thinking(Gifted, from, mek, '🕵️ _Cloning style…_');
        const { text, err } = await askAI(`Analyze this WhatsApp message and build a system prompt to clone this style exactly:\n"${sample}"\nEnsure the persona uses WhatsApp markdown. Return ONLY the system prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const name = `clone_${Date.now().toString(36)}`;
        Gems.save(name, text);
        return editMsg(Gifted, stub, `🧬 *Clone Created*\n\n*Name:* \`${name}\`\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd === 'remix') {
        const [gemName, ...tw] = rest;
        const tweak = tw.join(' ');
        if (!gemName || !tweak) return reply('📝 `.gem remix <name> <modification>`');
        const base = Gems.get(gemName);
        if (!base) return reply(`❌ Gem \`${gemName}\` not found.`);
        const stub = await thinking(Gifted, from, mek, `🔀 _Remixing "${gemName}"…_`);
        const { text, err } = await askAI(`Modify this system prompt per the instruction. Keep the core but apply the change. Return ONLY the updated prompt.\n\nOriginal:\n${base}\n\nChange: ${tweak}`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const newName = `${gemName}_remix`;
        Gems.save(newName, text);
        return editMsg(Gifted, stub, `🔀 *Remixed*\n\n\`${gemName}\` → \`${newName}\``);
    }
    if (cmd === 'list') {
        const list = Gems.list();
        if (!list.length) return reply('📚 *No gems yet.*\n`.gem gen <topic>` or `.gem create <n> <prompt>`');
        return reply(`📚 *Gems Vault (${list.length})*\n\n${list.map((g, i) => `${i + 1}. 💎 \`${g}\``).join('\n')}\n\n_Use_ \`.gem use <n>\``);
    }
    if (cmd === 'view') {
        const c = Gems.get(rest[0] || '');
        if (!rest[0]) return reply('📝 `.gem view <name>`');
        if (!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        return reply(`💎 *${rest[0].toUpperCase()}*\n\n${c}`);
    }
    if (cmd === 'use') {
        if (!rest[0]) return reply('📝 `.gem use <name>`');
        const c = Gems.get(rest[0]);
        if (!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        State.dmGem = c;
        return reply(`✅ *DM Persona set to:* \`${rest[0]}\`\nEnable with \`.gai dm on\``);
    }
    if (cmd === 'delete' || cmd === 'del') {
        if (!rest[0]) return reply('📝 `.gem delete <name>`');
        return Gems.del(rest[0]) ? reply(`🗑️ Gem \`${rest[0]}\` deleted.`) : reply(`❌ Not found.`);
    }
    return reply(
        `💎 *GEM — Persona Vault Management*\n\n` +
        `• \`.gem create <n> <prompt>\` — Save manual persona\n` +
        `• \`.gem gen <topic>\` — AI generates persona\n` +
        `• \`.gem analyze\` — Clone from replied message\n` +
        `• \`.gem remix <n> <tweak>\` — Edit existing persona\n` +
        `• \`.gem list\` — Show all saved gems\n` +
        `• \`.gem view <n>\` — View persona prompt\n` +
        `• \`.gem use <n>\` — Set as active DM persona\n` +
        `• \`.gem delete <n>\` — Remove a gem\n\n` +
        `*Tip:* Use \`.gai dm on\` after selecting a gem.`
    );
});
// ==============================================================================
// 11.  .gai  — ONE-SHOT AI + AUTO-REPLY CONTROL
// ==============================================================================
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'ask', 'brain'],
    category: 'ai',
    desc: 'AI assistant & auto-reply control. .gai help',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');
    const parts = q.trim().split(/\s+/),
        cmd = parts[0]?.toLowerCase() || '',
        rest = parts.slice(1),
        second = rest[0]?.toLowerCase() || '';

    if (cmd === 'dm') {
        if (second === 'on') {
            State.dmActive = true;
            return reply(`📨 *DM Auto-Pilot:* ✅ *ON*\n*Persona:* ${State.dmGem ? 'Custom gem' : 'Default'}`);
        }
        if (second === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot:* ❌ *OFF*');
        }
        return reply(`📨 *DM Auto-Pilot Status:* ${State.dmActive ? '✅ ON' : '❌ OFF'}`);
    }
    if (cmd === 'chat') {
        const gemName = second || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.chats.set(from, { gem: gemTxt, history: [], gemName, lastActive: Date.now() });
        return reply(`⚔️ *Chat AI Active*\n*Gem:* \`${gemName}\`\nAI will now reply to every message in this chat.`);
    }
    if (cmd === 'target' || cmd === 'bot') {
        const num = rest[0]?.replace(/[^0-9]/g, '');
        if (!num) return reply('📝 `.gai target <number> [gem]`\n_Enables AI for messages from this number in this chat._');
        const tjid = num + '@s.whatsapp.net',
            gemName = rest[1] || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.targets.set(tjid, { gem: gemTxt, history: [], chatId: from, gemName });
        return reply(`🤖 *Target Locked*\n*User:* @${num}\n*Gem:* \`${gemName}\`\nAI will reply only to this user here.`);
    }
    if (cmd === 'stalk') {
        const num = rest[0]?.replace(/[^0-9]/g, '');
        if (!num) return reply('📝 `.gai stalk <number> [gem]`\n_Enables AI for this user across ALL chats._');
        const tjid = num + '@s.whatsapp.net',
            gemName = rest[1] || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.stalkers.set(tjid, { gem: gemTxt, history: [], gemName });
        return reply(`🌍 *Global Stalker Active*\n*User:* @${num}\n*Gem:* \`${gemName}\`\nAI will track and reply to this user everywhere.`);
    }
    if (cmd === 'stop') {
        if (second === 'all') {
            State.dmActive = false;
            State.chats.clear();
            State.targets.clear();
            State.stalkers.clear();
            State.dmSessions.clear();
            return reply('☢️ *ALL AI SERVICES TERMINATED*\nDM: OFF | Chats: 0 | Targets: 0 | Stalkers: 0');
        }
        State.chats.delete(from);
        return reply('🛑 *AI stopped in this chat.*\n_To stop everything:_ `.gai stop all`');
    }
    if (cmd === 'wipe') {
        const sess = State.chats.get(from);
        if (sess) { sess.history = []; return reply('🧠 *Memory wiped for this session!*'); }
        return reply('ℹ️ No active session here.');
    }
    if (cmd === 'status') {
        const s = Limiter.stats(), cb = CB.open() ? `🔴 *TRIPPED* (${CB.fails}/${CB.THRESH})` : `🟢 *OK*`;
        let out = `📊 *AI SYSTEM STATUS*\n\n` +
            `• *DM Auto:* ${State.dmActive ? '✅' : '❌'}\n` +
            `• *Active Chats:* ${State.chats.size}\n` +
            `• *Targets:* ${State.targets.size}\n` +
            `• *Stalkers:* ${State.stalkers.size}\n` +
            `• *Load:* ${s.rpm} rpm / ${s.rph} rph\n` +
            `• *Today:* AI: ${s.ai} | Img: ${s.img} | Err: ${s.err}\n` +
            `• *Circuit:* ${cb}`;
        if (State.chats.size) {
            out += '\n\n*Active Sessions:*';
            State.chats.forEach((d, c) => { out += `\n• ${c.split('@')[0]}: ${d.history.length} msg (${d.gemName})`; });
        }
        return reply(out);
    }
    if (cmd === 'summary') {
        const sess = State.chats.get(from);
        if (!sess || sess.history.length < 2) return reply('ℹ️ Not enough history here.');
        const stub = await thinking(Gifted, from, mek, '📝 _Summarizing conversation…_');
        const { text, err } = await askAI(`Summarize this WhatsApp chat history into concise, key bullet points:\n\n${sess.history.join('\n')}\n\nFormat with WhatsApp Markdown.`);
        return editMsg(Gifted, stub, err ? `❌ ${text}` : `📝 *Conversation Summary*\n\n${text}`);
    }
    if (cmd === 'help') {
        return reply(
            `🧠 *GAI — AI MASTER CONTROL*\n\n` +
            `*Quick Ask:*\n• \`.gai <any question>\`\n\n` +
            `*Auto-Reply Modes:*\n` +
            `• \`.gai dm on/off\` — AI for all private DMs\n` +
            `• \`.gai chat [gem]\` — AI for everyone in this chat\n` +
            `• \`.gai target <num> [gem]\` — AI for specific user here\n` +
            `• \`.gai stalk <num> [gem]\` — AI for user in all chats\n\n` +
            `*Management:*\n` +
            `• \`.gai stop\` — Stop AI here\n` +
            `• \`.gai stop all\` — Kill all AI tasks\n` +
            `• \`.gai wipe\` — Clear AI memory here\n` +
            `• \`.gai status\` — System health & usage`
        );
    }

    const question = q.trim();
    if (!question) return reply('📝 *Usage:* \`.gai <your question>\` or \`.gai help\`');

    let imgUrls = [];
    const quotedMsg = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quotedMsg?.imageMessage) {
        await react('👁️');
        try {
            const tp = await Gifted.downloadAndSaveMediaMessage(quotedMsg.imageMessage, `tmp_gai_${Date.now()}`);
            if (tp) {
                const url = await uploadImgBB(tp);
                if (url) imgUrls.push(url);
                try { fs.unlinkSync(tp); } catch (_) {}
            }
        } catch (e) { console.error('[AIGems] vision error:', e.message); }
    }

    const stub = await thinking(Gifted, from, mek, '🧠 _thinking…_');
    let finalPrompt = question;
    const ctx = quotedMsg?.conversation || quotedMsg?.extendedTextMessage?.text;
    if (ctx) finalPrompt = `Context from previous message:\n"${ctx}"\n\nQuestion: ${question}\n\nUse WhatsApp Markdown in response.`;
    
    const { text, err } = await askAI(finalPrompt, imgUrls);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
});

// ==============================================================================
// 12.  .img  — IMAGE GENERATION (Media Handling Integration)
// ==============================================================================
gmd({
    pattern:'img', cmdname:'img', aliases:['imagine','genimg','drawai'],
    category:'ai', desc:'AI image generation. .img help for all sub-commands.', react:'🎨', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'help', rest=parts.slice(1);
    const KNOWN=['gen','surprise','chaos','models','config','enhance','setup','random','cache','help'];

    const doGen=async(prompt,stub)=>{
        const urls=await generateImage(prompt);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Generation failed. Check `.img setup`.');
        await del(Gifted,stub.key);
        await sendImg(Gifted,from,urls[0],`🎨 _${prompt.slice(0,200)}_\n🤖 \`${CFG.IMG_MODEL}\``,mek);
        for(const u of urls.slice(1)) await sendImg(Gifted,from,u,'🎨 _Variation_',mek);
    };

    if(cmd==='gen'||(!KNOWN.includes(cmd)&&q)){
        const prompt=cmd==='gen'?rest.join(' '):q;
        if(!prompt.trim()) return reply('📝 \`.img gen <prompt>\`');
        await react('🎨');
        return doGen(prompt, await thinking(Gifted,from,mek,'🎨 _Generating…_'));
    }
    if(cmd==='surprise'){
        const hint=rest.join(' ');
        const stub=await thinking(Gifted,from,mek,`🎲 _Dreaming${hint?` (${hint})`:''}…_`);
        const {text:dreamt,err}=await askAI(`Generate a highly detailed creative image prompt${hint?` themed: "${hint}"`:''}.\nReturn ONLY the prompt.`);
        if(err) return editMsg(Gifted,stub,`❌ ${dreamt}`);
        await editMsg(Gifted,stub,`🎲 _Visualising:_ "${dreamt.slice(0,80)}…"`);
        const urls=await generateImage(dreamt);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Failed. Retry.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`🎲 *Surprise!*\n💭 _${dreamt.slice(0,200)}_`,mek);
    }
    if(cmd==='chaos'){
        const free=Object.keys(CFG.IMG_MDLS).filter(k=>CFG.IMG_MDLS[k].tier==='free');
        CFG.IMG_MODEL=free[Math.floor(Math.random()*free.length)];
        CFG.IMG_SIZE=['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        CFG.IMG_QUALITY=Math.random()>.5?'hd':'standard'; CFG.IMG_STYLE=Math.random()>.5?'vivid':'natural';
        const stub=await thinking(Gifted,from,mek,`🌪️ *CHAOS* — ${CFG.IMG_MODEL} | ${CFG.IMG_SIZE}`);
        const {text:chaos}=await askAI('Generate a bizarre surreal image prompt defying logic. Return ONLY prompt.');
        const fp=chaos||'melting clocks cybernetic forest neon rain 8k';
        const urls=await generateImage(fp);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Chaos failed.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`🌪️ *CHAOS*\n💭 _${fp.slice(0,200)}_\n⚙️ \`${CFG.IMG_MODEL}\` \`${CFG.IMG_SIZE}\``,mek);
    }
    if(cmd==='models'){
        const lines=Object.entries(CFG.IMG_MDLS).map(([id,m])=>`${m.tier==='pro'?'👑':'🆓'} \`${id}\` — ${m.desc}`).join('\n');
        return reply(`📋 *Available Models*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\` \`.img config <model>\``);
    }
    if(cmd==='config'){
        if(!rest[0]) return reply(`⚙️ Model: \`${CFG.IMG_MODEL}\` Size: \`${CFG.IMG_SIZE}\` Count: ${CFG.IMG_COUNT}\n📝 \`.img config <model> [size] [n] [quality] [style]\``);
        const [model,size,count,quality,style]=rest;
        if(model&&!CFG.IMG_MDLS[model]) return reply(`❌ Model \`${model}\` unknown.`);
        if(model) CFG.IMG_MODEL=model; if(size) CFG.IMG_SIZE=size;
        if(count) CFG.IMG_COUNT=Math.min(parseInt(count)||1,4);
        if(quality) CFG.IMG_QUALITY=quality; if(style) CFG.IMG_STYLE=style;
        return reply(`✅ *Updated:* \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\``);
    }
    if(cmd==='enhance'){
        const p=rest.join(' '); if(!p) return reply('📝 \`.img enhance <prompt>\`');
        const stub=await thinking(Gifted,from,mek,'🧠 _Enhancing…_');
        const {text,err}=await askAI(`Enhance this image prompt — richer details. Return ONLY prompt.\n\n${p}`);
        return editMsg(Gifted,stub,err?`❌ ${text}`:`✨ *Enhanced Prompt*\n\n${text}`);
    }
    if(cmd==='setup'){
        const stub=await thinking(Gifted,from,mek,'🔧 _Validating Infip..._');
        _iOk=false; const ok=await ensureInfip();
        return editMsg(Gifted,stub,ok?`✅ *Infip Ready*`:`❌ *Setup Failed* — keys invalid`);
    }
    if(cmd==='cache'){ _iCache.clear(); return reply('🗑️ Image cache cleared.'); }
    return reply(`🎨 *IMAGE COMMANDS*\n\n• \`.img gen <prompt>\`\n• \`.img surprise\`\n• \`.img chaos\`\n• \`.img models\`\n• \`.img config\`\n• \`.img setup\`\n\n*Active:* \`${CFG.IMG_MODEL}\``);
});

// ==============================================================================
// 13.  .apimon  — API MONITOR
// ==============================================================================
gmd({
    pattern:'apimon', cmdname:'apimon', category:'ai', desc:'AI API health check.', react:'📊', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const cmd=q.trim().split(/\s+/)[0]?.toLowerCase()||'status';
    if(cmd==='status'||!q.trim()){
        const s=Limiter.stats(), cb=CB.open()?'🔴 *TRIPPED*':`🟢 *OK*`;
        return reply(`📊 *AI API Status*\n\n*RPM:* ${s.rpm}/${CFG.MAX_RPM}\n*RPH:* ${s.rph}/${CFG.MAX_RPH}\n*Today:* AI:${s.ai} Img:${s.img} Err:${s.err}\n*Circuit:* ${cb}`);
    }
    if(cmd==='health'){
        const stub=await thinking(Gifted,from,mek,'🔍 _System health check…_');
        const {text:tr,err:te}=await askAI('Reply ONLY with: HEALTH_OK');
        const lines=[
            (!te&&tr.includes('HEALTH_OK'))?'✅ QuillBot: Healthy':`❌ QuillBot: Error`,
            CB.open()?'🔴 Circuit: TRIPPED':'✅ Circuit: Closed',
            _iOk?'✅ Infip: Validated':'⚠️ Infip: Not tested'
        ];
        return editMsg(Gifted,stub,`🔍 *AI Health Check*\n\n${lines.join('\n')}`);
    }
    if(cmd==='reset'){
        CB.reset(); Limiter.daily={ai:0,img:0,err:0,day:new Date().toDateString()};
        return reply('✅ Stats and circuit reset.');
    }
    return reply('📊 \`.apimon status/health/reset\`');
});

