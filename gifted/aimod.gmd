    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');
    const parts = q.trim().split(/\s+/), type = parts[0]?.toLowerCase(), topic = parts.slice(1).join(' ');
    const templates = {
        roast: 'Write a savage WhatsApp roast about {t}. Use emojis.',
        caption: 'Write 3 catchy captions for {t}.',
        code: 'Write optimized code for {t}. Use markdown blocks.',
        email: 'Draft a professional email about {t}.'
    };
    if (!templates[type] || !topic) return reply(`✍️ \`.aiwrite <roast|caption|code|email> <topic>\``);
    const stub = await thinking(Gifted, from, mek, '✍️ _Drafting..._');
    const { text, err } = await askAI(templates[type].replace('{t}', topic) + "\n\nUse WhatsApp Markdown.");
    return editMsg(Gifted, stub, err ? `❌ ${text}` : `✨ *AI ${type.toUpperCase()}*\n\n${text}`);
});

// ==============================================================================
// 15. WATCHER ENGINE — REACTIVE AUTOMATION
// ==============================================================================
let _watchSet = false;
const attachWatcher = (Gifted) => {
    if (_watchSet || !Gifted?.ev) return;
    _watchSet = true;
    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;
        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;
                const chatId = msg.key.remoteJid, sender = (msg.key.participant || chatId || '').split('@')[0] + '@s.whatsapp.net';
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';
                if (!body.trim() && !msg.message.imageMessage) continue;
                if (body.startsWith('.') || body.startsWith('/')) continue;

                let sess = null;
                if (State.stalkers.has(sender)) sess = State.stalkers.get(sender);
                else if (State.targets.has(sender)) {
                    const t = State.targets.get(sender); if (!t.chatId || t.chatId === chatId) sess = t;
                } else if (State.chats.has(chatId)) sess = State.chats.get(chatId);
                else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) State.dmSessions.set(sender, { gem: State.dmGem || State.PERSONA, history: [] });
                    sess = State.dmSessions.get(sender);
                }

                if (!sess) continue;

                setImmediate(async () => {
                    let vis = [];
                    if (msg.message.imageMessage) {
                        try {
                            const tp = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, `tmp_w_${Date.now()}`);
                            const u = await uploadImgBB(tp); if (u) vis.push(u); if (fs.existsSync(tp)) fs.unlinkSync(tp);
                        } catch (e) {}
                    }
                    const input = body || '[image]'; State.addHist(sess, 'User', input);
                    const prompt = State.buildPrompt(sess.gem, sess.history, input);
                    await sleep(1000 + Math.random() * 2000);
                    try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}
                    const { text, err } = await askAI(prompt, vis);
                    try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (_) {}
                    if (!err) { State.addHist(sess, 'AI', text); await Gifted.sendMessage(chatId, { text }, { quoted: msg }); }
                });
            } catch (e) {}
        }
    });
};

// --- System Initialization ---
const _init = setInterval(() => {
    const G = global.conn || global.client;
    if (G) { attachWatcher(G); clearInterval(_init); }
}, 5000);

module.exports = { State, Gems, askAI, generateImage, attachWatcher };
console.log('[AIGems] Phase 5 (Master Suite) fully operational.');
