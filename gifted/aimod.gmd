if (typeof commandRegister === 'function') {

    /**
     * .img: Professional image generation with cache checking.
     */
    commandRegister({
        pattern: "img",
        cmdname: "img",
        alias: ["imagine", "draw", "generate"],
        category: "ai",
        desc: "Generate professional images using the Infip engine.",
        react: "🎨",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const prompt = args.join(" ");

        if (!prompt) return sock.sendMessage(jid, { text: "🎨 *Prompt Required:* Tell me what to draw.\nExample: `.img a neon cyberpunk cat in a rainy alley`" }, buildSafeQuote(m));

        const thinking = await sock.sendMessage(jid, { text: "🎨 _Generating your vision..._" }, buildSafeQuote(m));
        
        const urls = await generateImage(prompt);
        
        if (urls && urls.length > 0) {
            await sock.sendMessage(jid, { delete: thinking.key }).catch(() => {});
            await sock.sendMessage(jid, {
                image: { url: urls[0] },
                caption: `✨ *Prompt:* ${prompt}\n🤖 *Engine:* \`${CFG.IMG_MODEL}\`\n📏 *Size:* \`${CFG.IMG_SIZE}\``
            }, buildSafeQuote(m));
        } else {
            await sock.sendMessage(jid, { 
                text: "❌ *Error:* Generation failed. The neural forge is currently busy.", 
                edit: thinking.key 
            });
        }
    });

    /**
     * .setupimg: Re-validates the Infip key pool.
     */
    commandRegister({
        pattern: "setupimg",
        cmdname: "setupimg",
        category: "ai",
        desc: "Force refresh and validate image generation keys.",
        react: "🔧",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        _iOk = false;
        const status = await ensureInfip();
        const msg = status 
            ? `✅ *Infip System:* Active\n🔑 *Current Key:* \`${_iKey.slice(0, 15)}...*`
            : `❌ *Infip System:* Offline (Check keys in CFG)`;
        await sock.sendMessage(m.key.remoteJid, { text: msg }, buildSafeQuote(m));
    });

}

// ==============================================================================
// 19. REFINED STALK/TARGET LOGIC (Corrected for proper tracking)
// ==============================================================================

if (typeof commandRegister === 'function') {

    /**
     * Target: Focus on a user within a specific chat.
     */
    commandRegister({
        pattern: "target",
        cmdname: "target",
        alias: ["bot"],
        category: "ai",
        desc: "Force the AI to respond to a specific user in this chat.",
        react: "🎯",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");

        let targetJid = m.message?.extendedTextMessage?.contextInfo?.participant || q.split(" ")[0];
        if (!targetJid) return sock.sendMessage(jid, { text: "❌ *Error:* Mention a user or provide a number." }, buildSafeQuote(m));

        targetJid = targetJid.replace(/[^0-9]/g, "") + "@s.whatsapp.net";
        const gem = q.split(" ")[1] || "default";
        
        State.targets.set(targetJid, {
            gem: (gem !== "default" ? (Gems.get(gem) || State.DEFAULT_PROMPT) : State.DEFAULT_PROMPT),
            history: [],
            chatId: jid,
            gemName: gem
        });

        await sock.sendMessage(jid, { 
            text: `🎯 *Target Locked*\n*User:* @${targetJid.split("@")[0]}\n*Persona:* \`${gem}\`\n_AI will now automatically reply to this user in this chat._`,
            mentions: [targetJid]
        }, buildSafeQuote(m));
    });

    /**
     * Stalk: Global tracking across all shared chats.
     */
    commandRegister({
        pattern: "stalk",
        cmdname: "stalk",
        alias: ["follow"],
        category: "ai",
        desc: "AI follows and responds to a user in every chat.",
        react: "🕵️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");

        let stalkJid = m.message?.extendedTextMessage?.contextInfo?.participant || q.split(" ")[0];
        if (!stalkJid) return sock.sendMessage(jid, { text: "❌ *Error:* Tag a user to stalk." }, buildSafeQuote(m));

        stalkJid = stalkJid.replace(/[^0-9]/g, "") + "@s.whatsapp.net";
        const gem = q.split(" ")[1] || "default";

        State.stalkers.set(stalkJid, {
            gem: (gem !== "default" ? (Gems.get(gem) || State.DEFAULT_PROMPT) : State.DEFAULT_PROMPT),
            history: [],
            gemName: gem
        });

        await sock.sendMessage(jid, {
            text: `🕵️ *Global Stalker Engaged*\n*Target:* @${stalkJid.split("@")[0]}\n*Persona:* \`${gem}\`\n_AI will respond to this user globally._`,
            mentions: [stalkJid]
        }, buildSafeQuote(m));
    });

}

// ==============================================================================
// 20. WATCHER INITIALIZATION
// ==============================================================================
// This section will be expanded in Phase 6 to include the full messages.upsert 
// logic combining Stalkers, Targets, and the AI Core Engine.
// ==============================================================================
// 21. GEM PERSONA VAULT (.gem) — Command Suite
// ==============================================================================

if (typeof commandRegister === 'function') {

    /**
     * .gem - Central command for managing AI personalities.
     */
    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "brain-vault"],
        category: "ai",
        desc: "Manage custom AI personas. Use '.gem help' for all sub-commands.",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ").trim();
        const parts = q.split(/\s+/);
        const cmd = parts[0]?.toLowerCase();
        const input = parts.slice(1).join(" ");

        const send = async (txt) => await sock.sendMessage(jid, { text: txt }, buildSafeQuote(m));

        if (!cmd || cmd === 'help') {
            return send(
                `💎 *GEM PERSONA SYSTEM*\n\n` +
                `• \`.gem list\` — Show all saved personas\n` +
                `• \`.gem create <n> <p>\` — Manual creation\n` +
                `• \`.gem gen <topic>\` — AI generates a persona\n` +
                `• \`.gem analyze\` — Clone style from replied msg\n` +
                `• \`.gem remix <n> <tweak>\` — Evolve a persona\n` +
                `• \`.gem view <n>\` — See persona content\n` +
                `• \`.gem use <n>\` — Set as active DM persona\n` +
                `• \`.gem del <n>\` — Remove from vault\n` +
                `• \`.gem battle <n1> <n2> <topic>\` — Two gems fight`
            );
        }

        switch (cmd) {
            case 'list': {
                const list = Gems.list();
                if (!list.length) return send("📚 No gems found. Create one with `.gem gen sarcastic-cat`.");
                return send(`📚 *Gems Vault (${list.length})*\n\n${list.map((g, i) => `${i + 1}. 💎 \`${g}\``).join('\n')}`);
            }

            case 'create': {
                const name = parts[1];
                const content = parts.slice(2).join(" ");
                if (!name || !content) return send("📝 Usage: `.gem create <name> <prompt>`");
                Gems.save(name, content);
                return send(`✅ *Gem Created:* \`${name}\``);
            }

            case 'gen': {
                if (!input) return send("📝 Usage: `.gem gen <topic>` (e.g., `.gem gen 1920s detective`)");
                const { text, err } = await askAI(`Generate a detailed WhatsApp persona prompt for: ${input}. Focus on speech patterns, specific slang, and emotional reactions. Use WhatsApp markdown format for your description.`);
                if (err) return send(`❌ ${text}`);
                const name = (parts[1] || 'generated').toLowerCase();
                Gems.save(name, text);
                return send(`✨ *AI Forged Gem:* \`${name}\`\n\n${text}`);
            }

            case 'analyze': {
                const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
                if (!quoted) return send("📝 Reply to a message to clone that user's style.");
                const sample = quoted.conversation || quoted.extendedTextMessage?.text || "";
                const { text, err } = await askAI(`Analyze this message's tone, syntax, and emoji usage. Create a system prompt that perfectly replicates this style:\n\n"${sample}"`);
                if (err) return send(`❌ ${text}`);
                const name = `clone_${Date.now().toString(36)}`;
                Gems.save(name, text);
                return send(`🧬 *Style Analyzed & Cloned*\n*ID:* \`${name}\`\n\n_Use with:_ \`.gai chat ${name}\``);
            }

            case 'remix': {
                const name = parts[1];
                const tweak = parts.slice(2).join(" ");
                const base = Gems.get(name);
                if (!base) return send(`❌ Gem \`${name}\` not found.`);
                const { text, err } = await askAI(`Take this system prompt:\n"${base}"\n\nModify it with this instruction: "${tweak}". Return only the new prompt.`);
                if (err) return send(`❌ ${text}`);
                Gems.save(`${name}_v2`, text);
                return send(`🔀 *Remixed:* \`${name}_v2\``);
            }

            case 'view': {
                const content = Gems.get(input);
                if (!content) return send("❌ Gem not found.");
                return send(`💎 *PERSONA: ${input.toUpperCase()}*\n\n${content}`);
            }

            case 'use': {
                const content = Gems.get(input);
                if (!content) return send("❌ Gem not found.");
                State.dmGem = content;
                return send(`✅ *Default DM Persona updated to:* \`${input}\``);
            }

            case 'del':
            case 'delete': {
                if (Gems.del(input)) return send(`🗑️ Deleted \`${input}\`.`);
                return send("❌ Gem not found.");
            }

            case 'battle': {
                const p1 = parts[1], p2 = parts[2], topic = parts.slice(3).join(" ");
                const g1 = Gems.get(p1), g2 = Gems.get(p2);
                if (!g1 || !g2 || !topic) return send("📝 Usage: `.gem battle <gem1> <gem2> <topic>`");
                
                const { text: r1 } = await askAI(`PERSONA: ${g1}\n\nTOPIC: ${topic}\nREPLY TO PERSONA 2 IN A HEATED DEBATE.`);
                const { text: r2 } = await askAI(`PERSONA: ${g2}\n\nTOPIC: ${topic}\nPREVIOUS RESPONSE: ${r1}\n\nWIN THE ARGUMENT.`);
                
                return send(`⚔️ *GEM BATTLE: ${p1} vs ${p2}*\n\n*${p1.toUpperCase()}:*\n${r1}\n\n*${p2.toUpperCase()}:*\n${r2}`);
            }

            default:
                return send("❌ Unknown gem command.");
        }
    });

}

// ==============================================================================
// 22. AI MASTER WATCHER — Core Logic (Stalk, Target, Chat, DM)
// ==============================================================================

/**
 * Global Interceptor for all incoming messages.
 * Manages Stalkers, Targets, and Group Chats.
 */
const startGlobalWatcher = (sock) => {
    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        
        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;
                
                const chatId = msg.key.remoteJid;
                const sender = msg.key.participant || chatId;
                const senderNum = sender.replace(/[^0-9]/g, "");
                const isGroup = chatId.endsWith('@g.us');
                
                // 1. Extract body and images
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || "";
                if (!body && !msg.message.imageMessage) continue;
                if (body.startsWith('.') || body.startsWith('/') || body.startsWith('!')) continue;

                // 2. Identify the active session (Stalk > Target > Group Chat > DM)
                let session = null;
                let sessionType = "";

                if (State.stalkers.has(sender)) {
                    session = State.stalkers.get(sender);
                    sessionType = "STALK";
                } else if (State.targets.has(sender)) {
                    const t = State.targets.get(sender);
                    if (!t.chatId || t.chatId === chatId) {
                        session = t;
                        sessionType = "TARGET";
                    }
                } else if (State.chats.has(chatId)) {
                    session = State.chats.get(chatId);
                    sessionType = "GROUP";
                } else if (!isGroup && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, {
                            gem: State.dmGem || State.PERSONA,
                            history: [],
                            gemName: "DM_AUTO"
                        });
                    }
                    session = State.dmSessions.get(sender);
                    sessionType = "DM";
                }

                if (!session) continue;

                // 3. Rate limiting and circuit breaker check
                if (CB.open()) continue;
                if (!Limiter.check()) continue;

                // 4. Handle Vision/Images
                let imageUrls = [];
                if (msg.message.imageMessage) {
                    try {
                        const tempPath = path.join(__dirname, '..', 'gift', 'temp', `vision_${Date.now()}.jpg`);
                        const buffer = await sock.downloadMediaMessage(msg);
                        fs.writeFileSync(tempPath, buffer);
                        const url = await uploadImgBB(tempPath);
                        if (url) imageUrls.push(url);
                        fs.unlinkSync(tempPath);
                    } catch (err) { console.error("[Watcher Vision Error]", err.message); }
                }

                // 5. Build prompt with history
                const markdownInstruction = "\n\n*IMPORTANT:* Always format your response using WhatsApp markdown (*bold*, _italics_, ~strikethrough~, ```monospace```). Be conversational and human.";
                State.addHist(session, "User", body || "[Sent an Image]");
                
                const finalPrompt = `SYSTEM: ${session.gem}${markdownInstruction}\n\n` + 
                                    `--- CHAT HISTORY ---\n${session.history.slice(-10).join("\n")}\n` +
                                    `--- NEW MESSAGE ---\nUSER: ${body}\nAI REPLY:`;

                // 6. Thinking Simulation
                await sock.sendPresenceUpdate('composing', chatId);
                const typingDelay = Math.min(body.length * 40, 4000);
                await new Promise(r => setTimeout(r, typingDelay));

                // 7. Request AI Response
                const { text: aiResponse, err } = await askAI(finalPrompt, imageUrls);
                
                if (err) {
                    if (CB.open()) await sock.sendMessage(chatId, { text: "_[link connection unstable]_" });
                    continue;
                }

                State.addHist(session, "AI", aiResponse);

                // 8. Dispatch Response
                const safeQuote = buildSafeQuote(msg);
                await sock.sendMessage(chatId, { text: aiResponse }, safeQuote);
                await sock.sendPresenceUpdate('paused', chatId);

            } catch (err) {
                console.error("[Watcher Loop Error]", err);
            }
        }
    });
};

// ==============================================================================
// 23. BOOTSTRAP & INTEGRATION
// ==============================================================================

/**
 * Self-healing loader to ensure the watcher attaches to the socket.
 */
const bootstrapGems = () => {
    const interval = setInterval(() => {
        const activeSock = global.conn || global.client;
        if (activeSock && activeSock.ev) {
            startGlobalWatcher(activeSock);
            console.log("💎 [AIGems] AI Watcher successfully attached to protocol.");
            clearInterval(interval);
        }
    }, 5000);
};

bootstrapGems();

// ==============================================================================
// 24. ENHANCED SYSTEM COMMANDS (Strength Expansion)
// ==============================================================================

if (typeof commandRegister === 'function') {

    /**
     * .airoom: Creates a virtual space where multiple personas talk.
     */
    commandRegister({
        pattern: "airoom",
        cmdname: "airoom",
        category: "ai",
        desc: "Start a group chat between two saved gems.",
        react: "🎭",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");
        const [g1, g2, ...topicArr] = q.split(" ");
        const topic = topicArr.join(" ");

        if (!Gems.get(g1) || !Gems.get(g2) || !topic) {
            return sock.sendMessage(jid, { text: "📝 Usage: `.airoom <gem1> <gem2> <topic>`" });
        }

        const runTurn = async (personaName, lastMsg) => {
            const prompt = `PERSONA: ${Gems.get(personaName)}\n\nCONTEXT: You are in a room with another AI talking about "${topic}".\nLAST MESSAGE: "${lastMsg}"\n\nReply to them in character.`;
            const { text } = await askAI(prompt);
            return text;
        };

        let turn1 = await runTurn(g1, "Start the conversation about " + topic);
        await sock.sendMessage(jid, { text: `🎭 *${g1.toUpperCase()}:*\n${turn1}` });
        
        await new Promise(r => setTimeout(r, 3000));
        
        let turn2 = await runTurn(g2, turn1);
        await sock.sendMessage(jid, { text: `🎭 *${g2.toUpperCase()}:*\n${turn2}` });
    });

}
/**
     * .gai: Advanced AI Controller.
     * Manages targeting, stalking, and automated responses.
     */
    commandRegister({
        pattern: "gai",
        cmdname: "gai",
        alias: ["brain", "control"],
        category: "ai",
        desc: "Advanced AI controller for targeting, stalking, and DM automation.",
        react: "🧠",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");
        const parts = q.trim().split(/\s+/);
        const cmd = parts[0]?.toLowerCase();

        if (!cmd || cmd === "help") {
            const helpText = `🧠 *GAI CONTROL CENTER*\n\n` +
                `*Sub-Commands:*\n` +
                `• \`.gai target <number> [gem]\` - Intercept JID in current chat.\n` +
                `• \`.gai stalk <number> [gem]\` - Intercept JID globally.\n` +
                `• \`.gai dm <on|off> [gem]\` - Toggle auto-reply in DMs.\n` +
                `• \`.gai stop <target|stalk|all>\` - Clear active AI hooks.\n` +
                `• \`.gai status\` - View active sessions and rate limits.\n` +
                `• \`.gai wipe\` - Reset history for current chat AI.\n\n` +
                `_Note: All AI responses are forced into WhatsApp Markdown._`;
            return sock.sendMessage(jid, { text: helpText }, buildSafeQuote(m));
        }

        switch (cmd) {
            case "target": {
                const targetNum = parts[1]?.replace(/[^0-9]/g, "");
                if (!targetNum) return m.reply("❌ *Error:* Provide a valid phone number.");
                const targetJid = targetNum + "@s.whatsapp.net";
                const gemName = parts[2] || "default";
                const gemContent = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;

                State.targets.set(targetJid, {
                    gem: gemContent + "\nIMPORTANT: Always format your response using WhatsApp markdown (bold, italics, etc).",
                    history: [],
                    chatId: jid,
                    gemName: gemName
                });

                return sock.sendMessage(jid, {
                    text: `🎯 *Target Locked*\n*User:* @${targetNum}\n*Chat:* Current\n*Persona:* \`${gemName}\`\n\n_Messages from this user will be intercepted and handled by AI in this chat._`,
                    mentions: [targetJid]
                }, buildSafeQuote(m));
            }

            case "stalk": {
                const stalkNum = parts[1]?.replace(/[^0-9]/g, "");
                if (!stalkNum) return m.reply("❌ *Error:* Provide a valid phone number.");
                const stalkJid = stalkNum + "@s.whatsapp.net";
                const gemName = parts[2] || "default";
                const gemContent = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;

                State.stalkers.set(stalkJid, {
                    gem: gemContent + "\nIMPORTANT: Always format your response using WhatsApp markdown (bold, italics, etc).",
                    history: [],
                    gemName: gemName
                });

                return sock.sendMessage(jid, {
                    text: `📡 *Global Stalk Active*\n*User:* @${stalkNum}\n*Persona:* \`${gemName}\`\n\n_AI will shadow this user across all shared groups and DMs._`,
                    mentions: [stalkJid]
                }, buildSafeQuote(m));
            }

            case "dm": {
                const mode = parts[1]?.toLowerCase();
                if (mode === "on") {
                    State.dmActive = true;
                    if (parts[2]) {
                        const customGem = Gems.get(parts[2]);
                        if (customGem) State.dmGem = customGem + "\nUse WhatsApp markdown.";
                    }
                    return m.reply("📨 *DM Auto-Pilot:* ✅ _Activated_");
                } else if (mode === "off") {
                    State.dmActive = false;
                    return m.reply("📨 *DM Auto-Pilot:* ❌ _Deactivated_");
                }
                return m.reply(`📝 *Usage:* \`.gai dm <on|off> [gem]\` (Currently: ${State.dmActive ? "ON" : "OFF"})`);
            }

            case "stop": {
                const type = parts[1]?.toLowerCase();
                if (type === "target") {
                    State.targets.clear();
                    return m.reply("🛑 *Targets cleared.*");
                }
                if (type === "stalk") {
                    State.stalkers.clear();
                    return m.reply("🛑 *Stalkers cleared.*");
                }
                if (type === "all") {
                    State.targets.clear();
                    State.stalkers.clear();
                    State.dmActive = false;
                    State.chats.delete(jid);
                    return m.reply("☢️ *All AI Controllers Terminated.*");
                }
                State.chats.delete(jid);
                return m.reply("🛑 *AI stopped for this chat.*");
            }

            case "status": {
                const stats = Limiter.stats();
                const statusMsg = `📊 *AI OPERATIONAL STATUS*\n\n` +
                    `• *DM Engine:* ${State.dmActive ? "🟢 ACTIVE" : "🔴 INACTIVE"}\n` +
                    `• *Target Hooks:* \`${State.targets.size}\`\n` +
                    `• *Global Stalkers:* \`${State.stalkers.size}\`\n` +
                    `• *Active Chat Sessions:* \`${State.chats.size}\`\n\n` +
                    `*Rate Limits (QuillBot):*\n` +
                    `• Minute: \`${stats.rpm}/${CFG.MAX_RPM}\` requests\n` +
                    `• Hour: \`${stats.rph}/${CFG.MAX_RPH}\` requests\n` +
                    `• Lifetime Errors: \`${stats.err}\`\n\n` +
                    `*Circuit Breaker:* ${CB.open() ? "⚠️ TRIPPED (Cooldown)" : "✅ STABLE"}`;
                return m.reply(statusMsg);
            }

            case "wipe": {
                const sess = State.chats.get(jid);
                if (sess) {
                    sess.history = [];
                    return m.reply("🧠 *Memory Wiped.* AI context for this chat has been reset.");
                }
                return m.reply("ℹ️ *No active chat session found here.* Use `.gai chat` first.");
            }

            default: {
                // Direct Query Mode
                const prompt = q.trim();
                if (!prompt) return;

                const safeQuote = buildSafeQuote(m);
                const stub = await sock.sendMessage(jid, { text: "⏳ _thinking..._" }, safeQuote);
                
                const { text, err } = await askAI(prompt + "\n\n(Format your response using WhatsApp markdown: *bold*, _italics_, ~strikethrough~, ```code```)");
                
                if (err) return sock.sendMessage(jid, { text: `❌ *Error:* ${text}`, edit: stub.key });
                return sock.sendMessage(jid, { text: text, edit: stub.key });
            }
        }
    });

    /**
     * .aivision: Image processing and OCR via AI.
     */
    commandRegister({
        pattern: "aivision",
        cmdname: "aivision",
        alias: ["see", "ocr"],
        category: "ai",
        desc: "Analyze images and decode text or objects.",
        react: "👁️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ") || "Analyze this image and describe what you see.";
        
        const quotedMsg = m.message?.extendedTextMessage?.contextInfo?.quotedMessage || m.message;
        const image = quotedMsg?.imageMessage;

        if (!image) return m.reply("📝 *Reply to an image* with `.aivision <question>`");

        try {
            const stub = await sock.sendMessage(jid, { text: "👁️ _Decoding visual stream..._" }, buildSafeQuote(m));
            const buffer = await sock.downloadMediaMessage(image);
            const tmpPath = `./gift_vision_${Date.now()}.jpg`;
            fs.writeFileSync(tmpPath, buffer);
            
            const imageUrl = await uploadImgBB(tmpPath);
            if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);

            if (!imageUrl) return sock.sendMessage(jid, { text: "❌ *Visual hosting failed.* Check ImgBB key.", edit: stub.key });

            const { text, err } = await askAI(q, [imageUrl]);
            return sock.sendMessage(jid, { 
                text: err ? `❌ *AI Vision Error:* ${text}` : `🔍 *Vision Result*\n\n${text}`, 
                edit: stub.key 
            });

        } catch (error) {
            console.error("[Vision Error]", error);
            return m.reply(`❌ *Processing Error:* ${error.message}`);
        }
    });

    /**
     * .autoenhance: Intelligent message polishing.
     */
    commandRegister({
        pattern: "autoenhance",
        cmdname: "autoenhance",
        category: "ai",
        desc: "Automatically fix grammar and polish outgoing messages.",
        react: "✍️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args[0]?.toLowerCase();

        if (q === "on") {
            State.autoEnhance = true;
            return m.reply("✍️ *Auto-Enhance:* ✅ _Enabled. Your messages will be silently polished._");
        } else if (q === "off") {
            State.autoEnhance = false;
            return m.reply("✍️ *Auto-Enhance:* ❌ _Disabled._");
        }
        
        return m.reply(`✍️ *Auto-Enhance:* ${State.autoEnhance ? "✅ ON" : "❌ OFF"}\n\n_Usage: .autoenhance <on|off>_`);
    });

}

