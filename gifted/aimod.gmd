// 20. .aidecode — MULTIMODAL VISION ENGINE (PHASE 7)
// ==============================================================================
gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'whatis', 'aianalyze'],
    category: 'ai',
    desc: 'Analyze a quoted image or text using neural vision.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImg = quoted?.imageMessage || mek.message?.imageMessage;

    if (!hasImg && !q.trim() && !quoted?.conversation) {
        return reply('📝 *Usage:* Reply to an image or text block with \`.aidecode [instruction]\`');
    }

    const stub = await thinking(Gifted, from, mek, '🔍 _Decoding visual/textual data…_');
    let imgUrls = [];

    if (hasImg) {
        const target = quoted?.imageMessage || mek.message.imageMessage;
        const tmp = path.join(__dirname, `tmp_dec_${Date.now()}.jpg`);
        try {
            await Gifted.downloadAndSaveMediaMessage(target, tmp);
            const url = await uploadImgBB(tmp);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmp)) fs.unlinkSync(tmp);
        } catch (e) {
            console.error('[AIGems] Decoder vision error:', e.message);
        }
    }

    const input = q.trim() || quoted?.conversation || quoted?.extendedTextMessage?.text || 'Explain this in detail.';
    const prompt = imgUrls.length 
        ? `Analyze this image in depth and address the following query: ${input}` 
        : `Deeply analyze and explain this content: "${input}"`;

    const { text, err } = await askAI(prompt + "\n\nStrictly use WhatsApp markdown (*bold*, _italics_) for the summary. NO LaTeX.");
    return editMsg(Gifted, stub, err ? `❌ ${text}` : `🔍 *NEURAL ANALYSIS*\n\n${text}`);
});

