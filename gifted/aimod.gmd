const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT content FROM gems WHERE name=?').get(n.toLowerCase().trim())?.content ?? null; } catch(e){ return null; } },
    save : (n, c) => { try { return !!db?.prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(n.toLowerCase().trim(), c)?.changes; } catch(e){ return false; } },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};

// ==============================================================================
// 4. RATE LIMITER & CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q: [], hr_q: [], daily: { ai: 0, img: 0, err: 0, day: new Date().toDateString() },
    check() {
        const n = Date.now();
        this.min_q = this.min_q.filter(t => n - t < 60000);
        this.hr_q = this.hr_q.filter(t => n - t < 3600000);
        return this.min_q.length < CFG.MAX_RPM && this.hr_q.length < CFG.MAX_RPH;
    },
    hit(type = 'ai') {
        const n = Date.now(); 
        this.min_q.push(n); 
        this.hr_q.push(n);
        const d = new Date().toDateString();
        if (d !== this.daily.day) this.daily = { ai: 0, img: 0, err: 0, day: d };
        if (type === 'ai') this.daily.ai++;
        if (type === 'img') this.daily.img++;
    },
    err() { this.daily.err++; },
    stats() {
        const n = Date.now();
        return { 
            rpm: this.min_q.filter(t => n - t < 60000).length, 
            rph: this.hr_q.filter(t => n - t < 3600000).length, 
            ...this.daily 
        };
    }
};

const CB = {
    fails: 0, lastFail: 0, THRESH: 5, TTL: 300000,
    open()  { return this.fails >= this.THRESH && Date.now() - this.lastFail < this.TTL; },
    fail()  { this.fails++; this.lastFail = Date.now(); Limiter.err(); },
    ok()    { this.fails = 0; },
    reset() { this.fails = 0; this.lastFail = 0; },
    msg()   { return ['neural link glitchy rn', 'signal weak on my end', 'connection hiccupped', 'brain.exe crashed lol'][Math.floor(Math.random() * 4)]; }
};

// ==============================================================================
// 5. CORE AI ENGINE (QuillBot SSE Stream Implementation)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

/**
 * Executes a request to the AI engine with permanent WhatsApp Markdown forcing.
 * Handles SSE parsing and redundant retries.
 */
const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            // Prepend system markdown instruction to force output format
            content: `${CFG.SYSTEM_MD_PREFIX}${prompt}`,
            files  : imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id: 'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            // Robust SSE Parsing logic for 'chunk' tokens
            let fullText = '';
            const lines = rawText.split('\n');
            for (const line of lines) {
                const trimmed = line.trim();
                if (trimmed.startsWith('data: {')) {
                    try {
                        const jsonStr = trimmed.replace(/^data:\s*/, '');
                        const parsed = JSON.parse(jsonStr);
                        if (parsed.chunk) {
                            fullText += parsed.chunk;
                        }
                    } catch(e) {
                        // Ignore malformed JSON chunks in stream
                    }
                }
            }

            if (!fullText.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { 
                    await sleep(1200 * (attempt + 1)); 
                    continue; 
                }
                CB.fail();
                return { text: 'empty response — engine cold or cookies stale', err: true };
            }

            CB.ok();
            // Cleanup common LaTeX/Formatting artifacts from QuillBot
            const clean = fullText
                .replace(/\\\(|\\\)/g, '')
                .replace(/\\\[|\\\]/g, '')
                .replace(/\\([a-zA-Z])/g, '$1')
                .trim();

            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] Engine failure (Attempt ${attempt + 1}):`, e.message);
            if (attempt < CFG.RETRIES - 1) {
                await sleep(1200 * (attempt + 1));
            } else {
                CB.fail();
                return { text: `API unreachable — ${e.message}`, err: true };
            }
        }
    }
    return { text: CB.msg(), err: true };
};

// --- CHUNK: Database Schema & Advanced State Management ---
// ==============================================================================
// 6. DATABASE LOGIC — PERSONA VAULT (SQLite)
// ==============================================================================
let db = null;
if (Database) {
    try {
        const dbDir = path.dirname(CFG.DB_PATH);
        if (!fs.existsSync(dbDir)) fs.mkdirSync(dbDir, { recursive: true });

        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.pragma('synchronous = NORMAL');

        // Extended schema to support advanced state (mood/formatting)
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                mood TEXT DEFAULT 'natural',
                formatting TEXT DEFAULT 'whatsapp',
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        console.log('[AIGems] Database Schema Synchronized');
    } catch (e) {
        console.error('[AIGems] SQLite Error:', e.message);
        db = null;
    }
}

/** 
 * Persistence layer for AI Personas 
 */
const Gems = {
    get: (name) => {
        try {
            return db?.prepare('SELECT * FROM gems WHERE name = ?').get(name.toLowerCase().trim()) ?? null;
        } catch (e) { return null; }
    },
    save: (name, content, mood = 'natural', formatting = 'whatsapp') => {
        try {
            const stmt = db?.prepare(`
                INSERT INTO gems (name, content, mood, formatting) 
                VALUES (?, ?, ?, ?)
                ON CONFLICT(name) DO UPDATE SET 
                    content = excluded.content,
                    mood = excluded.mood,
                    formatting = excluded.formatting
            `);
            return !!stmt?.run(name.toLowerCase().trim(), content, mood, formatting)?.changes;
        } catch (e) { return false; }
    },
    del: (name) => {
        try {
            return (db?.prepare('DELETE FROM gems WHERE name = ?').run(name.toLowerCase().trim())?.changes ?? 0) > 0;
        } catch (e) { return false; }
    },
    list: () => {
        try {
            return db?.prepare('SELECT name, mood, formatting FROM gems ORDER BY name ASC').all() ?? [];
        } catch (e) { return []; }
    }
};

// ==============================================================================
// 7. ADVANCED STATE MANAGEMENT & SESSION TRACKING
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    autoEnhance: false,

    // Differentiated tracking maps
    chats: new Map(),      // Chat-wide AI: remoteJid -> Session
    targets: new Map(),    // Local Tracking: userJid -> Session (restricted to specific chat)
    stalkers: new Map(),   // Global Tracking: userJid -> Session (any chat)
    dmSessions: new Map(), // DM Cache: userJid -> Session

    PERSONA: 'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Never say you are an AI.',

    /**
     * Resolves the correct AI session based on hierarchy:
     * 1. Global Stalker (Tracked everywhere)
     * 2. Local Target (Tracked in this specific chat)
     * 3. Group/Chat Mode (Active for all in this chat)
     * 4. DM Auto-Pilot (Private messages)
     */
    resolveSession(sender, chatId, isGrp) {
        // 1. Global Stalking: Highest priority.
        if (this.stalkers.has(sender)) {
            return this.stalkers.get(sender);
        }

        // 2. Local Targeting: User is a target, but only if they speak in the designated chat.
        if (this.targets.has(sender)) {
            const target = this.targets.get(sender);
            if (!target.chatId || target.chatId === chatId) {
                return target;
            }
        }

        // 3. Local Chat Mode: The entire group/chat is AI-enabled.
        if (this.chats.has(chatId)) {
            return this.chats.get(chatId);
        }

        // 4. DM Auto-Pilot: Responding in private messages.
        if (!isGrp && this.dmActive) {
            if (!this.dmSessions.has(sender)) {
                this.dmSessions.set(sender, {
                    gem: this.dmGem || this.PERSONA,
                    mood: 'natural',
                    formatting: 'whatsapp',
                    history: [],
                    gemName: 'dm_pilot'
                });
            }
            return this.dmSessions.get(sender);
        }

        return null;
    },

    addHist(sess, role, txt) {
        if (!sess.history) sess.history = [];
        const time = new Date().toLocaleTimeString('en', { hour12: false, hour: '2-digit', minute: '2-digit' });
        sess.history.push(`[${time}] ${role}: ${txt}`);
        if (sess.history.length > CFG.MAX_HIST) sess.history.shift();
    },

    buildPrompt(sess, input) {
        const sys = sess.gem || this.PERSONA;
        const mood = sess.mood ? ` Current Mood: ${sess.mood}.` : '';
        const format = sess.formatting === 'whatsapp' ? ' Use WhatsApp markdown (*bold*, _italic_).' : '';
        
        return `SYSTEM:\n${sys}${mood}${format}\n\n--- HISTORY ---\n${sess.history.join('\n')}\n---\nUSER: ${input}\nREPLY:`;
    }
};

// ==============================================================================
// 8. MARKDOWN HELPER (WhatsApp Clean-up)
// ==============================================================================
/**
 * Ensures raw AI strings do not break WhatsApp's strict formatting engine.
 */
const markdownHelper = {
    /**
     * Cleans raw AI output to be WhatsApp compatible.
     */
    clean(text) {
        if (!text) return '';
        
        return text
            // Escape nested underscores inside words which break WA italics (e.g. user_profile -> user\_profile)
            .replace(/(\w)_(\w)/g, '$1\\_$2')
            
            // Standardize Bold: Convert **text** to *text*
            .replace(/\*\*(.*?)\*\*/g, '*$1*')
            
            // Standardize Italics: Convert __text__ to _text_
            .replace(/__(.*?)__/g, '_$1_')
            
            // Remove unsupported Markdown headers (#)
            .replace(/^#+\s+/gm, '* ')
            
            // Fix code blocks: ensure they use triple backticks correctly
            .replace(/`([^`\n]+)`/g, '```$1```')
            
            // Remove common LLM artifacts
            .replace(/\\\(|\\\)/g, '')
            .replace(/\\\[|\\\]/g, '')
            .replace(/\\([a-zA-Z])/g, '$1')
            .trim();
    },

    /**
     * Formats a response string based on user preference.
     */
    applyFormatting(text, preference = 'whatsapp') {
        const cleaned = this.clean(text);
        if (preference === 'monospace') return `\`\`\`${cleaned}\`\`\``;
        if (preference === 'bold') return `*${cleaned}*`;
        return cleaned;
    }
};

// --- CHUNK: Persona Vault & AI Control Commands (.gem & .gai) ---
// ==============================================================================
// 10. .gem — PERSONA VAULT (RECONSTRUCTED)
// ==============================================================================
gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['gems', 'persona', 'vault'],
    category: 'ai',
    desc: 'AI persona management system.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused:* High-level clearance required for Persona Vault.');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const rest = parts.slice(1);

    switch (cmd) {
        case 'create': {
            if (rest.length < 2) return reply('📝 *Usage:* `.gem create <name> <persona_prompt>`');
            const [name, ...pArr] = rest;
            const content = pArr.join(' ');
            const success = Gems.save(name, content);
            return reply(success 
                ? `✅ *Gem Forged:* \`${name.toLowerCase()}\`\n\n_System instructions stored in vault._` 
                : '❌ *Error:* Vault database write failed.');
        }

        case 'gen': {
            const topic = rest.join(' ');
            if (!topic) return reply('📝 *Usage:* `.gem gen <topic>` (e.g., `.gem gen 1920s detective`)');
            const stub = await thinking(Gifted, from, mek, '🔮 _Synthesizing persona logic..._');
            
            const prompt = `Construct a comprehensive system prompt for a WhatsApp AI persona based on the topic: "${topic}". 
            Include: personality traits, linguistic style, knowledge boundaries, and emoji usage. 
            Keep it under 1000 characters. Return ONLY the prompt text.`;
            
            const { text, err } = await askAI(prompt);
            if (err) return editMsg(Gifted, stub, `❌ *Synthesis Failed:* ${text}`);
            
            const name = (rest[0] || 'gem').toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 10) + '_' + Math.floor(Math.random() * 1000);
            Gems.save(name, text);
            
            return editMsg(Gifted, stub, `✨ *New Gem Synthesized*\n\n*ID:* \`${name}\`\n*Logic:* _${text.slice(0, 250)}..._\n\n_Activate with:_ \`.gem use ${name}\``);
        }

        case 'analyze': {
            const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
            if (!quoted) return reply('📝 *Action:* Reply to a message to clone the sender\'s writing style.');
            
            const sample = quoted.conversation || quoted.extendedTextMessage?.text || quoted.imageMessage?.caption;
            if (!sample) return reply('❌ *Error:* No text found in quoted message.');

            const stub = await thinking(Gifted, from, mek, '🕵️ _Analyzing linguistic patterns..._');
            const { text, err } = await askAI(`Analyze this message: "${sample}". 
            Create a system prompt that clones this exact tone, vocabulary, and sentence structure for future replies. 
            Return ONLY the system prompt.`);

            if (err) return editMsg(Gifted, stub, `❌ *Analysis Failed:* ${text}`);
            
            const name = `clone_${Math.floor(Math.random() * 9999)}`;
            Gems.save(name, text);
            return editMsg(Gifted, stub, `🧬 *Style Cloned*\n\n*ID:* \`${name}\`\n_The vault now mimics this behavior._\n\n_Use:_ \`.gem use ${name}\``);
        }

        case 'remix': {
            const [gemName, ...tw] = rest;
            const tweak = tw.join(' ');
            if (!gemName || !tweak) return reply('📝 *Usage:* `.gem remix <existing_name> <modification>`');
            
            const base = Gems.get(gemName);
            if (!base) return reply(`❌ *Error:* Gem \`${gemName}\` not found in vault.`);

            const stub = await thinking(Gifted, from, mek, `🔀 _Refining "${gemName}"..._`);
            const { text, err } = await askAI(`Update the following system prompt based on these instructions: "${tweak}".
            Original Prompt: ${base}
            Return ONLY the updated prompt.`);

            if (err) return editMsg(Gifted, stub, `❌ *Refinement Failed:* ${text}`);
            
            const newName = `${gemName}_v2`;
            Gems.save(newName, text);
            return editMsg(Gifted, stub, `🔀 *Gem Refined*\n\n*New ID:* \`${newName}\`\n_Modifications applied successfully._`);
        }

        case 'list': {
            const list = Gems.list();
            if (!list.length) return reply('📂 *Vault Empty:* No custom personas found.');
            const formattedList = list.map((g, i) => `*${i + 1}.* 💎 \`${g}\``).join('\n');
            return reply(`📂 *Persona Vault (${list.length})*\n\n${formattedList}\n\n_Load with:_ \`.gem use <name>\``);
        }

        case 'use': {
            const name = rest[0]?.toLowerCase();
            if (!name) return reply('📝 *Usage:* `.gem use <name>`');
            
            const content = Gems.get(name);
            if (!content) return reply(`❌ *Error:* \`${name}\` does not exist.`);
            
            State.dmGem = content;
            return reply(`✅ *Global Persona Set:* \`${name}\`\n_All future AI interactions will use this logic._`);
        }

        case 'del':
        case 'delete': {
            const name = rest[0]?.toLowerCase();
            if (!name) return reply('📝 *Usage:* `.gem delete <name>`');
            return Gems.del(name) 
                ? reply(`🗑️ *Purged:* Gem \`${name}\` removed from vault.`) 
                : reply(`❌ *Error:* Gem \`${name}\` not found.`);
        }

        default:
            return reply(`💎 *Vault Command Interface*\n\n` +
                `• \`.gem create <n> <p>\` - Manual entry\n` +
                `• \`.gem gen <topic>\` - AI generation\n` +
                `• \`.gem analyze\` - Style cloning\n` +
                `• \`.gem remix <n> <t>\` - Edit persona\n` +
                `• \`.gem list\` - View all gems\n` +
                `• \`.gem use <n>\` - Set active persona\n` +
                `• \`.gem del <n>\` - Remove from vault`);
    }
});

// ==============================================================================
// 11. .gai — AI CONTROL & TARGETING (FIXED)
// ==============================================================================
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'ask', 'brain'],
    category: 'ai',
    desc: 'Advanced AI assistant and auto-reply control.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused:* Master credentials required.');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || '';
    const rest = parts.slice(1);

    // ── SUB-COMMANDS ──────────────────────────────────────────────────────────
    
    if (cmd === 'target' || cmd === 'bot') {
        let num = rest[0]?.replace(/[^0-9]/g, '');
        if (!num) return reply('📝 *Usage:* `.gai target <number> [gem_name]`');
        
        const tjid = num + '@s.whatsapp.net';
        const gemName = rest[1] || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.targets.set(tjid, {
            gem: gemTxt,
            mood: 'neutral',
            formatting: 'whatsapp',
            history: [],
            chatId: from,
            gemName
        });
        return reply(`🤖 *Target Locked*\n*User:* @${num}\n*Scope:* Local Chat\n*Persona:* \`${gemName}\``);
    }

    if (cmd === 'stalk') {
        let num = rest[0]?.replace(/[^0-9]/g, '');
        if (!num) return reply('📝 *Usage:* `.gai stalk <number> [gem_name]`');
        
        // Fix: Explicitly mapping to correct WhatsApp JID format
        const tjid = num + '@s.whatsapp.net';
        const gemName = rest[1] || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.stalkers.set(tjid, {
            gem: gemTxt,
            mood: 'neutral',
            formatting: 'whatsapp',
            history: [],
            gemName
        });
        return reply(`🌍 *Global Stalker Active*\n*Tracking:* @${num}\n*Scope:* All Shared Chats\n*Persona:* \`${gemName}\``);
    }

    if (cmd === 'mood') {
        const moodType = rest.join(' ') || 'default';
        const sess = State.resolveSession(mek.key.participant || mek.key.remoteJid, from, from.endsWith('@g.us'));
        
        if (!sess) return reply('❌ *Error:* No active session found in this chat. Start one with `.gai chat`.');
        
        sess.mood = moodType;
        return reply(`🎭 *Mood Shift:* Session behavior updated to \`${moodType}\`.`);
    }

    if (cmd === 'dm') {
        const state = rest[0]?.toLowerCase();
        if (state === 'on') {
            State.dmActive = true;
            return reply('📨 *DM Auto-Pilot:* ✅ ENABLED');
        }
        if (state === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot:* ❌ DISABLED');
        }
        return reply(`📨 *DM Auto-Pilot Status:* ${State.dmActive ? 'Active' : 'Inactive'}`);
    }

    if (cmd === 'chat') {
        const gemName = rest[0] || 'default';
        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.chats.set(from, {
            gem: gemTxt,
            mood: 'natural',
            formatting: 'whatsapp',
            history: [],
            gemName
        });
        return reply(`⚔️ *Chat Intelligence Active*\n*Persona:* \`${gemName}\`\n_Replying to all messages in this thread._`);
    }

    if (cmd === 'stop') {
        if (rest[0]?.toLowerCase() === 'all') {
            State.chats.clear();
            State.targets.clear();
            State.stalkers.clear();
            State.dmSessions.clear();
            State.dmActive = false;
            return reply('☢️ *System Purge:* All AI sessions terminated.');
        }
        State.chats.delete(from);
        return reply('🛑 *Session Terminated:* AI deactivated for this chat.');
    }

    // ── ONE-SHOT LOGIC ────────────────────────────────────────────────────────
    const question = q.trim();
    if (!question) return reply('🧠 *GAI Command Suite*\n\n' +
        '• `.gai <question>` - Ask anything\n' +
        '• `.gai chat [gem]` - Enable in this chat\n' +
        '• `.gai target <num> [gem]` - Track specific user\n' +
        '• `.gai stalk <num> [gem]` - Track user everywhere\n' +
        '• `.gai mood <type>` - Change session vibe\n' +
        '• `.gai dm on/off` - Toggle private auto-pilot\n' +
        '• `.gai stop [all]` - Kill AI sessions');

    await react('🧠');
    const stub = await thinking(Gifted, from, mek, '🧠 _thinking..._');
    
    let imgUrls = [];
    const quotedMsg = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quotedMsg?.imageMessage) {
        const tp = await Gifted.downloadAndSaveMediaMessage(quotedMsg.imageMessage, `tmp_gai_${Date.now()}`);
        if (tp) {
            const url = await uploadImgBB(tp);
            if (url) imgUrls.push(url);
            try { fs.unlinkSync(tp); } catch (e) {}
        }
    }

    let finalPrompt = question;
    const contextText = quotedMsg?.conversation || quotedMsg?.extendedTextMessage?.text;
    if (contextText) finalPrompt = `CONTEXT FROM PREVIOUS MESSAGE:\n"${contextText}"\n\nUSER REQUEST: ${question}`;

    const { text, err } = await askAI(finalPrompt, imgUrls);
    const formattedResponse = markdownHelper.applyFormatting(text, 'whatsapp');
    
    return editMsg(Gifted, stub, err ? `❌ *AI Error:* ${text}` : formattedResponse);
});

// --- CHUNK: Visual & Creative Writing Engine (.img & .aiwrite) ---
// ==============================================================================
// 12.  .img  — ELITE IMAGE GENERATION SUITE
// ==============================================================================
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'genimg', 'art', 'draw'],
    category: 'ai',
    desc: 'Advanced AI image generation using Infip & ImgBB.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Administrative privileges required.');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const rest = parts.slice(1);

    /** Helper: Wrap response in a robust Markdown Box */
    const box = (title, body) => `*┏━━━━━━━━━━━━━━━━━━━━━━━━┓*\n*┃  ${title.toUpperCase()}*\n*┗━━━━━━━━━━━━━━━━━━━━━━━━┛*\n\n${body}\n\n_— Generated via Phoenix-Engine —_`;

    /** Logic: Execute Image Generation */
    const executeGen = async (prompt, stubMsg) => {
        const urls = await generateImage(prompt, {
            model: CFG.IMG_MODEL,
            size: CFG.IMG_SIZE,
            count: CFG.IMG_COUNT,
            quality: CFG.IMG_QUALITY,
            style: CFG.IMG_STYLE
        });

        if (!urls || urls.length === 0) {
            return editMsg(Gifted, stubMsg, box('Error', 'Generation failed. The neural engine returned an empty set. Try changing models with `.img config`.'));
        }

        await del(Gifted, stubMsg.key);
        
        // Send primary image with full caption
        const mainCaption = `*🎨 Prompt:* _${prompt}_\n*⚙️ Model:* \`${CFG.IMG_MODEL}\`\n*📐 Size:* \`${CFG.IMG_SIZE}\``;
        await sendImg(Gifted, from, urls[0], mainCaption, mek);

        // Send additional variations if count > 1
        for (let i = 1; i < urls.length; i++) {
            await sendImg(Gifted, from, urls[i], `*🎨 Variation ${i + 1}*`, mek);
        }
    };

    // Sub-Command: Models List
    if (cmd === 'models') {
        const list = Object.entries(CFG.IMG_MDLS)
            .map(([id, m]) => `${m.tier === 'pro' ? '👑' : '🆓'} *${id}*: _${m.desc}_`)
            .join('\n');
        return reply(box('Image Models', list + `\n\n*Current Active:* \`${CFG.IMG_MODEL}\``));
    }

    // Sub-Command: Configuration
    if (cmd === 'config' || cmd === 'set') {
        if (!rest[0]) {
            return reply(box('Current Config', 
                `*Model:* \`${CFG.IMG_MODEL}\`\n` +
                `*Size:* \`${CFG.IMG_SIZE}\`\n` +
                `*Count:* \`${CFG.IMG_COUNT}\`\n` +
                `*Quality:* \`${CFG.IMG_QUALITY}\`\n` +
                `*Style:* \`${CFG.IMG_STYLE}\`\n\n` +
                `_Usage: .img config <model> [size] [count] [quality] [style]_`
            ));
        }
        const [model, size, count, quality, style] = rest;
        if (model && !CFG.IMG_MDLS[model]) return reply(`❌ *Invalid Model:* \`${model}\`. Run \`.img models\` for the list.`);
        
        if (model) CFG.IMG_MODEL = model;
        if (size) CFG.IMG_SIZE = size;
        if (count) CFG.IMG_COUNT = Math.min(parseInt(count) || 1, 4);
        if (quality) CFG.IMG_QUALITY = quality;
        if (style) CFG.IMG_STYLE = style;

        return reply(box('Config Updated', `Settings synchronized across all nodes.\n\n*Model:* \`${CFG.IMG_MODEL}\`\n*Size:* \`${CFG.IMG_SIZE}\``));
    }

    // Sub-Command: Enhance Prompt
    if (cmd === 'enhance') {
        const rawPrompt = rest.join(' ');
        if (!rawPrompt) return reply('📝 *Usage:* `.img enhance <simple prompt>`');
        
        const stub = await thinking(Gifted, from, mek, '✨ _Enhancing prompt architecture..._');
        const { text, err } = await askAI(`Act as a prompt engineer. Expand this simple prompt into a high-detail, artistic master-prompt for AI generation. Focus on lighting, texture, and composition. Return ONLY the enhanced prompt.\n\nPrompt: ${rawPrompt}`);
        
        if (err) return editMsg(Gifted, stub, box('Enhance Error', text));
        return editMsg(Gifted, stub, box('Prompt Enhanced', `*Original:* ${rawPrompt}\n\n*Enhanced:* ${text}\n\n_Generate this?_ \`.img gen ${text}\``));
    }

    // Sub-Command: Surprise / Dream
    if (cmd === 'surprise' || cmd === 'dream') {
        const theme = rest.join(' ') || 'anything';
        const stub = await thinking(Gifted, from, mek, '🎲 _Casting the dice of imagination..._');
        const { text: generatedPrompt, err } = await askAI(`Generate a unique, vivid, and complex image prompt themed around "${theme}". Be creative and surreal. Return ONLY the prompt.`);
        
        if (err) return editMsg(Gifted, stub, box('Dream Error', generatedPrompt));
        await editMsg(Gifted, stub, `🎲 *Dreaming:* _${generatedPrompt.slice(0, 100)}..._`);
        return executeGen(generatedPrompt, stub);
    }

    // Sub-Command: Chaos
    if (cmd === 'chaos') {
        const models = Object.keys(CFG.IMG_MDLS).filter(k => CFG.IMG_MDLS[k].tier === 'free');
        const randomModel = models[Math.floor(Math.random() * models.length)];
        const sizes = ['1024x1024', '1792x1024', '1024x1792'];
        const randomSize = sizes[Math.floor(Math.random() * sizes.length)];
        
        CFG.IMG_MODEL = randomModel;
        CFG.IMG_SIZE = randomSize;
        
        const stub = await thinking(Gifted, from, mek, `🌪️ *Initiating Chaos Mode...* (\`${randomModel}\`)`);
        const { text: chaosPrompt } = await askAI('Generate a completely absurd, chaotic, and visually impossible prompt. Return ONLY the prompt.');
        return executeGen(chaosPrompt || 'cybernetic glitch octopus in a tea cup, neon explosion', stub);
    }

    // Sub-Command: Setup/Key Refresh
    if (cmd === 'setup') {
        const stub = await thinking(Gifted, from, mek, '🔧 _Refreshing Infip API Tunnel..._');
        _iOk = false;
        const success = await ensureInfip();
        return editMsg(Gifted, stub, box('API Setup', success ? `✅ *Success:* Handshake established with Infip.\n*Active Key:* \`${_iKey.slice(0, 15)}...\`` : '❌ *Failed:* All keys in pool are exhausted.'));
    }

    // Default: Generation
    const prompt = (cmd === 'gen') ? rest.join(' ') : q;
    if (!prompt) {
        return reply(box('IMG Suite', 
            '• `.img <prompt>` - Generate image\n' +
            '• `.img surprise [theme]` - AI dreams for you\n' +
            '• `.img enhance <text>` - Improve a prompt\n' +
            '• `.img chaos` - Randomized generation\n' +
            '• `.img models` - List available models\n' +
            '• `.img config` - View/Change settings\n' +
            '• `.img setup` - Reset API connection'
        ));
    }

    await react('🎨');
    const stub = await thinking(Gifted, from, mek, `🎨 _Generating image using ${CFG.IMG_MODEL}..._`);
    return executeGen(prompt, stub);
});

// ==============================================================================
// 13.  .aiwrite  — CREATIVE WRITING ENGINE (EXTENDED)
// ==============================================================================
gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['write', 'compose', 'draft', 'author'],
    category: 'ai',
    desc: 'Advanced creative writing for various formats.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const WRITER_MODES = {
        message:    `Write a natural, casual WhatsApp message about: ${topic}.`,
        roast:      `Write a sharp, witty, but playful roast about: ${topic}.`,
        caption:    `Write 3 punchy Instagram captions with emojis for: ${topic}.`,
        essay:      `Write a comprehensive and structured short essay about: ${topic}.`,
        story:      `Write an engaging short story (3-4 paragraphs) about: ${topic}.`,
        bio:        `Write 2 professional and 2 funny bios for: ${topic}.`,
        email:      `Write a formal professional email about: ${topic}. Include a subject line.`,
        reply:      `Draft a clever and intelligent reply to this context: ${topic}.`,
        flirt:      `Write a smooth, respectful, and charming message about: ${topic}.`,
        apology:    `Write a sincere, well-worded apology regarding: ${topic}.`,
        tweet:      `Write a viral-style tweet with hashtags about: ${topic}.`,
        speech:     `Write a short, inspiring speech for: ${topic}.`,
        code:       `Write highly optimized, clean, and commented code for: ${topic}. Explain logic briefly.`,
        brainstorm: `Generate 10 unique, creative, and out-of-the-box ideas or solutions for: ${topic}.`,
        thread:     `Write a 5-7 part educational and engaging Twitter/X thread about: ${topic}. Use hooks.`
    };

    if (!type || !WRITER_MODES[type]) {
        const available = Object.keys(WRITER_MODES).map(t => `\`${t}\``).join(', ');
        return reply(`✍️ *AI Writer Engine*\n\n*Available Modes:*\n${available}\n\n*Usage:* \`.aiwrite <mode> <topic>\``);
    }

    if (!topic) return reply(`📝 *Missing Topic:* What should I write the \`${type}\` about?`);

    const stub = await thinking(Gifted, from, mek, `✍️ _Authoring your ${type}..._`);
    
    // Requesting AI with explicit instruction for WhatsApp Markdown
    const prompt = `${WRITER_MODES[type]}\n\nIMPORTANT: Use WhatsApp markdown (*bold*, _italic_, \`monospace\`). Format beautifully.`;
    const { text, err } = await askAI(prompt);

    if (err) return editMsg(Gifted, stub, `❌ *Writing Error:* ${text}`);

    const box = `*┏━━━━━━━━━━━━━━━━━━━━━━━━┓*\n*┃  ${type.toUpperCase()} DEPLOYED*\n*┗━━━━━━━━━━━━━━━━━━━━━━━━┛*\n\n${text}\n\n_— Authored by Gifted Creative Engine —_`;
    
    return editMsg(Gifted, stub, box);
});

// ==============================================================================
// 14.  STALK FIX & REFINEMENT
// ==============================================================================
// Ensuring the stalker logic is correctly identifying targets across all group chats
// This replaces/augments the watcher logic for better tracking.

const StalkerLogic = {
    isTarget: (senderId) => {
        const cleanId = senderId.split(':')[0].replace(/[^0-9]/g, '') + '@s.whatsapp.net';
        return State.stalkers.has(cleanId) ? State.stalkers.get(cleanId) : null;
    }
};

/**
 * Robust Markdown Helper for Global Use
 */
const markdownHelper = {
    applyFormatting: (text, type = 'whatsapp') => {
        if (type === 'whatsapp') {
            return text
                .replace(/\*\*(.*?)\*\*/g, '*$1*') // Bold
                .replace(/__(.*?)__/g, '_$1_')     // Italic
                .replace(/### (.*?)(\n|$)/g, '*$1*$2') // Headers to Bold
                .trim();
        }
        return text;
    }
};

// Final closure of the script segment for CHUNK 4.
// Ensure all state mappings are initialized.
if (!State.resolveSession) {
    State.resolveSession = (participant, remoteJid, isGroup) => {
        const sender = participant || remoteJid;
        if (State.stalkers.has(sender)) return State.stalkers.get(sender);
        if (State.targets.has(sender)) return State.targets.get(sender);
        if (isGroup && State.chats.has(remoteJid)) return State.chats.get(remoteJid);
        if (!isGroup && State.dmActive) {
            if (!State.dmSessions.has(sender)) {
                State.dmSessions.set(sender, {
                    gem: State.dmGem || State.PERSONA,
                    mood: 'natural',
                    formatting: 'whatsapp',
                    history: [],
                    gemName: 'dm-auto'
                });
            }
            return State.dmSessions.get(sender);
        }
        return null;
    };
}

// --- CHUNK: Productivity & Analysis Suite (.aidecode & .aitranslate) ---
// ==============================================================================
// 15.  .aidecode — VISION & DEEP ANALYSIS
// ==============================================================================
gmd({
    pattern: 'aidecode', cmdname: 'aidecode', aliases: ['aianalyze', 'explain', 'vision'],
    category: 'ai', desc: 'Vision-to-text analysis via ImgBB and QuillBot.', react: '🔍', filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Senior Developer clearance required.');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    let imgUrls = [];
    let focusText = q.trim();

    // Handle Vision (Image) Input
    if (quoted?.imageMessage || mek.message?.imageMessage) {
        await react('👁️');
        const stub = await thinking(Gifted, from, mek, '📸 _Extracting visual metadata..._');
        try {
            const mediaMsg = quoted?.imageMessage ? quoted.imageMessage : mek.message.imageMessage;
            const tmpPath = path.join(__dirname, '..', 'gift', `tmp_dec_${Date.now()}.jpg`);
            
            // Download using the Gifted framework helper
            const stream = await Gifted.downloadMediaMessage({ message: { imageMessage: mediaMsg } });
            fs.writeFileSync(tmpPath, stream);
            
            const url = await uploadImgBB(tmpPath);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
            
            if (!url) return editMsg(Gifted, stub, '❌ *Vision Link Failure:* ImgBB rejected the payload.');
            await editMsg(Gifted, stub, '🔍 _Decoding image context..._');
        } catch (e) {
            return editMsg(Gifted, stub, `❌ *Optical Error:* ${e.message}`);
        }
    }

    // Context Resolution
    const contextText = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    if (!imgUrls.length && !focusText && !contextText) {
        return reply('📝 *Usage:* Reply to an image/text with `.aidecode [optional focus]`');
    }

    const stub = imgUrls.length ? null : await thinking(Gifted, from, mek, '🧠 _Processing neural analysis..._');
    
    // Construct sophisticated prompt
    let prompt = '';
    if (imgUrls.length) {
        prompt = `Analyze this image in high detail. ${focusText ? `Focus specifically on: ${focusText}` : 'Extract all text, identify key objects, and describe the scene.'} 
        \n\nIMPORTANT: Start every line of your analysis with the blockquote character ">".`;
    } else {
        prompt = `Deep analysis of the following content:\n"${contextText || focusText}"\n\nFocus: ${focusText || 'Comprehensive breakdown'}.
        \n\nIMPORTANT: Start every line of your analysis with the blockquote character ">".`;
    }

    const { text, err } = await askAI(prompt, imgUrls);
    const finalOutput = err ? `❌ *Analysis Halted:* ${text}` : `🔍 *DECODED ANALYSIS*\n\n${text}`;
    
    return imgUrls.length ? Gifted.sendMessage(from, { text: finalOutput }, { quoted: mek }) : editMsg(Gifted, stub, finalOutput);
});

// ==============================================================================
// 16.  .aitranslate — MULTI-LINGUAL ENGINE
// ==============================================================================
gmd({
    pattern: 'aitranslate', cmdname: 'aitranslate', aliases: ['translate', 'gitrans', 'aitrans'],
    category: 'ai', desc: 'AI-powered translation into any language.', react: '🌐', filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied.*');

    const parts = q.trim().split(/\s+/);
    const targetLang = parts[0];
    let sourceText = parts.slice(1).join(' ');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (!sourceText && quoted) {
        sourceText = quoted.conversation || quoted.extendedTextMessage?.text || '';
    }

    if (!targetLang || !sourceText) {
        return reply('📝 *Usage:* `.aitranslate <language> <text>` or reply to a message.');
    }

    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${targetLang.toUpperCase()}..._`);
    const prompt = `Translate the following text to ${targetLang}. Preserve the original tone and emojis. 
    \n\nText: "${sourceText}"\n\nReturn ONLY the translation and start every line with the blockquote character ">".`;
    
    const { text, err } = await askAI(prompt);
    
    if (err) return editMsg(Gifted, stub, `❌ *Translation Error:* ${text}`);
    
    const output = `🌐 *TRANSLATION [${targetLang.toUpperCase()}]*\n\n${text}\n\n_Generated via Gifted Neural Link_`;
    return editMsg(Gifted, stub, output);
});

// ==============================================================================
// 17.  .codex — DEBUGGING & CODE OPTIMIZATION
// ==============================================================================
gmd({
    pattern: 'codex', cmdname: 'codex', aliases: ['debug', 'fixcode', 'refactor', 'gitfix'],
    category: 'ai', desc: 'Elite debugging suite for provided code snippets.', react: '💻', filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Elite Senior Developer clearance only.');

    let rawCode = q.trim();
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (!rawCode && quoted) {
        rawCode = quoted.conversation || quoted.extendedTextMessage?.text || '';
    }

    if (!rawCode) return reply('📝 *Usage:* Reply to code or provide a snippet: `.codex [code]`');

    const stub = await thinking(Gifted, from, mek, '💻 _Scanning source for logic flaws and anti-patterns..._');
    
    const prompt = `Act as an Elite Senior Developer. Analyze the following code:\n\n\`\`\`\n${rawCode}\n\`\`\`\n\n
    Perform the following:
    1. Identify bugs, security vulnerabilities, or performance bottlenecks.
    2. Provide a clean, optimized, and refactored version in a code block.
    3. Explain your reasoning.
    
    CRITICAL: For every line of your explanation and your bug-list, start the line with the blockquote character ">". The code block itself should NOT have blockquotes.`;

    const { text, err } = await askAI(prompt);
    
    if (err) return editMsg(Gifted, stub, `❌ *Compiler Error:* ${text}`);
    
    const report = `💻 *CODEX DEBUG REPORT*\n\n${text}\n\n_— End of Report —_`;
    return editMsg(Gifted, stub, report);
});

// ==============================================================================
// 18.  ROBUST WATCHER & STALKER RE-IMPLEMENTATION
// ==============================================================================
// Re-initializing the watcher with the improved session resolution logic.

const InitializeWatcher = (Gifted) => {
    if (!Gifted?.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;

                const remoteJid = msg.key.remoteJid;
                const participant = msg.key.participant || remoteJid;
                const isGroup = remoteJid.endsWith('@g.us');
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';

                // Use the resolution logic from Chunk 4
                const session = State.resolveSession(participant, remoteJid, isGroup);
                if (!session) continue;

                // Ignore command triggers to prevent loops
                if (['.', '/', '!', '+'].includes(body[0])) continue;

                setImmediate(async () => {
                    try {
                        let attachedImages = [];
                        
                        // Handle stalker vision
                        if (msg.message.imageMessage) {
                            const tPath = path.join(__dirname, '..', 'gift', `stalk_tmp_${Date.now()}.jpg`);
                            const buffer = await Gifted.downloadMediaMessage({ message: { imageMessage: msg.message.imageMessage } });
                            fs.writeFileSync(tPath, buffer);
                            const url = await uploadImgBB(tPath);
                            if (url) attachedImages.push(url);
                            if (fs.existsSync(tPath)) fs.unlinkSync(tPath);
                        }

                        // Add to session history
                        State.addHist(session, 'User', body || '[Image Attachment]');

                        // Circuit Breaker Check
                        if (CB.open()) return;

                        // AI Response Generation
                        const prompt = State.buildPrompt(session.gem, session.history, body);
                        
                        // Human-like typing delay based on input length
                        const delay = Math.min(body.length * 30, 4000) + 500;
                        await sleep(delay);
                        
                        try { await Gifted.sendPresenceUpdate('composing', remoteJid); } catch (_) {}
                        
                        const { text: aiResponse, err } = await askAI(prompt, attachedImages);
                        
                        try { await Gifted.sendPresenceUpdate('paused', remoteJid); } catch (_) {}

                        if (err) {
                            if (CB.open()) return; 
                            // Silent fail on watcher to avoid spamming errors in group chats
                            return;
                        }

                        State.addHist(session, 'AI', aiResponse);

                        // Robust Reply Structure
                        const replyRef = {
                            quoted: {
                                key: {
                                    remoteJid: msg.key.remoteJid,
                                    fromMe: false,
                                    id: msg.key.id,
                                    participant: msg.key.participant
                                },
                                message: msg.message
                            }
                        };

                        await Gifted.sendMessage(remoteJid, { text: aiResponse }, replyRef);

                    } catch (err) {
                        console.error('[AIGems.Watcher] Error:', err.message);
                    }
                });
            } catch (globalErr) {
                console.error('[AIGems.GlobalWatcher] Critical:', globalErr.message);
            }
        }
    });
};

// Re-hook into the global instance
if (global.conn) InitializeWatcher(global.conn);
else if (global.client) InitializeWatcher(global.client);

// ==============================================================================
// 19.  END OF CHUNK 5: PRODUCTIVITY & ANALYSIS
// ==============================================================================

// --- CHUNK: The Master Watcher & Stalk Logic Fix ---
// ==============================================================================
// 20. MASTER WATCHER & STALK LOGIC FIX
// ==============================================================================

/**
 * @function attachWatcher
 * @description Master event listener for message upserts.
 *              Handles Stalkers, Targets, Chat AI, DM Auto-pilot, and Auto-Enhance.
 */
const attachWatcher = (Gifted) => {
    if (!Gifted?.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        // Only process new incoming/outgoing messages
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.remoteJid === 'status@broadcast') continue;

                const remoteJid = msg.key.remoteJid;
                const participant = msg.key.participant || '';
                const fromMe = msg.key.fromMe;
                const isGroup = remoteJid.endsWith('@g.us');
                
                // Content extraction
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || 
                             msg.message.videoMessage?.caption || '';

                // --- 1. AUTO-ENHANCE (Owner's outgoing messages) ---
                if (fromMe && State.autoEnhance && body.length > 8 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        try {
                            const enhancePrompt = `You are a professional editor. Fix the grammar, spelling, and punctuation of the following WhatsApp message. Keep the tone, language, and emojis exactly the same. Only return the corrected text, nothing else.\n\nText: ${body}`;
                            const { text: improved, err } = await askAI(enhancePrompt);
                            
                            if (!err && improved && improved.trim().toLowerCase() !== body.trim().toLowerCase()) {
                                await sleep(800); // Slight delay for natural feel
                                await Gifted.sendMessage(remoteJid, { text: improved.trim(), edit: msg.key });
                            }
                        } catch (e) {
                            console.error('[AIGems.Enhance] Failed:', e.message);
                        }
                    });
                    continue; // Don't process AI reply for our own enhanced messages
                }

                if (fromMe) continue;
                if (['.', '/', '!', '+'].includes(body[0])) continue;

                // --- 2. SESSION RESOLUTION (Stalk Logic Fix) ---
                let sess = null;
                let sessionType = '';

                // CRITICAL FIX: Check participant (Groups) and remoteJid (DMs) against stalkers map
                if (State.stalkers.has(participant)) {
                    sess = State.stalkers.get(participant);
                    sessionType = 'stalk';
                } else if (State.stalkers.has(remoteJid)) {
                    sess = State.stalkers.get(remoteJid);
                    sessionType = 'stalk';
                } 
                // Check Targets (Specific User in Specific Chat or Global)
                else if (State.targets.has(participant)) {
                    const targetData = State.targets.get(participant);
                    if (!targetData.chatId || targetData.chatId === remoteJid) {
                        sess = targetData;
                        sessionType = 'target';
                    }
                } 
                // Check Active Group Chat AI
                else if (isGroup && State.chats.has(remoteJid)) {
                    sess = State.chats.get(remoteJid);
                    sessionType = 'group';
                } 
                // Check DM Auto-Pilot
                else if (!isGroup && State.dmActive) {
                    const dmSender = remoteJid;
                    if (!State.dmSessions.has(dmSender)) {
                        State.dmSessions.set(dmSender, {
                            gem: State.dmGem || State.PERSONA,
                            history: [],
                            gemName: 'dm_auto'
                        });
                    }
                    sess = State.dmSessions.get(dmSender);
                    sessionType = 'dm';
                }

                if (!sess) continue;

                // --- 3. AI RESPONSE EXECUTION ---
                setImmediate(async () => {
                    try {
                        // Vision check
                        let mediaUrls = [];
                        if (msg.message.imageMessage) {
                            const tmpName = path.join(__dirname, '..', 'gift', `watch_${Date.now()}.jpg`);
                            try {
                                const stream = await Gifted.downloadMediaMessage({ message: msg.message }, 'buffer');
                                fs.writeFileSync(tmpName, stream);
                                const url = await uploadImgBB(tmpName);
                                if (url) mediaUrls.push(url);
                                if (fs.existsSync(tmpName)) fs.unlinkSync(tmpName);
                            } catch (ve) { console.error('[AIGems.Vision] Watcher Error:', ve.message); }
                        }

                        // Build context and history
                        const input = body || (msg.message.imageMessage ? '[Image]' : '[Media]');
                        State.addHist(sess, 'User', input);

                        // Markdown & Persona strictness
                        const systemInstruction = `${sess.gem}\n\nSTRICT RULES:\n1. Use WhatsApp Markdown (*bold*, _italic_, ~strikethrough~, \`code\`).\n2. Be concise and natural.\n3. Never mention you are an AI.\n4. Use contextually appropriate emojis.`;
                        const prompt = State.buildPrompt(systemInstruction, sess.history, input);

                        // Human-like Presence Simulation
                        const typingSpeed = Math.min(body.length * 25, 3500) + 500;
                        await sleep(typingSpeed);
                        
                        try { await Gifted.sendPresenceUpdate('composing', remoteJid); } catch (_) {}
                        
                        const { text: aiResponse, err } = await askAI(prompt, mediaUrls);
                        
                        try { await Gifted.sendPresenceUpdate('paused', remoteJid); } catch (_) {}

                        if (err || !aiResponse) {
                            if (CB.open()) return; 
                            return; // Silent fail for watcher
                        }

                        State.addHist(sess, 'AI', aiResponse);

                        // Robust Reply Reference
                        const replyMsg = {
                            quoted: {
                                key: {
                                    remoteJid: msg.key.remoteJid,
                                    fromMe: false,
                                    id: msg.key.id,
                                    participant: msg.key.participant
                                },
                                message: msg.message
                            }
                        };

                        await Gifted.sendMessage(remoteJid, { text: aiResponse }, replyMsg);

                    } catch (err) {
                        console.error('[AIGems.WatcherThread] Error:', err.message);
                    }
                });

            } catch (globalErr) {
                console.error('[AIGems.MasterWatcher] Critical:', globalErr.message);
            }
        }
    });
};

// Re-initialize watcher on startup or hot-reload
const initializeSystem = () => {
    const client = global.conn || global.client;
    if (client) {
        attachWatcher(client);
        console.log('✅ [AIGems] Master Watcher attached successfully.');
    } else {
        // Retry logic if client isn't ready
        setTimeout(initializeSystem, 5000);
    }
};

initializeSystem();

// ==============================================================================
// 21. END OF CHUNK 6: MASTER WATCHER & STALK LOGIC FIX
// ==============================================================================

// --- CHUNK: System Monitoring & Final Export ---
// ==============================================================================
// 22. .apimon — ENHANCED MONITORING & SYSTEM CONTROL
// ==============================================================================

/**
 * Toggle for debugging AI formatting. 
 * When true, responses are wrapped in code blocks to reveal raw markdown.
 */
State.markdownView = false; 

gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    aliases: ['apihealth', 'sysstat', 'monitor', 'cb'],
    category: 'ai',
    desc: 'Deep diagnostics, circuit breaker status, and markdown debugging.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Administrative Access Required.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'status';

    if (cmd === 'status') {
        const s = Limiter.stats();
        const cbStatus = CB.open() ? '🔴 *TRIPPED* (Open)' : `🟢 *OPERATIONAL* (Closed - ${CB.fails}/${CB.THRESH})`;
        
        const createBar = (val, max) => {
            const size = 12;
            const progress = Math.min(size, Math.round((val / max) * size));
            return '█'.repeat(progress) + '░'.repeat(size - progress);
        };

        let report = `📊 *SYSTEM DIAGNOSTICS: [AIGEMS]*\n\n`;
        report += `📡 *Network Load:*\n`;
        report += `• 1m Load: \`${createBar(s.rpm, CFG.MAX_RPM)}\` \`${s.rpm}/${CFG.MAX_RPM}\`\n`;
        report += `• 1h Load: \`${createBar(s.rph, CFG.MAX_RPH)}\` \`${s.rph}/${CFG.MAX_RPH}\`\n\n`;
        report += `🧠 *Session Metrics:*\n`;
        report += `• Active Chats: \`${State.chats.size}\` sessions\n`;
        report += `• Target Locks: \`${State.targets.size}\` accounts\n`;
        report += `• Global Stalk: \`${State.stalkers.size}\` active\n\n`;
        report += `🛡️ *Circuit Breaker:*\n`;
        report += `• Status: ${cbStatus}\n`;
        report += `• Cooldown: \`${CB.TTL / 60000} minutes\`\n\n`;
        report += `📊 *Lifetime Today:*\n`;
        report += `• AI Reqs: \`${s.ai}\` | Img Reqs: \`${s.img}\` | Errors: \`${s.err}\`\n\n`;
        report += `_Cycle Date: ${s.day}_`;

        return reply(report);
    }

    if (cmd === 'health') {
        const stub = await thinking(Gifted, from, mek, '🔍 *Initializing heuristic probe...*');
        const results = [];

        // Probe 1: Core Connectivity (QuillBot SSE)
        const startQB = Date.now();
        const { text: qbCheck, err: qbErr } = await askAI('PING: REPLY "PONG"');
        const qbTime = Date.now() - startQB;
        results.push(qbErr ? `❌ *AI Engine:* Unreachable/Auth Error` : `✅ *AI Engine:* Healthy (${qbTime}ms)`);

        // Probe 2: Infip Model Pool
        const infipOk = await ensureInfip();
        results.push(infipOk ? `✅ *Infip Engine:* Models Authenticated` : `⚠️ *Infip Engine:* Key Depletion/Failure`);

        // Probe 3: Persistence Layer (SQLite)
        try {
            const list = Gems.list();
            results.push(`✅ *Database:* WAL Journal Healthy (${list.length} gems)`);
        } catch (e) {
            results.push(`❌ *Database:* Read/Write Blocked`);
        }

        // Probe 4: Throttle Status
        results.push(Limiter.check() ? `✅ *Rate Limiter:* Within Limits` : `⚠️ *Rate Limiter:* Throttling Active`);

        const finalReport = `🔍 *CORE HEALTH CHECK*\n\n${results.map(r => `• ${r}`).join('\n')}\n\n*Uptime:* \`${process.uptime().toFixed(0)}s\`\n*Circuit:* \`${CB.fails}\` fails total.`;
        return editMsg(Gifted, stub, finalReport);
    }

    if (cmd === 'markdown') {
        State.markdownView = !State.markdownView;
        return reply(`📝 *Markdown Preview:* \`${State.markdownView ? 'ON' : 'OFF'}\`\nWhen enabled, AI responses will be wrapped in raw code blocks to inspect the formatting logic.`);
    }

    if (cmd === 'reset') {
        const type = parts[1]?.toLowerCase();
        if (type === 'circuit') {
            CB.reset();
            return reply('⚡ *Circuit Reset:* All AI safety overrides cleared.');
        }
        if (type === 'stats') {
            Limiter.daily = { ai: 0, img: 0, err: 0, day: new Date().toDateString() };
            return reply('♻️ *Metrics Purged:* Daily counters have been reset.');
        }
        return reply('📝 Usage: \`.apimon reset <circuit|stats>\`');
    }

    return reply(
        `📊 *API MONITOR COMMANDS*\n\n` +
        `• \`.apimon status\` - System load & stats\n` +
        `• \`.apimon health\` - Connectivity diagnostics\n` +
        `• \`.apimon markdown\` - Toggle raw format debug\n` +
        `• \`.apimon reset <type>\` - Forced system override`
    );
});

// ==============================================================================
// 23. FINAL INITIALIZATION & EXPORTS
// ==============================================================================

/**
 * Boot check interval to attach the Master Watcher to the Gifted instance.
 * Polls for global.conn (Baileys/Gifted common) or global.client.
 */
const BOOT_CHECK_INTERVAL = 5000;
const bootInterval = setInterval(() => {
    const GiftedClient = global.conn || global.client;
    if (GiftedClient) {
        console.log('[AIGems] Global client found. Finalizing attachment...');
        if (typeof attachWatcher === 'function') {
            attachWatcher(GiftedClient);
            clearInterval(bootInterval);
        }
    }
}, BOOT_CHECK_INTERVAL);

/**
 * Robust Cleanup: Ensure DB and intervals are handled on exit
 */
process.on('SIGINT', () => {
    if (db) {
        db.close();
        console.log('[AIGems] Database connection safely closed.');
    }
    process.exit(0);
});

/**
 * Final Export Pattern
 * Optimized for Atassa Bulletproof Framework & Gifted-MD.
 */
module.exports = {
    State,
    CFG,
    Gems,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB,
    attachWatcher,
    initializeSystem,
    metadata: {
        module: 'AIGems',
        version: '2.5.0',
        author: 'Elite Senior Developer',
        architecture: 'SSE-Streaming-SQLite'
    }
};

console.log('💎 [AIGems] Module Chunk 7/7: System Monitoring & Exports Loaded.');
