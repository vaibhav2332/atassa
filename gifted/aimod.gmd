//  .poem — AI POEM GENERATOR (NEW)
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'poem',
        aliases : ['aipoem', 'poetry', 'verse'],
        category: 'ai',
        react   : '🌸',
        desc    : 'Generate an AI poem on any topic',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek, pushName } = conText;
        const topic = q || `life and ${pushName}`;
        await editOrReply(Gifted, from, mek, '🌸 *Writing poem...*');
        const styles = ['rhyming', 'free verse', 'haiku-inspired', 'romantic', 'humorous'];
        const style  = styles[Math.floor(Math.random()*styles.length)];
        const r = await smartAI(
            `Write a beautiful ${style} poem about: "${topic}". Make it 8-12 lines. Evocative and original.`,
            [], conText
        );
        return editOrReply(Gifted, from, mek, `🌸 *${style.charAt(0).toUpperCase()+style.slice(1)} Poem*\n\n${r}`);
    }
);

