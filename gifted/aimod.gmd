    } catch(e) { 
        console.error('[AIGems] Database failure:', e.message); 
        db = null; 
    }
}

const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT * FROM gems WHERE name=?').get(n.toLowerCase().trim()) ?? null; } catch(e){ return null; } },
    save : (n, c, m = 'natural', f = 'whatsapp') => { 
        try { 
            const stmt = db?.prepare('INSERT OR REPLACE INTO gems(name, content, mood, formatting) VALUES(?,?,?,?)');
            return !!stmt?.run(n.toLowerCase().trim(), c, m, f)?.changes; 
        } catch(e){ return false; } 
    },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};

// ==============================================================================
// 4. RATE LIMITER & CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q: [], hr_q: [], daily: { ai: 0, img: 0, err: 0, day: new Date().toDateString() },
    check() {
        const n = Date.now();
        this.min_q = this.min_q.filter(t => n - t < 60000);
        this.hr_q = this.hr_q.filter(t => n - t < 3600000);
        return this.min_q.length < CFG.MAX_RPM && this.hr_q.length < CFG.MAX_RPH;
    },
    hit(type = 'ai') {
        const n = Date.now(); 
        this.min_q.push(n); 
        this.hr_q.push(n);
        const d = new Date().toDateString();
        if (d !== this.daily.day) this.daily = { ai: 0, img: 0, err: 0, day: d };
        if (type === 'ai') this.daily.ai++;
        if (type === 'img') this.daily.img++;
    },
    err() { this.daily.err++; },
    stats() {
        const n = Date.now();
        return { 
            rpm: this.min_q.filter(t => n - t < 60000).length, 
            rph: this.hr_q.filter(t => n - t < 3600000).length, 
            ...this.daily 
        };
    }
};

const CB = {
    fails: 0, lastFail: 0, THRESH: 5, TTL: 300000,
    open()  { return this.fails >= this.THRESH && Date.now() - this.lastFail < this.TTL; },
    fail()  { this.fails++; this.lastFail = Date.now(); Limiter.err(); },
    ok()    { this.fails = 0; },
    reset() { this.fails = 0; this.lastFail = 0; },
    msg()   { return ['neural link glitchy rn', 'signal weak on my end', 'connection hiccupped', 'brain.exe crashed lol'][Math.floor(Math.random() * 4)]; }
};

// ==============================================================================
// 5. CORE AI ENGINE (QuillBot SSE Stream Implementation)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

/**
 * Executes a request to the AI engine with permanent WhatsApp Markdown forcing.
 * Handles SSE parsing and redundant retries.
 */
let askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            // Injecting the absolute markdown formatting requirement
            content: `${CFG.SYSTEM_MD_PREFIX}${prompt}`,
            files  : imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id: 'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            let fullText = '';
            const lines = rawText.split('\n');
            for (const line of lines) {
                const trimmed = line.trim();
                if (trimmed.startsWith('data: {')) {
                    try {
                        const jsonStr = trimmed.replace(/^data:\s*/, '');
                        const parsed = JSON.parse(jsonStr);
                        if (parsed.chunk) fullText += parsed.chunk;
                    } catch(e) {}
                }
            }

            if (!fullText.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1200); continue; }
                CB.fail();
                return { text: 'empty response — system saturation reached', err: true };
            }

            CB.ok();
            // Post-process to remove common non-WhatsApp markdown symbols
            const clean = fullText
                .replace(/\\\(|\\\)|\\\[|\\\]/g, '')
                .replace(/\\([a-zA-Z])/g, '$1')
                .replace(/\*\*\*(.*?)\*\*\*/g, '*$1*') // Fix triple asterisk issues
                .replace(/\*\*(.*?)\*\*/g, '*$1*')    // Convert double asterisk to single for WA Bold
                .trim();

            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] Engine failure (Attempt ${attempt + 1}):`, e.message);
            if (attempt < CFG.RETRIES - 1) {
                await sleep(1500 * (attempt + 1));
            } else {
                CB.fail();
                return { text: `API unreachable — ${e.message}`, err: true };
            }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 6. ADVANCED STATE MANAGEMENT (Hierarchy of Attention)
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    autoEnhance: false,
    
    chats: new Map(),      // Chat-wide AI
    targets: new Map(),    // Specific users in specific chats
    stalkers: new Map(),   // Specific users globally
    dmSessions: new Map(), // DM auto-pilot sessions

    PERSONA: 'You are a highly efficient, witty, and helpful AI assistant. You keep your tone professional yet conversational. You never identify as an AI model and strictly follow formatting instructions.',

    /**
     * Resolves the session based on priority:
     * Stalker > Target > Chat-AI > DM-Pilot
     */
    resolveSession(sender, chatId, isGrp) {
        const cleanSender = sender.split(':')[0].replace(/[^0-9]/g, '') + '@s.whatsapp.net';
        
        if (this.stalkers.has(cleanSender)) return this.stalkers.get(cleanSender);
        
        if (this.targets.has(cleanSender)) {
            const t = this.targets.get(cleanSender);
            if (!t.chatId || t.chatId === chatId) return t;
        }

        if (this.chats.has(chatId)) return this.chats.get(chatId);

        if (!isGrp && this.dmActive) {
            if (!this.dmSessions.has(cleanSender)) {
                this.dmSessions.set(cleanSender, {
                    gem: this.dmGem || this.PERSONA,
                    history: [],
                    gemName: 'dm_auto'
                });
            }
            return this.dmSessions.get(cleanSender);
        }
        return null;
    },

    addHist(sess, role, txt) {
        if (!sess.history) sess.history = [];
        const time = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        sess.history.push(`[${time}] ${role}: ${txt}`);
        if (sess.history.length > CFG.MAX_HIST) sess.history.shift();
    },

    buildPrompt(system, history, currentInput) {
        return `SYSTEM_INSTRUCTION:\n${system}\n\nRELEVANT_HISTORY:\n${history.join('\n')}\n\nCURRENT_MESSAGE:\n${currentInput}\n\nASSISTANT_REPLY:`;
    }
};
// ==============================================================================
// 7. IMAGE INFRASTRUCTURE (Infip & ImgBB Integration)
// ==============================================================================
let _iKey = CFG.INFIP_POOL[0], _iOk = false;

/**
 * Ensures the Infip API handshake is active. Rotates keys on failure.
 */
const ensureInfip = async () => {
    if (_iOk) return true;
    for (const key of CFG.INFIP_POOL) {
        try {
            const r = await axios.get(`${CFG.INFIP_URL}/status?key=${key}`, { timeout: 5000 });
            if (r.data?.status) { _iKey = key; _iOk = true; return true; }
        } catch(e) {}
    }
    return false;
};

/**
 * Uploads local media to ImgBB for AI Vision processing.
 */
let uploadImgBB = async (filePath) => {
    try {
        const form = new (require('form-data'))();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(`https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}`, form, {
            headers: { ...form.getHeaders() }
        });
        return res.data?.data?.url || null;
    } catch (e) {
        console.error('[AIGems] ImgBB Upload Error:', e.message);
        return null;
    }
};

/**
 * High-performance image generation via Infip Neural Pool.
 */
let generateImage = async (prompt, opts = {}) => {
    if (!await ensureInfip()) return null;
    try {
        Limiter.hit('img');
        const res = await axios.post(`${CFG.INFIP_URL}/generate`, {
            key    : _iKey,
            prompt : prompt,
            model  : opts.model || CFG.IMG_MODEL,
            size   : opts.size || CFG.IMG_SIZE,
            count  : opts.count || CFG.IMG_COUNT,
            quality: opts.quality || CFG.IMG_QUALITY
        }, { timeout: CFG.TIMEOUT });

        if (res.data?.images) return res.data.images;
        if (res.data?.url) return [res.data.url];
        return null;
    } catch (e) {
        console.error('[AIGems] Generation Error:', e.message);
        _iOk = false; // Trigger re-handshake
        return null;
    }
};

// ==============================================================================
// 8. COMMAND REGISTRATION BRIDGE (Atassa Framework)
// ==============================================================================
let commandRegister;
try {
    const cmdSys = require('../gift/gmdCmds');
    commandRegister = cmdSys.gifted || cmdSys.gmd || cmdSys.cmd || cmdSys.smd || cmdSys.Module || cmdSys;
} catch (err) {
    console.error("[AIGems] Dynamic registrar failed to bridge.");
}

/**
 * Helper to resolve target JID from mentions, replies, or numbers.
 */
const resolveUser = (m, text) => {
    let jid = text.replace(/[^0-9]/g, '');
    if (m.message?.extendedTextMessage?.contextInfo?.mentionedJid?.[0]) {
        jid = m.message.extendedTextMessage.contextInfo.mentionedJid[0];
    } else if (m.message?.extendedTextMessage?.contextInfo?.participant) {
        jid = m.message.extendedTextMessage.contextInfo.participant;
    } else if (jid) {
        jid = jid + '@s.whatsapp.net';
    }
    return jid || null;
};

/**
 * Context Resolver as per modulebase blueprint.
 */
let resolveContext = (arg1, args) => {
    let sock = global.conn || global.client || arg1.bot || arg1.client;
    let m = arg1;
    const allArgs = [arg1, ...args];
    allArgs.forEach(arg => {
        if (arg && typeof arg === 'object' && !Array.isArray(arg)) {
            if (typeof arg.sendMessage === 'function') sock = arg;
            else if (arg.sock && typeof arg.sock.sendMessage === 'function') sock = arg.sock;
            if (arg.chat || arg.from || arg.jid || (arg.key && arg.key.remoteJid)) m = arg;
        }
    });
    return { m, sock };
};

let buildSafeQuote = (m) => {
    if (!m?.key) return {};
    return { quoted: { key: { remoteJid: m.key.remoteJid, fromMe: m.key.fromMe, id: m.key.id, participant: m.key.participant }, message: m.message } };
};

if (typeof commandRegister === 'function') {

    // --- COMMAND: .gem (Vault Management) ---
    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "vault"],
        category: "ai",
        desc: "Manage AI Persona Gems in SQLite vault.",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(' ').trim();
        const [sub, name, ...rest] = q.split(/\s+/);
        const content = rest.join(' ');
        const chatId = m.chat || m.from || m.key.remoteJid;

        if (!sub || sub === 'list') {
            const list = Gems.list();
            const txt = list.length ? `📂 *AI PERSONA VAULT:*\n\n${list.map((g,i)=>`*${i+1}.* \`${g}\``).join('\n')}\n\n_Use .gem use <name> to activate._` : `📂 *Vault is empty.*`;
            return sock.sendMessage(chatId, { text: txt }, buildSafeQuote(m));
        }

        if (sub === 'create' || sub === 'add') {
            if (!name || !content) return m.reply("📝 *Usage:* `.gem create <name> <persona_instructions>`");
            const ok = Gems.save(name, content);
            return m.reply(ok ? `✅ *Gem Forged:* \`${name}\` is now in the vault.` : `❌ *Error:* Database write failed.`);
        }

        if (sub === 'del' || sub === 'delete') {
            if (!name) return m.reply("📝 *Usage:* `.gem del <name>`");
            return m.reply(Gems.del(name) ? `🗑️ *Purged:* \`${name}\` removed from vault.` : `❌ *Error:* Gem not found.`);
        }

        if (sub === 'use' || sub === 'set') {
            const prompt = Gems.get(name);
            if (!prompt) return m.reply("❌ Gem not found.");
            State.dmGem = prompt;
            return m.reply(`⚙️ *Global Persona Updated:* Now using \`${name}\`.`);
        }
    });

    // --- COMMAND: .gai (AI Intelligence & Tracking) ---
    commandRegister({
        pattern: "gai",
        cmdname: "gai",
        alias: ["ai", "brain", "ask"],
        category: "ai",
        desc: "Advanced AI control and targeting suite.",
        react: "🧠",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(' ').trim();
        const chatId = m.chat || m.from || m.key.remoteJid;

        if (!q) return m.reply(`🧠 *GAI COMMAND SUITE:*\n\n` +
            `• \`.gai <text>\` - Ask AI a question\n` +
            `• \`.gai chat [gem]\` - AI mode for this chat\n` +
            `• \`.gai target <user> [gem]\` - Reply to specific user here\n` +
            `• \`.gai stalk <user> [gem]\` - Tracking user globally\n` +
            `• \`.gai stop\` - End AI sessions in this chat\n` +
            `• \`.gai dm on/off\` - Auto-pilot for DMs`);

        const parts = q.split(/\s+/);
        const cmd = parts[0].toLowerCase();

        // Target Logic (Local)
        if (cmd === 'target') {
            const user = resolveUser(m, parts[1] || '');
            if (!user) return m.reply("❌ Tag/Reply to a user or provide a number.");
            const gem = (parts[2] ? Gems.get(parts[2]) : null) || State.PERSONA;
            State.targets.set(user, { gem, history: [], chatId, gemName: parts[2] || 'default' });
            return m.reply(`🎯 *Target Locked:* @${user.split('@')[0]}\n*Scope:* Local Chat\n*Persona:* \`${parts[2] || 'Standard'}\``, { mentions: [user] });
        }

        // Stalk Logic (Global)
        if (cmd === 'stalk') {
            const user = resolveUser(m, parts[1] || '');
            if (!user) return m.reply("❌ Tag/Reply to a user or provide a number.");
            const gem = (parts[2] ? Gems.get(parts[2]) : null) || State.PERSONA;
            State.stalkers.set(user, { gem, history: [], gemName: parts[2] || 'default' });
            return m.reply(`🌍 *Global Stalk Active:* @${user.split('@')[0]}\n*Scope:* All Chats\n*Persona:* \`${parts[2] || 'Standard'}\``, { mentions: [user] });
        }

        if (cmd === 'chat') {
            const gem = (parts[1] ? Gems.get(parts[1]) : null) || State.PERSONA;
            State.chats.set(chatId, { gem, history: [], gemName: parts[1] || 'default' });
            return m.reply(`⚔️ *Chat Intelligence Active* using \`${parts[1] || 'Standard'}\`.`);
        }

        if (cmd === 'stop') {
            State.chats.delete(chatId);
            for (let [k,v] of State.targets) if (v.chatId === chatId) State.targets.delete(k);
            return m.reply("🛑 AI session terminated for this chat.");
        }

        // Direct AI Query
        const { text, err } = await askAI(q);
        return sock.sendMessage(chatId, { text: err ? `⚠️ *Error:* ${text}` : text }, buildSafeQuote(m));
    });

    // --- COMMAND: .img (Generation) ---
    commandRegister({
        pattern: "img",
        cmdname: "img",
        alias: ["imagine", "draw"],
        category: "ai",
        desc: "Generate AI art from the Infip pool.",
        react: "🎨",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(' ');
        if (!q) return m.reply("🎨 Describe your imagination.");
        
        const chatId = m.chat || m.from || m.key.remoteJid;
        const urls = await generateImage(q);
        if (!urls) return m.reply("❌ Generation failed. Engine cold.");

        return sock.sendMessage(chatId, { 
            image: { url: urls[0] }, 
            caption: `🎨 *Generated Result*\n\n*Prompt:* _${q}_\n*Model:* \`${CFG.IMG_MODEL}\`` 
        }, buildSafeQuote(m));
    });
}

// ==============================================================================
// 9. AUTOMATIC RESPONSE WATCHER (Auto-Reply Engine)
// ==============================================================================
const startWatcher = (client) => {
    client.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        for (const msg of messages) {
            if (!msg.message || msg.key.fromMe) continue;

            const from = msg.key.remoteJid;
            const sender = msg.key.participant || from;
            const isGrp = from.endsWith('@g.us');
            const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';

            if (!body || body.startsWith('.')) continue;

            const sess = State.resolveSession(sender, from, isGrp);
            if (!sess) continue;

            // Circuit Breaker Guard
            if (CB.open()) return;

            try {
                State.addHist(sess, 'User', body);
                const { text, err } = await askAI(State.buildPrompt(sess.gem, sess.history, body));
                if (err) return;

                State.addHist(sess, 'AI', text);
                await client.sendMessage(from, { text }, { quoted: msg });
            } catch (e) {
                console.error('[AIGems.Watcher] Error:', e.message);
            }
        }
    });
};

// Initial trigger for watcher attachment
setTimeout(() => {
    const activeClient = global.conn || global.client;
    if (activeClient) startWatcher(activeClient);
}, 10000);

// ==============================================================================
// 10. EXPORTS (Chunk Finalization)
// ==============================================================================
module.exports = {
    Gems,
    State,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB
};
// ==============================================================================
// 7. ADVANCED STATE MANAGEMENT & SESSION TRACKING (PHASE 3 REFINEMENT)
// ==============================================================================

/**
 * Resolves the AI session using a strict hierarchical priority system.
 * This correction ensures that Stalkers are tracked globally, while Targets
 * are constrained to specific chat contexts unless otherwise specified.
 * 
 * @param {string} sender - The JID of the user sending the message.
 * @param {string} chatId - The JID of the current chat/group.
 * @param {boolean} isGrp - Whether the context is a group.
 * @returns {Object|null} The resolved session object.
 */
State.resolveSession = function(sender, chatId, isGrp) {
    // Normalize JIDs to ensure ID matching works across multi-device instances
    const userJid = sender.split(':')[0].split('@')[0] + '@s.whatsapp.net';
    const groupJid = isGrp ? chatId.split('@')[0] + '@g.us' : userJid;

    // 1. GLOBAL STALKER: Highest priority. AI responds to this user in any shared chat.
    if (this.stalkers.has(userJid)) {
        return this.stalkers.get(userJid);
    }

    // 2. LOCAL TARGET: Responds to a user only within the chat where they were targeted.
    if (this.targets.has(userJid)) {
        const targetSess = this.targets.get(userJid);
        if (!targetSess.chatId || targetSess.chatId === groupJid) {
            return targetSess;
        }
    }

    // 3. CHAT MODE: Responds to all users within an AI-enabled group or DM thread.
    if (this.chats.has(groupJid)) {
        return this.chats.get(groupJid);
    }

    // 4. DM AUTO-PILOT: Fallback for private messages if the global toggle is ON.
    if (!isGrp && this.dmActive) {
        if (!this.dmSessions.has(userJid)) {
            this.dmSessions.set(userJid, {
                gem: this.dmGem || this.PERSONA,
                mood: 'natural',
                formatting: 'whatsapp',
                history: [],
                gemName: 'dm_pilot'
            });
        }
        return this.dmSessions.get(userJid);
    }

    return null;
};

/**
 * Enhanced prompt builder with forced WhatsApp Markdown instructions.
 */
State.buildPrompt = function(sess, input) {
    const sys = sess.gem || this.PERSONA;
    const mood = sess.mood ? ` Current Mood: ${sess.mood}.` : '';
    
    // Inject the global formatting engine requirement
    const formatRule = `\n\nCRITICAL: You must respond using WhatsApp Markdown (*bold* for emphasis, _italics_ for subtle notes, ~strikethrough~ for corrections, \`\`\`code blocks\`\`\` for technical data). Always use bullet points for lists. Be concise and human-like.`;
    
    return `SYSTEM:\n${sys}${mood}${formatRule}\n\n--- SESSION HISTORY ---\n${sess.history.join('\n')}\n---\nUSER: ${input}\nREPLY:`;
};

// ==============================================================================
// 11. .gai — AI CONTROL & TARGETING (FIXED & ENHANCED)
// ==============================================================================

if (typeof commandRegister === 'function') {
    commandRegister({
        pattern: "gai",
        cmdname: "gai",
        alias: ["ai", "stalk", "target", "brain"],
        category: "ai",
        desc: "Advanced AI control for stalking, targeting, and chat automation.",
        react: "🧠",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(' ');
        const parts = q.split(/\s+/);
        const cmd = parts[0]?.toLowerCase();
        
        const chatId = m.chat || m.from || m.key.remoteJid;
        const isGrp = chatId.endsWith('@g.us');

        // Helper to extract JID from mention, reply, or number
        const getTargetJid = () => {
            let num = parts[1]?.replace(/[^0-9]/g, '');
            if (m.message?.extendedTextMessage?.contextInfo?.mentionedJid?.[0]) {
                return m.message.extendedTextMessage.contextInfo.mentionedJid[0];
            }
            if (m.message?.extendedTextMessage?.contextInfo?.participant) {
                return m.message.extendedTextMessage.contextInfo.participant;
            }
            return num ? num + '@s.whatsapp.net' : null;
        };

        // Sub-command: STALK (Global Tracking)
        if (cmd === 'stalk') {
            const tJid = getTargetJid();
            if (!tJid) return m.reply("⚠️ Please tag a user, reply to their message, or provide a number to stalk.");
            
            const gemName = parts[2] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.stalkers.set(tJid, {
                gem: gemContent,
                mood: 'natural',
                formatting: 'whatsapp',
                history: [],
                gemName
            });
            
            return sock.sendMessage(chatId, { 
                text: `🌍 *Global Stalk Engaged*\n\n*Target:* @${tJid.split('@')[0]}\n*Scope:* All Shared Chats\n*Persona:* \`${gemName}\`\n\n_AI will now follow and respond to this user everywhere._`,
                mentions: [tJid]
            }, buildSafeQuote(m));
        }

        // Sub-command: TARGET (Local Tracking)
        if (cmd === 'target') {
            const tJid = getTargetJid();
            if (!tJid) return m.reply("⚠️ Please tag a user or reply to their message to target them in this chat.");
            
            const gemName = parts[2] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.targets.set(tJid, {
                gem: gemContent,
                mood: 'natural',
                formatting: 'whatsapp',
                history: [],
                chatId: chatId, // Lock to this specific chat
                gemName
            });
            
            return sock.sendMessage(chatId, { 
                text: `🎯 *Local Target Locked*\n\n*Target:* @${tJid.split('@')[0]}\n*Scope:* This Chat Only\n*Persona:* \`${gemName}\`\n\n_AI will only interact with them in this thread._`,
                mentions: [tJid]
            }, buildSafeQuote(m));
        }

        // Sub-command: CHAT (Group Automation)
        if (cmd === 'chat') {
            const state = parts[1]?.toLowerCase();
            if (state === 'off') {
                State.chats.delete(chatId);
                return m.reply("🛑 *Chat Intelligence Deactivated.* AI will no longer auto-reply here.");
            }

            const gemName = parts[1] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.chats.set(chatId, {
                gem: gemContent,
                mood: 'natural',
                formatting: 'whatsapp',
                history: [],
                gemName
            });
            
            return m.reply(`⚔️ *Chat Intelligence Active*\n\n*Persona:* \`${gemName}\`\n*Mode:* Global Response\n\n_AI will now respond to every message in this thread._`);
        }

        // Sub-command: DM (Auto-Pilot)
        if (cmd === 'dm') {
            const state = parts[1]?.toLowerCase();
            if (state === 'on') {
                State.dmActive = true;
                return m.reply("📨 *DM Auto-Pilot:* ✅ ENABLED\n_AI will handle all incoming private messages._");
            }
            if (state === 'off') {
                State.dmActive = false;
                return m.reply("📨 *DM Auto-Pilot:* ❌ DISABLED");
            }
            return m.reply(`📨 *DM Auto-Pilot:* ${State.dmActive ? '✅ ACTIVE' : '❌ INACTIVE'}`);
        }

        // Default: One-shot AI Query
        if (!q) {
            return m.reply(`🧠 *Advanced AI Control Suite*\n\n` +
                `• \`.gai stalk <@user> [gem]\` - Global shadow tracking\n` +
                `• \`.gai target <@user> [gem]\` - Context-aware targeting\n` +
                `• \`.gai chat <gem|off>\` - Toggle group automation\n` +
                `• \`.gai dm <on|off>\` - Private auto-pilot\n` +
                `• \`.gai <question>\` - Direct neural query`);
        }

        // Execute Query
        const { text, err } = await askAI(q);
        const cleaned = text.replace(/\*\*(.*?)\*\*/g, '*$1*').replace(/__(.*?)__/g, '_$1_');
        return sock.sendMessage(chatId, { text: err ? `⚠️ *Neural Link Error:* ${text}` : cleaned }, buildSafeQuote(m));
    });
}

// ==============================================================================
// 12. .gem — PERSONA VAULT (STRENGTH ENHANCEMENT)
// ==============================================================================

if (typeof commandRegister === 'function') {
    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "vault"],
        category: "ai",
        desc: "Store and manage custom AI personalities.",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const q = args.join(' ');
        const parts = q.split(/\s+/);
        const cmd = parts[0]?.toLowerCase();

        if (cmd === 'add' || cmd === 'save') {
            const name = parts[1]?.toLowerCase();
            const prompt = parts.slice(2).join(' ');
            if (!name || !prompt) return m.reply("📝 *Usage:* `.gem add <name> <system_instructions>`");
            
            Gems.save(name, prompt);
            return m.reply(`✅ *Gem Forged:* \`${name}\` has been added to the vault.`);
        }

        if (cmd === 'list') {
            const list = Gems.list();
            if (!list.length) return m.reply("📂 *Vault Empty.* Create your first gem with `.gem add`.");
            return m.reply(`📂 *Persona Vault:*\n\n${list.map(g => `• \`${g}\``).join('\n')}\n\n_Use with .gai chat <name>_`);
        }

        if (cmd === 'show') {
            const name = parts[1]?.toLowerCase();
            const content = Gems.get(name);
            if (!content) return m.reply("❌ Gem not found.");
            return m.reply(`💎 *Gem Details: [${name}]*\n\n${content}`);
        }

        if (cmd === 'del') {
            const name = parts[1]?.toLowerCase();
            if (Gems.del(name)) return m.reply(`🗑️ *Purged:* \`${name}\` removed from vault.`);
            return m.reply("❌ Gem not found.");
        }

        return m.reply(`💎 *Gem Persona Vault*\n\n• \`.gem add <name> <prompt>\` - Create persona\n• \`.gem list\` - View all gems\n• \`.gem show <name>\` - View prompt\n• \`.gem del <name>\` - Remove gem`);
    });
}

// ==============================================================================
// 13. MASTER WATCHER (REFINED FOR STALK/TARGET LOGIC)
// ==============================================================================

const reAttachWatcher = (client) => {
    client.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        
        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;

                const from = msg.key.remoteJid;
                const sender = msg.key.participant || from;
                const isGrp = from.endsWith('@g.us');
                
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                if (!body || body.startsWith('.') || body.startsWith('!')) continue;

                // Use the refined hierarchical resolver
                const session = State.resolveSession(sender, from, isGrp);
                if (!session) continue;

                if (CB.open()) return;

                // Update internal history
                const userTag = sender.split('@')[0];
                const time = new Date().toLocaleTimeString();
                session.history.push(`[${time}] ${userTag}: ${body}`);
                if (session.history.length > 20) session.history.shift();

                // Build prompt and request AI
                const prompt = State.buildPrompt(session, body);
                
                // Simulate human-like response delay
                const delay = Math.min(body.length * 50, 5000);
                await new Promise(r => setTimeout(r, delay));
                
                const { text, err } = await askAI(prompt);
                if (err || !text) continue;

                // Format for WhatsApp
                const formatted = text.replace(/\*\*(.*?)\*\*/g, '*$1*').replace(/__(.*?)__/g, '_$1_');
                
                session.history.push(`[${time}] AI: ${formatted}`);
                
                await client.sendMessage(from, { text: formatted }, { quoted: msg });

            } catch (err) {
                console.error('[AIGems.Watcher.Critical] ', err.message);
            }
        }
    });
};

// Auto-boot sequence
setTimeout(() => {
    const sock = global.conn || global.client;
    if (sock) reAttachWatcher(sock);
}, 15000);

module.exports = {
    Gems,
    State,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB
};
// ==============================================================================
// 14. MARKDOWN HELPER & SANITIZATION UTILITY
// ==============================================================================

/**
 * @constant markdownHelper
 * @description Advanced utility to translate LLM-standard markdown to WhatsApp's 
 *              specialized syntax. Handles nested symbols and LaTeX artifacts.
 */
const markdownHelper = {
    /**
     * Cleans raw AI strings for WhatsApp compatibility.
     * @param {string} text - Raw output from LLM.
     * @returns {string} - WhatsApp-safe formatted string.
     */
    clean(text) {
        if (!text || typeof text !== 'string') return '';

        return text
            // 1. Standardize Bold: Convert **text** to *text*
            .replace(/\*\*(.*?)\*\*/g, '*$1*')
            
            // 2. Standardize Italics: Convert __text__ to _text_
            .replace(/__(.*?)__/g, '_$1_')
            
            // 3. Prevent nested underscore breakage: user_profile -> user\_profile
            // WhatsApp treats underscores as italic markers only if they have whitespace/start/end context
            .replace(/(\w)_(\w)/g, '$1\\_$2')
            
            // 4. Convert Markdown Headers to Bold (WhatsApp doesn't support #)
            .replace(/^#+\s+(.*)$/gm, '*$1*')
            
            // 5. Code Blocks: Ensure triple backticks (```) are used correctly
            .replace(/`([^`\n]+)`/g, '```$1```')
            
            // 6. LaTeX Stripping: QuillBot often leaks \( or \[ notation
            .replace(/\\\(|\\\)/g, '')
            .replace(/\\\[|\\\]/g, '')
            
            // 7. List item cleanup: Ensure single asterisk followed by space
            .replace(/^\s*[-+]\s+/gm, '* ')
            
            // 8. Blockquote Conversion: Use standard WhatsApp quote symbol (>)
            .replace(/^>\s+/gm, '> ')
            
            .trim();
    },

    /**
     * Applies a specific visual style to the entire response.
     */
    applyStyle(text, style = 'natural') {
        const cleaned = this.clean(text);
        switch (style) {
            case 'monospace': return '```' + cleaned + '```';
            case 'bold':      return '*' + cleaned + '*';
            case 'italic':    return '_' + cleaned + '_';
            default:          return cleaned;
        }
    }
};

// ==============================================================================
// 15. ELITE AI ENGINE (QUILLBOT SSE STREAM PARSER)
// ==============================================================================

/**
 * @function askAI
 * @description Enhanced QuillBot Raven-Chat interface with SSE stream parsing.
 *              Forces WhatsApp Markdown in every prompt.
 */
askAI = async (prompt, imgUrls = []) => {
    if (CB.open()) return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: '*Rate Limit:* Neural link saturated. Please wait.', err: true };

    const systemContext = 'SYSTEM: You are an Elite AI Assistant. Use WhatsApp Markdown (*bold*, _italic_, ~strikethrough~, ```code```). Use bullet points for lists. Be concise.\n\n';
    
    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: `${systemContext}${prompt}`,
            files: imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'input.jpg' }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat' },
        tools: []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');
            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout: CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const fullOutput = await new Promise((resolve, reject) => {
                let accumulated = '';
                const timer = setTimeout(() => resolve(accumulated), CFG.TIMEOUT - 5000);
                
                res.data.on('data', chunk => {
                    const lines = chunk.toString().split('\n');
                    for (const line of lines) {
                        const trimmed = line.trim();
                        if (trimmed.startsWith('data: {')) {
                            try {
                                const parsed = JSON.parse(trimmed.replace(/^data:\s*/, ''));
                                if (parsed.chunk) accumulated += parsed.chunk;
                            } catch (e) { /* Ignore partial stream chunks */ }
                        }
                    }
                });

                res.data.on('end', () => { clearTimeout(timer); resolve(accumulated); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            if (!fullOutput.trim()) {
                if (attempt < CFG.RETRIES - 1) continue;
                return { text: '_The engine remained silent._', err: true };
            }

            CB.ok();
            return { text: markdownHelper.clean(fullOutput), err: false };

        } catch (error) {
            CB.fail();
            if (attempt === CFG.RETRIES - 1) return { text: `*Connection Error:* ${error.message}`, err: true };
            await new Promise(r => setTimeout(r, 1000 * (attempt + 1)));
        }
    }
};

// ==============================================================================
// 16. ENHANCED COMMAND: .gai (MULTI-ENGINE AI)
// ==============================================================================

gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'ask', 'brain', 'think'],
    category: 'ai',
    desc: 'Advanced AI assistant with stalking, targeting, and vision capabilities.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, sock, q = '', isSuperUser, react, reply } = conText;
    if (!isSuperUser) return reply('*Refused:* Credentials mismatch.');

    const parts = q.trim().split(/\s+/);
    const sub = parts[0]?.toLowerCase();
    const rest = parts.slice(1);

    // --- Sub-Command: STALK (Global Tracking) ---
    if (sub === 'stalk') {
        const target = (rest[0] || '').replace(/[^0-9]/g, '');
        if (!target) return reply('📝 *Usage:* `.gai stalk <number> [gem_name]`');
        
        const tjid = target + '@s.whatsapp.net';
        const gem = rest[1] || 'default';
        const persona = (gem !== 'default' ? Gems.get(gem) : null) || State.PERSONA;
        
        State.stalkers.set(tjid, {
            gem: persona,
            history: [],
            gemName: gem,
            formatting: 'whatsapp'
        });
        return reply(`🌍 *Global Stalker Activated*\n*User:* @${target}\n*Persona:* \`${gem}\`\n_I will follow this user across all groups._`, { mentions: [tjid] });
    }

    // --- Sub-Command: TARGET (Local Chat Tracking) ---
    if (sub === 'target') {
        const target = (rest[0] || '').replace(/[^0-9]/g, '');
        if (!target) return reply('📝 *Usage:* `.gai target <number> [gem_name]`');
        
        const tjid = target + '@s.whatsapp.net';
        const gem = rest[1] || 'default';
        const persona = (gem !== 'default' ? Gems.get(gem) : null) || State.PERSONA;
        
        State.targets.set(tjid, {
            gem: persona,
            chatId: from,
            history: [],
            gemName: gem,
            formatting: 'whatsapp'
        });
        return reply(`⚔️ *Target Locked*\n*User:* @${target}\n*Chat:* This Chat Only\n*Persona:* \`${gem}\``, { mentions: [tjid] });
    }

    // --- Sub-Command: CHAT (Room AI) ---
    if (sub === 'chat') {
        const gem = rest[0] || 'default';
        const persona = (gem !== 'default' ? Gems.get(gem) : null) || State.PERSONA;
        
        State.chats.set(from, {
            gem: persona,
            history: [],
            gemName: gem,
            formatting: 'whatsapp'
        });
        return reply(`⚔️ *Chat Intelligence Active*\n*Persona:* \`${gem}\`\n_Responding to all input in this thread._`);
    }

    // --- Sub-Command: STOP ---
    if (sub === 'stop') {
        if (rest[0] === 'all') {
            State.stalkers.clear(); State.targets.clear(); State.chats.clear();
            return reply('☢️ *System Purge:* All tracking sessions terminated.');
        }
        State.chats.delete(from);
        return reply('🛑 *Session Stopped:* AI is no longer watching this chat.');
    }

    // --- Sub-Command: DM ---
    if (sub === 'dm') {
        const toggle = rest[0]?.toLowerCase();
        if (toggle === 'on') { State.dmActive = true; return reply('📨 *DM Auto-Pilot:* ✅'); }
        if (toggle === 'off') { State.dmActive = false; return reply('📨 *DM Auto-Pilot:* ❌'); }
        return reply(`📨 *DM Status:* ${State.dmActive ? 'Active' : 'Inactive'}`);
    }

    // --- ONE-SHOT QUESTION MODE ---
    if (!q.trim()) return reply(`🧠 *GAI Command Suite*\n\n• \`.gai <text>\` - Ask anything\n• \`.gai stalk <num> [gem]\` - Global track\n• \`.gai target <num> [gem]\` - Local track\n• \`.gai chat [gem]\` - Group track\n• \`.gai stop [all]\` - Deactivate\n• \`.gai dm <on/off>\` - Private auto-pilot`);

    await react('🧠');
    const stub = await thinking(Gifted, from, m, '🧠 _Accessing neural data..._');
    
    // Handle Vision context if image is quoted
    let imgUrls = [];
    const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quoted?.imageMessage) {
        const buffer = await Gifted.downloadMediaMessage({ message: quoted });
        const tmpPath = `./temp_gai_${Date.now()}.jpg`;
        require('fs').writeFileSync(tmpPath, buffer);
        const url = await uploadImgBB(tmpPath);
        if (url) imgUrls.push(url);
        try { require('fs').unlinkSync(tmpPath); } catch(e){}
    }

    const { text, err } = await askAI(q, imgUrls);
    return editMsg(Gifted, stub, err ? `❌ *AI Error:* ${text}` : text);
});

