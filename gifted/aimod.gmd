// ==============================================================================
// 5. SQLITE DATABASE (Gem storage)
// ==============================================================================
const DB_PATH = path.join(__dirname, '..', 'gift', 'database', 'aigems.db');

let _db = null;
const getDB = () => {
    if (_db) return _db;
    if (!Database) throw new Error('better-sqlite3 not available');
    _db = new Database(DB_PATH);
    _db.exec(`
        CREATE TABLE IF NOT EXISTS gems (
            name    TEXT PRIMARY KEY,
            content TEXT NOT NULL,
            created INTEGER DEFAULT (strftime('%s','now'))
        );
        CREATE TABLE IF NOT EXISTS pfp_history (
            id        INTEGER PRIMARY KEY AUTOINCREMENT,
            filepath  TEXT,
            prompt    TEXT,
            ts        INTEGER DEFAULT (strftime('%s','now'))
        );
        CREATE TABLE IF NOT EXISTS profile_log (
            id      INTEGER PRIMARY KEY AUTOINCREMENT,
            type    TEXT,
            content TEXT,
            ts      INTEGER DEFAULT (strftime('%s','now'))
        );
    `);
    return _db;
};

const DB = {
    gemSave:   (name, content)    => getDB().prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(name.toLowerCase(), content),
    gemGet:    (name)             => getDB().prepare('SELECT content FROM gems WHERE name=?').get(name.toLowerCase())?.content || null,
    gemDel:    (name)             => getDB().prepare('DELETE FROM gems WHERE name=?').run(name.toLowerCase()).changes > 0,
    gemList:   ()                 => getDB().prepare('SELECT name FROM gems ORDER BY name').all().map(r => r.name),
    logProfile:(type,content)    => getDB().prepare('INSERT INTO profile_log(type,content) VALUES(?,?)').run(type, content),
    profileHistory:(type,limit)  => getDB().prepare('SELECT content FROM profile_log WHERE type=? ORDER BY ts DESC LIMIT ?').all(type, limit).map(r=>r.content),
    savePfp:   (fp, prompt)      => getDB().prepare('INSERT INTO pfp_history(filepath,prompt) VALUES(?,?)').run(fp, prompt),
    pfpHistory:(limit)           => getDB().prepare('SELECT filepath,prompt,ts FROM pfp_history ORDER BY ts DESC LIMIT ?').all(limit)
};

