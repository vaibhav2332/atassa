/**
 * Periodic clean-up of old sessions and temporary caches.
 * Runs every 30 minutes.
 */
setInterval(() => {
    const now = Date.now();
    const expiry = 3600000 * 2; // 2 hours of inactivity

    // Clean ephemeral DM sessions
    State.dmSessions.forEach((sess, jid) => {
        if (sess.lastActive && (now - sess.lastActive > expiry)) {
            State.dmSessions.delete(jid);
        }
    });

    // Clean image cache
    _iCache.forEach((data, key) => {
        if (now - data.ts > 3600000) {
            _iCache.delete(key);
        }
    });

    // Check circuit breaker recovery
    if (CB.fails > 0 && (now - CB.lastFail > CB.TTL)) {
        CB.reset();
        console.log('[AIGems] Circuit breaker automatically reset.');
    }
}, 1800000);

/**
 * Handle process termination gracefully.
 */
process.on('SIGINT', () => {
    console.log('[AIGems] Shutting down AI module...');
    if (db) db.close();
    process.exit(0);
});

