gmd({
    pattern:'aitranslate', cmdname:'aitranslate', aliases:['aitrans'], category:'ai', desc:'AI translation.', react:'🌐', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
