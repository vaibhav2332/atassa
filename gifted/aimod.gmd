gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['write', 'compose', 'draft'],
    category: 'ai',
    desc: 'Generate creative content in various modes.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *ACCESS DENIED*');

    const args = q.trim().split(/\s+/);
    const mode = args[0]?.toLowerCase();
    const topic = args.slice(1).join(' ');

    if (!mode || !WRITING_MODES[mode]) {
        const modesList = Object.keys(WRITING_MODES).map(m => `• \`${m}\``).join('\n');
        return reply(
            `✍️ *AI WRITER ENGINE*\n\n` +
            `📝 *Usage:* \`.aiwrite <mode> <topic>\`\n\n` +
            `*Available Modes:*\n${modesList}\n\n` +
            `💡 *Example:* \`.aiwrite roast my friend who sleeps in class\``
        );
    }

    if (!topic) return reply(`📝 *Please provide a topic or context for the ${mode} mode.*`);

    const stub = await thinking(Gifted, from, mek, `${WRITING_MODES[mode].emoji} _Generating ${mode}..._`);

    const writingPrompt = `
        MODE: ${mode.toUpperCase()}
        INSTRUCTIONS: ${WRITING_MODES[mode].prompt(topic)}
        FORMATTING RULES:
        - Use ONLY WhatsApp Markdown (*bold*, _italic_, ~strike~, \`code\`, \`\`\`block\`\`\`).
        - NO Markdown headers (no # or ##). Use *BOLD CAPS* for headers.
        - Ensure the output is natural for a WhatsApp chat.
    `.trim();

    const { text, err } = await askAI(writingPrompt);

    if (err) {
        return editMsg(Gifted, stub, `❌ *WRITER ERROR:* ${text}`);
    }

    const finalOutput = `${WRITING_MODES[mode].emoji} *AI ${mode.toUpperCase()}*\n\n${text}`;
    return editMsg(Gifted, stub, finalOutput);
});

// ==============================================================================
// 3. ROBUSTNESS PATCH: STALK LOGIC SYNC
// ==============================================================================

/**
 * Ensures the event watcher correctly identifies stalking targets across
 * various message types and applies the formatted AI response logic.
 */
const syncStalkWatcher = (Gifted) => {
    // This logic enhances the existing watcher in section 18 of reference.
    // It is designed to be injected or used as a logic-check for stalker persistence.
    if (!global.StalkManager) {
        global.StalkManager = {
            add: (num, gem) => {
                const jid = num.includes('@') ? num : num.replace(/[^0-9]/g, '') + '@s.whatsapp.net';
                const gemTxt = Gems.get(gem) || State.PERSONA;
                State.stalkers.set(jid, { gem: gemTxt, history: [], gemName: gem, startTime: Date.now() });
                return { success: true, jid };
            },
            remove: (num) => {
                const jid = num.includes('@') ? num : num.replace(/[^0-9]/g, '') + '@s.whatsapp.net';
                if (State.stalkers.has(jid)) {
                    State.stalkers.delete(jid);
                    return { success: true, jid };
                }
                return { success: false, message: 'Target not found in active stalk list.' };
            }
        };
    }
};

syncStalkWatcher(global.conn || global.client);

/**
