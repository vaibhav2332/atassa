    if (!lang || !text) return reply('📝 \`.aitranslate <lang> <text>\`');
    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${lang}..._`);
    const { text: out, err } = await askAI(`Translate to ${lang}. Return ONLY translated text:\n\n${text}`);
    return editMsg(Gifted, stub, err ? `❌ ${out}` : `🌐 *Translation (${lang})*\n\n${out}`);
