// 12.  .img  — IMAGE GENERATION STUDIO
// ==============================================================================
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'art'],
    category: 'ai',
    desc: 'Advanced AI Image Studio. .img help',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/), cmd = parts[0]?.toLowerCase() || '', rest = parts.slice(1).join(' ');

    if (cmd === 'models') {
        const lines = Object.entries(CFG.IMG_MDLS).map(([id, m]) => `${m.tier === 'pro' ? '👑' : '🆓'} \`${id}\` — ${m.desc}`).join('\n');
        return reply(`📋 *AVAILABLE MODELS*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\``);
    }

    if (cmd === 'config') {
        if (!parts[1]) return reply(`⚙️ *Current:* \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\` | Count: ${CFG.IMG_COUNT}\n📝 \`.img config <model> [size] [n]\``);
        if (!CFG.IMG_MDLS[parts[1]]) return reply('❌ Unknown model. Run `.img models`');
        CFG.IMG_MODEL = parts[1];
        if (parts[2]) CFG.IMG_SIZE = parts[2];
        if (parts[3]) CFG.IMG_COUNT = Math.min(parseInt(parts[3]) || 1, 4);
        return reply(`✅ *Config Updated:* \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\``);
    }

    if (cmd === 'surprise') {
        const stub = await thinking(Gifted, from, mek, '🎲 _Dreaming..._');
        const { text: dream, err } = await askAI(`Generate a vivid, detailed creative image prompt about: ${rest || 'anything bizarre'}. Return ONLY the prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ ${dream}`);
        await editMsg(Gifted, stub, `🔮 _Visualizing:_ "${dream.slice(0, 80)}..."`);
        const urls = await generateImage(dream);
        if (!urls.length) return editMsg(Gifted, stub, '❌ Generation failed.');
        await del(Gifted, stub.key);
        return sendImg(Gifted, from, urls[0], `🎲 *Surprise Generation*\n\n*Prompt:* _${dream.slice(0, 200)}_`, mek);
    }

    if (cmd === 'setup') {
        _iOk = false; const ok = await ensureInfip();
        return reply(ok ? '✅ *Infip API Ready*' : '❌ *Infip Setup Failed* — check key pool');
    }

    if (!q.trim() || cmd === 'help') {
        return reply(`🎨 *IMAGE STUDIO*\n\n• \`.img <prompt>\` — Generate image\n• \`.img models\` — List engines\n• \`.img config <model> [size]\` — Change settings\n• \`.img surprise [topic]\` — AI prompt design\n• \`.img setup\` — Validate keys`);
    }

    const prompt = (cmd === 'gen') ? rest : q;
    await react('🎨');
    const stub = await thinking(Gifted, from, mek, '🎨 _Generating…_');
    const urls = await generateImage(prompt);
    if (!urls.length) return editMsg(Gifted, stub, '❌ *Failed.* Check `.img setup`.');
    await del(Gifted, stub.key);
    await sendImg(Gifted, from, urls[0], `🎨 _${prompt.slice(0, 150)}_\n🤖 \`${CFG.IMG_MODEL}\``, mek);
    for (const u of urls.slice(1)) await sendImg(Gifted, from, u, '🎨 _Variation_', mek);
});

