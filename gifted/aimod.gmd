// ─── RATE LIMITER ─────────────────────────────────────────────────────────────
const RATE = {
    minuteReqs : [],
    hourReqs   : [],
    dailyStats : { ai:0, img:0, err:0, date: new Date().toDateString() },

    check() {
        this._resetDaily();
        const now = Date.now();
        this.minuteReqs = this.minuteReqs.filter(t => now - t < 60000);
        this.hourReqs   = this.hourReqs.filter(t => now - t < 3600000);
        return this.minuteReqs.length < CFG.MAX_RPM && this.hourReqs.length < CFG.MAX_RPH;
    },
    record(type = 'ai') {
        this._resetDaily();
        const now = Date.now();
        this.minuteReqs.push(now);
        this.hourReqs.push(now);
        if (type === 'ai')  this.dailyStats.ai++;
        if (type === 'img') this.dailyStats.img++;
    },
    recordErr() { this._resetDaily(); this.dailyStats.err++; },
    _resetDaily() {
        const today = new Date().toDateString();
        if (this.dailyStats.date !== today)
            this.dailyStats = { ai:0, img:0, err:0, date: today };
    },
    stats() {
        const now = Date.now();
        return {
            rpm  : this.minuteReqs.filter(t => now-t<60000).length,
            rph  : this.hourReqs.filter(t => now-t<3600000).length,
            daily: { ...this.dailyStats },
        };
    },
};

// ─── CIRCUIT BREAKER ──────────────────────────────────────────────────────────
const CIRCUIT = {
    errors    : 0,
    lastErr   : 0,
    threshold : 5,
    timeout   : 300000,   // 5 min
    fallbacks : [
        "Having a quick nap 😴 try me in a sec.",
        "Neural link glitched — gimme a moment 🔧",
        "Cosmic interference detected. Standby ⚡",
    ],
    isOpen() {
        if (this.errors >= this.threshold) {
            if (Date.now() - this.lastErr < this.timeout) return true;
            this.reset();
        }
        return false;
    },
    trip()  { this.errors++; this.lastErr = Date.now(); },
    reset() { this.errors = 0; },
    fallback() { return this.fallbacks[Math.floor(Math.random() * this.fallbacks.length)]; },
};

// ─── QUILLBOT AI CLIENT (exact same endpoint as Python) ───────────────────────
const QB_URL = 'https://quillbot.com/api/raven/quill-chat/responses';

async function qbRequest(prompt, imageUrls = []) {
    if (!RATE.check())    return '⚠️ Rate limit reached. Please slow down.';
    if (CIRCUIT.isOpen()) return CIRCUIT.fallback();

    const cookieStr = Object.entries(CFG.QB_COOKIES).map(([k,v]) => `${k}=${v}`).join('; ');
    const headers   = { ...CFG.QB_HEADERS, Cookie: cookieStr };

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: prompt,
            files  : imageUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' })),
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : [],
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            RATE.record('ai');
            const res = await axios.post(QB_URL, payload, {
                headers,
                timeout      : CFG.TIMEOUT,
                responseType : 'stream',
            });

            let full = '';
            await new Promise((resolve, reject) => {
                res.data.on('data', chunk => {
                    const lines = chunk.toString().split('\n');
                    for (const line of lines) {
                        if (line.startsWith('data: {') && line.includes('"chunk":"')) {
                            try {
                                const obj = JSON.parse(line.slice(6));
                                full += obj.chunk || '';
                            } catch (_) {}
                        }
                    }
                });
                res.data.on('end',   resolve);
                res.data.on('error', reject);
            });

            if (!full.trim()) { CIRCUIT.trip(); return '⚠️ Empty response from AI.'; }
            CIRCUIT.reset();
            return cleanText(full);

        } catch (e) {
            CIRCUIT.trip();
            RATE.recordErr();
            if (attempt < CFG.RETRIES - 1) await sleep(1000 * (2 ** attempt));
        }
    }
    return CIRCUIT.fallback();
}

function cleanText(t) {
    if (!t) return '';
    return t
        .replace(/\\\(|\\\)/g, '')
        .replace(/\\\[|\\\]/g, '')
        .replace(/\\([a-zA-Z])/g, '$1')
        .trim();
}

// ─── INFIP IMAGE GENERATOR ────────────────────────────────────────────────────
let _infipValidated = false;

async function infipSetup() {
    if (_infipValidated) return true;
    try {
        const res = await axios.get(`${CFG.INFIP_BASE}/v1/models`, {
            headers: { Authorization: `Bearer ${CFG.INFIP_KEY}` },
            timeout: 20000,
        });
        _infipValidated = res.status === 200;
        return _infipValidated;
    } catch (_) {
        // Try generating new key
        try {
            const r2 = await axios.post(`${CFG.INFIP_BASE}/v1/api-keys`, {}, { timeout: 20000 });
            if (r2.data?.api_key) { CFG.INFIP_KEY = r2.data.api_key; _infipValidated = true; }
        } catch (__) {}
        return _infipValidated;
    }
}

async function generateImages(prompt, opts = {}) {
    await infipSetup();
    if (!RATE.check()) return [];

    const { model, size, count, quality, style } = {
        model  : opts.model   || STATE.imgConfig.model,
        size   : opts.size    || STATE.imgConfig.size,
        count  : opts.count   || STATE.imgConfig.count,
        quality: opts.quality || STATE.imgConfig.quality,
        style  : opts.style   || STATE.imgConfig.style,
    };

    const models = [model, 'flux-schnell', 'sdxl', 'phoenix'];

    for (const m of models) {
        try {
            RATE.record('img');
            const res = await axios.post(
                `${CFG.INFIP_BASE}/v1/images/generations`,
                { model:m, prompt, n:Math.min(count,4), size, response_format:'url', quality, style },
                { headers:{ Authorization:`Bearer ${CFG.INFIP_KEY}`, 'Content-Type':'application/json' }, timeout: CFG.TIMEOUT }
            );
            if (res.status === 200 && res.data?.data?.length) {
                return res.data.data.map(d => d.url);
            }
        } catch (e) {
            RATE.recordErr();
        }
    }
    return [];
}

async function enhancePrompt(prompt) {
    const r = await qbRequest(
        `Enhance this image generation prompt to be more detailed and vivid. Return ONLY the enhanced prompt.\n\nOriginal: ${prompt}`
    );
    return (!r || r.startsWith('⚠️')) ? prompt : r.trim();
}

// ─── IMGBB UPLOADER ───────────────────────────────────────────────────────────
async function uploadToImgBBLocal(filePath) {
    if (!fs.existsSync(filePath)) return null;
    try {
        const form = new (require('form-data'))();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url || null;
    } catch (e) { return null; }
}

// ─── GEM MANAGER ─────────────────────────────────────────────────────────────
const GEM = {
    DEFAULT_PERSONA:
        'You are a witty, slightly sarcastic but helpful human chatting on WhatsApp. '
        + 'Keep replies short, casual, and natural. Recall the Chat History provided.',

    save(name, content) {
        getDb().prepare('INSERT OR REPLACE INTO gems (name,content) VALUES (?,?)').run(name.toLowerCase().trim(), content.trim());
    },
    get(name) {
        const row = getDb().prepare('SELECT content FROM gems WHERE name=?').get(name.toLowerCase().trim());
        return row?.content || null;
    },
    delete(name) {
        const info = getDb().prepare('DELETE FROM gems WHERE name=?').run(name.toLowerCase().trim());
        return info.changes > 0;
    },
    list() {
        return getDb().prepare('SELECT name FROM gems ORDER BY name').all().map(r => r.name);
    },
};

// ─── HISTORY MANAGER ──────────────────────────────────────────────────────────
const HIST = {
    push(ctxId, role, content) {
        const db = getDb();
        db.prepare('INSERT INTO chat_history (ctx_id,role,content) VALUES (?,?,?)').run(ctxId, role, content);
        // Prune to MAX_HIST
        db.prepare(
            'DELETE FROM chat_history WHERE ctx_id=? AND id NOT IN (SELECT id FROM chat_history WHERE ctx_id=? ORDER BY id DESC LIMIT ?)'
        ).run(ctxId, ctxId, CFG.MAX_HIST);
    },
    get(ctxId) {
        return getDb().prepare('SELECT role,content FROM chat_history WHERE ctx_id=? ORDER BY id ASC').all(ctxId);
    },
    clear(ctxId) {
        getDb().prepare('DELETE FROM chat_history WHERE ctx_id=?').run(ctxId);
    },
    buildPrompt(gem, ctxId, input) {
        const hist = HIST.get(ctxId)
            .map(r => `[${r.role === 'User' ? 'User' : 'AI'}]: ${r.content}`)
            .join('\n');
        return `SYSTEM:\n${gem}\n\n--- CONVERSATION MEMORY ---\n${hist}\n---------------------------\nLATEST: ${input}\nYOUR REPLY:`;
    },
};

// ─── NATURAL LANGUAGE INTENT DETECTOR ─────────────────────────────────────────
const INTENTS = [
    'play_music','play_video','weather','google_search','lyrics',
    'sticker_search','translate','ping','screenshot','qr_code',
    'download_file','group_info','kick_user','promote_user','demote_user',
    'mute_group','unmute_group','bot_settings','get_pfp','send_sticker',
    'tts_voice','summary','define_word','npm_search','general_chat',
];

async function detectIntent(query) {
    const prompt =
        `You are a WhatsApp bot command interpreter. Analyse the request and return ONLY valid JSON (no markdown):\n`
        + `{"intent":"${INTENTS.join('|')}","query":"extracted query or null","confidence":0.0}\n\n`
        + `Request: "${query}"`;
    try {
        const raw = await qbRequest(prompt);
        return JSON.parse(raw.replace(/```json|```/g, '').trim());
    } catch (_) {
        return { intent: 'general_chat', query, confidence: 0.5 };
    }
}

// ─── INTENT EXECUTORS ─────────────────────────────────────────────────────────
const EXEC = {

    async play_music(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey, gmdBuffer: gBuf, formatAudio: fAu, mek } = conText;
        const results = await yts(query).catch(() => null);
        if (!results?.videos?.length) return '❌ No song found for that query.';
        const v = results.videos[0];
        await editOrReply(Gifted, from, mek, `🎶 Found: *${v.title}*\n⬇️ Downloading...`);
        const endpoints = ['ytmp3v2','ytaudio','ytmp3','savetubemp3'];
        let buf;
        for (const ep of endpoints) {
            try {
                const r = await axios.get(`${GiftedTechApi}/api/download/${ep}?apikey=${GiftedApiKey}&url=${encodeURIComponent(v.url)}`, { timeout: 25000 });
                if (r.data?.success && r.data?.result?.download_url) {
                    buf = await gBuf(r.data.result.download_url);
                    if (buf?.length > 10240) break;
                }
            } catch (_) {}
        }
        if (!buf || buf.length < 10240) return '❌ Download failed. Try `.play` command directly.';
        const audio = await fAu(buf);
        await Gifted.sendMessage(from, { audio, mimetype:'audio/mpeg' }, { quoted: mek });
        return null;
    },

    async play_video(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey, gmdBuffer: gBuf, mek } = conText;
        const results = await yts(query).catch(() => null);
        if (!results?.videos?.length) return '❌ No video found.';
        const v = results.videos[0];
        await editOrReply(Gifted, from, mek, `🎥 Found: *${v.title}*\n⬇️ Downloading...`);
        const endpoints = ['ytmp4v2','ytvideo','ytmp4','savetubemp4'];
        let dlUrl;
        for (const ep of endpoints) {
            try {
                const r = await axios.get(`${GiftedTechApi}/api/download/${ep}?apikey=${GiftedApiKey}&url=${encodeURIComponent(v.url)}`, { timeout: 25000 });
                if (r.data?.success && r.data?.result?.download_url) { dlUrl = r.data.result.download_url; break; }
            } catch (_) {}
        }
        if (!dlUrl) return '❌ Video download failed.';
        await Gifted.sendMessage(from, { document:{ url:dlUrl }, fileName:`${v.title.replace(/[^\w]/g,'_')}.mp4`, mimetype:'video/mp4' }, { quoted:mek });
        return null;
    },

    async weather(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/search/weather?apikey=${GiftedApiKey}&location=${encodeURIComponent(query)}`, { timeout:20000 });
            if (!r.data?.success || !r.data?.result) return '❌ Could not fetch weather.';
            const w = r.data.result;
            const icons = { Clear:'☀️', Clouds:'☁️', Rain:'🌧️', Snow:'❄️', Thunderstorm:'⛈️', Mist:'🌫️', Haze:'🌫️' };
            return `${icons[w.weather?.main]||'🌡️'} *${w.location}* ${w.sys?.country||''}\n\n🌡️ Temp: *${w.main?.temp}°C* (feels ${w.main?.feels_like}°C)\n💧 Humidity: ${w.main?.humidity}%\n🌬️ Wind: ${w.wind?.speed} m/s\n☁️ ${w.weather?.description}`;
        } catch (_) { return '❌ Weather fetch failed.'; }
    },

    async lyrics(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/search/lyricsv2?apikey=${GiftedApiKey}&query=${encodeURIComponent(query)}`, { timeout:20000 });
            if (!r.data?.success || !r.data?.result) return '❌ Lyrics not found.';
            const { title, artist, lyrics } = r.data.result;
            return `🎵 *${title}* — ${artist}\n\n${lyrics?.slice(0,1500)}${lyrics?.length>1500?'\n..._(truncated)_':''}`;
        } catch (_) { return '❌ Lyrics fetch failed.'; }
    },

    async google_search(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/search/google?apikey=${GiftedApiKey}&query=${encodeURIComponent(query)}`, { timeout:20000 });
            if (!r.data?.success || !r.data?.results?.length) return '❌ No results found.';
            return r.data.results.slice(0,5).map((x,i) => `*${i+1}. ${x.title}*\n${x.description?.slice(0,80)}\n${x.link}`).join('\n\n');
        } catch (_) { return '❌ Search failed.'; }
    },

    async define_word(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/tools/define?apikey=${GiftedApiKey}&term=${encodeURIComponent(query)}`, { timeout:20000 });
            if (!r.data?.success || !r.data?.results?.length) return `❌ No definition found for "${query}".`;
            return r.data.results.slice(0,3).map((d,i) =>
                `*${i+1}. ${d.word}*\n📝 ${d.definition?.replace(/\[([^\]]+)\]/g,'$1')}\n💬 _"${d.example?.replace(/\[([^\]]+)\]/g,'$1')||'N/A'}"_`
            ).join('\n\n');
        } catch (_) { return '❌ Definition fetch failed.'; }
    },

    async translate(query, from, Gifted, conText) {
        const parts  = query.split(' to ');
        const text   = parts[0]?.trim();
        const target = parts[1]?.trim() || 'en';
        const r = await qbRequest(`Translate the following text to ${target}. Return ONLY the translation, no explanation.\n\nText: ${text}`);
        return (!r || r.startsWith('⚠️')) ? '❌ Translation failed.' : `🌐 *Translation (→ ${target}):*\n\n${r}`;
    },

    async screenshot(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey, mek } = conText;
        const url = query.startsWith('http') ? query : `https://${query}`;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/tools/ssweb?apikey=${GiftedApiKey}&url=${encodeURIComponent(url)}`, { timeout:30000, responseType:'arraybuffer' });
            await Gifted.sendMessage(from, { image:Buffer.from(r.data), caption:`📸 Screenshot of ${url}` }, { quoted:mek });
            return null;
        } catch (_) { return '❌ Screenshot failed.'; }
    },

    async qr_code(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey, mek } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/tools/createqr?apikey=${GiftedApiKey}&query=${encodeURIComponent(query)}`, { timeout:20000, responseType:'arraybuffer' });
            await Gifted.sendMessage(from, { image:Buffer.from(r.data), caption:`📱 QR Code for: ${query}` }, { quoted:mek });
            return null;
        } catch (_) { return '❌ QR generation failed.'; }
    },

    async tts_voice(query, from, Gifted, conText) {
        const { mek } = conText;
        const r = await qbRequest(`Write the phonetic pronunciation guide for: "${query}". Just the text we'd need to speak aloud.`);
        if (!r || r.startsWith('⚠️')) return '❌ TTS not available right now.';
        // Fallback: just reply with the text representation
        return `🔊 *TTS Text:* ${r}\n\n_(Audio TTS via native .toptt command)_`;
    },

    async npm_search(query, from, Gifted, conText) {
        const { GiftedTechApi, GiftedApiKey } = conText;
        try {
            const r = await axios.get(`${GiftedTechApi}/api/search/npmsearch?apikey=${GiftedApiKey}&packagename=${encodeURIComponent(query)}`, { timeout:20000 });
            if (!r.data?.success || !r.data?.result) return `❌ Package "${query}" not found.`;
            const p = r.data.result;
            return `📦 *${p.name}*\n${p.description||'No description'}\n\n🏷️ v${p.version} | 📜 ${p.license||'N/A'}\n🔗 ${p.packageLink}`;
        } catch (_) { return '❌ NPM search failed.'; }
    },

    async ping(query, from, Gifted, conText) {
        const start = Date.now();
        await Gifted.sendMessage(from, { text:'🏓' }, { quoted: conText.mek });
        return `⚡ Pong: *${Date.now()-start}ms*`;
    },

    async group_info(query, from, Gifted, conText) {
        const { isGroup, groupName, participants, groupAdmins } = conText;
        if (!isGroup) return '❌ Not in a group.';
        return `📋 *Group Info*\n\n👥 Name: *${groupName}*\n👤 Members: ${participants?.length||0}\n👑 Admins: ${groupAdmins?.length||0}`;
    },

    // Stub executors for moderation (safety checks happen at the real command level)
    async kick_user     (q,f,G,c) { return `ℹ️ Use the dedicated *.kick* command with @mention or number.`; },
    async promote_user  (q,f,G,c) { return `ℹ️ Use *.promote @user* to promote someone.`; },
    async demote_user   (q,f,G,c) { return `ℹ️ Use *.demote @user* to demote someone.`; },
    async mute_group    (q,f,G,c) { return `ℹ️ Use *.mute* to mute this group.`; },
    async unmute_group  (q,f,G,c) { return `ℹ️ Use *.unmute* to unmute this group.`; },
    async bot_settings  (q,f,G,c) { return `ℹ️ Use *.settings* to view/change bot settings.`; },
    async get_pfp       (q,f,G,c) { return `ℹ️ Use *.getpp* and reply to a user.`; },

    async summary(query, from, Gifted, conText) {
        return `ℹ️ Use *.gai summary ${query||50}* for chat summary.`;
    },
};

// ─── AUTO-REPLY ENGINE ────────────────────────────────────────────────────────
async function processAutoReply(userId, chatId, msgText, hasPhoto, photoPath, Gifted, m) {
    let data      = null;
    let ctxSource = '';

    if (STATE.globalStalks.has(userId))           { data = STATE.globalStalks.get(userId); ctxSource='global'; }
    else if (STATE.targets.has(userId))            { data = STATE.targets.get(userId);      ctxSource='target'; }
    else if (STATE.activeChats.has(chatId))        { data = STATE.activeChats.get(chatId);  ctxSource='chat';   }
    else if (STATE.dmMode && !chatId.endsWith('@g.us')) {
        const gem = STATE.dmGem || GEM.DEFAULT_PERSONA;
        data = { gem, ctxId: chatId };
        STATE.activeChats.set(chatId, data);
        ctxSource = 'dm';
    }

    if (!data) return;

    const ctxId = data.ctxId || `${ctxSource}_${chatId}_${userId}`;
    data.ctxId  = ctxId;

    // Reading delay (human mimicry)
    await sleep(600 + Math.random() * 1800);
    try { await Gifted.readMessages([m.key]); } catch (_) {}

    // Image handling
    let imgUrls = [];
    if (hasPhoto && photoPath) {
        await sleep(1500 + Math.random() * 1500); // "staring at image"
        const url = await uploadToImgBBLocal(photoPath).catch(() => null);
        if (url) imgUrls.push(url);
        try { await fsp.unlink(photoPath); } catch (_) {}
    }

    // Build prompt
    HIST.push(ctxId, 'User', msgText || '[Photo]');
    const prompt = HIST.buildPrompt(data.gem || GEM.DEFAULT_PERSONA, ctxId, msgText || '[User sent a photo]');

    // Typing delay
    const typingLen = Math.min(100 + Math.random() * 200, 600);
    try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}
    await sleep(typingLen);

    const response = await qbRequest(prompt, imgUrls);
    HIST.push(ctxId, 'AI', response);

    try { await Gifted.sendPresenceUpdate('available', chatId); } catch (_) {}

    // Send
    await sendSafe(Gifted, chatId, response, m);
}

// ─── HELPERS ──────────────────────────────────────────────────────────────────
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

async function editOrReply(Gifted, chatId, mek, text) {
    try {
        await Gifted.sendMessage(chatId, { text, edit: mek.key });
    } catch (_) {
        try { await Gifted.sendMessage(chatId, { text }, { quoted: mek }); } catch (__) {}
    }
}

async function sendSafe(Gifted, chatId, text, quoted = null) {
    const opts = quoted ? { quoted } : {};
    try {
        await Gifted.sendMessage(chatId, { text }, opts);
    } catch (_) {
        try { await Gifted.sendMessage(chatId, { text: text.replace(/\*|_|~|`/g, ''), parse_mode:'plaintext' }, opts); } catch (__) {}
    }
}

// ─── GLOBAL WATCHER (catches all incoming messages for auto-reply) ─────────────
gmd(
    {
        pattern: 'gai_watcher_internal__',
        on: 'body',
        category: 'ai',
        dontAddCommandList: true,
        desc: 'Internal AI auto-reply watcher',
    },
    async (from, Gifted, conText) => {
        const { sender, body, isGroup, mek, quoted } = conText;
        if (!sender) return;
        const chatId = from;
        const userId = sender.split('@')[0];
        const numId  = parseInt(userId);

        // Skip commands
        const prefix = conText.botPrefix || '.';
        if (body?.startsWith(prefix)) return;

        const inGlobal = STATE.globalStalks.has(numId) || STATE.globalStalks.has(userId);
        const inTarget = STATE.targets.has(numId)      || STATE.targets.has(userId);
        const inChat   = STATE.activeChats.has(chatId);
        const inDM     = STATE.dmMode && !chatId.endsWith('@g.us');

        if (!inGlobal && !inTarget && !inChat && !inDM) return;

        // If global stalk or target, normalise key
        const dataKey = inGlobal ? (STATE.globalStalks.get(numId) ? numId : userId)
                      : inTarget ? (STATE.targets.get(numId)      ? numId : userId)
                      : chatId;

        let photoPath = null;
        if (mek?.message?.imageMessage) {
            try { photoPath = await Gifted.downloadAndSaveMediaMessage(mek.message.imageMessage, 'temp_ai_img'); } catch (_) {}
        }

        await processAutoReply(
            inGlobal || inTarget ? dataKey : userId,
            chatId,
            body || mek?.message?.imageMessage?.caption || '',
            !!photoPath,
            photoPath,
            Gifted,
            mek
        );
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .gai — MAIN AI COMMAND
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'gai',
        aliases : ['ai2','gem_ai','smartai'],
        category: 'ai',
        react   : '🧠',
        desc    : 'Natural language AI — ask anything or control the bot',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const {
            q, mek, sender, pushName, isGroup,
            groupAdmins, participants, groupName,
            isSuperUser, isAdmin, isBotAdmin,
            GiftedTechApi, GiftedApiKey,
        } = conText;

        const args   = (q || '').trim().split(/\s+/);
        const cmd    = args[0]?.toLowerCase();
        const rest   = args.slice(1).join(' ');
        const chatId = from;

        // ── Shortcuts ──────────────────────────────────────────────────────────
        if (cmd === 'dm') {
            const s = args[1]?.toLowerCase();
            if (s === 'on')       STATE.dmMode = true;
            else if (s === 'off') STATE.dmMode = false;
            return editOrReply(Gifted, chatId, mek,
                `📨 *DM Auto-Pilot:* ${STATE.dmMode ? '✅ ON' : '❌ OFF'}`);
        }

        if (cmd === 'chat') {
            const gemName = args[1] || 'default';
            const gem     = GEM.get(gemName) || GEM.DEFAULT_PERSONA;
            STATE.activeChats.set(chatId, { gem, ctxId: `chat_${chatId}` });
            return editOrReply(Gifted, chatId, mek,
                `⚔️ *Chat Agent Active*\nGem: *${gemName}*\nReplying to everyone here.`);
        }

        if (cmd === 'bot') {
            if (!args[1]) return editOrReply(Gifted, chatId, mek, 'Usage: `.gai bot @user [gem]`');
            const targetUser = await Gifted.onWhatsApp(args[1].replace('@','').replace(/\D/g,'')).catch(() => null);
            const uid        = targetUser?.[0]?.jid?.split('@')[0] || args[1].replace(/\D/g,'');
            const gemName    = args[2] || 'default';
            const gem        = GEM.get(gemName) || GEM.DEFAULT_PERSONA;
            STATE.targets.set(parseInt(uid) || uid, { gem, ctxId:`target_${uid}` });
            return editOrReply(Gifted, chatId, mek, `🤖 *Target Locked*\nUID: ${uid} | Gem: *${gemName}*`);
        }

        if (cmd === 'stalk') {
            if (!args[1]) return editOrReply(Gifted, chatId, mek, 'Usage: `.gai stalk @user [gem]`');
            const uid     = args[1].replace(/\D/g,'');
            const gemName = args[2] || 'default';
            const gem     = GEM.get(gemName) || GEM.DEFAULT_PERSONA;
            STATE.globalStalks.set(parseInt(uid)||uid, { gem, ctxId:`stalk_${uid}` });
            return editOrReply(Gifted, chatId, mek,
                `🌍 *Global Stalker Active*\nUID: ${uid} | Gem: *${gemName}*\nReplying everywhere I see them.`);
        }

        if (cmd === 'stop') {
            if (args[1] === 'all') {
                STATE.dmMode = false;
                STATE.activeChats.clear();
                STATE.targets.clear();
                STATE.globalStalks.clear();
                return editOrReply(Gifted, chatId, mek,
                    `☢️ *KILL SWITCH ACTIVATED*\n\nAll AI systems shut down:\n• DM Mode: OFF\n• Active Chats: 0\n• Targets: 0\n• Stalkers: 0`);
            }
            STATE.activeChats.delete(chatId);
            return editOrReply(Gifted, chatId, mek, `🛑 AI stopped in this chat.`);
        }

        if (cmd === 'wipe') {
            HIST.clear(`chat_${chatId}`);
            return editOrReply(Gifted, chatId, mek, `🧹 Conversation memory wiped.`);
        }

        if (cmd === 'status') {
            const s = RATE.stats();
            return editOrReply(Gifted, chatId, mek,
                `📊 *AI System Status*\n\n`
                + `📨 DM Mode: ${STATE.dmMode?'✅':'❌'}\n`
                + `⚔️ Active Chats: ${STATE.activeChats.size}\n`
                + `🤖 Local Targets: ${STATE.targets.size}\n`
                + `🌍 Global Stalkers: ${STATE.globalStalks.size}\n\n`
                + `📈 RPM: ${s.rpm}/${CFG.MAX_RPM} | RPH: ${s.rph}/${CFG.MAX_RPH}\n`
                + `📅 Daily AI: ${s.daily.ai} | Imgs: ${s.daily.img} | Errs: ${s.daily.err}\n`
                + `⚡ Circuit: ${CIRCUIT.isOpen()?'🔴 OPEN':'🟢 CLOSED'}`);
        }

        if (cmd === 'summary') {
            const limit = parseInt(args[1]) || 50;
            await editOrReply(Gifted, chatId, mek, `📝 Reading last *${limit}* messages...`);
            // Build summary from history if available, else generic
            const hist = HIST.get(`chat_${chatId}`).slice(-limit);
            if (!hist.length) return editOrReply(Gifted, chatId, mek, '❌ No conversation history available. Use `.gai chat` first.');
            const block = hist.map(h => `${h.role}: ${h.content}`).join('\n');
            await editOrReply(Gifted, chatId, mek, '🧠 Generating summary...');
            const summary = await qbRequest(`Summarize this WhatsApp conversation in bullet points:\n\n${block}`);
            return editOrReply(Gifted, chatId, mek, `📝 *Chat Summary*\n\n${summary}`);
        }

        // ── Natural Language + Intent Routing ─────────────────────────────────
        if (!q) {
            return editOrReply(Gifted, chatId, mek,
                `🧠 *GAI Commands*\n\n`
                + `*.gai [question]* — Ask anything\n`
                + `*.gai play [song]* — Download & send music\n`
                + `*.gai video [title]* — Download YouTube video\n`
                + `*.gai weather [city]* — Weather info\n`
                + `*.gai lyrics [song]* — Song lyrics\n`
                + `*.gai translate [text] to [lang]* — Translate\n`
                + `*.gai screenshot [url]* — Website screenshot\n`
                + `*.gai qr [text]* — Generate QR code\n`
                + `*.gai define [word]* — Dictionary\n`
                + `*.gai npm [package]* — NPM package info\n`
                + `*.gai ping* — Test bot speed\n`
                + `*.gai dm on/off* — DM auto-pilot\n`
                + `*.gai chat [gem]* — Chat auto-reply\n`
                + `*.gai stalk [uid] [gem]* — Global stalker\n`
                + `*.gai stop [all]* — Stop AI\n`
                + `*.gai wipe* — Clear memory\n`
                + `*.gai status* — System stats\n`
                + `*.gai summary [n]* — Summarize chat`);
        }

        await editOrReply(Gifted, chatId, mek, '🧠 *Thinking...*');

        // Check for image in reply
        let imgUrls = [];
        const reply = mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (reply?.imageMessage) {
            try {
                const tp = await Gifted.downloadAndSaveMediaMessage(reply.imageMessage, 'temp_gai_img');
                const url = await uploadToImgBBLocal(tp);
                if (url) imgUrls.push(url);
                await fsp.unlink(tp).catch(() => {});
            } catch (_) {}
        }

        // Intent detection for potential command execution
        const intent = await detectIntent(q);

        if (intent.intent !== 'general_chat' && intent.confidence >= 0.7 && EXEC[intent.intent]) {
            const result = await EXEC[intent.intent](intent.query || rest, chatId, Gifted, conText);
            if (result !== null) {
                return editOrReply(Gifted, chatId, mek, result || '✅ Done.');
            }
            // null means media was sent directly
            try { await Gifted.sendMessage(chatId, { delete: mek.key }); } catch (_) {}
            return;
        }

        // General AI chat
        const ctxId   = `oneshot_${sender}`;
        HIST.push(ctxId, 'User', q);
        const prompt  = HIST.buildPrompt(GEM.DEFAULT_PERSONA, ctxId, q);
        const response = await qbRequest(prompt, imgUrls);
        HIST.push(ctxId, 'AI', response);
        return editOrReply(Gifted, chatId, mek, response);
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .gem — GEM PERSONA MANAGER
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'gem',
        aliases : ['gems','persona'],
        category: 'ai',
        react   : '💎',
        desc    : 'Manage AI personas (Gems)',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek, isSuperUser } = conText;
        const args = (q || '').trim().split(/\s+/);
        const cmd  = args[0]?.toLowerCase();
        const rest = args.slice(1).join(' ');

        // ── list ───────────────────────────────────────────────────────────────
        if (cmd === 'list') {
            const gems = GEM.list();
            if (!gems.length) return editOrReply(Gifted, from, mek, `📚 *Gem Collection*\n\nThe vault is empty.\nUse *.gem create* or *.gem gen* to add personas.`);
            return editOrReply(Gifted, from, mek,
                `📚 *Gem Collection (${gems.length})*\n\n` + gems.map(g => `💎 \`${g}\``).join('\n'));
        }

        // ── create ─────────────────────────────────────────────────────────────
        if (cmd === 'create') {
            const spaceIdx = rest.indexOf(' ');
            if (spaceIdx < 0) return editOrReply(Gifted, from, mek, 'Usage: `.gem create <name> <prompt content>`');
            const name    = rest.slice(0, spaceIdx).toLowerCase();
            const content = rest.slice(spaceIdx + 1).trim();
            if (!content) return editOrReply(Gifted, from, mek, '❌ Content cannot be empty.');
            GEM.save(name, content);
            return editOrReply(Gifted, from, mek, `💾 *Gem Saved*\n\nName: \`${name}\`\nLength: ${content.length} chars`);
        }

        // ── delete ─────────────────────────────────────────────────────────────
        if (cmd === 'delete' || cmd === 'del') {
            const name = args[1]?.toLowerCase();
            if (!name) return editOrReply(Gifted, from, mek, 'Usage: `.gem delete <name>`');
            if (GEM.delete(name)) return editOrReply(Gifted, from, mek, `🗑️ Gem *${name}* destroyed.`);
            return editOrReply(Gifted, from, mek, `❌ Gem *${name}* not found.`);
        }

        // ── use ────────────────────────────────────────────────────────────────
        if (cmd === 'use') {
            const name    = args[1]?.toLowerCase();
            const content = name && GEM.get(name);
            if (!content) return editOrReply(Gifted, from, mek, `❌ Gem *${name||'?'}* not found.`);
            STATE.dmGem = content;
            return editOrReply(Gifted, from, mek, `✅ DM Gem set to *${name}*.`);
        }

        // ── view ───────────────────────────────────────────────────────────────
        if (cmd === 'view') {
            const name    = args[1]?.toLowerCase();
            const content = name && GEM.get(name);
            if (!content) return editOrReply(Gifted, from, mek, `❌ Gem *${name||'?'}* not found.`);
            return editOrReply(Gifted, from, mek,
                `💎 *Gem: ${name}*\n\n${content.slice(0,800)}${content.length>800?'\n...':''}` );
        }

        // ── gen (AI-generated) ─────────────────────────────────────────────────
        if (cmd === 'gen') {
            if (!rest) return editOrReply(Gifted, from, mek, 'Usage: `.gem gen <topic>`');
            await editOrReply(Gifted, from, mek, `🔮 *Forging Persona...*`);
            const result = await qbRequest(
                `Create a detailed System Prompt for an AI to roleplay as: "${rest}". Return ONLY the raw prompt text.`
            );
            const name = rest.split(/\s+/)[0].toLowerCase() + '_ai';
            GEM.save(name, result);
            return editOrReply(Gifted, from, mek,
                `✨ *Gem Created*\n\nName: \`${name}\`\n\n${result.slice(0,200)}...`);
        }

        // ── analyze (clone from single message) ───────────────────────────────
        if (cmd === 'analyze') {
            const quoted = conText.mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage;
            if (!quoted) return editOrReply(Gifted, from, mek, '❌ Reply to a user message.');
            await editOrReply(Gifted, from, mek, `🕵️ *Analysing Personality...*`);
            const txt  = quoted.conversation || quoted.extendedTextMessage?.text || 'Media';
            const result = await qbRequest(
                `Analyse this chat message and create a System Prompt to perfectly mimic this person's style. Return ONLY the raw prompt:\n\n"${txt}"`
            );
            const name = `clone_${Date.now().toString(36)}`;
            GEM.save(name, result);
            return editOrReply(Gifted, from, mek,
                `🧬 *Clone Created*\n\nName: \`${name}\`\n\n${result.slice(0,200)}...`);
        }

        // ── learn (deep chat scrape) — owner only ─────────────────────────────
        if (cmd === 'learn') {
            if (!isSuperUser) return editOrReply(Gifted, from, mek, '❌ Owner only.');
            return editOrReply(Gifted, from, mek,
                `ℹ️ Deep learn from chat history requires account-level access.\n`
                + `Use *.gem analyze* (reply to a message) for quick cloning.\n`
                + `Or *.gem create <name> <prompt>* to manually define a persona.`);
        }

        // ── default help ───────────────────────────────────────────────────────
        return editOrReply(Gifted, from, mek,
            `💎 *Gem System*\n\n`
            + `*.gem list* — Show all gems\n`
            + `*.gem create <name> <prompt>* — Save a persona\n`
            + `*.gem gen <topic>* — AI-generate a persona\n`
            + `*.gem analyze* — Clone from a quoted message\n`
            + `*.gem view <name>* — View a gem's prompt\n`
            + `*.gem use <name>* — Set DM persona\n`
            + `*.gem delete <name>* — Delete a gem`);
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .img — IMAGE GENERATION
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'img',
        aliases : ['imagine','genimg','aiimg'],
        category: 'ai',
        react   : '🎨',
        desc    : 'Generate images with AI (Infip API)',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        const args = (q || '').trim().split(/\s+/);
        const cmd  = args[0]?.toLowerCase();
        const rest = args.slice(1).join(' ');

        // ── gen ────────────────────────────────────────────────────────────────
        if (!cmd || cmd === 'gen') {
            const prompt = cmd === 'gen' ? rest : q;
            if (!prompt) return editOrReply(Gifted, from, mek, 'Usage: `.img gen <prompt>` or `.img <prompt>`');
            await editOrReply(Gifted, from, mek, `🎨 *Generating Image...*\nPrompt: _${prompt.slice(0,60)}_`);
            const urls = await generateImages(prompt);
            if (!urls.length) return editOrReply(Gifted, from, mek, '❌ Image generation failed. Try again later.');
            try { await Gifted.sendMessage(from, { delete: mek.key }); } catch (_) {}
            for (const url of urls) {
                await Gifted.sendMessage(from, {
                    image: { url },
                    caption: `🎨 *Generated*\n\n*Prompt:* ${prompt}\n*Model:* ${STATE.imgConfig.model}`,
                }, { quoted: mek });
            }
            return;
        }

        // ── surprise ───────────────────────────────────────────────────────────
        if (cmd === 'surprise') {
            const topic = rest || '';
            await editOrReply(Gifted, from, mek, `🎲 *Dreaming up${topic?' a '+topic:' a random'} concept...*`);
            const topicInstr = topic ? ` based on: "${topic}"` : '';
            const p = await qbRequest(
                `Generate a highly detailed, creative, unique prompt for an AI image generator${topicInstr}. Focus on visuals, lighting, atmosphere, and artistic style. Return ONLY the prompt.`
            );
            const finalPrompt = (!p || p.startsWith('⚠️'))
                ? 'A majestic phoenix rising from crystal nebula, 8k, cinematic lighting'
                : p.trim();
            await editOrReply(Gifted, from, mek, `🎨 *Visualising:*\n_${finalPrompt.slice(0,100)}..._`);
            const urls = await generateImages(finalPrompt);
            if (!urls.length) return editOrReply(Gifted, from, mek, '❌ Generation failed.');
            try { await Gifted.sendMessage(from, { delete: mek.key }); } catch (_) {}
            await Gifted.sendMessage(from, {
                image  : { url: urls[0] },
                caption: `🎲 *Surprise Creation*\n\n*Dream:* ${finalPrompt}\n*Model:* ${STATE.imgConfig.model}`,
            }, { quoted: mek });
            return;
        }

        // ── chaos ──────────────────────────────────────────────────────────────
        if (cmd === 'chaos') {
            const sizes   = ['1024x1024','1792x1024','1024x1792'];
            const free    = Object.entries(CFG.IMG_MODELS).filter(([,v]) => v.tier==='free').map(([k]) => k);
            STATE.imgConfig.size    = sizes[Math.floor(Math.random()*sizes.length)];
            STATE.imgConfig.model   = free[Math.floor(Math.random()*free.length)];
            STATE.imgConfig.quality = Math.random() > 0.5 ? 'hd' : 'standard';
            STATE.imgConfig.style   = Math.random() > 0.5 ? 'vivid' : 'natural';
            await editOrReply(Gifted, from, mek, `🌪️ *CHAOS MODE*\nSettings randomised. Dreaming...\nModel: ${STATE.imgConfig.model} | Size: ${STATE.imgConfig.size}`);
            const p = await qbRequest('Generate a bizarre, surreal, chaotic image prompt. Return ONLY the prompt.');
            const prompt = (!p||p.startsWith('⚠️')) ? 'Abstract chaos, melting clocks, cybernetic forest, neon rain' : p.trim();
            const urls = await generateImages(prompt);
            if (!urls.length) return editOrReply(Gifted, from, mek, '❌ Chaos could not be manifested.');
            try { await Gifted.sendMessage(from, { delete: mek.key }); } catch (_) {}
            await Gifted.sendMessage(from, {
                image  : { url: urls[0] },
                caption: `🌪️ *CHAOS*\n\n*Prompt:* ${prompt}\n*Model:* ${STATE.imgConfig.model} | *Size:* ${STATE.imgConfig.size}`,
            }, { quoted: mek });
            return;
        }

        // ── models ─────────────────────────────────────────────────────────────
        if (cmd === 'models') {
            const lines = Object.entries(CFG.IMG_MODELS).map(([id,v]) =>
                `${v.tier==='pro'?'👑':'🆓'}${v.async?'⚡':''} \`${id}\` — ${v.desc}`
            ).join('\n');
            return editOrReply(Gifted, from, mek,
                `🎨 *Available Models*\n\n${lines}\n\n_👑=Pro 🆓=Free ⚡=Async_`);
        }

        // ── config ─────────────────────────────────────────────────────────────
        if (cmd === 'config') {
            if (!rest) {
                const c = STATE.imgConfig;
                return editOrReply(Gifted, from, mek,
                    `⚙️ *Image Config*\n\n`
                    + `• Model: \`${c.model}\`\n`
                    + `• Size: \`${c.size}\`\n`
                    + `• Count: \`${c.count}\`\n`
                    + `• Quality: \`${c.quality}\`\n`
                    + `• Style: \`${c.style}\`\n\n`
                    + `Usage: \`.img config <model> [size] [count] [quality] [style]\``);
            }
            const p = rest.split(/\s+/);
            if (p[0] && CFG.IMG_MODELS[p[0]]) STATE.imgConfig.model   = p[0];
            else return editOrReply(Gifted, from, mek, `❌ Model not found. Use \`.img models\` to see list.`);
            if (p[1]) STATE.imgConfig.size    = p[1];
            if (p[2]) STATE.imgConfig.count   = Math.min(parseInt(p[2])||1, 4);
            if (p[3]) STATE.imgConfig.quality = p[3];
            if (p[4]) STATE.imgConfig.style   = p[4];
            const c = STATE.imgConfig;
            return editOrReply(Gifted, from, mek,
                `✅ *Config Updated*\n\nModel: \`${c.model}\` | Size: \`${c.size}\` | Count: ${c.count}\nQuality: ${c.quality} | Style: ${c.style}`);
        }

        // ── enhance ────────────────────────────────────────────────────────────
        if (cmd === 'enhance') {
            if (!rest) return editOrReply(Gifted, from, mek, 'Usage: `.img enhance <prompt>`');
            await editOrReply(Gifted, from, mek, `🧠 *Enhancing Prompt...*`);
            const enhanced = await enhancePrompt(rest);
            return editOrReply(Gifted, from, mek,
                `✨ *Prompt Enhanced*\n\n*Original:* ${rest}\n\n*Enhanced:* ${enhanced}\n\nUse: \`.img gen ${enhanced}\``);
        }

        // ── random ─────────────────────────────────────────────────────────────
        if (cmd === 'random') {
            const sizes = ['1024x1024','1792x1024','1024x1792'];
            const free  = Object.entries(CFG.IMG_MODELS).filter(([,v]) => v.tier==='free').map(([k]) => k);
            STATE.imgConfig.size    = sizes[Math.floor(Math.random()*sizes.length)];
            STATE.imgConfig.model   = free[Math.floor(Math.random()*free.length)];
            STATE.imgConfig.quality = Math.random()>0.5 ? 'hd' : 'standard';
            STATE.imgConfig.style   = Math.random()>0.5 ? 'vivid' : 'natural';
            const c = STATE.imgConfig;
            return editOrReply(Gifted, from, mek,
                `🎲 *Settings Randomised*\n\nModel: \`${c.model}\`\nSize: \`${c.size}\`\nQuality: ${c.quality} | Style: ${c.style}`);
        }

        // ── setup ──────────────────────────────────────────────────────────────
        if (cmd === 'setup') {
            await editOrReply(Gifted, from, mek, `🔧 *Setting up Infip API...*`);
            const ok = await infipSetup();
            return editOrReply(Gifted, from, mek,
                ok
                ? `✅ *API Ready*\n\nKey: \`${CFG.INFIP_KEY.slice(0,20)}...\`\n\nUse \`.img gen <prompt>\` to generate.`
                : `❌ Setup failed. Check internet connection.`);
        }

        // ── cache (clear internal image URL cache) ─────────────────────────────
        if (cmd === 'cache') { _infipValidated = false; return editOrReply(Gifted, from, mek, `🗑️ API cache cleared.`); }

        // ── default: treat q as prompt ──────────────────────────────────────────
        if (q) {
            await editOrReply(Gifted, from, mek, `🎨 *Generating...*\n_${q.slice(0,60)}_`);
            const urls = await generateImages(q);
            if (!urls.length) return editOrReply(Gifted, from, mek, '❌ Generation failed.');
            try { await Gifted.sendMessage(from, { delete: mek.key }); } catch (_) {}
            await Gifted.sendMessage(from, { image:{ url:urls[0] }, caption:`🎨 ${q}` }, { quoted:mek });
            return;
        }

        return editOrReply(Gifted, from, mek,
            `🎨 *Image Generation*\n\n`
            + `*.img gen <prompt>* — Generate image\n`
            + `*.img <prompt>* — Quick generate\n`
            + `*.img surprise [topic]* — AI-dreamed image\n`
            + `*.img chaos* — Random everything\n`
            + `*.img models* — Available models\n`
            + `*.img config [model] [size] [count] [quality] [style]* — Configure\n`
            + `*.img enhance <prompt>* — AI-improve prompt\n`
            + `*.img random* — Randomise settings\n`
            + `*.img setup* — Test API connection`);
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .profile — DYNAMIC AI PROFILE MANAGER
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'profile',
        aliases : ['dynprofile','aiprofile'],
        category: 'ai',
        react   : '🎭',
        desc    : 'AI-powered dynamic Telegram/WA profile manager',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek, isSuperUser } = conText;
        if (!isSuperUser) return editOrReply(Gifted, from, mek, '❌ Owner only command.');

        const args = (q||'').trim().split(/\s+/);
        const cmd  = args[0]?.toLowerCase();
        const rest = args.slice(1).join(' ');

        const genName = async () => {
            const styles = [
                'Unicode symbols and special chars','aesthetic letters',
                'cyberpunk style','minimalist style','bold dramatic',
            ];
            const style = styles[Math.floor(Math.random()*styles.length)];
            const r = await qbRequest(
                `Generate a unique creative display name using ${style}. Max 20 chars. Return ONLY the name.`
            );
            return (!r||r.startsWith('⚠️')) ? null : r.replace(/\*|_|`/g,'').trim().slice(0,20);
        };

        const genBio = async () => {
            const moods = ['mysterious','funny','philosophical','minimalist','chaotic','aesthetic'];
            const mood  = moods[Math.floor(Math.random()*moods.length)];
            const r = await qbRequest(
                `Generate a creative ${mood} social media bio, max 70 chars. Return ONLY the bio.`
            );
            const bio = (!r||r.startsWith('⚠️')) ? null : r.replace(/"|'/g,'').trim().slice(0,70);
            if (bio) { getDb().prepare('INSERT INTO profile_history(type,content) VALUES(?,?)').run('bio', bio); }
            return bio;
        };

        const genPfp = async () => {
            const cats = [
                'anime landscape inspired by Makoto Shinkai, emotional, nostalgic, night sky, lake, fireflies',
                'Studio Ghibli nature scene, rolling hills, clouds, cottage, warm sunlight',
                'cyberpunk cityscape at night, neon lights, rain reflection, dramatic',
                'cosmic nebula scene, stars, planets, ethereal purple and blue',
                'fantasy floating islands, waterfalls, magical lighting, vivid colours',
                'abstract nature, flowing shapes, limited palette, modern aesthetic',
                'misty forest morning, sunbeams, golden hour, peaceful photography',
                'surreal dreamscape, soft pastels, floating elements, ethereal',
            ];
            const cat = cats[Math.floor(Math.random()*cats.length)];
            const prompt = `${cat}, highly detailed, 8k, professional, breathtaking`;
            const urls   = await generateImages(prompt, { model:'flux2-dev', quality:'hd', size:'1024x1024', count:1, style:'vivid' });
            if (!urls.length) return null;
            const dir = path.join(__dirname, '../gift/temp');
            if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive:true });
            const fp  = path.join(dir, `pfp_${Date.now()}.jpg`);
            try {
                const res = await axios.get(urls[0], { responseType:'arraybuffer', timeout:30000 });
                await fsp.writeFile(fp, res.data);
                getDb().prepare('INSERT INTO pfp_history(file_path,prompt) VALUES(?,?)').run(fp, prompt);
                return fp;
            } catch (_) { return null; }
        };

        // ── update (all) ───────────────────────────────────────────────────────
        if (cmd === 'update') {
            await editOrReply(Gifted, from, mek, `🎭 *Updating Profile...*\nGenerating AI content...`);
            const [name, bio, pfpPath] = await Promise.all([genName(), genBio(), genPfp()]);
            const updated = [];
            if (name) { try { await Gifted.updateProfile({ first_name:name }); updated.push(`Name: ${name}`); } catch (_) {} }
            if (bio)  { try { await Gifted.updateProfile({ bio }); updated.push(`Bio: ${bio}`); } catch (_) {} }
            if (pfpPath && fs.existsSync(pfpPath)) {
                try { await Gifted.updateProfilePicture(Gifted.user.id, { url: pfpPath }); updated.push('Profile Picture'); } catch (_) {}
            }
            return editOrReply(Gifted, from, mek,
                updated.length
                    ? `✅ *Profile Updated*\n\n${updated.map(u=>`• ${u}`).join('\n')}`
                    : `❌ No updates applied.`);
        }

        // ── name ───────────────────────────────────────────────────────────────
        if (cmd === 'name') {
            await editOrReply(Gifted, from, mek, `🎭 *Generating Name...*`);
            const name = await genName();
            if (!name) return editOrReply(Gifted, from, mek, '❌ Name generation failed.');
            try { await Gifted.updateProfile({ first_name:name }); return editOrReply(Gifted, from, mek, `✅ Name updated: *${name}*`); }
            catch (_) { return editOrReply(Gifted, from, mek, `⚠️ Generated *${name}* but update failed.`); }
        }

        // ── bio ────────────────────────────────────────────────────────────────
        if (cmd === 'bio') {
            await editOrReply(Gifted, from, mek, `🎭 *Generating Bio...*`);
            const bio = await genBio();
            if (!bio) return editOrReply(Gifted, from, mek, '❌ Bio generation failed.');
            try { await Gifted.updateProfile({ bio }); return editOrReply(Gifted, from, mek, `✅ Bio updated: _${bio}_`); }
            catch (_) { return editOrReply(Gifted, from, mek, `⚠️ Generated _${bio}_ but update failed.`); }
        }

        // ── pfp ────────────────────────────────────────────────────────────────
        if (cmd === 'pfp') {
            await editOrReply(Gifted, from, mek, `🎭 *Generating Profile Picture...*\nCreating AI art...`);
            const pfpPath = await genPfp();
            if (!pfpPath) return editOrReply(Gifted, from, mek, '❌ PFP generation failed.');
            try {
                await Gifted.updateProfilePicture(Gifted.user.id, { url: pfpPath });
                return editOrReply(Gifted, from, mek, `✅ Profile picture updated!`);
            } catch (_) { return editOrReply(Gifted, from, mek, `⚠️ Generated PFP but failed to set it.`); }
        }

        // ── auto ───────────────────────────────────────────────────────────────
        if (cmd === 'auto') {
            const action = args[1]?.toLowerCase();
            if (action === 'on') {
                STATE.profileAutoOn = true;
                if (STATE.profileTimer) clearInterval(STATE.profileTimer);
                STATE.profileTimer = setInterval(async () => {
                    // lightweight auto-update
                    const bio = await genBio();
                    if (bio) { try { await Gifted.updateProfile({ bio }); } catch (_) {} }
                }, STATE.profileInterval);
                return editOrReply(Gifted, from, mek,
                    `🤖 Auto profile updates *ENABLED*\nInterval: every ${STATE.profileInterval/3600000}h`);
            }
            if (action === 'off') {
                STATE.profileAutoOn = false;
                if (STATE.profileTimer) { clearInterval(STATE.profileTimer); STATE.profileTimer = null; }
                return editOrReply(Gifted, from, mek, `🤖 Auto profile updates *DISABLED*`);
            }
            return editOrReply(Gifted, from, mek,
                `🤖 *Auto Profile*\nStatus: ${STATE.profileAutoOn?'✅ ON':'❌ OFF'}\nUse: \`.profile auto on/off\``);
        }

        // ── interval ───────────────────────────────────────────────────────────
        if (cmd === 'interval') {
            const h = parseFloat(args[1]);
            if (!h || h < 0.5) return editOrReply(Gifted, from, mek, `Current: *${STATE.profileInterval/3600000}h*\nUsage: \`.profile interval <hours>\` (min 0.5)`);
            STATE.profileInterval = h * 3600000;
            return editOrReply(Gifted, from, mek, `⏰ Update interval: *${h}h*`);
        }

        // ── history ────────────────────────────────────────────────────────────
        if (cmd === 'history') {
            const type  = args[1]?.toLowerCase();
            if (type === 'bios') {
                const rows = getDb().prepare('SELECT content,ts FROM profile_history WHERE type=? ORDER BY ts DESC LIMIT 10').all('bio');
                if (!rows.length) return editOrReply(Gifted, from, mek, '📭 No bio history.');
                return editOrReply(Gifted, from, mek, `📝 *Bio History*\n\n${rows.map((r,i)=>`${i+1}. _${r.content}_`).join('\n')}`);
            }
            if (type === 'pfps') {
                const rows = getDb().prepare('SELECT file_path,prompt,ts FROM pfp_history ORDER BY ts DESC LIMIT 10').all();
                if (!rows.length) return editOrReply(Gifted, from, mek, '📭 No PFP history.');
                return editOrReply(Gifted, from, mek, `🖼️ *PFP History*\n\n${rows.map((r,i)=>`${i+1}. ${path.basename(r.file_path)}\n   _${r.prompt?.slice(0,60)}..._`).join('\n')}`);
            }
            return editOrReply(Gifted, from, mek, 'Usage: `.profile history [bios|pfps]`');
        }

        // ── help ───────────────────────────────────────────────────────────────
        return editOrReply(Gifted, from, mek,
            `🎭 *Dynamic Profile*\n\n`
            + `*.profile update* — Update all (name/bio/pfp)\n`
            + `*.profile name* — AI-generate new name\n`
            + `*.profile bio* — AI-generate new bio\n`
            + `*.profile pfp* — AI-generate profile picture\n`
            + `*.profile auto on/off* — Auto-updates\n`
            + `*.profile interval <h>* — Set update interval\n`
            + `*.profile history [bios|pfps]* — View history`);
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .api — API MONITOR & CIRCUIT BREAKER CONTROL
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'aistats',
        aliases : ['apimon','aiapi','ratelimit'],
        category: 'ai',
        react   : '📊',
        desc    : 'AI API usage statistics and circuit breaker control',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek, isSuperUser } = conText;
        if (!isSuperUser) return editOrReply(Gifted, from, mek, '❌ Owner only.');

        const args = (q||'').trim().split(/\s+/);
        const cmd  = args[0]?.toLowerCase();

        if (!cmd || cmd === 'status') {
            const s = RATE.stats();
            const progBar = (c,t,l=10) => { const f=Math.round(l*Math.min(c/t,1)); return '█'.repeat(f)+'░'.repeat(l-f); };
            return editOrReply(Gifted, from, mek,
                `📊 *API Status Report*\n━━━━━━━━━━━━━━━━━━━━\n`
                + `📈 *Load:*\n`
                + `• 1m: \`${progBar(s.rpm,CFG.MAX_RPM)}\` ${s.rpm}/${CFG.MAX_RPM}\n`
                + `• 1h: \`${progBar(s.rph,CFG.MAX_RPH)}\` ${s.rph}/${CFG.MAX_RPH}\n\n`
                + `📅 *Daily:*\n`
                + `• AI Requests: ${s.daily.ai}\n`
                + `• Image Uploads: ${s.daily.img}\n`
                + `• Errors: ${s.daily.err}\n\n`
                + `⚡ *Circuit:* ${CIRCUIT.isOpen()?`🔴 OPEN (${CIRCUIT.errors} errors)`:'🟢 CLOSED'}\n`
                + `🔑 *Infip Key:* \`${CFG.INFIP_KEY}\`\n`
                + `⚙️ Timeout: ${CFG.TIMEOUT/1000}s | Retries: ${CFG.RETRIES}`);
        }

        if (cmd === 'reset') {
            CIRCUIT.reset();
            RATE.minuteReqs = [];
            RATE.hourReqs   = [];
            return editOrReply(Gifted, from, mek, `✅ Rate limits and circuit breaker reset.`);
        }

        if (cmd === 'health') {
            await editOrReply(Gifted, from, mek, `🔍 *Checking API Health...*`);
            const testResp = await qbRequest('Reply with "OK" only.');
            const qbOk    = testResp?.includes('OK') || (!testResp?.startsWith('⚠️'));
            const infipOk = await infipSetup();
            return editOrReply(Gifted, from, mek,
                `🏥 *Health Check*\n\n`
                + `${qbOk?'✅':'❌'} QuillBot AI\n`
                + `${infipOk?'✅':'❌'} Infip Image Gen\n`
                + `${RATE.check()?'✅':'⚠️'} Rate Limits\n`
                + `${!CIRCUIT.isOpen()?'✅':'🔴'} Circuit Breaker`);
        }

        if (cmd === 'key') {
            const idx = parseInt(args[1]);
            if (idx >= 0 && idx < CFG.INFIP_KEYS.length) {
                CFG.INFIP_KEY      = CFG.INFIP_KEYS[idx];
                _infipValidated    = false;
                return editOrReply(Gifted, from, mek, `✅ Switched to key index ${idx}: \`${CFG.INFIP_KEY}\``);
            }
            return editOrReply(Gifted, from, mek,
                `🔑 *Available Keys:*\n${CFG.INFIP_KEYS.map((k,i)=>`${i}: \`${k}\``).join('\n')}\n\nUsage: \`.aistats key <index>\``);
        }

        return editOrReply(Gifted, from, mek,
            `📊 *AI API Monitor*\n\n`
            + `*.aistats status* — Usage stats\n`
            + `*.aistats health* — API health check\n`
            + `*.aistats reset* — Reset limits & circuit\n`
            + `*.aistats key <n>* — Switch Infip key`);
    }
);

// ═══════════════════════════════════════════════════════════════════════════════
//  .ask — Quick single-shot AI (shortcut)
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'ask',
        aliases : ['qb','quillbot'],
        category: 'ai',
        react   : '💬',
        desc    : 'Quick AI question (one-shot, no history)',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        if (!q) return editOrReply(Gifted, from, mek, 'Usage: `.ask <your question>`');
        await editOrReply(Gifted, from, mek, '💬 *Thinking...*');
        const r = await qbRequest(q);
        return editOrReply(Gifted, from, mek, r);
    }
);

