// --- CHUNK: Data Persistence: Enhanced SQLite Schema ---
// ==============================================================================
// 4. DATA PERSISTENCE: ENHANCED SQLITE SCHEMA
// ==============================================================================

/**
 * @class DataManager
 * @description Manages SQLite persistence with WAL mode, robust error recovery, 
 * and automated schema migrations for GEMS, Usage Tracking, and Stalk Lists.
 */
class DataManager {
    constructor(dbPath) {
        this.dbPath = dbPath;
        this.db = null;
        this.initialize();
    }

    /**
     * @method initialize
     * @description Establishes connection, sets performance pragmas, and ensures schema integrity.
     */
    initialize() {
        try {
            const dbDir = path.dirname(this.dbPath);
            if (!fs.existsSync(dbDir)) {
                fs.mkdirSync(dbDir, { recursive: true });
            }

            // Initialize better-sqlite3 with a 7-second busy timeout for concurrent access
            this.db = new Database(this.dbPath, { timeout: 7000 });
            
            // Performance Optimization: Write-Ahead Logging
            this.db.pragma('journal_mode = WAL');
            this.db.pragma('synchronous = NORMAL');
            this.db.pragma('temp_store = MEMORY');

            this.createTables();
            console.log(`[DataManager] Database initialized at: ${this.dbPath}`);
        } catch (error) {
            console.error('[DataManager] Critical DB Initialization Error:', error.message);
            if (error.message.includes('malformed') || error.message.includes('corrupt')) {
                this.handleCorruption();
            }
        }
    }

    /**
     * @method handleCorruption
     * @description Rescues the system by archiving corrupted database and starting fresh.
     */
    handleCorruption() {
        const timestamp = Date.now();
        const corruptPath = `${this.dbPath}.corrupt.${timestamp}`;
        console.warn(`[DataManager] Corruption detected. Archiving to: ${corruptPath}`);
        try {
            if (this.db) this.db.close();
            fs.renameSync(this.dbPath, corruptPath);
            this.initialize();
        } catch (e) {
            console.error('[DataManager] Recovery failed:', e.message);
        }
    }

    /**
     * @method createTables
     * @description Rebuilds the robust schema with enhanced metadata fields.
     */
    createTables() {
        const schema = `
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                usage_count INTEGER DEFAULT 0,
                last_used DATETIME,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );

            CREATE TABLE IF NOT EXISTS usage_stats (
                command TEXT PRIMARY KEY,
                count INTEGER DEFAULT 0,
                last_triggered DATETIME DEFAULT CURRENT_TIMESTAMP
            );

            CREATE TABLE IF NOT EXISTS stalk_list (
                jid TEXT PRIMARY KEY,
                gem_name TEXT DEFAULT 'default',
                added_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `;
        this.db.exec(schema);
    }

    /**
     * @method safeRun
     * @description Wrapper for write operations to handle locked states gracefully.
     */
    safeRun(query, ...params) {
        try {
            return this.db.prepare(query).run(...params);
        } catch (error) {
            console.error('[DataManager] Write Error:', error.message);
            return { changes: 0, lastInsertRowid: null };
        }
    }

    /**
     * @method safeGet
     * @description Wrapper for read operations.
     */
    safeGet(query, ...params) {
        try {
            return this.db.prepare(query).get(...params);
        } catch (error) {
            console.error('[DataManager] Read Error:', error.message);
            return null;
        }
    }

    /**
     * @method safeAll
     * @description Wrapper for bulk read operations.
     */
    safeAll(query, ...params) {
        try {
            return this.db.prepare(query).all(...params);
        } catch (error) {
            console.error('[DataManager] Bulk Read Error:', error.message);
            return [];
        }
    }
}

// Instantiate the Core Data Layer
const DB_CORE = new DataManager(CFG.DB_PATH);

/**
 * @namespace Gems
 * @description Persistence logic for AI Personas (Gems).
 */
const Gems = {
    save: (name, content) => {
        const sanitizedName = name.toLowerCase().trim();
        const query = `
            INSERT INTO gems (name, content, last_used) 
            VALUES (?, ?, CURRENT_TIMESTAMP)
            ON CONFLICT(name) DO UPDATE SET 
                content = excluded.content,
                last_used = CURRENT_TIMESTAMP;
        `;
        return DB_CORE.safeRun(query, sanitizedName, content).changes > 0;
    },

    get: (name) => {
        const sanitizedName = name.toLowerCase().trim();
        const gem = DB_CORE.safeGet('SELECT * FROM gems WHERE name = ?', sanitizedName);
        if (gem) {
            DB_CORE.safeRun('UPDATE gems SET usage_count = usage_count + 1, last_used = CURRENT_TIMESTAMP WHERE name = ?', sanitizedName);
        }
        return gem;
    },

    delete: (name) => {
        return DB_CORE.safeRun('DELETE FROM gems WHERE name = ?', name.toLowerCase().trim()).changes > 0;
    },

    list: () => {
        return DB_CORE.safeAll('SELECT name, usage_count, last_used FROM gems ORDER BY usage_count DESC');
    },

    getTopGem: () => {
        return DB_CORE.safeGet('SELECT * FROM gems ORDER BY usage_count DESC LIMIT 1');
    }
};

/**
 * @namespace UsageStats
 * @description Logic for tracking bot command frequency and health.
 */
const UsageStats = {
    record: (command) => {
        const query = `
            INSERT INTO usage_stats (command, count, last_triggered)
            VALUES (?, 1, CURRENT_TIMESTAMP)
            ON CONFLICT(command) DO UPDATE SET
                count = usage_stats.count + 1,
                last_triggered = CURRENT_TIMESTAMP;
        `;
        return DB_CORE.safeRun(query, command.toLowerCase().trim());
    },

    getGlobalStats: () => {
        return DB_CORE.safeAll('SELECT * FROM usage_stats ORDER BY count DESC');
    },

    reset: () => {
        return DB_CORE.safeRun('DELETE FROM usage_stats');
    }
};

/**
 * @namespace StalkList
 * @description Persistence for the persistent tracking/auto-reply system.
 */
const StalkList = {
    add: (jid, gemName = 'default') => {
        const query = `
            INSERT INTO stalk_list (jid, gem_name, added_at)
            VALUES (?, ?, CURRENT_TIMESTAMP)
            ON CONFLICT(jid) DO UPDATE SET
                gem_name = excluded.gem_name;
        `;
        return DB_CORE.safeRun(query, jid, gemName.toLowerCase().trim()).changes > 0;
    },

    remove: (jid) => {
        return DB_CORE.safeRun('DELETE FROM stalk_list WHERE jid = ?', jid).changes > 0;
    },

    isActive: (jid) => {
        return !!DB_CORE.safeGet('SELECT 1 FROM stalk_list WHERE jid = ?', jid);
    },

    getDetails: (jid) => {
        return DB_CORE.safeGet('SELECT * FROM stalk_list WHERE jid = ?', jid);
    },

    getAll: () => {
        return DB_CORE.safeAll('SELECT * FROM stalk_list ORDER BY added_at DESC');
    }
};

// Exporting Data Layers for internal use in subsequent modules
module.exports = {
    ...module.exports,
    DB_CORE,
    Gems,
    UsageStats,
    StalkList
};

// --- CHUNK: API Communication: Robust QuillBot SSE and Infip Integration ---
/**
 * @section 5. CORE AI — API Communication: Robust QuillBot SSE and Infip Integration
 * @description Advanced SSE stream parsing, WhatsApp markdown enforcement, and intelligent API key rotation.
 */

const WHATSAPP_MD_ENFORCER = `
[STRICT FORMATTING RULE]
1. Use ONLY WhatsApp-compatible markdown:
   - *bold* (single asterisk)
   - _italic_ (underscore)
   - ~strikethrough~ (tilde)
   - \`\`\`monospace\`\`\` (triple backticks)
2. DO NOT use: **bold**, # headers, [links], or standard markdown lists with dashes.
3. Keep responses concise, conversational, and avoid escaping characters with backslashes unless essential.
`;

/**
 * Sanitizes AI output to ensure perfect WhatsApp rendering.
 * @param {string} text Raw response from AI.
 * @returns {string} Cleaned WhatsApp-ready text.
 */
const sanitizeOutput = (text) => {
    if (!text) return '';
    return text
        // Convert **bold** to *bold*
        .replace(/\*\*(.*?)\*\*/g, '*$1*')
        // Remove LaTeX or specific escaping often used by AI models
        .replace(/\\\[|\\\]|\\\(|\\\)/g, '')
        // Remove double backslashes
        .replace(/\\\\/g, '')
        // Clean up any remaining backslashes that aren't functional
        .replace(/\\([*_~`])/g, '$1')
        .trim();
};

/**
 * Robust SSE Parser for QuillBot Raven API
 * @param {ReadableStream} stream 
 * @returns {Promise<string>}
 */
const parseQuillStream = (stream) => {
    return new Promise((resolve, reject) => {
        let accumulatedText = '';
        let buffer = '';
        const timeout = setTimeout(() => resolve(accumulatedText), CFG.TIMEOUT - 2000);

        stream.on('data', (chunk) => {
            buffer += chunk.toString();
            const lines = buffer.split('\n');
            // Keep the last partial line in the buffer
            buffer = lines.pop();

            for (const line of lines) {
                const trimmed = line.trim();
                if (!trimmed || !trimmed.startsWith('data: ')) continue;

                const rawJson = trimmed.slice(6);
                if (rawJson === '[DONE]') continue;

                try {
                    const parsed = JSON.parse(rawJson);
                    if (parsed.chunk) {
                        accumulatedText += parsed.chunk;
                    }
                } catch (e) {
                    // Ignore malformed JSON chunks in the stream
                }
            }
        });

        stream.on('end', () => {
            clearTimeout(timeout);
            resolve(accumulatedText);
        });

        stream.on('error', (err) => {
            clearTimeout(timeout);
            reject(err);
        });
    });
};

/**
 * Main AI Interaction logic with System Prompt Injection.
 */
const askAI = async (prompt, imgUrls = [], customPersona = null) => {
    if (CB.open()) return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: '*System:* Signal saturated. Wait a minute.', err: true };

    const persona = customPersona || State.PERSONA;
    const systemPrompt = `[SYSTEM PERSONA]\n${persona}\n\n${WHATSAPP_MD_ENFORCER}`;

    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: prompt,
            files: imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'vision_input.jpg' }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat', custom_system_prompt: systemPrompt },
        tools: []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');
            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout: CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await parseQuillStream(res.data);
            
            if (!rawText || !rawText.trim()) {
                if (attempt < CFG.RETRIES - 1) {
                    await sleep(1500 * (attempt + 1));
                    continue;
                }
                return { text: '*Error:* Empty response from neural core.', err: true };
            }

            CB.ok();
            return { text: sanitizeOutput(rawText), err: false };

        } catch (e) {
            Limiter.err();
            console.error(`[AIGems] askAI (Attempt ${attempt + 1}):`, e.message);
            if (attempt < CFG.RETRIES - 1) {
                await sleep(2000 * (attempt + 1));
            } else {
                CB.fail();
                return { text: `*Connection Failure:* ${e.message}`, err: true };
            }
        }
    }
};

/**
 * Intelligent Infip API Key Manager
 */
const InfipKeyManager = {
    currentIndex: Math.floor(Math.random() * CFG.INFIP_POOL.length),
    failedKeys: new Set(),

    getNextKey() {
        // Find next key that isn't in failed set
        for (let i = 0; i < CFG.INFIP_POOL.length; i++) {
            this.currentIndex = (this.currentIndex + 1) % CFG.INFIP_POOL.length;
            const key = CFG.INFIP_POOL[this.currentIndex];
            if (!this.failedKeys.has(key)) return key;
        }
        // If all failed, reset the set and try again
        this.failedKeys.clear();
        return CFG.INFIP_POOL[0];
    },

    markFailed(key) {
        this.failedKeys.add(key);
    }
};

/**
 * Intelligent Image Generation with key rotation and rate-limit recovery.
 */
const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;
    const n = Math.min(opts.count || CFG.IMG_COUNT, 4);
    const quality = opts.quality || CFG.IMG_QUALITY;
    const style = opts.style || CFG.IMG_STYLE;

    const cacheKey = `img:${model}:${size}:${prompt.toLowerCase().trim()}`;
    const cached = _iCache.get(cacheKey);
    if (cached && Date.now() - cached.ts < 3600000) return cached.urls;

    if (!Limiter.check()) return [];

    let currentKey = _iKey;

    for (let attempt = 0; attempt < CFG.RETRIES + 2; attempt++) {
        try {
            Limiter.hit('img');
            const response = await axios.post(
                `${CFG.INFIP_URL}/v1/images/generations`,
                { model, prompt, n, size, response_format: 'url', quality, style },
                {
                    headers: { 
                        'Authorization': `Bearer ${currentKey}`,
                        'Content-Type': 'application/json' 
                    },
                    timeout: CFG.TIMEOUT
                }
            );

            if (response.status === 200 && response.data?.data?.length) {
                const urls = response.data.data.map(d => d.url);
                _iCache.set(cacheKey, { urls, ts: Date.now() });
                _iKey = currentKey; // Keep working key
                return urls;
            }
        } catch (e) {
            Limiter.err();
            const status = e.response?.status;

            if (status === 429 || status === 401) {
                // Rate limited or Unauthorized: Rotate key immediately
                InfipKeyManager.markFailed(currentKey);
                currentKey = InfipKeyManager.getNextKey();
                await sleep(500); // Small cooldown
                continue;
            }

            console.error(`[AIGems] generateImage (Attempt ${attempt + 1}):`, e.message);
            if (attempt < CFG.RETRIES) {
                await sleep(2000 * (attempt + 1));
            } else {
                break;
            }
        }
    }
    return [];
};

module.exports = {
    ...module.exports,
    askAI,
    generateImage,
    sanitizeOutput,
    WHATSAPP_MD_ENFORCER
};

// --- CHUNK: Message Dispatcher: Thinking, Editing, and Media Helpers ---
/**
 * @section MESSAGE DISPATCHER: THINKING, EDITING, AND MEDIA HELPERS
 * @description Robust communication layer for WhatsApp. Handles markdown sanitization, 
 *              message chunking, and resilient editing/fallback mechanisms.
 */

const WAMarkdown = {
    /**
     * Sanitizes AI-generated text for WhatsApp.
     * Removes LaTeX noise, converts standard Markdown to WA-compatible syntax, 
     * and ensures no system-leak characters remain.
     */
    clean(text) {
        if (!text || typeof text !== 'string') return '';

        return text
            // 1. Remove LaTeX math delimiters often hallucinated by AI
            .replace(/\\\(|\\\)/g, '_') 
            .replace(/\\\[|\\\]/g, '*')
            // 2. Remove escape characters for standard punctuation
            .replace(/\\([!?.(){}[\]\-_])/g, '$1')
            // 3. Convert Markdown bold (**) to WA bold (*)
            .replace(/\*\*(.*?)\*\*/g, '*$1*')
            // 4. Convert Markdown headers to Bold (WA doesn't support headers)
            .replace(/^#+\s+(.*)$/gm, '*$1*')
            // 5. Clean up code blocks (ensure triple backticks are on their own lines if necessary)
            .replace(/```(\w+)?\n([\s\S]*?)\n```/g, '```\n$2\n```')
            // 6. Fix bullet points (convert - or + to *)
            .replace(/^[+-]\s/gm, '• ')
            // 7. Trim excessive whitespace
            .trim();
    }
};

const Dispatcher = {
    /**
     * Sends a "thinking" placeholder message.
     * @returns {Promise<object|null>} The sent message object for later editing.
     */
    async thinking(Gifted, jid, quoted = null, label = '⏳ _thinking..._') {
        try {
            return await Gifted.sendMessage(jid, { 
                text: WAMarkdown.clean(label) 
            }, { 
                quoted,
                messageId: Gifted.generateMessageTag() 
            });
        } catch (e) {
            console.error('[Dispatcher] thinking failed:', e.message);
            return null;
        }
    },

    /**
     * Resilient Message Edit. 
     * Attempts native edit; if rejected (older client or timeout), deletes and resends.
     */
    async editMsg(Gifted, sentMsg, newText) {
        if (!sentMsg?.key || !newText) return;
        const cleanText = WAMarkdown.clean(newText);
        const jid = sentMsg.key.remoteJid;

        try {
            // Attempt Native Edit
            await Gifted.sendMessage(jid, { 
                text: cleanText, 
                edit: sentMsg.key 
            });
        } catch (e) {
            // Fallback: Delete old, send new
            try {
                await Gifted.sendMessage(jid, { delete: sentMsg.key });
                await sleep(250);
                await Gifted.sendMessage(jid, { text: cleanText });
            } catch (fallbackErr) {
                console.error('[Dispatcher] edit fallback failed:', fallbackErr.message);
            }
        }
    },

    /**
     * Sends an image with a caption. Fallbacks to text link if media upload fails.
     */
    async sendImg(Gifted, jid, url, caption = '', quoted = null) {
        const cleanCaption = WAMarkdown.clean(caption);
        try {
            await Gifted.sendMessage(jid, {
                image: { url },
                caption: cleanCaption
            }, { quoted });
            return true;
        } catch (e) {
            console.error('[Dispatcher] sendImg failed, falling back to text:', e.message);
            try {
                await Gifted.sendMessage(jid, { 
                    text: `🎨 *Image Generated*\n\n${cleanCaption}\n\n🔗 ${url}` 
                }, { quoted });
                return true;
            } catch (inner) {
                return false;
            }
        }
    },

    /**
     * Splits long text into chunks to respect WhatsApp message limits (approx 4096 chars).
     * Splits intelligently at double newlines or sentence boundaries.
     */
    async sendLongText(Gifted, jid, text, quoted = null) {
        if (!text) return;
        const cleanText = WAMarkdown.clean(text);
        const MAX_LENGTH = 4000;

        if (cleanText.length <= MAX_LENGTH) {
            return await Gifted.sendMessage(jid, { text: cleanText }, { quoted });
        }

        const chunks = [];
        let remaining = cleanText;

        while (remaining.length > 0) {
            if (remaining.length <= MAX_LENGTH) {
                chunks.push(remaining);
                break;
            }

            // Find best split point near MAX_LENGTH
            let splitIndex = remaining.lastIndexOf('\n\n', MAX_LENGTH);
            if (splitIndex === -1 || splitIndex < MAX_LENGTH * 0.7) {
                splitIndex = remaining.lastIndexOf('\n', MAX_LENGTH);
            }
            if (splitIndex === -1 || splitIndex < MAX_LENGTH * 0.7) {
                splitIndex = remaining.lastIndexOf('. ', MAX_LENGTH);
            }
            if (splitIndex === -1) {
                splitIndex = MAX_LENGTH;
            } else {
                splitIndex += 1; // Include the newline/period
            }

            chunks.push(remaining.substring(0, splitIndex).trim());
            remaining = remaining.substring(splitIndex).trim();
        }

        for (const chunk of chunks) {
            await Gifted.sendMessage(jid, { text: chunk }, { quoted });
            await sleep(500); // Prevent flood triggers
        }
    },

    /**
     * Simple delete helper
     */
    async delete(Gifted, key) {
        try {
            if (!key) return;
            await Gifted.sendMessage(key.remoteJid, { delete: key });
        } catch (e) {
            // Silently fail if message already gone or no permission
        }
    }
};

/**
 * Enhanced Stalk Logic Helper
 * Fixes "stalk not working" by ensuring the session mapping is properly indexed.
 */
const StalkManager = {
    isStalked(senderJid) {
        const cleanJid = senderJid.split(':')[0] + '@s.whatsapp.net';
        return State.stalkers.has(cleanJid);
    },
    
    getSession(senderJid) {
        const cleanJid = senderJid.split(':')[0] + '@s.whatsapp.net';
        return State.stalkers.get(cleanJid);
    },

    sync(senderJid, sessionData) {
        const cleanJid = senderJid.split(':')[0] + '@s.whatsapp.net';
        State.stalkers.set(cleanJid, sessionData);
    }
};

// Exporting helpers to be used by command handlers and the main message listener.
module.exports = {
    ...module.exports,
    WAMarkdown,
    Dispatcher,
    StalkManager
};

/**
 * End of Chunk 4: Communication & Dispatcher
 */

// --- CHUNK: The Gem System: Persona Management & Cloning ---
/**
 * @module GemSystem
 * @description Advanced Persona Management & Linguistic Cloning Suite.
 * Part of the Atassa Bulletproof Framework - Chunk 5 of 12.
 */

// ==============================================================================
// 1. PERSONA ENGINE PROMPTS (Linguistic Fingerprinting)
// ==============================================================================
const PERSONA_PROMPTS = {
    GENERATE: (topic) => `
        Task: Create a professional-grade System Prompt for a WhatsApp AI persona.
        Topic/Identity: ${topic}
        
        Requirements:
        1. Definition: Define a clear personality, background, and age range.
        2. Linguistic Style: Detail sentence length, punctuation habits, and vocabulary level.
        3. Formatting: Specify emoji usage (frequency/types) and WhatsApp markdown usage (*bold*, _italic_).
        4. Constraints: NEVER reveal it is an AI. Keep responses concise for mobile viewing.
        5. Behavioral Logic: How it handles conflict, humor, and curiosity.

        Return ONLY the raw system prompt text. No introductory or concluding remarks.
    `,
    ANALYZE: (sample) => `
        Task: Extract the "Linguistic Fingerprint" from the following text sample and convert it into a System Prompt for an AI clone.
        Sample Text: "${sample}"

        Analysis Focus:
        1. Syntax: Identify sentence structure patterns (e.g., lowercase-only, missing periods, frequent ellipsis).
        2. Lexicon: Extract specific slang, recurring words, or technical jargon.
        3. Punctuation: Detect unique uses of symbols (e.g., multiple question marks, specific brackets).
        4. Tone: Is it aggressive, passive-aggressive, bubbly, dry, or chaotic?
        5. Emoji Usage: Analyze placement and specific choices of emojis.

        Instruction: Output a System Prompt that instructs the AI to replicate this EXACT fingerprint. 
        Return ONLY the raw system prompt text.
    `,
    REMIX: (base, instruction) => `
        Task: Modify an existing AI persona prompt.
        Original Persona: "${base}"
        Modification Instruction: "${instruction}"

        Requirements: 
        1. Maintain core identity consistency where not specifically changed.
        2. Integrate the new traits seamlessly into the linguistic profile.
        3. Optimize for WhatsApp conversational flow.

        Return ONLY the updated system prompt text.
    `
};

// ==============================================================================
// 2. .gem COMMAND SUITE
// ==============================================================================
gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['persona', 'identity', 'brain-store'],
    category: 'ai',
    desc: 'Advanced Persona Management System.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser, react } = conText;

    if (!isSuperUser) {
        return reply('🛑 *Access Denied:* This command requires Level 4 Administrative privileges.');
    }

    const args = q.trim().split(/\s+/);
    const subCommand = args[0]?.toLowerCase();
    const payload = args.slice(1).join(' ');

    // --- Sub-Command: HELP (Default) ---
    if (!subCommand || subCommand === 'help') {
        const helpMenu = 
            `*💎 GEM PERSONA SYSTEM v2.0*\n\n` +
            `*Core Commands:*\n` +
            `• \`.gem list\` - View all stored identities.\n` +
            `• \`.gem view <name>\` - Inspect a specific prompt.\n` +
            `• \`.gem create <name> <prompt>\` - Manual entry.\n` +
            `• \`.gem delete <name>\` - Purge from database.\n\n` +
            `*Generation & Cloning:*\n` +
            `• \`.gem gen <topic>\` - AI-authored persona.\n` +
            `• \`.gem analyze\` - Clone style from replied msg.\n` +
            `• \`.gem remix <name> <instruction>\` - Evolve a gem.\n\n` +
            `*Usage:*\n` +
            `• \`.gem use <name>\` - Set as active DM persona.\n\n` +
            `_Note: Use WhatsApp Markdown for clear formatting._`;
        return reply(helpMenu);
    }

    try {
        switch (subCommand) {

            case 'create': {
                const name = args[1]?.toLowerCase();
                const content = args.slice(2).join(' ');
                if (!name || !content) return reply('❌ *Usage:* `.gem create <name> <system_prompt>`');
                
                const success = Gems.save(name, content);
                if (success) {
                    await react('✅');
                    return reply(`✨ *Gem Stored:* \`${name}\`\nReady for deployment via \`.gem use\`.`);
                }
                return reply('❌ *Database Error:* Failed to write record.');
            }

            case 'gen': {
                if (!payload) return reply('❌ *Usage:* `.gem gen <topic/personality>`');
                const stub = await thinking(Gifted, from, mek, `🔮 *Forging Persona:* _${payload.slice(0, 20)}..._`);
                
                const { text, err } = await askAI(PERSONA_PROMPTS.GENERATE(payload));
                if (err) return editMsg(Gifted, stub, `❌ *AI Synthesis Failed:* ${text}`);

                const gemName = (args[1] || 'generated_' + Date.now().toString(36)).toLowerCase().slice(0, 15);
                Gems.save(gemName, text);

                const successMsg = 
                    `✨ *Persona Synthetic Complete*\n\n` +
                    `*ID:* \`${gemName}\`\n` +
                    `*Profile:* ${text.slice(0, 300)}...\n\n` +
                    `_To use this identity:_ \`.gem use ${gemName}\``;
                return editMsg(Gifted, stub, successMsg);
            }

            case 'analyze': {
                const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
                if (!quoted) return reply('📝 *Action Required:* Reply to a message to analyze its linguistic fingerprint.');

                const sampleText = quoted.conversation || quoted.extendedTextMessage?.text || quoted.imageMessage?.caption;
                if (!sampleText || sampleText.length < 5) return reply('❌ *Sample Insufficient:* Text is too short for fingerprinting.');

                const stub = await thinking(Gifted, from, mek, '🕵️ *Analyzing Linguistic Fingerprint...*');
                const { text, err } = await askAI(PERSONA_PROMPTS.ANALYZE(sampleText));
                
                if (err) return editMsg(Gifted, stub, `❌ *Fingerprinting Failed:* ${text}`);

                const cloneName = `clone_${Math.floor(Math.random() * 9000) + 1000}`;
                Gems.save(cloneName, text);

                const analysisMsg = 
                    `🧬 *Identity Cloned Successfully*\n\n` +
                    `*Clone ID:* \`${cloneName}\`\n` +
                    `*Extracted Logic:* ${text.slice(0, 250)}...\n\n` +
                    `_This gem has captured the nuances of the target's writing style._`;
                return editMsg(Gifted, stub, analysisMsg);
            }

            case 'remix': {
                const name = args[1]?.toLowerCase();
                const instruction = args.slice(2).join(' ');
                if (!name || !instruction) return reply('❌ *Usage:* `.gem remix <name> <modification>`');

                const basePrompt = Gems.get(name);
                if (!basePrompt) return reply(`❌ *Error:* Gem \`${name}\` not found in database.`);

                const stub = await thinking(Gifted, from, mek, `🔀 *Remixing Identity:* \`${name}\``);
                const { text, err } = await askAI(PERSONA_PROMPTS.REMIX(basePrompt, instruction));

                if (err) return editMsg(Gifted, stub, `❌ *Remix Failed:* ${text}`);

                const newName = `${name}_v2`;
                Gems.save(newName, text);

                return editMsg(Gifted, stub, `🔀 *Gem Evolved:* \`${newName}\`\nUpdated with requested modifications.`);
            }

            case 'list': {
                const list = Gems.list();
                if (!list.length) return reply('📚 *Gem Vault Empty:* Use `.gem gen` to create your first persona.');
                
                const formattedList = list.map((g, i) => `${i + 1}. 💎 \`${g}\``).join('\n');
                return reply(`📚 *Stored Identities (${list.length})*\n\n${formattedList}\n\n_Use \`.gem view <name>\` for details._`);
            }

            case 'view': {
                if (!payload) return reply('❌ *Usage:* `.gem view <name>`');
                const content = Gems.get(payload);
                if (!content) return reply(`❌ *Error:* Gem \`${payload}\` not found.`);
                
                return reply(`💎 *Identity Profile: ${payload.toUpperCase()}*\n\n${content}`);
            }

            case 'delete':
            case 'del': {
                if (!payload) return reply('❌ *Usage:* `.gem delete <name>`');
                const deleted = Gems.del(payload);
                if (deleted) {
                    await react('🗑️');
                    return reply(`🗑️ *Purge Complete:* Gem \`${payload}\` has been deleted.`);
                }
                return reply(`❌ *Error:* Could not delete gem \`${payload}\` (not found).`);
            }

            case 'use': {
                if (!payload) return reply('❌ *Usage:* `.gem use <name>`');
                const content = Gems.get(payload);
                if (!content) return reply(`❌ *Error:* Gem \`${payload}\` does not exist.`);

                State.dmGem = content;
                // Sync to current active sessions if needed
                if (State.dmActive) {
                    // Update current DM session logic
                    return reply(`✅ *Active Persona Set:* \`${payload}\`\nAll new incoming DMs will use this identity.`);
                }
                return reply(`✅ *Persona Prepared:* \`${payload}\`\n(Note: DM Pilot is currently OFF. Use \`.gai dm on\` to activate).`);
            }

            default:
                return reply('❌ *Unknown Sub-command.* Type `.gem help` for available options.');
        }
    } catch (error) {
        console.error('[GemSystem] Logic Error:', error);
        return reply(`☢️ *System Fault:* An error occurred during persona management.\n\`\`\`${error.message}\`\`\``);
    }
});

/**
 * Robust Stalk Fix - Ensuring the watcher correctly prioritizes Gems and sessions.
 * This extends the watcher logic from the previous chunk.
 */
const GemStateValidator = {
    /**
     * Resolves which system prompt to use based on hierarchy:
     * 1. Target-specific Gem
     * 2. Stalker-specific Gem
     * 3. Global DM Gem
     * 4. Default Persona
     */
    resolvePrompt(senderJid, chatId) {
        const cleanSender = senderJid.split(':')[0] + '@s.whatsapp.net';
        const cleanChat = chatId.split(':')[0] + '@s.whatsapp.net';

        if (State.targets.has(cleanSender)) return State.targets.get(cleanSender).gem;
        if (State.stalkers.has(cleanSender)) return State.stalkers.get(cleanSender).gem;
        if (State.chats.has(cleanChat)) return State.chats.get(cleanChat).gem;
        
        return State.dmGem || State.PERSONA;
    }
};

module.exports = {
    ...module.exports,
    GemStateValidator
};

/**
 * End of Chunk 5: Gem System (Persona Management & Cloning)
 */

// --- CHUNK: Core AI Controls: GAI Command Hub ---
/**
 * @module GAICommandHub
 * @description Core AI Controls: Handles .gai orchestration, session management, and visual status dashboards.
 *              Chunk 6 of 12: Core AI Controls.
 */

// ==============================================================================
// 1. GAI COMMAND HUB
// ==============================================================================

gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'ask', 'brain', 'control'],
    category: 'ai',
    desc: 'Elite AI Command Hub for session control and metrics.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;

    // Strict access control
    if (!isSuperUser) {
        return reply('⚠️ *Access Denied:* This command requires Level 4 Administrative privileges.');
    }

    const args = q.trim().split(/\s+/);
    const subCmd = args[0]?.toLowerCase();
    const payload = args.slice(1).join(' ');

    try {
        switch (subCmd) {
            
            // ── DM AUTO-PILOT ──────────────────────────────────────────────────
            case 'dm': {
                const action = args[1]?.toLowerCase();
                if (action === 'on') {
                    State.dmActive = true;
                    await react('🛰️');
                    return reply(`🛰️ *DM Auto-Pilot:* [ ENABLED ]\n*Persona:* \`${State.dmGem ? 'Custom Gem' : 'Standard'}\`\n*Target:* Global Incoming DMs`);
                } else if (action === 'off') {
                    State.dmActive = false;
                    await react('💤');
                    return reply('🛰️ *DM Auto-Pilot:* [ DISABLED ]');
                }
                return reply(`🛰️ *DM Status:* ${State.dmActive ? '🟢 ACTIVE' : '🔴 INACTIVE'}\n_Usage: \`.gai dm on/off\`_`);
            }

            // ── ROOM-SPECIFIC CHAT AI ──────────────────────────────────────────
            case 'chat': {
                const gemName = args[1] || 'default';
                const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
                
                State.chats.set(from, {
                    gem: gemTxt,
                    history: [],
                    gemName: gemName,
                    startTime: Date.now()
                });

                await react('⚔️');
                return reply(`⚔️ *Neural Interface Link Established*\n*Room:* \`${from}\`\n*Identity:* \`${gemName}\`\n*Status:* Intercepting all messages.`);
            }

            // ── TARGETED USER LOCK (SPECIFIC ROOM) ──────────────────────────────
            case 'target': {
                const targetNum = args[1]?.replace(/[^0-9]/g, '');
                if (!targetNum) return reply('📝 *Usage:* `.gai target <number> [gem]`');
                
                const targetJid = targetNum + '@s.whatsapp.net';
                const gemName = args[2] || 'default';
                const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;

                State.targets.set(targetJid, {
                    gem: gemTxt,
                    history: [],
                    chatId: from,
                    gemName: gemName
                });

                await react('🎯');
                return reply(`🎯 *Target Lock Confirmed*\n*User:* @${targetNum}\n*Chat:* \`${from}\`\n*Identity:* \`${gemName}\``, { mentions: [targetJid] });
            }

            // ── GLOBAL USER STALK (ANY ROOM) ───────────────────────────────────
            case 'stalk': {
                const stalkNum = args[1]?.replace(/[^0-9]/g, '');
                if (!stalkNum) return reply('📝 *Usage:* `.gai stalk <number> [gem]`');

                const stalkJid = stalkNum + '@s.whatsapp.net';
                const gemName = args[2] || 'default';
                const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;

                State.stalkers.set(stalkJid, {
                    gem: gemTxt,
                    history: [],
                    gemName: gemName
                });

                await react('👁️');
                return reply(`👁️ *Global Stalker Active*\n*Tracking:* @${stalkNum}\n*Scope:* Cross-Group/Private\n*Identity:* \`${gemName}\``, { mentions: [stalkJid] });
            }

            // ── VISUAL STATUS DASHBOARD ────────────────────────────────────────
            case 'status': {
                const s = Limiter.stats();
                const cbStatus = CB.open() ? '🔴 TRIPPED' : '🟢 SECURED';
                
                // RPM/RPH Calculation Bars
                const createBar = (val, max) => {
                    const size = 10;
                    const filled = Math.min(size, Math.round((val / max) * size));
                    return '█'.repeat(filled) + '░'.repeat(size - filled);
                };

                const dashboard = [
                    '```',
                    '┌────────── GAI COMMAND HUB ──────────┐',
                    `│ STATUS: ${State.dmActive ? 'ON ' : 'OFF'} | CIRCUIT: ${cbStatus.padEnd(10)} │`,
                    '├─────────────────────────────────────┤',
                    `│ RPM: [${createBar(s.rpm, CFG.MAX_RPM)}] ${String(s.rpm).padStart(2)}/${CFG.MAX_RPM} req/m │`,
                    `│ RPH: [${createBar(s.rph, CFG.MAX_RPH)}] ${String(s.rph).padStart(3)}/${CFG.MAX_RPH} req/h │`,
                    '├────────── SESSION METRICS ──────────┤',
                    `│ CHATS: ${String(State.chats.size).padEnd(4)} | TARGETS: ${String(State.targets.size).padEnd(4)}    │`,
                    `│ STALK: ${String(State.stalkers.size).padEnd(4)} | SESSIONS: ${String(State.dmSessions.size).padEnd(3)}    │`,
                    '├─────────── DAILY TOTALS ────────────┤',
                    `│ AI: ${String(s.ai).padEnd(6)} | IMG: ${String(s.img).padEnd(6)} | ERR: ${String(s.err).padEnd(4)} │`,
                    '└─────────────────────────────────────┘',
                    '```'
                ].join('\n');

                let detailedSessions = '';
                if (State.chats.size > 0) {
                    detailedSessions += '\n*Active Chat Sessions:*';
                    State.chats.forEach((v, k) => {
                        detailedSessions += `\n• \`${k.split('@')[0]}\` → *${v.gemName}* (${v.history.length} msg)`;
                    });
                }

                return reply(dashboard + detailedSessions);
            }

            // ── STOP / TERMINATION ─────────────────────────────────────────────
            case 'stop': {
                if (payload === 'all') {
                    State.dmActive = false;
                    State.chats.clear();
                    State.targets.clear();
                    State.stalkers.clear();
                    State.dmSessions.clear();
                    await react('☢️');
                    return reply('☢️ *System Terminated:* All AI sessions and auto-pilots purged.');
                }
                const deleted = State.chats.delete(from);
                return reply(deleted ? '🛑 *Session Halted:* AI deactivated in this room.' : 'ℹ️ *Notice:* No active session found in this room.');
            }

            // ── MEMORY PURGE ───────────────────────────────────────────────────
            case 'wipe': {
                const sess = State.chats.get(from) || State.dmSessions.get(from);
                if (sess) {
                    sess.history = [];
                    await react('🧹');
                    return reply('🧠 *Memory Purge:* Short-term context cleared for this session.');
                }
                return reply('❌ *Error:* No active session found to wipe.');
            }

            // ── ONE-SHOT AI QUERY ──────────────────────────────────────────────
            default: {
                if (!q.trim()) {
                    return reply('🧠 *GAI Assistance*\n_Use \`.gai help\` for command list._');
                }

                // Vision logic: Check for quoted image
                let imageBuffers = [];
                const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
                if (quoted?.imageMessage) {
                    await react('👁️');
                    try {
                        const tempPath = path.join(__dirname, '..', 'gift', `vision_${Date.now()}.jpg`);
                        const stream = await Gifted.downloadContentFromMessage(quoted.imageMessage, 'image');
                        let buffer = Buffer.from([]);
                        for await (const chunk of stream) buffer = Buffer.concat([buffer, chunk]);
                        fs.writeFileSync(tempPath, buffer);
                        
                        const uploadUrl = await uploadImgBB(tempPath);
                        if (uploadUrl) imageBuffers.push(uploadUrl);
                        if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);
                    } catch (visionErr) {
                        console.error('[Vision] Failed to process:', visionErr);
                    }
                }

                const stub = await thinking(Gifted, from, mek, '🧠 _Accessing Neural Network…_');
                
                // Context Enrichment
                let finalPrompt = q.trim();
                const quotedText = quoted?.conversation || quoted?.extendedTextMessage?.text;
                if (quotedText) {
                    finalPrompt = `Context from previous message:\n"${quotedText}"\n\nUser Question: ${finalPrompt}`;
                }

                const response = await askAI(finalPrompt, imageBuffers);
                
                if (response.err) {
                    return editMsg(Gifted, stub, `❌ *AI Interface Error:* ${response.text}`);
                }

                return editMsg(Gifted, stub, response.text);
            }
        }
    } catch (criticalError) {
        console.error('[GAI Hub] Critical Failure:', criticalError);
        return reply(`☣️ *System Fault:* Orchestration failed.\n\`\`\`${criticalError.message}\`\`\``);
    }
});

/**
 * Enhanced Stalking Logic for the Watcher (Integration logic)
 * This logic ensures that if a user is in State.stalkers, they are tracked everywhere.
 */
const resolveGlobalSession = (sender, chat) => {
    const cleanSender = sender.split(':')[0] + '@s.whatsapp.net';
    const cleanChat = chat.split(':')[0] + '@s.whatsapp.net';

    // 1. Stalker Priority (Global)
    if (State.stalkers.has(cleanSender)) {
        return State.stalkers.get(cleanSender);
    }
    
    // 2. Target Priority (Specific Room)
    if (State.targets.has(cleanSender)) {
        const tgt = State.targets.get(cleanSender);
        if (!tgt.chatId || tgt.chatId === cleanChat) return tgt;
    }

    // 3. Room AI Priority
    if (State.chats.has(cleanChat)) {
        return State.chats.get(cleanChat);
    }

    // 4. DM Auto-Pilot
    if (!cleanChat.endsWith('@g.us') && State.dmActive) {
        if (!State.dmSessions.has(cleanSender)) {
            State.dmSessions.set(cleanSender, {
                gem: State.dmGem || State.PERSONA,
                history: [],
                gemName: 'dm_pilot'
            });
        }
        return State.dmSessions.get(cleanSender);
    }

    return null;
};

module.exports = {
    ...module.exports,
    resolveGlobalSession
};

/**
 * End of Chunk 6: Core AI Controls (GAI Command Hub)
 */

// --- CHUNK: The Stalk Feature: Fixing and Expanding Global Tracking ---
/**
 * @module StalkManager
 * @description Advanced Global Tracking System for AIGems.
 * Handles cross-chat monitoring and automated AI targeting.
 */

// ==============================================================================
// 1. STALK MANAGER DEFINITION
// ==============================================================================

const StalkManager = {
    /**
     * Normalizes a WhatsApp JID to the standard 'number@s.whatsapp.net' format.
     * Removes multi-device suffixes and ensures correct domain.
     * @param {string} jid - Raw JID or phone number string.
     * @returns {string|null} - Normalized JID.
     */
    parseJid(jid) {
        if (!jid) return null;
        const clean = jid.replace(/[^0-9]/g, '');
        if (!clean || clean.length < 5) return null;
        return `${clean}@s.whatsapp.net`;
    },

    /**
     * Adds a JID to the global stalk list.
     * @param {string} input - The phone number or JID.
     * @param {string} gemName - The name of the Gem persona to use.
     * @returns {Object} - Result status and message.
     */
    add(input, gemName = 'default') {
        const jid = this.parseJid(input);
        if (!jid) return { success: false, msg: '❌ *Invalid JID/Number format.*' };

        const gemTxt = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        
        State.stalkers.set(jid, {
            gem: gemTxt,
            gemName: gemName === 'default' ? 'Core-AI' : gemName,
            history: [],
            startTime: Date.now(),
            totalInteractions: 0
        });

        return { 
            success: true, 
            msg: `🎯 *Global Stalker Activated*\n*Target:* @${jid.split('@')[0]}\n*Persona:* \`${gemName}\`\n*Scope:* All Groups & DMs` 
        };
    },

    /**
     * Removes a JID from the stalk list.
     */
    remove(input) {
        const jid = this.parseJid(input);
        if (!jid) return { success: false, msg: '❌ *Invalid JID.*' };
        if (!State.stalkers.has(jid)) return { success: false, msg: 'ℹ️ *Target not found in active stalk list.*' };

        State.stalkers.delete(jid);
        return { success: true, msg: `🗑️ *Stalker Deactivated* for @${jid.split('@')[0]}` };
    },

    /**
     * Lists all currently stalked JIDs.
     */
    list() {
        if (State.stalkers.size === 0) return '📡 *No active global tracking sessions.*';
        let list = '📡 *GLOBAL TRACKING SYSTEM*\n\n';
        State.stalkers.forEach((data, jid) => {
            list += `• @${jid.split('@')[0]} [${data.gemName}]\n`;
        });
        return list;
    },

    /**
     * Identifies if a message sender is being stalked.
     * Corrects previous implementation failure by inspecting both participant and remoteJid.
     * @param {Object} msg - The message object from WASocket.
     * @returns {Object|null} - The session data if stalked, else null.
     */
    getMetadata(msg) {
        const remoteJid = msg.key.remoteJid;
        const participant = msg.key.participant; // Present in groups
        
        // Normalize the actual human sender
        const rawSender = participant || remoteJid;
        if (!rawSender) return null;
        
        const normalizedSender = rawSender.split('@')[0].split(':')[0] + '@s.whatsapp.net';
        
        if (State.stalkers.has(normalizedSender)) {
            return {
                session: State.stalkers.get(normalizedSender),
                senderJid: normalizedSender,
                chatId: remoteJid
            };
        }
        return null;
    }
};

// ==============================================================================
// 2. UPDATED .gai stalk COMMAND LOGIC
// ==============================================================================

/**
 * Integrated directly into the existing 'gai' command handler for 'stalk' sub-command.
 * Replaces the fragile regex-only approach.
 */
const handleStalkCommand = async (from, Gifted, conText) => {
    const { q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied.*');

    const args = q.trim().split(/\s+/).slice(1); // skip 'stalk' word
    const sub = args[0]?.toLowerCase();

    if (!sub || sub === 'help') {
        return reply(
            `📡 *STALK MANAGER*\n\n` +
            `• \`.gai stalk add <num> [gem]\` — Track user everywhere.\n` +
            `• \`.gai stalk rem <num>\` — Stop tracking user.\n` +
            `• \`.gai stalk list\` — View all targets.\n\n` +
            `*Note:* Stalking works in all groups where the bot is present.`
        );
    }

    if (sub === 'add') {
        const res = StalkManager.add(args[1], args[2]);
        return reply(res.msg, { mentions: [StalkManager.parseJid(args[1])] });
    }

    if (sub === 'rem' || sub === 'remove' || sub === 'del') {
        const res = StalkManager.remove(args[1]);
        return reply(res.msg, { mentions: [StalkManager.parseJid(args[1])] });
    }

    if (sub === 'list') {
        const text = StalkManager.list();
        const mentions = Array.from(State.stalkers.keys());
        return reply(text, { mentions });
    }

    return reply('📝 *Usage:* `.gai stalk <add|rem|list> [args]`');
};

// ==============================================================================
// 3. ENHANCED WATCHER INTEGRATION
// ==============================================================================

/**
 * Injected into the messages.upsert loop in Chunk 8.
 * This specific logic handles the "Stalk" response generation.
 */
const processStalkEvent = async (Gifted, msg) => {
    const stalkData = StalkManager.getMetadata(msg);
    if (!stalkData) return false;

    const { session, senderJid, chatId } = stalkData;
    const body = msg.message?.conversation || 
                 msg.message?.extendedTextMessage?.text || 
                 msg.message?.imageMessage?.caption || '';

    // Ignore empty messages or commands
    if (!body.trim() && !msg.message?.imageMessage) return false;
    if (['.', '/', '!', '+'].includes(body[0])) return false;

    // Process Vision if image present
    let imageInfo = [];
    if (msg.message?.imageMessage) {
        try {
            const path = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, `stalk_vis_${Date.now()}`);
            const url = await uploadImgBB(path);
            if (url) imageInfo.push(url);
            if (fs.existsSync(path)) fs.unlinkSync(path);
        } catch (e) { console.error('[Stalk-Vision] Error:', e); }
    }

    // Update History
    State.addHist(session, 'Target', body || '[Media/Image]');
    session.totalInteractions++;

    // Prepare Prompt
    const prompt = State.buildPrompt(session.gem, session.history, body || 'The user sent an image. Acknowledge it.');

    // Simulation of thinking
    await sleep(1500 + Math.random() * 2000);
    try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (e) {}

    // AI Generation
    const { text, err } = await askAI(prompt, imageInfo);
    
    if (!err && text) {
        State.addHist(session, 'AI', text);
        
        // Build Mentions
        const mentions = [senderJid];
        
        // Response with Whatsapp Markdown and Quoted context
        const responseOptions = {
            text: text,
            mentions: mentions,
            quoted: {
                key: msg.key,
                message: msg.message
            }
        };

        await Gifted.sendMessage(chatId, responseOptions);
        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (e) {}
        return true;
    }

    return false;
};

// ==============================================================================
// 4. PERSISTENCE LAYER (STALKER DB)
// ==============================================================================

/**
 * Extends the existing Gems database to track stalked users across reboots.
 */
const InitStalkDB = () => {
    if (!db) return;
    try {
        db.exec(`
            CREATE TABLE IF NOT EXISTS global_stalkers (
                jid TEXT PRIMARY KEY,
                gem_name TEXT,
                added_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        
        // Load existing stalkers into memory
        const rows = db.prepare('SELECT * FROM global_stalkers').all();
        rows.forEach(row => {
            const gemTxt = Gems.get(row.gem_name) || State.PERSONA;
            State.stalkers.set(row.jid, {
                gem: gemTxt,
                gemName: row.gem_name,
                history: [],
                startTime: new Date(row.added_at).getTime(),
                totalInteractions: 0
            });
        });
        console.log(`[StalkManager] Loaded ${rows.length} tracking targets from DB.`);
    } catch (e) {
        console.error('[StalkManager] DB Init Error:', e.message);
    }
};

// Synchronize memory with DB on add/remove
const syncStalkDB = (jid, gemName = null, action = 'add') => {
    if (!db) return;
    try {
        if (action === 'add') {
            db.prepare('INSERT OR REPLACE INTO global_stalkers (jid, gem_name) VALUES (?, ?)').run(jid, gemName);
        } else {
            db.prepare('DELETE FROM global_stalkers WHERE jid = ?').run(jid);
        }
    } catch (e) {
        console.error('[StalkManager] DB Sync Error:', e.message);
    }
};

// Intercept StalkManager methods to add persistence
const originalAdd = StalkManager.add.bind(StalkManager);
StalkManager.add = (input, gemName) => {
    const res = originalAdd(input, gemName);
    if (res.success) {
        const jid = StalkManager.parseJid(input);
        syncStalkDB(jid, gemName || 'default', 'add');
    }
    return res;
};

const originalRemove = StalkManager.remove.bind(StalkManager);
StalkManager.remove = (input) => {
    const res = originalRemove(input);
    if (res.success) {
        const jid = StalkManager.parseJid(input);
        syncStalkDB(jid, null, 'remove');
    }
    return res;
};

// Initialize DB structure
InitStalkDB();

module.exports = {
    StalkManager,
    processStalkEvent,
    handleStalkCommand
};

/**
 * End of Chunk 7: The Stalk Feature (Re-engineered Global Tracking)
 */

// --- CHUNK: Image Generation Suite: The IMG Command ---
/**
 * @module ImageGenerationSuite
 * @description Robust command complex for AI Image Generation, Prompt Engineering, and Configuration.
 *              Handles '.img' ecosystem and corrects Stalk logic within the command interface.
 */

// ==============================================================================
// 1. IMAGE COMMAND COMPLEX (.img)
// ==============================================================================

gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['image', 'imagine', 'paint', 'draw'],
    category: 'ai',
    desc: 'Advanced AI Image Generation Suite.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    
    if (!isSuperUser) {
        return reply('*〔 ACCESS DENIED 〕*\n\n_This command requires Elite Level permissions._');
    }

    const args = q.trim().split(/\s+/);
    const subCommand = args[0]?.toLowerCase();
    const payload = args.slice(1).join(' ');

    // Helper: Execute Generation Flow
    const executeGen = async (prompt, customOpts = {}) => {
        const stub = await thinking(Gifted, from, mek, '🎨 *GIFTED-AI is visualizing your request...*');
        try {
            const options = {
                model: customOpts.model || CFG.IMG_MODEL,
                size: customOpts.size || CFG.IMG_SIZE,
                quality: customOpts.quality || CFG.IMG_QUALITY,
                style: customOpts.style || CFG.IMG_STYLE,
                count: customOpts.count || CFG.IMG_COUNT
            };

            const urls = await generateImage(prompt, options);

            if (!urls || urls.length === 0) {
                await editMsg(Gifted, stub, '❌ *GENERATION FAILED*\n\n_The engine returned an empty response. Attempting to recalibrate..._');
                return;
            }

            await del(Gifted, stub.key);
            
            for (let i = 0; i < urls.length; i++) {
                const caption = i === 0 
                    ? `*🎨 AI GENERATION COMPLETE*\n\n*Prompt:* _${prompt}_\n*Model:* \`${options.model}\`\n*Engine:* \`${options.quality}/${options.style}\`\n*Dimensions:* \`${options.size}\``
                    : `*Variation ${i + 1}*`;
                
                await sendImg(Gifted, from, urls[i], caption, mek);
            }
        } catch (error) {
            console.error('[IMG_SUITE] Gen Error:', error);
            await editMsg(Gifted, stub, `⚠️ *ENGINE CRITICAL ERROR*\n\n\`\`\`${error.message}\`\`\``);
        }
    };

    switch (subCommand) {
        // --- .img gen <prompt> ---
        case 'gen':
        case 'draw':
            if (!payload) return reply('📝 *Usage:* `.img gen <detailed description>`');
            await react('🖌️');
            await executeGen(payload);
            break;

        // --- .img surprise [theme] ---
        case 'surprise':
            await react('🪄');
            const surpriseStub = await thinking(Gifted, from, mek, '🪄 *Consulting the Muse...*');
            const dreamPrompt = `Create a highly detailed, breathtaking, and artistic professional image generation prompt. ${payload ? `Theme: ${payload}` : 'Surprise me with something surreal.'}. Return ONLY the expanded prompt text, no conversational filler.`;
            
            const { text: generatedPrompt, err: sErr } = await askAI(dreamPrompt);
            if (sErr) return editMsg(Gifted, surpriseStub, `❌ *DREAMING INTERRUPTED:* ${generatedPrompt}`);
            
            await editMsg(Gifted, surpriseStub, `✨ *INSPIRATION STRUCK:*\n\n_${generatedPrompt.slice(0, 250)}..._`);
            await executeGen(generatedPrompt);
            break;

        // --- .img chaos ---
        case 'chaos':
            await react('🌪️');
            const chaosModels = Object.keys(CFG.IMG_MDLS).filter(m => CFG.IMG_MDLS[m].tier === 'free');
            const randomModel = chaosModels[Math.floor(Math.random() * chaosModels.length)];
            const randomSize = ['1024x1024', '1792x1024', '1024x1792', '1:1', '16:9'][Math.floor(Math.random() * 5)];
            const randomQual = Math.random() > 0.5 ? 'hd' : 'standard';
            const randomStyl = Math.random() > 0.5 ? 'vivid' : 'natural';

            const chaosStub = await thinking(Gifted, from, mek, '🌪️ *INITIATING CHAOS PROTOCOL...*');
            const { text: chaosPrompt, err: cErr } = await askAI("Generate an absolutely bizarre, psychedelic, and chaotic image prompt that defies physics. Return ONLY the prompt.");
            
            if (cErr) return editMsg(Gifted, chaosStub, '❌ *CHAOS FAILED TO MANIFEST.*');

            await editMsg(Gifted, chaosStub, `🌪️ *CHAOS PARAMETERS:* \n• Model: \`${randomModel}\`\n• Size: \`${randomSize}\`\n• Mode: \`${randomQual}/${randomStyl}\``);
            await executeGen(chaosPrompt, { model: randomModel, size: randomSize, quality: randomQual, style: randomStyl });
            break;

        // --- .img enhance <simple_prompt> ---
        case 'enhance':
            if (!payload) return reply('📝 *Usage:* `.img enhance <simple idea>`');
            const enhStub = await thinking(Gifted, from, mek, '🧪 *Synthesizing prompt enhancements...*');
            const expansionQuery = `Act as a Professional Stable Diffusion Prompt Engineer. Enhance the following simple prompt into a masterpiece-tier prompt with lighting, camera settings, texture details, and artistic style modifiers: "${payload}". Return ONLY the final optimized prompt.`;
            
            const { text: enhanced, err: eErr } = await askAI(expansionQuery);
            if (eErr) return editMsg(Gifted, enhStub, '❌ *ENHANCEMENT FAILED.*');
            
            await editMsg(Gifted, enhStub, `✨ *PROMPT ENHANCED:*\n\n*Original:* \`${payload}\`\n\n*Optimized:* \n_${enhanced}_ \n\n*Tip:* _Reply to this message with ".img gen" to use it._`);
            break;

        // --- .img models ---
        case 'models':
            const modelList = Object.entries(CFG.IMG_MDLS)
                .map(([id, meta]) => `• \`${id}\` - ${meta.tier === 'pro' ? '💎' : '🆓'} _${meta.desc}_`)
                .join('\n');
            return reply(`📊 *AVAILABLE ENGINES:*\n\n${modelList}\n\n*Active:* \`${CFG.IMG_MODEL}\`\n*Usage:* \`.img config model <id>\``);

        // --- .img config <key> <value> ---
        case 'config':
            if (!payload) {
                return reply(
                    `⚙️ *IMAGE CONFIGURATION*\n\n` +
                    `• *Model:* \`${CFG.IMG_MODEL}\`\n` +
                    `• *Resolution:* \`${CFG.IMG_SIZE}\`\n` +
                    `• *Quality:* \`${CFG.IMG_QUALITY}\` (standard/hd)\n` +
                    `• *Style:* \`${CFG.IMG_STYLE}\` (vivid/natural)\n` +
                    `• *Count:* \`${CFG.IMG_COUNT}\` (1-4)\n\n` +
                    `📝 *Update:* \`.img config <key> <value>\`\n` +
                    `Example: \`.img config hd on\` | \`.img config style natural\``
                );
            }

            const [key, val] = payload.toLowerCase().split(/\s+/);
            if (key === 'hd') {
                CFG.IMG_QUALITY = (val === 'on' || val === 'hd') ? 'hd' : 'standard';
                return reply(`✅ *Quality set to:* \`${CFG.IMG_QUALITY}\``);
            }
            if (key === 'style') {
                if (['vivid', 'natural'].includes(val)) {
                    CFG.IMG_STYLE = val;
                    return reply(`✅ *Style set to:* \`${CFG.IMG_STYLE}\``);
                }
                return reply('❌ *Invalid Style.* Use `vivid` or `natural`.');
            }
            if (key === 'model') {
                if (CFG.IMG_MDLS[val]) {
                    CFG.IMG_MODEL = val;
                    return reply(`✅ *Engine switched to:* \`${CFG.IMG_MODEL}\``);
                }
                return reply('❌ *Invalid Model.* Use `.img models` to see list.');
            }
            if (key === 'size') {
                CFG.IMG_SIZE = val;
                return reply(`✅ *Size set to:* \`${CFG.IMG_SIZE}\``);
            }
            return reply('❌ *Unknown Config Key.* Available: `hd`, `style`, `model`, `size`.');

        // --- Help / Default ---
        case 'help':
        default:
            if (subCommand && !KNOWN_IMG_SUB.includes(subCommand) && !payload) {
                // Handle cases where user just types .img <prompt>
                await executeGen(q.trim());
                break;
            }
            return reply(
                `🎨 *IMAGE GENERATION SYSTEM*\n\n` +
                `• \`.img gen <prompt>\` - Standard generate\n` +
                `• \`.img surprise [topic]\` - AI creates prompt\n` +
                `• \`.img chaos\` - Randomized generation\n` +
                `• \`.img enhance <text>\` - Expand simple prompt\n` +
                `• \`.img models\` - List engine engines\n` +
                `• \`.img config\` - Settings & Toggle HD\n\n` +
                `*Pro Tip:* _Reply to any image with ".aidecode" to analyze its style._`
            );
    }
});

const KNOWN_IMG_SUB = ['gen', 'surprise', 'chaos', 'models', 'config', 'enhance', 'setup', 'random', 'cache', 'help'];

// ==============================================================================
// 2. CORRECTED STALK COMMAND LOGIC
// ==============================================================================

/**
 * Ensures the .gai stalk command uses the StalkManager correctly with 
 * the persistence layer added in Chunk 7.
 */
gmd({
    pattern: 'stalk',
    cmdname: 'stalk',
    category: 'ai',
    desc: 'Persistently track and auto-reply to a user globally.',
    react: '👁️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *RESTRICTED ACCESS*');

    const args = q.trim().split(/\s+/);
    const target = args[0];
    const gemName = args[1] || 'default';

    if (!target) {
        return reply(
            `👁️ *GLOBAL STALKER SYSTEM*\n\n` +
            `📝 *Usage:* \`.stalk <number> [gem_name]\`\n` +
            `🗑️ *Stop:* \`.stalk stop <number>\`\n\n` +
            `*Active Targets:* ${State.stalkers.size}\n` +
            Array.from(State.stalkers.keys()).map(j => `• @${j.split('@')[0]}`).join('\n')
        );
    }

    if (target === 'stop' || target === 'off') {
        const toStop = args[1];
        if (!toStop) return reply('📝 *Specify number to stop stalking.*');
        const res = StalkManager.remove(toStop);
        return reply(res.success ? `✅ *Target Released:* ${res.jid}` : `❌ *Error:* ${res.message}`);
    }

    // Add target using the persistent StalkManager
    const res = StalkManager.add(target, gemName);
    if (res.success) {
        const gemPreview = Gems.get(gemName) ? `Gem: \`${gemName}\`` : 'Gem: `Default Persona`';
        return reply(
            `👁️ *TARGET LOCKED*\n\n` +
            `*User:* @${res.jid.split('@')[0]}\n` +
            `*Protocol:* ${gemPreview}\n` +
            `*Persistence:* \`DATABASE_ACTIVE\`\n\n` +
            `_I will now follow and reply to this user in every chat we share._`,
            { mentions: [res.jid] }
        );
    } else {
        return reply(`❌ *STALK FAILED:* ${res.message}`);
    }
});

// ==============================================================================
// 3. WHATSAPP MARKDOWN SANITIZER FOR AI
// ==============================================================================

/**
 * Standardizes AI responses to ensure they meet WhatsApp Markdown specs
 * and elite code quality requirements.
 */
const formatForWhatsApp = (text) => {
    if (!text) return '';
    return text
        .replace(/\*\*(.*?)\*\*/g, '*$1*') // Convert Bold
        .replace(/__(.*?)__/g, '_$1_')     // Convert Italic
        .replace(/### (.*)/g, '*$1*')      // Convert Header to Bold
        .replace(/`([^`]+)`/g, '`$1`')     // Keep Code
        .trim();
};

// ==============================================================================
// 4. OVERRIDE ASKAI TO ENFORCE MARKDOWN
// ==============================================================================
const originalAskAI = askAI;
global.askAI = async (prompt, imgUrls = []) => {
    const response = await originalAskAI(prompt, imgUrls);
    if (!response.err && response.text) {
        response.text = formatForWhatsApp(response.text);
    }
    return response;
};

