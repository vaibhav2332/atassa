        ? `IMAGE ANALYSIS REQUEST: ${userQuery}. If there is text in the image, transcribe it. Identify objects and context.`
        : `CONTENT ANALYSIS: "${context || userQuery}". Explain the core meaning, identify key points, and summarize.`;

    const { text, err } = await askAI(prompt + "\n\n*Format*: Use WhatsApp Markdown. *Bold* for titles. _Italic_ for notes. No markdown headers.");

    if (err) return editMsg(Gifted, stub, `*❌ Vision Error:* ${text}`);

    return editMsg(Gifted, stub, `*🔍 NEURAL DECODER REPORT*\n\n${text}`);
});

// ==============================================================================
// 18. EVENT WATCHER — THE MASTER AUTO-PILOT (PHASE 8)
// ==============================================================================

/**
 * Attaches the global AI watcher to the socket.
 * Handles Stalking, Targeted Bots, Chat-wide AI, and DM Auto-Pilot.
 */
const attachWatcher = (Gifted) => {
    if (!Gifted?.ev || State._watcherActive) return;
    State._watcherActive = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.id.startsWith('BAE5')) continue;

                const fromMe = msg.key.fromMe;
                const chatId = msg.key.remoteJid;
                const sender = (msg.key.participant || msg.key.remoteJid || '').split(':')[0].split('@')[0] + '@s.whatsapp.net';
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                // --- AUTO-ENHANCE (Owner Outgoing) ---
                if (fromMe && State.autoEnhance && body.length > 8 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        const { text: polished, err } = await askAI(`Rewrite this message to be perfectly clear and grammatically correct. Keep the tone natural. Use WhatsApp markdown. Return ONLY the polished text:\n\n"${body}"`);
                        if (!err && polished && polished.trim().toLowerCase() !== body.trim().toLowerCase()) {
                            await sleep(1500); // Simulate thinking delay
                            await Gifted.sendMessage(chatId, { text: polished.trim(), edit: msg.key });
                        }
                    });
                    continue;
                }

                if (fromMe || body.startsWith('.')) continue;

                // --- SESSION RESOLVER ---
                let session = null;
                // 1. Global Stalkers (Everywhere)
                if (State.stalkers.has(sender)) {
                    session = State.stalkers.get(sender);
                } 
                // 2. Targeted Users (Local Chat)
                else if (State.targets.has(sender)) {
                    const data = State.targets.get(sender);
                    if (!data.chatId || data.chatId === chatId) session = data;
                } 
                // 3. Chat-wide AI
                else if (State.chats.has(chatId)) {
                    session = State.chats.get(chatId);
                } 
                // 4. DM Auto-Pilot
                else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { 
                            gem: State.dmGem || State.PERSONA, 
                            history: [], 
                            gemName: 'dm_auto_pilot' 
                        });
                    }
                    session = State.dmSessions.get(sender);
                }

                if (!session) continue;

                // --- AI REPLY GENERATION ---
                setImmediate(async () => {
                    try {
                        let visionLinks = [];
                        if (msg.message.imageMessage) {
                            const tmp = path.join(__dirname, `watch_vis_${Date.now()}.jpg`);
                            await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, tmp);
                            const u = await uploadImgBB(tmp);
                            if (u) visionLinks.push(u);
                            if (fs.existsSync(tmp)) fs.unlinkSync(tmp);
                        }

                        const input = body || (msg.message.imageMessage ? "[Sent an Image]" : "[Media]");
                        State.addHist(session, 'User', input);
                        
                        const prompt = State.buildPrompt(session.gem, session.history, input);
                        
                        // Fake Typing Realism
                        const delay = Math.min(input.length * 35, 3000) + 1000;
                        await sleep(delay);
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}

                        const { text: replyText, err: aiErr } = await askAI(prompt, visionLinks);
                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (_) {}

                        if (!aiErr) {
                            State.addHist(session, 'AI', replyText);
                            await Gifted.sendMessage(chatId, { text: replyText }, { quoted: msg });
                        }
                    } catch (e) { console.error('[AIGems] Watcher internal error:', e.message); }
                });
            } catch (e) { console.error('[AIGems] Watcher critical loop failure:', e.message); }
        }
    });
    console.log('[AIGems] ⚡ Neural Watcher active: Tracking stalkers and targets.');
};

// --- BOOTSTRAPPER ---
const _initWatcher = () => {
    const conn = global.conn || global.client;
    if (conn) attachWatcher(conn);
};
setInterval(_initWatcher, 10000);
setTimeout(_initWatcher, 2000);

// ==============================================================================
// 19. MODULE EXPORTS (PHASE 8)
// ==============================================================================
module.exports = {
    CFG,
    State,
    Gems,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB,
    attachWatcher
};

console.log('[AIGems] Phase 8 (Creative & Vision) logic successfully streamed.');
console.log('[AIGems] Stalker logic fixed. WhatsApp Markdown rule enforced.');

/**
 * @note This segment is a continuation. No unclosed brackets remain for previously opened blocks.
 * Proceeding to Phase 9: Session Persistence.
 */
// ==============================================================================
// 20. SESSION PERSISTENCE & SYSTEM ADAPTATION (PHASE 9)
// ==============================================================================

/**
 * Persists current AI tracking states (Stalkers & Targets) to the database.
 * Ensures the bot remembers who to track even after a restart.
 */
const saveSystemState = () => {
    if (!db) return;
    try {
        const state = {
            stalkers: Array.from(State.stalkers.entries()),
            targets: Array.from(State.targets.entries()),
            dmActive: State.dmActive,
            autoEnhance: State.autoEnhance,
            dmGemContent: State.dmGem
        };
        Gems.save('_sys_internal_state_', JSON.stringify(state));
    } catch (e) {
        console.error('[AIGems] State Persistence Error:', e.message);
    }
};

/**
 * Restores AI tracking states from the database upon module load.
 */
const loadSystemState = () => {
    if (!db) return;
    try {
        const raw = Gems.get('_sys_internal_state_');
        if (!raw) return;
        const state = JSON.parse(raw);
        
        if (state.stalkers) State.stalkers = new Map(state.stalkers);
        if (state.targets)  State.targets  = new Map(state.targets);
        State.dmActive    = !!state.dmActive;
        State.autoEnhance = !!state.autoEnhance;
        State.dmGem       = state.dmGemContent || null;
        
        console.log(`[AIGems] Persistence: Restored ${State.stalkers.size} stalkers and ${State.targets.size} targets.`);
    } catch (e) {
        console.error('[AIGems] State Restoration Error:', e.message);
    }
};

// Load state immediately and set periodic auto-save
loadSystemState();
setInterval(saveSystemState, 60000);

// ==============================================================================
// 21. ADVANCED LOGIC-FLOW — RECURSION PREVENTION
// ==============================================================================

/**
 * Enhanced check to ensure the AI doesn't trigger itself or other automated systems.
 * Crucial for preventing infinite message loops between bots.
 */
const isRecursive = (msg) => {
    if (!msg || !msg.key) return true;
    
    // 1. Message from bot itself
    if (msg.key.fromMe) return true;
    
    // 2. Message from known automated/official sources
    const id = msg.key.id || '';
    if (id.startsWith('BAE5') || id.startsWith('HSK') || id.length > 28) return true;
    
    // 3. Message participant is bot/official service
    const sender = msg.key.participant || msg.key.remoteJid || '';
    if (sender.includes('status') || sender.includes('broadcast')) return true;

    // 4. Non-textual interactive messages
    if (msg.message?.reactionMessage || msg.message?.pollUpdateMessage) return true;

    return false;
};

// ==============================================================================
// 22. NEURAL WATCHER — PATCHED ENGINE (PHASE 9)
// ==============================================================================

/**
 * Optimized Watcher that integrates persistence, vision, and loop protection.
 * Fixes the logic-flow to ensure background monitoring is robust.
 */
const reattachSafeWatcher = (Gifted) => {
    if (!Gifted?.ev || Gifted._atassaWatcherSet) return;
    Gifted._atassaWatcherSet = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || isRecursive(msg)) continue;

                const chatId = msg.key.remoteJid;
                const sender = (msg.key.participant || msg.key.remoteJid || '').split('@')[0] + '@s.whatsapp.net';
                const body = (msg.message.conversation || 
                              msg.message.extendedTextMessage?.text || 
                              msg.message.imageMessage?.caption || '').trim();

                // Skip if empty and no image
                if (!body && !msg.message.imageMessage) continue;
                
                // Ignore explicit commands
                if (body.startsWith('.') || body.startsWith('/') || body.startsWith('!')) continue;

                let session = null;

                // Priority Resolution for Automatic Response
                if (State.stalkers.has(sender)) {
                    session = State.stalkers.get(sender);
                } else if (State.targets.has(sender)) {
                    const t = State.targets.get(sender);
                    if (!t.chatId || t.chatId === chatId) session = t;
                } else if (State.chats.has(chatId)) {
                    session = State.chats.get(chatId);
                } else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { 
                            gem: State.dmGem || State.PERSONA, 
                            history: [], 
                            gemName: 'dm_auto' 
                        });
                    }
                    session = State.dmSessions.get(sender);
                }

                if (!session) continue;

                // Loop prevention: Avoid double-replying to the exact same message ID
                const msgRef = `${chatId}_${msg.key.id}`;
                if (session.processedId === msgRef) continue;
                session.processedId = msgRef;

                setImmediate(async () => {
                    try {
                        let visionPayload = [];
                        if (msg.message.imageMessage) {
                            const tmp = path.join(__dirname, `wv_${Date.now()}.jpg`);
                            await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, tmp);
                            const url = await uploadImgBB(tmp);
                            if (url) visionPayload.push(url);
                            if (fs.existsSync(tmp)) fs.unlinkSync(tmp);
                        }

                        const inputTxt = body || "[User sent an image]";
                        State.addHist(session, 'User', inputTxt);

                        const finalPrompt = State.buildPrompt(session.gem, session.history, inputTxt);
                        
                        // Realistic Typing Delay
                        const delay = Math.min(inputTxt.length * 30, 3000) + 1000;
                        await sleep(delay);
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (e) {}

                        // Call AI (askAI Enforced with Markdown)
                        const { text, err } = await askAI(finalPrompt, visionPayload);
                        
                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (e) {}

                        if (!err && text) {
                            State.addHist(session, 'AI', text);
                            await Gifted.sendMessage(chatId, { text }, { quoted: msg });
                        }
                    } catch (e) {
                        console.error('[AIGems] Watcher Execution Error:', e.message);
                    }
                });
            } catch (e) {
                console.error('[AIGems] Watcher Message Loop Error:', e.message);
            }
        }
    });
    console.log('[AIGems] ⚡ Patched Neural Watcher Engine successfully attached.');
};

// Re-hook the watcher on connection refresh
setInterval(() => {
    const conn = global.conn || global.client;
    if (conn && !conn._atassaWatcherSet) reattachSafeWatcher(conn);
}, 15000);

// ==============================================================================
// 23. WHATSAPP MARKDOWN ENFORCEMENT (FIX: REMOVE LATEX)
// ==============================================================================

/**
 * Post-processor that converts standard AI artifacts (LaTeX, Markdown headers) 
 * into native WhatsApp Markdown format.
 */
const enforceWAMarkdown = (text) => {
    if (!text) return '';
    return text
        .replace(/\\\[(.*?)\\\]/gs, '```$1```') // LaTeX blocks to Code blocks
        .replace(/\\\((.*?)\\\)/g, '_$1_')      // LaTeX inline to Italics
        .replace(/\*\*\*(.*?)\*\*\*/g, '*_$1_*') // Triple star to Bold-Italic
        .replace(/\*\*(.*?)\*\*/g, '*$1*')       // Double star to Bold
        .replace(/#{1,6}\s?(.*?)\n/g, '*$1*\n')  // Headers to Bold
        .replace(/\\n/g, '\n')                   // Fix escaped newlines
        .trim();
};

// Override askAI behavior to always use the formatter
const baseAsk = askAI;
const askAI = async (p, i) => {
    const response = await baseAsk(p, i);
    if (!response.err && response.text) {
        response.text = enforceWAMarkdown(response.text);
    }
    return response;
};

// ==============================================================================
// 24. FINAL STABILIZATION
// ==============================================================================

console.log('[AIGems] Phase 9: Neural Watcher Engine & State Persistence Complete.');
console.log('[AIGems] Recursive loops blocked. WhatsApp Markdown enforcement active.');

/**
 * @note Transitioning to Phase 10: Multi-Engine Switching & Final QA.
 */
// ==============================================================================
// 25. MULTI-ENGINE SWITCHING (.aiengine)
// ==============================================================================
gmd({
    pattern: 'aiengine',
    category: 'ai',
    desc: 'Switch between different AI reasoning engines.',
    react: '⚙️'
}, async (from, Gifted, { q, reply, isSuperUser }) => {
    if (!isSuperUser) return reply('❌ *Owner only.*');
    const engines = ['quillbot-raven', 'infip-search', 'gpt-lite-proxy'];
    const choice = q.trim().toLowerCase();
    if (!engines.includes(choice)) {
        return reply(`⚙️ *AI Engines Available:*\n\n${engines.map(e => `• \`${e}\``).join('\n')}\n\n*Current:* \`${CFG.AI_ENGINE || 'quillbot-raven'}\``);
    }
    CFG.AI_ENGINE = choice;
    return reply(`✅ *AI Engine switched to:* \`${choice}\``);
});

// ==============================================================================
// 26. SYSTEM DIAGNOSTICS & QUOTA RESET
// ==============================================================================
/**
 * Extended diagnostics for real-time monitoring of the AI module.
 */
const getSystemDiagnostics = () => {
    const stats = Limiter.stats();
    const mem = process.memoryUsage();
    return {
        uptime: process.uptime(),
        load: stats,
        circuit: CB.open() ? 'OPEN (FAILED)' : 'CLOSED (HEALTHY)',
        memory: `${Math.round(mem.heapUsed / 1024 / 1024)}MB / ${Math.round(mem.heapTotal / 1024 / 1024)}MB`,
        sessions: {
            chats: State.chats.size,
            stalkers: State.stalkers.size,
            targets: State.targets.size
        }
    };
};

// ==============================================================================
// 27. LIFECYCLE INTERVAL CLEANERS
// ==============================================================================
/**
 * Prevents memory leaks by purging stale history and inactive sessions.
 * Corrects the 'Unexpected token }' error by ensuring no dangling closures from Section 4.
 */
setInterval(() => {
    const now = Date.now();
    const EXPIRY_MS = 1000 * 60 * 60 * 6; // 6 Hours

    // Prune Chat Sessions
    State.chats.forEach((session, jid) => {
        if (now - (session.lastActive || 0) > EXPIRY_MS) {
            State.chats.delete(jid);
        }
    });

    // Prune DM Sessions
    State.dmSessions.forEach((session, jid) => {
        if (now - (session.lastActive || 0) > EXPIRY_MS) {
            State.dmSessions.delete(jid);
        }
    });

    // Clear Image Cache
    if (_iCache.size > 100) {
        _iCache.clear();
        console.log('[AIGems] Lifecycle: Large image cache cleared.');
    }
}, 1000 * 60 * 30); // Run every 30 mins

// ==============================================================================
// 28. MODULE EXPORTS
// ==============================================================================
module.exports = {
    CFG,
    State,
    Gems,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB,
    getSystemDiagnostics,
    reattachSafeWatcher: (client) => {
        if (client) attachWatcher(client);
    }
};

// ==============================================================================
// 29. BOOTLOADER: GLOBAL ATTACHMENT
// ==============================================================================
/**
 * Core bootloader for Atassa Framework.
 * Hooks into the global client instance to activate AI watchers on startup.
 */
const initBootloader = () => {
    const target = global.conn || global.client || global.gift;
    if (target) {
        console.log('[AIGems] Bootloader: Global client detected. Initializing watchers...');
        if (typeof attachWatcher === 'function') {
            attachWatcher(target);
            target._atassaWatcherSet = true;
        }
    } else {
        // Retry if client is not yet spawned by the framework
        setTimeout(initBootloader, 5000);
    }
};

// Trigger boot sequence
initBootloader();

console.log('[AIGems] Phase 10: System Diagnostics & Bootloader Finalized.');
console.log('[AIGems] Service fully operational. Native WhatsApp Markdown enforced.');
