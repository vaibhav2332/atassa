    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ").trim();
        const parts = q.split(/\s+/);
        const sub = parts[0]?.toLowerCase();

        if (!q || sub === "help") {
            return sock.sendMessage(jid, { text: `🎨 *AI Image Suite*\n\n` +
                `• \`.img gen <prompt>\` — Generate image\n` +
                `• \`.img chaos\` — Random prompt & model\n` +
                `• \`.img models\` — List available engines\n` +
                `• \`.img config <model>\` — Set default engine\n` +
                `• \`.img enhance <prompt>\` — Refine your prompt\n\n` +
                `*Current Model:* \`${CFG.IMG_MODEL}\`` }, buildSafeQuote(m));
        }

        if (sub === "gen") {
            const prompt = parts.slice(1).join(" ");
            if (!prompt) return sock.sendMessage(jid, { text: "📝 *Provide a prompt:* `.img gen a futuristic city`" }, buildSafeQuote(m));
            const stub = await sock.sendMessage(jid, { text: "🎨 _Generating your vision..._" }, buildSafeQuote(m));
            const urls = await generateImage(prompt);
            if (!urls.length) return sock.sendMessage(jid, { text: "❌ *Generation failed.* Try another model or prompt.", edit: stub.key });
            try { await sock.sendMessage(jid, { delete: stub.key }); } catch(e) {}
            return sock.sendMessage(jid, { image: { url: urls[0] }, caption: `✨ *Prompt:* ${prompt}\n🤖 *Model:* ${CFG.IMG_MODEL}` }, buildSafeQuote(m));
        }

        if (sub === "models") {
            const list = Object.entries(CFG.IMG_MDLS).map(([id, info]) => `• \`${id}\` — ${info.desc} (${info.tier})`).join("\n");
            return sock.sendMessage(jid, { text: `📋 *Available AI Models:*\n\n${list}` }, buildSafeQuote(m));
        }

        if (sub === "config") {
            const model = parts[1]?.toLowerCase();
            if (!CFG.IMG_MDLS[model]) return sock.sendMessage(jid, { text: `❌ *Invalid model.* Use \`.img models\` to see options.` }, buildSafeQuote(m));
            CFG.IMG_MODEL = model;
            return sock.sendMessage(jid, { text: `✅ *Default model set to:* \`${model}\`` }, buildSafeQuote(m));
        }

        if (sub === "chaos") {
            const models = Object.keys(CFG.IMG_MDLS);
            const randModel = models[Math.floor(Math.random() * models.length)];
            const stub = await sock.sendMessage(jid, { text: `🌪️ *Chaos Mode:* Using \`${randModel}\`...` }, buildSafeQuote(m));
            const { text: randPrompt } = await askAI("Generate a short, extremely detailed, and surreal image prompt. Return only the prompt.");
            const urls = await generateImage(randPrompt, { model: randModel });
            if (!urls.length) return sock.sendMessage(jid, { text: "❌ *Chaos failed.* Trigger again.", edit: stub.key });
            try { await sock.sendMessage(jid, { delete: stub.key }); } catch(e) {}
            return sock.sendMessage(jid, { image: { url: urls[0] }, caption: `🌪️ *Chaos Result*\n\n*Prompt:* ${randPrompt}\n*Engine:* ${randModel}` }, buildSafeQuote(m));
        }
    });

    /**
     * .apimon: Health and performance monitoring.
     */
    commandRegister({
        pattern: "apimon",
        cmdname: "apimon",
        alias: ["health", "usage"],
        category: "ai",
        desc: "Monitor AI API health and circuit breaker status.",
        react: "📊",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const stats = Limiter.stats();
        const cbStatus = CB.open() ? "🔴 *TRIPPED* (Cooldown active)" : "🟢 *CLOSED* (Healthy)";
        
        const report = `📊 *AI API Monitor*\n\n` +
            `• *Circuit Breaker:* ${cbStatus}\n` +
            `• *Requests (1m):* ${stats.rpm} / ${CFG.MAX_RPM}\n` +
            `• *Requests (1h):* ${stats.rph} / ${CFG.MAX_RPH}\n` +
            `• *Daily Total:* ${stats.ai} calls\n` +
            `• *Error Rate:* ${stats.err} failed\n` +
            `• *Provider:* QuillBot (Scraper/SSE)\n\n` +
            `_Note: If circuit is tripped, wait 5 mins for auto-reset._`;
        
        return sock.sendMessage(m.key.remoteJid, { text: report }, buildSafeQuote(m));
    });

    /**
     * .aitranslate: Fast multi-lingual translation.
     */
    commandRegister({
        pattern: "aitranslate",
        cmdname: "aitranslate",
        alias: ["tr", "translate"],
        category: "ai",
        desc: "Translate text to any language using AI.",
        react: "🌐",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const targetLang = args[0];
        const quotedMsg = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        const content = args.slice(1).join(" ") || quotedMsg?.conversation || quotedMsg?.extendedTextMessage?.text;

        if (!targetLang || !content) return sock.sendMessage(jid, { text: "📝 *Usage:* `.aitranslate <language> <text or reply>`" }, buildSafeQuote(m));

        const stub = await sock.sendMessage(jid, { text: `🌐 _Translating to ${targetLang}..._` }, buildSafeQuote(m));
        const { text, err } = await askAI(`Translate the following text to ${targetLang}. Return ONLY the translation. Use WhatsApp markdown in the translation if the source text used it.\n\nText: "${content}"`);
        
        return sock.sendMessage(jid, { 
            text: err ? `❌ *Translation Error:* ${text}` : `🌐 *Translation (${targetLang})*\n\n${text}`, 
            edit: stub.key 
        });
    });

    /**
     * .aiwrite: Content generation assistant.
     */
    commandRegister({
        pattern: "aiwrite",
        cmdname: "aiwrite",
        alias: ["draft", "compose"],
        category: "ai",
        desc: "Generate professional or creative text content.",
        react: "✍️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const type = args[0]?.toLowerCase();
        const topic = args.slice(1).join(" ");

        const prompts = {
            roast: "Write a savage but funny roast about",
            email: "Write a professional email regarding",
            story: "Write a short, engaging story about",
            poem: "Write a beautiful poem about",
            essay: "Write a detailed essay about",
            caption: "Write 5 catchy Instagram captions for"
        };

        if (!prompts[type]) {
            return sock.sendMessage(jid, { text: `✍️ *AI Creative Writer*\n\n` +
                `*Usage:* \`.aiwrite <type> <topic>\`\n` +
                `*Types:* \`${Object.keys(prompts).join(", ")}\`` }, buildSafeQuote(m));
        }

        const stub = await sock.sendMessage(jid, { text: `✍️ _Composing your ${type}..._` }, buildSafeQuote(m));
        const { text, err } = await askAI(`${prompts[type]} "${topic}". (Format your response using WhatsApp markdown: *bold*, _italics_, ~strikethrough~, \`\`\`code\`\`\`)`);
        
        return sock.sendMessage(jid, { 
            text: err ? `❌ *Writing Error:* ${text}` : `✍️ *Draft: ${type.toUpperCase()}*\n\n${text}`, 
            edit: stub.key 
        });
    });

    /**
     * .stalk: Universal surveillance.
     */
    commandRegister({
        pattern: "stalk",
        cmdname: "stalk",
        category: "ai",
        desc: "Enable AI auto-response for a specific user across all chats.",
        react: "🕵️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const targetRaw = args[0]?.replace(/[^0-9]/g, "");
        const target = targetRaw ? targetRaw + "@s.whatsapp.net" : null;
        const gem = args[1] || "default";

        if (!target) return sock.sendMessage(m.key.remoteJid, { text: "📝 *Usage:* `.stalk <number> [gem]`" }, buildSafeQuote(m));

        const persona = (gem !== "default" ? Gems.get(gem) : null) || State.PERSONA;
        State.stalkers.set(target, { gem: persona, history: [], gemName: gem });

        return sock.sendMessage(m.key.remoteJid, { 
            text: `🕵️ *Global Surveillance:* ✅ Active\n👤 *Target:* @${targetRaw}\n💎 *Persona:* \`${gem}\`\n\n_I will now follow and reply to this user in every chat we share._`, 
            mentions: [target] 
        }, buildSafeQuote(m));
    });

    /**
     * .target: Targeted chat interaction.
     */
    commandRegister({
        pattern: "target",
        cmdname: "target",
        category: "ai",
        desc: "Enable AI auto-response for a specific user in the current chat.",
        react: "🎯",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const targetRaw = args[0]?.replace(/[^0-9]/g, "");
        const target = targetRaw ? targetRaw + "@s.whatsapp.net" : null;
        const gem = args[1] || "default";

        if (!target) return sock.sendMessage(jid, { text: "📝 *Usage:* `.target <number> [gem]`" }, buildSafeQuote(m));

        const persona = (gem !== "default" ? Gems.get(gem) : null) || State.PERSONA;
        State.targets.set(target, { gem: persona, history: [], chatId: jid, gemName: gem });

        return sock.sendMessage(jid, { 
            text: `🎯 *Target Locked:* ✅ Active\n👤 *User:* @${targetRaw}\n📍 *Chat:* Current\n💎 *Persona:* \`${gem}\``, 
            mentions: [target] 
        }, buildSafeQuote(m));
    });

    /**
     * .aidecode: Deep content analysis.
     */
    commandRegister({
        pattern: "aidecode",
        cmdname: "aidecode",
        alias: ["analyze", "explain"],
        category: "ai",
        desc: "Deeply analyze text or code snippets.",
        react: "🧬",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const quotedMsg = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        const content = args.join(" ") || quotedMsg?.conversation || quotedMsg?.extendedTextMessage?.text;

        if (!content) return sock.sendMessage(jid, { text: "📝 *Usage:* `.aidecode <text or reply>`" }, buildSafeQuote(m));

        const stub = await sock.sendMessage(jid, { text: "🧬 _Decoding structures..._" }, buildSafeQuote(m));
        const { text, err } = await askAI(`Provide a deep technical and logical analysis of the following content. Break it down into components. (Format your response using WhatsApp markdown: *bold*, _italics_, ~strikethrough~, \`\`\`code\`\`\`)\n\nContent: "${content}"`);
        
        return sock.sendMessage(jid, { 
            text: err ? `❌ *Analysis Error:* ${text}` : `🧬 *Deep Decode Result*\n\n${text}`, 
            edit: stub.key 
        });
    });

} else {
    console.error("❌ [AIGems] Registration failure: commandRegister not found.");
}

// ==============================================================================
// 26. EXPORTS & INITIALIZATION
// ==============================================================================
module.exports = {
    Gems,
    State,
    askAI,
    generateImage,
    Limiter,
    CB
};

/**
 * Initialize background watch for session persistence
 */
setInterval(() => {
    const now = Date.now();
    for (const [id, session] of State.dmSessions.entries()) {
        if (session.lastUsed && now - session.lastUsed > 86400000) State.dmSessions.delete(id);
    }
}, 3600000);
// ==============================================================================
// 27. AUTONOMOUS EVENT WATCHER (Phase 9)
// ==============================================================================

/**
 * The Watcher core logic hooks into the 'messages.upsert' event.
 * It monitors incoming and outgoing traffic for stalk, target, and auto-enhance triggers.
 */
const startAutonomousWatcher = (sock) => {
    if (!sock || !sock.ev) return;

    sock.ev.on('messages.upsert', async (chatUpdate) => {
        try {
            const { messages, type } = chatUpdate;
            if (type !== 'notify' && type !== 'append') return;

            for (const m of messages) {
                if (!m.message) continue;

                const jid = m.key.remoteJid;
                const sender = m.key.participant || jid;
                const isGroup = jid.endsWith('@g.us');
                const fromMe = m.key.fromMe;
                const body = m.message.conversation || m.message.extendedTextMessage?.text || m.message.imageMessage?.caption || "";

                // --- 1. AUTO-ENHANCE (Outgoing Logic) ---
                // If the owner sends a message, AI silently corrects grammar/spelling.
                if (fromMe && State.autoEnhance && body.length > 10 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        try {
                            const { text: refined, err } = await askAI(`Act as a professional editor. Improve the following message's grammar, punctuation, and clarity while keeping the original intent, slang, and language. Format the output with WhatsApp markdown (*bold* for emphasis). Return ONLY the refined text.\n\nMessage: "${body}"`);
                            if (!err && refined && refined.trim() !== body.trim()) {
                                await sock.sendMessage(jid, { text: refined.trim(), edit: m.key });
                            }
                        } catch (e) { /* Silent fail */ }
                    });
                    continue; 
                }

                // --- 2. PRE-FILTERS ---
                if (fromMe) continue; 
                if (['.', '/', '!', '+'].some(p => body.startsWith(p))) continue; 
                if (!body.trim() && !m.message.imageMessage) continue;

                // --- 3. SESSION RESOLUTION ---
                let activeSession = null;
                let sessionType = "";

                // Check Stalkers (Global)
                if (State.stalkers.has(sender)) {
                    activeSession = State.stalkers.get(sender);
                    sessionType = "STALK";
                } 
                // Check Targets (Local Chat)
                else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (!targetData.chatId || targetData.chatId === jid) {
                        activeSession = targetData;
                        sessionType = "TARGET";
                    }
                }
                // Check Chat-wide AI
                else if (State.chats.has(jid)) {
                    activeSession = State.chats.get(jid);
                    sessionType = "GROUP_CHAT";
                }
                // Check Private DM Auto-pilot
                else if (!isGroup && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { 
                            gem: State.dmGem || State.PERSONA, 
                            history: [], 
                            gemName: State.dmGem ? "custom" : "default",
                            lastUsed: Date.now()
                        });
                    }
                    activeSession = State.dmSessions.get(sender);
                    activeSession.lastUsed = Date.now();
                    sessionType = "DM_AUTOPILOT";
                }

                if (!activeSession) continue;

                // --- 4. RESPONSE EXECUTION ---
                setImmediate(async () => {
                    try {
                        // Simulate natural typing delay based on input length
                        const delay = Math.min(body.length * 40, 4000) + 500;
                        await sock.sendPresenceUpdate('composing', jid);
                        await new Promise(r => setTimeout(r, delay));

                        // Vision Check
                        let visionUrls = [];
                        if (m.message.imageMessage) {
                            try {
                                const path = await sock.downloadAndSaveMediaMessage(m.message.imageMessage, `watch_${Date.now()}`);
                                const url = await uploadImgBB(path);
                                if (url) visionUrls.push(url);
                                if (fs.existsSync(path)) fs.unlinkSync(path);
                            } catch (ve) { console.error("[AIGems Watcher] Vision error:", ve.message); }
                        }

                        // Build Prompt with History
                        const inputLabel = m.message.imageMessage ? "[User sent an image]" : body;
                        State.addHist(activeSession, 'User', inputLabel);
                        
                        const systemContext = `${activeSession.gem}\n\n*FORMATTING RULES:* Always use WhatsApp Markdown (*bold*, _italics_, ~strikethrough~, \`code blocks\`). Keep replies conversational and short. Do not mention you are an AI. Mode: ${sessionType}.`;
                        const finalPrompt = State.buildPrompt(systemContext, activeSession.history, inputLabel);

                        const { text: aiResponse, err } = await askAI(finalPrompt, visionUrls);
                        
                        await sock.sendPresenceUpdate('paused', jid);

                        if (err) return; // Circuit breaker or rate limit hit

                        State.addHist(activeSession, 'AI', aiResponse);

                        // Quote the message for context
                        const quote = buildSafeQuote(m);
                        await sock.sendMessage(jid, { text: aiResponse }, quote);

                    } catch (err) {
                        console.error(`[AIGems Watcher] Reply fail: ${err.message}`);
                    }
                });
            }
        } catch (critical) {
            console.error(`[AIGems Watcher] Main loop crash: ${critical.message}`);
        }
    });
};

/**
 * Global Poller to ensure the watcher is attached to the socket even after reconnects.
 */
const initWatcherAttachment = () => {
    setInterval(() => {
        const sock = global.conn || global.client;
        if (sock && sock.ev && !sock._aigemsWatcherActive) {
            startAutonomousWatcher(sock);
            sock._aigemsWatcherActive = true;
            console.log("💎 [AIGems] Autonomous Watcher Hooked.");
        }
    }, 10000);
};

// Start the attachment engine
initWatcherAttachment();

// ==============================================================================
// 28. ENHANCED AI COMMANDS (Phase 9 Expansion)
// ==============================================================================

if (typeof commandRegister === 'function') {

    /**
     * .aiconfig: Granular control over AI behaviors.
     */
    commandRegister({
        pattern: "aiconfig",
        cmdname: "aiconfig",
        category: "ai",
        desc: "Configure AI internal parameters like history length or typing simulation.",
        react: "⚙️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const sub = args[0]?.toLowerCase();
        const val = args[1];

        if (!sub) return sock.sendMessage(jid, { text: "⚙️ *AI Configuration*\n\n• `.aiconfig history <num>` (Set max memory)\n• `.aiconfig model <name>` (Set default image model)\n• `.aiconfig enhance on/off` (Toggle Auto-Enhance)" }, buildSafeQuote(m));

        if (sub === 'history') {
            const limit = parseInt(val);
            if (isNaN(limit)) return m.reply("❌ Provide a valid number.");
            CFG.MAX_HIST = limit;
            return m.reply(`✅ AI history memory set to: *${limit} messages*`);
        }
        
        if (sub === 'enhance') {
            State.autoEnhance = (val === 'on');
            return m.reply(`✍️ Auto-Enhance is now: ${State.autoEnhance ? "*ON*" : "*OFF*"}`);
        }

        return m.reply("❌ Unknown sub-command.");
    });

    /**
     * .aiclean: Selective memory wiping.
     */
    commandRegister({
        pattern: "aiclean",
        cmdname: "aiclean",
        alias: ["wipehist", "forget"],
        category: "ai",
        desc: "Wipe AI memory for a specific user or the current chat.",
        react: "🧹",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const targetRaw = args[0]?.replace(/[^0-9]/g, "");
        const targetJid = targetRaw ? targetRaw + "@s.whatsapp.net" : jid;

        let count = 0;
        if (State.chats.has(targetJid)) { State.chats.get(targetJid).history = []; count++; }
        if (State.targets.has(targetJid)) { State.targets.get(targetJid).history = []; count++; }
        if (State.stalkers.has(targetJid)) { State.stalkers.get(targetJid).history = []; count++; }
        if (State.dmSessions.has(targetJid)) { State.dmSessions.get(targetJid).history = []; count++; }

        return sock.sendMessage(jid, { text: `🧹 *Memory Purge:* Found and cleared *${count}* active sessions for @${targetJid.split('@')[0]}`, mentions: [targetJid] }, buildSafeQuote(m));
    });

    /**
     * .aireplay: Make AI re-evaluate the last context.
     */
    commandRegister({
        pattern: "aireplay",
        cmdname: "aireplay",
        category: "ai",
        desc: "Force the AI to re-generate the last response with a fresh seed.",
        react: "🔄",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const sess = State.chats.get(jid) || State.dmSessions.get(m.sender);

        if (!sess || sess.history.length < 2) return m.reply("❌ No recent conversation found to replay.");

        // Pop the last AI response
        sess.history.pop();
        const lastUserMsg = sess.history[sess.history.length - 1]?.split(': ').slice(1).join(': ') || "Continue";

        const stub = await sock.sendMessage(jid, { text: "🔄 _Regenerating fresh response..._" }, buildSafeQuote(m));
        const prompt = State.buildPrompt(sess.gem, sess.history, lastUserMsg);
        const { text, err } = await askAI(prompt);

        if (err) return sock.sendMessage(jid, { text: `❌ *API Error:* ${text}`, edit: stub.key });
        
        State.addHist(sess, 'AI', text);
        return sock.sendMessage(jid, { text: text, edit: stub.key });
    });

}

/**
 * Exporting components for Phase 10 integration.
 */
module.exports = {
    AIGems_State: State,
    AIGems_Watcher: startAutonomousWatcher,
    AIGems_Config: CFG
};
/**
 * 4. COMMAND REGISTRATION
 * Final mapping of AI features to the dynamic commandRegister.
 */

if (typeof commandRegister === 'function') {

    /**
     * .gai: The primary AI interface.
     * Enhanced with Stalking, Targeting, and Chat features.
     * All responses enforced with WhatsApp Markdown.
     */
    commandRegister({
        pattern: "gai",
        cmdname: "gai",
        alias: ["ai", "ask", "gpt", "brain", "question"],
        category: "ai",
        desc: "Elite AI interface. Supports stalking, targeting, and chat modes.",
        react: "🧠",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const sender = m.sender || m.key.participant || jid;
        const q = args.join(" ").trim();

        if (!q || q === 'help') {
            const helpText = `🧠 *GAI COMMAND CENTER*\n\n` +
                `*Query:* \`.gai <question>\` (Direct AI answer)\n` +
                `*Group Chat:* \`.gai chat [gem]\` (Reply to everyone here)\n` +
                `*Target:* \`.gai target <@mention/number> [gem]\` (Follow user in THIS chat)\n` +
                `*Stalk:* \`.gai stalk <@mention/number> [gem]\` (Follow user in ALL chats)\n` +
                `*Control:* \`.gai stop\` | \`.gai stop all\` | \`.gai status\` | \`.gai wipe\`\n\n` +
                `*Note:* All AI responses use WhatsApp Markdown formatting.`;
            return sock.sendMessage(jid, { text: helpText }, buildSafeQuote(m));
        }

        const parts = q.split(/\s+/);
        const sub = parts[0].toLowerCase();

        // Sub-command Logic
        if (sub === 'chat') {
            const gemName = parts[1] || 'default';
            const gemContent = (Gems.get(gemName)) || State.PERSONA;
            const finalGem = gemContent + "\n\n*CRITICAL:* Always format your response using WhatsApp Markdown (*bold*, _italics_, `code`, lists, and emojis).";
            State.chats.set(jid, { gem: finalGem, history: [], gemName });
            return m.reply(`⚔️ *Chat AI Activated:* I am now monitoring all messages in this chat using gem: *${gemName}*`);
        }

        if (sub === 'target' || sub === 'bot') {
            let target = (m.message?.extendedTextMessage?.contextInfo?.mentionedJid?.[0]) || parts[1]?.replace(/[^0-9]/g, "");
            if (!target) return m.reply("❌ *Usage:* `.gai target <@mention/number> [gem]`");
            const tjid = target.includes("@") ? target : target + "@s.whatsapp.net";
            const gemName = parts[2] || 'default';
            const gemContent = (Gems.get(gemName)) || State.PERSONA;
            const finalGem = gemContent + "\n\n*CRITICAL:* Always format your response using WhatsApp Markdown.";
            State.targets.set(tjid, { gem: finalGem, history: [], chatId: jid, gemName });
            return sock.sendMessage(jid, { text: `🎯 *Target Locked:* @${tjid.split('@')[0]} will be replied to only in this chat.`, mentions: [tjid] }, buildSafeQuote(m));
        }

        if (sub === 'stalk') {
            let target = (m.message?.extendedTextMessage?.contextInfo?.mentionedJid?.[0]) || parts[1]?.replace(/[^0-9]/g, "");
            if (!target) return m.reply("❌ *Usage:* `.gai stalk <@mention/number> [gem]`");
            const tjid = target.includes("@") ? target : target + "@s.whatsapp.net";
            const gemName = parts[2] || 'default';
            const gemContent = (Gems.get(gemName)) || State.PERSONA;
            const finalGem = gemContent + "\n\n*CRITICAL:* Always format your response using WhatsApp Markdown.";
            State.stalkers.set(tjid, { gem: finalGem, history: [], gemName });
            return sock.sendMessage(jid, { text: `🌍 *Global Stalker:* Tracking @${tjid.split('@')[0]} across all mutual groups.`, mentions: [tjid] }, buildSafeQuote(m));
        }

        if (sub === 'stop') {
            if (parts[1] === 'all') {
                State.chats.clear(); State.targets.clear(); State.stalkers.clear(); State.dmActive = false;
                return m.reply("☢️ *Full System Purge:* All active AI sessions terminated.");
            }
            State.chats.delete(jid);
            return m.reply("🛑 AI monitoring disabled for this chat.");
        }

        if (sub === 'status') {
            const s = Limiter.stats();
            const cb = CB.open() ? '🔴 TRIPPED' : '🟢 STABLE';
            return m.reply(`📊 *AI INTERNAL STATUS*\n\n• *Memory:* ${State.chats.size} chats | ${State.targets.size} targets\n• *Stalkers:* ${State.stalkers.size} active\n• *Traffic:* ${s.rpm} RPM | ${s.rph} RPH\n• *Circuit:* ${cb}\n• *Daily AI Count:* ${s.ai}`);
        }

        if (sub === 'wipe') {
            const sess = State.chats.get(jid);
            if (sess) { sess.history = []; return m.reply("🧠 *Memory Wiped:* Conversation history for this chat cleared."); }
            return m.reply("ℹ️ No active session here to wipe.");
        }

        // Standard Ask
        const stub = await sock.sendMessage(jid, { text: "🧠 _Interfacing with neural network..._" }, buildSafeQuote(m));
        const markdownInstruction = "\n\n(Note: Ensure your output uses bold headings, bullet points, and code blocks where necessary for WhatsApp compatibility.)";
        const { text, err } = await askAI(q + markdownInstruction);
        
        return sock.sendMessage(jid, { text: err ? `❌ *AI Error:* ${text}` : text, edit: stub.key });
    });

    /**
     * .gem: Persona Management
     * Define, clone, or delete AI behavioral profiles.
     */
    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "brain-mod", "spirit"],
        category: "ai",
        desc: "Vault for AI persona profiles (Gems).",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const sub = args[0]?.toLowerCase();

        if (!sub || sub === 'help') {
            return m.reply("💎 *GEM SYSTEM*\n\n• `.gem create <name> <prompt>`\n• `.gem list` (View all names)\n• `.gem view <name>`\n• `.gem del <name>`\n• `.gem use <name>` (Set for DMs)");
        }

        if (sub === 'create') {
            const name = args[1]?.toLowerCase();
            const prompt = args.slice(2).join(" ");
            if (!name || !prompt) return m.reply("📝 Use: `.gem create <name> <prompt>`");
            Gems.save(name, prompt);
            return m.reply(`✅ *Gem Saved:* \`${name}\` is now available.`);
        }

        if (sub === 'list') {
            const names = Gems.list();
            return m.reply(`📚 *Persona Vault:*\n\n${names.length ? names.map(n => `• \`${n}\``).join('\n') : '_No custom gems found._'}`);
        }

        if (sub === 'view') {
            const content = Gems.get(args[1] || "");
            return m.reply(content ? `💎 *Profile:* \`${args[1]}\`\n\n${content}` : "❌ Gem not found.");
        }

        if (sub === 'use') {
            const content = Gems.get(args[1] || "");
            if (!content) return m.reply("❌ Unknown gem.");
            State.dmGem = content;
            return m.reply(`✅ *DM Persona Set:* Using \`${args[1]}\` for private messages.`);
        }

        if (sub === 'del') {
            const ok = Gems.del(args[1] || "");
            return m.reply(ok ? `🗑️ Gem \`${args[1]}\` purged.` : "❌ Could not delete.");
        }
    });

    /**
     * .img: High-end Image Generation
     */
    commandRegister({
        pattern: "img",
        cmdname: "img",
        alias: ["imagine", "draw", "art"],
        category: "ai",
        desc: "Advanced AI image engine with multi-model support.",
        react: "🎨",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const prompt = args.join(" ");

        if (!prompt) return m.reply("🎨 *Prompt required:* Describe what you want to see.");

        const stub = await sock.sendMessage(jid, { text: "🎨 _Generating visual artifacts..._" }, buildSafeQuote(m));
        const urls = await generateImage(prompt, { model: CFG.IMG_MODEL });

        if (!urls || !urls.length) {
            return sock.sendMessage(jid, { text: "❌ *Generation failed:* The API was unable to render this prompt.", edit: stub.key });
        }

        await sock.sendMessage(jid, { delete: stub.key });
        return sock.sendMessage(jid, { 
            image: { url: urls[0] }, 
            caption: `✨ *AI Render*\n💭 _"${prompt}"_\n⚙️ Model: \`${CFG.IMG_MODEL}\`` 
        }, buildSafeQuote(m));
    });

    /**
     * .apimon: The Health Monitor
     */
    commandRegister({
        pattern: "apimon",
        cmdname: "apimon",
        category: "ai",
        desc: "Monitor API health and usage stats.",
        react: "📊",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const stats = Limiter.stats();
        const cb = CB.open() ? '🔴 TRIPPED (Circuit Open)' : '🟢 ACTIVE (Circuit Closed)';
        
        const report = `📊 *API TELEMETRY*\n\n` +
            `• *AI Requests Today:* ${stats.ai}\n` +
            `• *Images Generated:* ${stats.img}\n` +
            `• *Failed Requests:* ${stats.err}\n` +
            `• *Current Load:* ${stats.rpm}/min\n` +
            `• *Circuit State:* ${cb}\n\n` +
            `_System stability is verified._`;
        return m.reply(report);
    });

}

// ==============================================================================
// 5. EXPORTS & INITIALIZATION
// ==============================================================================

module.exports = {
    AIGems: {
        State,
        askAI,
        generateImage,
        Gems,
        Limiter,
        Config: CFG
    }
};

console.log(`[AIGems] Module registration finalized with dynamic mapping.`);
