gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'whatis'],
    category: 'ai',
    desc: 'Advanced visual analysis for images or complex text.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('*❌ Owner access required.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImage = quoted?.imageMessage || mek.message?.imageMessage;

    if (!hasImage && !q.trim() && !quoted?.conversation) {
        return reply('*🖼️ Please reply to an image or text block with .aidecode [query]*');
    }

    await react('🔍');
    const stub = await thinking(Gifted, from, mek, '*👁️ Analysing visual and textual data...*');
    
    let imgUrls = [];
    if (hasImage) {
        try {
            const target = quoted?.imageMessage ? quoted.imageMessage : mek.message.imageMessage;
            const tmpPath = path.join(__dirname, `vision_dec_${Date.now()}.jpg`);
            await Gifted.downloadAndSaveMediaMessage(target, tmpPath);
            const url = await uploadImgBB(tmpPath);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);
        } catch (e) {
            console.error('[AIGems] Vision upload error:', e.message);
        }
    }

    const context = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    const userQuery = q.trim() || 'Describe this in detail.';
    
