/**
 * @command .apimon
 * @description Real-time monitoring of AI endpoint health and quotas.
 */
gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    category: 'ai',
    desc: 'Monitor AI system health and circuit breakers.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const stats = Limiter.stats();
    const circuit = CB.open() ? '🔴 *TRIPPED* (Cooldown)' : '🟢 *STABLE*';
    
    // Quick latency probe
    const start = Date.now();
    let health = 'Testing...';
    try {
        const { err } = await askAI('Ping');
        health = !err ? `✅ *Online* (${Date.now() - start}ms)` : '❌ *Error/Blocked*';
    } catch(e) { health = '❌ *Timeout*'; }

    const report = 
        `📊 *AI SYSTEM DIAGNOSTICS*\n\n` +
        `• *Endpoint:* QuillBot/Raven\n` +
        `• *Health:* ${health}\n` +
        `• *Circuit:* ${circuit}\n\n` +
        `*Quota Tracking:*\n` +
        `• RPM: \`${stats.rpm}/${CFG.MAX_RPM}\` requests\n` +
        `• RPH: \`${stats.rph}/${CFG.MAX_RPH}\` requests\n\n` +
        `*Daily Total:* \n` +
        `• Text: \`${stats.ai}\` | Img: \`${stats.img}\` | Err: \`${stats.err}\` \n\n` +
        `*State Management:* \n` +
        `• Chats Active: ${State.chats.size}\n` +
        `• DB Gems: ${Gems.list().length}`;

    return reply(report);
});

// ==============================================================================
// 34. PHASE 7: AUTOMATION MAINTENANCE
// ==============================================================================

/**
 * Clean up stale sessions every 15 minutes to prevent memory leaks.
 */
setInterval(() => {
    const now = Date.now();
    const SESSION_EXPIRY = 3600000 * 4; // 4 hours
    
    State.chats.forEach((sess, id) => {
        if (sess.lastActive && (now - sess.lastActive > SESSION_EXPIRY)) {
            State.chats.delete(id);
        }
    });

    State.dmSessions.forEach((sess, id) => {
        if (sess.lastActive && (now - sess.lastActive > SESSION_EXPIRY)) {
            State.dmSessions.delete(id);
        }
    });
}, 900000);

console.log('[AIGems] Phase 7 (.gai Suite) deployed. Automation engine refined.');
/**
 * Phase 7 complete.
 * Logic flow moves to Phase 8: Advanced Media AI.
 */
// ==============================================================================
// 35. PHASE 8: ADVANCED IMAGE STUDIO (.img Suite)
// ==============================================================================

/**
 * @command .img
 * @description The comprehensive Image Generation suite.
 * Features: Generation, Surprise Prompting, Chaos Engine, Prompt Enhancer, 
 * Model switching, and Aspect Ratio control.
 */
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'genimg', 'art', 'draw'],
    category: 'ai',
    desc: 'Advanced Image Generation Suite. .img help for all sub-commands.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const rest = parts.slice(1).join(' ');

    /**
     * Internal: Execution logic for prompt generation.
     */
    const executeGen = async (prompt, label = '🎨 _Processing…_') => {
        await react('⏳');
        const stub = await thinking(Gifted, from, mek, label);
        const urls = await generateImage(prompt, {
            model: CFG.IMG_MODEL,
            size: CFG.IMG_SIZE,
            quality: CFG.IMG_QUALITY,
            style: CFG.IMG_STYLE,
            count: CFG.IMG_COUNT
        });

        if (!urls || !urls.length) {
            await react('❌');
            return editMsg(Gifted, stub, '❌ *Generation Failed.* Possible safety filter or API timeout. Try `.img setup` to verify keys.');
        }

        await del(Gifted, stub.key);
        await react('✨');

        const caption = `*🎨 AI GENERATED IMAGE*\n\n*Prompt:* _${prompt}_\n*Model:* \`${CFG.IMG_MODEL}\`\n*Size:* \`${CFG.IMG_SIZE}\``;
        
        // Send main image
        await sendImg(Gifted, from, urls[0], caption, mek);
        
        // Send extra variations if IMG_COUNT > 1
        if (urls.length > 1) {
            for (let i = 1; i < urls.length; i++) {
                await sendImg(Gifted, from, urls[i], `*🎨 Variation ${i + 1}*`, mek);
                await sleep(500);
            }
        }
    };

    // --- Sub-Command: HELP ---
    if (cmd === 'help') {
        return reply(
            `🎨 *ADVANCED IMAGE STUDIO*\n\n` +
            `• \`.img gen <prompt>\` — Generate standard image\n` +
            `• \`.img surprise [topic]\` — AI-designed creative prompt\n` +
            `• \`.img chaos\` — Bizarre prompts & random models\n` +
            `• \`.img enhance <prompt>\` — Rewrite for hyper-realism\n\n` +
            `*Settings:*\n` +
            `• \`.img models\` — List available AI engines\n` +
            `• \`.img set <model_id>\` — Switch default engine\n` +
            `• \`.img ratio <sq|port|land>\` — Change dimensions\n` +
            `• \`.img setup\` — Test API health\n\n` +
            `*Current:* \`${CFG.IMG_MODEL}\` @ \`${CFG.IMG_SIZE}\``
        );
    }

    // --- Sub-Command: MODELS ---
    if (cmd === 'models' || cmd === 'list') {
        const lines = Object.entries(CFG.IMG_MDLS).map(([id, m]) => 
            `${m.tier === 'pro' ? '👑' : '🆓'} \`${id}\` — ${m.desc}`
        ).join('\n');
        return reply(`📋 *AVAILABLE AI MODELS*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\``);
    }

    // --- Sub-Command: CONFIG / SET ---
    if (cmd === 'set' || cmd === 'config') {
        const newModel = parts[1]?.toLowerCase();
        if (!newModel || !CFG.IMG_MDLS[newModel]) {
            return reply(`📝 *Usage:* \`.img set <model_id>\`\n_Check models with_ \`.img models\``);
        }
        CFG.IMG_MODEL = newModel;
        return reply(`✅ *Default Model Updated:* \`${CFG.IMG_MODEL}\``);
    }

    // --- Sub-Command: RATIO ---
    if (cmd === 'ratio' || cmd === 'aspect') {
        const r = parts[1]?.toLowerCase();
        const map = { sq: '1024x1024', port: '1024x1792', land: '1792x1024' };
        if (!map[r]) return reply('📝 *Usage:* \`.img ratio <sq|port|land>\`');
        CFG.IMG_SIZE = map[r];
        return reply(`✅ *Dimensions Updated:* \`${CFG.IMG_SIZE}\` (${r})`);
    }

    // --- Sub-Command: SURPRISE ---
    if (cmd === 'surprise') {
        const topic = rest || 'anything bizarre and beautiful';
        const stub = await thinking(Gifted, from, mek, '🎲 _Dreaming up a prompt..._');
        const { text: dream, err } = await askAI(`Generate a highly creative, vivid, and cinematic image generation prompt about: ${topic}. Focus on lighting, art style, and texture. Return ONLY the prompt text.`);
        if (err) return editMsg(Gifted, stub, `❌ ${dream}`);
        await editMsg(Gifted, stub, `🔮 _Visualizing:_ "${dream.slice(0, 120)}..."`);
        return executeGen(dream, '🎨 _Surprise Generation..._');
    }

    // --- Sub-Command: CHAOS ---
    if (cmd === 'chaos') {
        const models = Object.keys(CFG.IMG_MDLS).filter(k => CFG.IMG_MDLS[k].tier === 'free');
        const randModel = models[Math.floor(Math.random() * models.length)];
        const randSize = ['1024x1024', '1792x1024', '1024x1792'][Math.floor(Math.random() * 3)];
        
        const stub = await thinking(Gifted, from, mek, '🌪️ *Triggering Chaos...*');
        const { text: chaosP } = await askAI("Write a surreal, abstract, and chaotic image prompt. Be weird.");
        
        // Temporarily override for this one call
        const oldM = CFG.IMG_MODEL; const oldS = CFG.IMG_SIZE;
        CFG.IMG_MODEL = randModel; CFG.IMG_SIZE = randSize;
        
        await executeGen(chaosP || 'liquid entropy neon void', `🌪️ _Chaos with ${randModel}..._`);
        
        CFG.IMG_MODEL = oldM; CFG.IMG_SIZE = oldS;
        return;
    }

    // --- Sub-Command: ENHANCE ---
    if (cmd === 'enhance') {
        if (!rest) return reply('📝 *Usage:* \`.img enhance <basic_prompt>\`');
        const stub = await thinking(Gifted, from, mek, '🧠 _Prompt Engineering..._');
        const { text: expanded, err } = await askAI(`Rewrite and expand this image prompt for DALL-E 3/Flux quality. Add details about camera settings, lighting, and cinematic composition: "${rest}". Return ONLY the rewritten prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ ${expanded}`);
        return editMsg(Gifted, stub, `✨ *Hyper-Enhanced Prompt:*\n\n${expanded}\n\n_Use_ \`.img gen\` _to visualize._`);
    }

    // --- Sub-Command: SETUP ---
    if (cmd === 'setup') {
        const stub = await thinking(Gifted, from, mek, '🔧 _Testing API Connection..._');
        _iOk = false;
        const success = await ensureInfip();
        return editMsg(Gifted, stub, success ? `✅ *Infip Ready:* Key \`${_iKey.slice(0, 15)}...\` validated.` : '❌ *Infip Offline:* Keys may be exhausted. Update pool.');
    }

    // --- DEFAULT: GENERATE ---
    const finalPrompt = (cmd === 'gen') ? rest : q;
    if (!finalPrompt.trim()) return reply('📝 *Usage:* \`.img <prompt>\` or \`.img help\`');
    return executeGen(finalPrompt);
});

