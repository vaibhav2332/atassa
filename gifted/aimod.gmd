// ==============================================================================
// 31. PHASE 7: MASTER AI CONTROL (.gai Suite)
// ==============================================================================

/**
 * @command .gai
 * @description Central command for AI one-shot queries and automation state.
 * Handles vision decoding, DM toggles, target tracking, and summarization.
 */
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain', 'ask'],
    category: 'ai',
    desc: 'AI Master Control: One-shot queries, DM toggles, and targeted tracking.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner access required.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase();
    const arg = parts[1]?.toLowerCase();

    // --- Sub-command: DM Auto-Pilot ---
    if (cmd === 'dm') {
        if (arg === 'on') {
            State.dmActive = true;
            return reply(`📨 *DM Auto-Pilot:* ✅ *ON*\n*Persona:* ${State.dmGem ? 'Custom' : 'Default'}`);
        }
        if (arg === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot:* ❌ *OFF*');
        }
        return reply(`📨 *DM Auto-Pilot Status:* ${State.dmActive ? '✅ ON' : '❌ OFF'}`);
    }

    // --- Sub-command: Chat-wide AI ---
    if (cmd === 'chat') {
        const gemName = parts[1] || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.chats.set(from, { gem: persona, history: [], gemName, lastActive: Date.now() });
        return reply(`⚔️ *Chat AI Activated*\n*Gem:* \`${gemName}\`\nI will now respond to all messages in this chat.`);
    }

    // --- Sub-command: Target Tracking ---
    if (cmd === 'target' || cmd === 'bot') {
        const num = parts[1]?.replace(/\D/g, '');
        if (!num) return reply('📝 *Usage:* `.gai target <number> [gem]`');
        const jid = num + '@s.whatsapp.net';
        const gemName = parts[2] || 'default';
        State.targets.set(jid, { 
            gem: (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA, 
            history: [], 
            chatId: from, 
            gemName 
        });
        return reply(`🤖 *Target Locked:* @${num}\n*Gem:* \`${gemName}\`\nI will reply to this user in this specific chat.`, { mentions: [jid] });
    }

    // --- Sub-command: Global Stalking ---
    if (cmd === 'stalk') {
        const num = parts[1]?.replace(/\D/g, '');
        if (!num) return reply('📝 *Usage:* `.gai stalk <number> [gem]`');
        const jid = num + '@s.whatsapp.net';
        const gemName = parts[2] || 'default';
        State.stalkers.set(jid, { 
            gem: (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA, 
            history: [], 
            gemName 
        });
        return reply(`🕵️ *Global Stalker Active:* @${num}\n*Gem:* \`${gemName}\`\nTracking this user across all shared chats.`, { mentions: [jid] });
    }

    // --- Sub-command: Stop/Wipe ---
    if (cmd === 'stop') {
        if (arg === 'all') {
            State.dmActive = false;
            State.chats.clear();
            State.targets.clear();
            State.stalkers.clear();
            State.dmSessions.clear();
            return reply('☢️ *All AI automations terminated.*');
        }
        State.chats.delete(from);
        return reply('🛑 *AI disabled for this chat.*');
    }

    if (cmd === 'wipe') {
        const sess = State.chats.get(from) || State.dmSessions.get(from);
        if (sess) { sess.history = []; return reply('🧠 *Session memory cleared.*'); }
        return reply('ℹ️ No active AI session to wipe.');
    }

    // --- Sub-command: Summarize ---
    if (cmd === 'summary' || cmd === 'summarize') {
        const sess = State.chats.get(from);
        if (!sess || sess.history.length < 3) return reply('ℹ️ Not enough history here to summarize.');
        const stub = await thinking(Gifted, from, mek, '📝 _Summarizing chat context..._');
        const { text, err } = await askAI(`Summarize this chat history into key bullet points. Identify the main topics discussed and any action items:\n\n${sess.history.join('\n')}`);
        return editMsg(Gifted, stub, err ? `❌ ${text}` : `📝 *Chat Summary*\n\n${text}`);
    }

    // --- Sub-command: Status ---
    if (cmd === 'status') {
        const s = Limiter.stats();
        const cb = CB.open() ? '🔴 *TRIPPED*' : '🟢 *CLOSED*';
        return reply(
            `📊 *AI SYSTEM HEALTH*\n\n` +
            `• *DM Auto-Pilot:* ${State.dmActive ? '✅' : '❌'}\n` +
            `• *Group Sessions:* ${State.chats.size}\n` +
            `• *Tracked Targets:* ${State.targets.size}\n` +
            `• *Global Stalkers:* ${State.stalkers.size}\n\n` +
            `• *Load (1m):* ${s.rpm}/${CFG.MAX_RPM}\n` +
            `• *Usage (24h):* ${s.ai} Text | ${s.img} Img\n` +
            `• *Circuit Status:* ${cb}`
        );
    }

    // --- ONE-SHOT QUESTION LOGIC (Default) ---
    const question = q.trim();
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImg = mek.message?.imageMessage || quoted?.imageMessage;

    if (!question && !hasImg) {
        return reply(
            `🧠 *GAI CONTROL HELP*\n\n` +
            `• \`.gai <question>\` — Ask AI anything\n` +
            `• \`.gai dm on/off\` — Toggle private AI\n` +
            `• \`.gai chat [gem]\` — Enable for everyone here\n` +
            `• \`.gai stalk <num>\` — Global user tracking\n` +
            `• \`.gai target <num>\` — Local user tracking\n` +
            `• \`.gai summary\` — Condense current history\n` +
            `• \`.gai status\` — System metrics\n` +
            `• \`.gai stop [all]\` — Disable automations`
        );
    }

    await react('🧠');
    const stub = await thinking(Gifted, from, mek);
    
    // --- Vision Processing (If Image Included) ---
    let imgUrls = [];
    if (hasImg) {
        const target = quoted?.imageMessage || mek.message.imageMessage;
        try {
            const tmpFile = path.join(__dirname, `tmp_gai_${Date.now()}.jpg`);
            await Gifted.downloadAndSaveMediaMessage(target, tmpFile);
            const url = await uploadImgBB(tmpFile);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmpFile)) fs.unlinkSync(tmpFile);
        } catch (e) { 
            console.error('[AIGems] One-shot Vision Error:', e.message); 
        }
    }

    // Assemble Context
    let finalPrompt = question;
    const quotedText = quoted?.conversation || quoted?.extendedTextMessage?.text;
    if (quotedText && !hasImg) {
        finalPrompt = `Context from replied message: "${quotedText}"\n\nUser Question: ${question}`;
    }

    const { text, err } = await askAI(finalPrompt || 'Describe this image in detail.', imgUrls);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
});

// ==============================================================================
// 32. PHASE 7: CREATIVE SUITE REFINEMENT (.aiwrite, .aitranslate)
// ==============================================================================

/**
 * @command .aiwrite
 * @description Generates structured creative content based on specific templates.
 */
gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'writer'],
    category: 'ai',
    desc: 'Creative drafting engine for specific styles.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner access required.*');

    const parts = q.trim().split(/\s+/);
    const style = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const templates = {
        'roast': 'Write a savage but witty WhatsApp roast about {topic}. Use emojis and bold text.',
        'email': 'Draft a professional email regarding {topic}. Include a clear subject line and formal closing.',
        'code': 'Write a high-performance, well-commented code snippet for {topic}. Use markdown code blocks.',
        'story': 'Write a compelling short story about {topic}. Max 250 words. Focus on atmosphere.',
        'caption': 'Generate 5 engaging captions for {topic} suitable for social media. Include relevant hashtags.',
        'lyrics': 'Write song lyrics about {topic} in the style of a modern pop/rap artist.',
        'slang': 'Explain {topic} using heavy Gen-Z slang and modern internet culture terms.'
    };

    if (!templates[style]) {
        return reply(
            `✍️ *AI WRITER OPTIONS*\n\n` +
            `• Styles: \`${Object.keys(templates).join('`, `')}\`\n` +
            `• Usage: \`.aiwrite <style> <topic>\`\n\n` +
            `_Example: .aiwrite roast my procrastination_`
        );
    }

    if (!topic) return reply(`⚠️ Please provide a topic for the \`${style}\` style.`);

    const stub = await thinking(Gifted, from, mek, `✍️ _Drafting ${style}..._`);
    const prompt = templates[style].replace('{topic}', topic);
    
    const { text, err } = await askAI(prompt + "\n\nAdhere strictly to WhatsApp markdown formatting.");
    if (err) return editMsg(Gifted, stub, `❌ *Composition Error:* ${text}`);

    return editMsg(Gifted, stub, `✨ *AI ${style.toUpperCase()}*\n\n${text}`);
});

/**
 * @command .aitranslate
 * @description Context-aware translation using LLM reasoning.
 */
gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['tr', 'translate'],
    category: 'ai',
    desc: 'Reasoning-based AI translation.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/);
    const targetLang = parts[0];
    let sourceText = parts.slice(1).join(' ');

    // Handle quoted text fallback
    if (!sourceText) {
        sourceText = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage?.conversation || 
                     mek.message?.extendedTextMessage?.contextInfo?.quotedMessage?.extendedTextMessage?.text;
    }

    if (!targetLang || !sourceText) {
        return reply('📝 *Usage:* `.aitranslate <language> <text>` or reply to text.');
    }

    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${targetLang}..._`);
    const prompt = `Translate the following text to ${targetLang}. Preserve the original tone and slang. Return ONLY the translated text:\n\n"${sourceText}"`;

    const { text, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `❌ *Translation Failed:* ${text}`);

    return editMsg(Gifted, stub, `🌐 *AI TRANSLATION [${targetLang.toUpperCase()}]*\n\n${text}`);
});

