/**
 * .aitranslate — Advanced multi-lingual translation tool.
 * Features: Auto-detection of source language, preservation of formatting,
 * and strict adherence to WhatsApp Markdown.
 */
gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['translate', 'aitrans', 'tr'],
    category: 'ai',
    desc: 'Translate text to any language using AI with auto-detection.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *ACCESS DENIED*');

    const args = q.trim().split(/\s+/);
    const targetLang = args[0];
    let textToTranslate = args.slice(1).join(' ');

    // Context Retrieval: check if the user is replying to a message
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (!textToTranslate && quoted) {
        textToTranslate = quoted.conversation || quoted.extendedTextMessage?.text || quoted.imageMessage?.caption;
    }

    if (!targetLang || !textToTranslate) {
        return reply(
            `🌐 *AI TRANSLATOR*\n\n` +
            `📝 *Usage:* \`.aitranslate <language> <text>\`\n` +
            `🔄 *Example:* \`.aitranslate Japanese Hello, how are you?\`\n\n` +
            `_Note: You can also reply to a message with \`.aitranslate <language>\`_`
        );
    }

    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${targetLang.toUpperCase()}..._`);

    const translationPrompt = `
        TASK: Translate the provided text to ${targetLang}.
        RULES:
        1. Auto-detect the source language.
        2. Preserve the original tone (formal/informal).
        3. KEEP all WhatsApp formatting (like *bold*, _italic_, ~strike~).
        4. Return ONLY the translated text. Do not include "Here is the translation" or "Translated to...".
        5. Use WhatsApp Markdown for any emphasis.
        
        TEXT:
        "${textToTranslate}"
    `.trim();

    const { text, err } = await askAI(translationPrompt);

    if (err) {
        return editMsg(Gifted, stub, `❌ *TRANSLATION ERROR:* ${text}`);
    }

    const formattedResult = `🌐 *TRANSLATION [→ ${targetLang.toUpperCase()}]*\n\n${text}`;
    return editMsg(Gifted, stub, formattedResult);
});

