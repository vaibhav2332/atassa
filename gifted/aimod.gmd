// ═══════════════════════════════════════════════════════════════════════════════
//  .aiimg <url> — Vision: describe/analyse a quoted/URL image
// ═══════════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'vision',
        aliases : ['aiimg','describe','analyse'],
        category: 'ai',
        react   : '👁️',
        desc    : 'AI vision — describe or analyse an image',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        await editOrReply(Gifted, from, mek, '👁️ *Processing image...*');

        let imgUrl = q?.startsWith('http') ? q : null;

        // Check quoted image
        const quoted = mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        const imgMsg = quoted?.imageMessage;

        if (!imgUrl && imgMsg) {
            try {
                const tp  = await Gifted.downloadAndSaveMediaMessage(imgMsg, 'temp_vision');
                imgUrl    = await uploadToImgBBLocal(tp);
                await fsp.unlink(tp).catch(() => {});
            } catch (_) {}
        }

        if (!imgUrl) return editOrReply(Gifted, from, mek, '❌ Please quote an image or provide an image URL.');

        const prompt = q && !q.startsWith('http') ? q : 'Describe this image in detail. Note all important elements, colours, mood, and any text visible.';
        const r      = await qbRequest(prompt, [imgUrl]);
        return editOrReply(Gifted, from, mek, `👁️ *Vision Analysis*\n\n${r}`);
    }
);

console.log('[AIGemMod] ✅ Loaded — Gems, Image Gen, NL Control, Auto-Reply, Dynamic Profile');
