/**
 * @command .apimon
 * @description Master system monitor for API health, load, and circuit breaker.
 */
gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    aliases: ['aihealth', 'apistat', 'sysmon'],
    category: 'ai',
    desc: 'Deep AI health monitoring and API status.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only Command.*');

    const parts = q.trim().split(/\s+/);
    const sub = parts[0]?.toLowerCase() || 'status';

    if (sub === 'status' || !q.trim()) {
        const s = Limiter.stats();
        const cb = CB.open() ? '🔴 *TRIPPED* (Cooldown)' : `🟢 *ACTIVE* (${CB.fails}/${CB.THRESH})`;
        const bar = (v, max, l = 10) => {
            const f = Math.min(l, Math.round((v / max) * l));
            return '█'.repeat(f) + '░'.repeat(Math.max(0, l - f));
        };

        return reply(
            `📊 *AI SYSTEM INTELLIGENCE*\n\n` +
            `• *Circuit:* ${cb}\n` +
            `• *RPM (1m):* \`${bar(s.rpm, CFG.MAX_RPM)}\` \`${s.rpm}/${CFG.MAX_RPM}\` \n` +
            `• *RPH (1h):* \`${bar(s.rph, CFG.MAX_RPH)}\` \`${s.rph}/${CFG.MAX_RPH}\` \n\n` +
            `• *AI Queries:* \`${s.ai}\` \n` +
            `• *Img Gens:* \`${s.img}\` \n` +
            `• *API Errors:* \`${s.err}\` \n\n` +
            `• *Active Chats:* \`${State.chats.size}\` \n` +
            `• *Tracked Users:* \`${State.targets.size + State.stalkers.size}\` \n` +
            `• *Persona Vault:* \`${Gems.list().length}\` gems`
        );
    }

    if (sub === 'health' || sub === 'ping') {
        const stub = await thinking(Gifted, from, mek, '🔍 _Probing neural endpoints..._');
        const start = Date.now();
        const results = [];
        
        // Test QuillBot SSE
        const { text: qOk, err: qErr } = await askAI('Respond ONLY with the word OK');
        results.push((!qErr && qOk.includes('OK')) ? '✅ *AI Engine:* Online' : '❌ *AI Engine:* Critical/Blocked');

        // Test Infip
        const iOk = await ensureInfip();
        results.push(iOk ? '✅ *Infip API:* Validated' : '❌ *Infip API:* Exhausted/Invalid');

        // Latency
        results.push(`🛰️ *Latency:* \`${Date.now() - start}ms\``);

        return editMsg(Gifted, stub, `🔍 *SYSTEM HEALTH CHECK*\n\n${results.join('\n')}\n\n_Last Scan: ${new Date().toLocaleTimeString()}_`);
    }

    if (sub === 'reset') {
        const type = parts[1]?.toLowerCase();
        if (type === 'circuit') { CB.reset(); return reply('✅ *Circuit Breaker reset.*'); }
        if (type === 'stats') { Limiter.daily = { ai: 0, img: 0, err: 0, day: new Date().toDateString() }; return reply('✅ *Daily usage stats cleared.*'); }
        return reply('📝 \`.apimon reset <circuit|stats>\`');
    }

    return reply(`📊 *APIMON COMMANDS*\n\n• \`.apimon status\`\n• \`.apimon health\`\n• \`.apimon reset\``);
});

/**
 * @command .autoenhance
 * @description Toggles AI-driven grammar/style polishing for the owner's messages.
 */
gmd({
    pattern: 'autoenhance',
    cmdname: 'autoenhance',
    aliases: ['smartedit', 'aiwriter', 'polish'],
    category: 'ai',
    desc: 'Toggle AI auto-correction of your sent messages.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only Command.*');

    const opt = q.trim().toLowerCase();
    if (opt === 'on' || opt === 'enable') {
        State.autoEnhance = true;
        return reply('✍️ *Auto-Enhance:* ✅ *ENABLED*\n_Your outgoing messages will now be silently improved for clarity and grammar._');
    }
    if (opt === 'off' || opt === 'disable') {
        State.autoEnhance = false;
        return reply('✍️ *Auto-Enhance:* ❌ *DISABLED*');
    }

    return reply(`✍️ *AUTO-ENHANCE SYSTEM*\n\nStatus: ${State.autoEnhance ? '✅ *ON*' : '❌ *OFF*'}\n\n• \`.autoenhance on\`\n• \`.autoenhance off\``);
});

/**
 * @command .aitranslate
 * @description AI-powered multilingual engine.
 */
gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['aitr', 'translate', 'gi-trans'],
    category: 'ai',
    desc: 'Translate text to any language using AI context.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only.*');

    const parts = q.trim().split(/\s+/);
    const lang = parts[0];
    const text = parts.slice(1).join(' ') || mek.message?.extendedTextMessage?.contextInfo?.quotedMessage?.conversation;

    if (!lang || !text) return reply('📝 *Usage:* `.aitranslate <language> <text>`\n_Example: .aitranslate Spanish Hello world_');

    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${lang}..._`);
    const prompt = `Translate the following text to ${lang}. Keep the tone natural for WhatsApp. Return ONLY the translated text:\n\n"${text}"`;

    const { text: result, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `❌ *Translation failed:* ${result}`);

    return editMsg(Gifted, stub, `🌐 *AI TRANSLATION*\n\n*Target:* ${lang}\n\n📝 ${result}`);
});

/**
 * @command .aiwrite
 * @description Creative utility suite: roasts, captions, story, code.
 */
gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'draft', 'aiwriter'],
    category: 'ai',
    desc: 'AI creative writing suite.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ') || mek.message?.extendedTextMessage?.contextInfo?.quotedMessage?.conversation;

    const map = {
        'roast': 'Write a savage but witty roast about {t}. Use emojis.',
        'caption': 'Generate 3 creative captions for {t}. Use hashtags.',
        'code': 'Write a documented code snippet in the appropriate language for: {t}. Use markdown.',
        'story': 'Write a short engaging story about {t} in under 200 words.',
        'email': 'Write a professional email about {t}. Include a clear subject.',
        'lyrics': 'Write 8 bars of rap lyrics about {t}.'
    };

    if (!map[type] || !topic) {
        return reply(`✍️ *AI WRITER UTILITIES*\n\n*Styles:* \`roast\`, \`caption\`, \`code\`, \`story\`, \`email\`, \`lyrics\`\n\n📝 \`.aiwrite <style> <topic>\``);
    }

    const stub = await thinking(Gifted, from, mek, `✍️ _Composing ${type}..._`);
    const prompt = map[type].replace('{t}', topic) + "\n\nFormat output with WhatsApp Markdown.";

    const { text, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `❌ ${text}`);

    return editMsg(Gifted, stub, `✨ *AI ${type.toUpperCase()}*\n\n${text}`);
});

/**
 * @command .aidecode
 * @description Advanced image/text analyzer.
 */
gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'aianalyze'],
    category: 'ai',
    desc: 'Analyze a quoted image or text with AI vision.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImg = quoted?.imageMessage || mek.message?.imageMessage;

    if (!hasImg && !q.trim() && !quoted?.conversation) return reply('📝 *Usage:* Reply to an image or text with \`.aidecode\`');

    const stub = await thinking(Gifted, from, mek, '🔍 _Analyzing context..._');
    let imgUrls = [];

    if (hasImg) {
        const target = quoted?.imageMessage || mek.message.imageMessage;
        const tmp = path.join(__dirname, `tmp_dec_${Date.now()}.jpg`);
        try {
            await Gifted.downloadAndSaveMediaMessage(target, tmp);
            const url = await uploadImgBB(tmp);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tmp)) fs.unlinkSync(tmp);
        } catch (e) {}
    }

    const input = q.trim() || quoted?.conversation || quoted?.extendedTextMessage?.text || 'Explain this in detail.';
    const prompt = imgUrls.length ? `Describe this image in detail and address this: ${input}` : `Analyze this text in depth: "${input}"`;

    const { text, err } = await askAI(prompt + "\n\nStrictly use WhatsApp markdown for the analysis report.", imgUrls);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : `🔍 *AI ANALYSIS*\n\n${text}`);
});

// ==============================================================================
// 39. AI WATCHER — REACTIVE ENGINE (AUTO-REPLY / STALKING)
// ==============================================================================

/**
 * Core event listener for AI automation.
 * Monitors stalked users, targeted chats, and owner's outgoing messages.
 */
const attachWatcher = (Gifted) => {
    if (!Gifted?.ev) return;
    
    // Custom flag to prevent duplicate attachment
    if (Gifted._gemsWatcherSet) return;
    Gifted._gemsWatcherSet = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.id.startsWith('BAE5')) continue;

                const fromMe = msg.key.fromMe;
                const chatId = msg.key.remoteJid;
                const sender = (msg.key.participant || msg.key.remoteJid || '').split('@')[0] + '@s.whatsapp.net';
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || msg.message.imageMessage?.caption || '';

                // 1. OWNER AUTO-POLISH (Outgoing)
                if (fromMe && State.autoEnhance && body.length > 8 && !body.startsWith('.')) {
                    setImmediate(async () => {
                        try {
                            const { text: polished, err } = await askAI(`Strictly fix grammar and spelling. Keep the same tone. Return ONLY corrected text: "${body}"`);
                            if (!err && polished && polished.trim().toLowerCase() !== body.trim().toLowerCase()) {
                                await sleep(1200);
                                await Gifted.sendMessage(chatId, { text: polished.trim(), edit: msg.key });
                            }
                        } catch (e) {}
                    });
                    continue;
                }

                if (fromMe || body.startsWith('.')) continue;

                // 2. SESSION RESOLVER (Incoming)
                let sess = null;
                if (State.stalkers.has(sender)) {
                    sess = State.stalkers.get(sender);
                } else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (!targetData.chatId || targetData.chatId === chatId) sess = targetData;
                } else if (State.chats.has(chatId)) {
                    sess = State.chats.get(chatId);
                } else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { gem: State.dmGem || State.PERSONA, history: [] });
                    }
                    sess = State.dmSessions.get(sender);
                }

                if (!sess) continue;

                // 3. GENERATE NEURAL REPLY
                setImmediate(async () => {
                    try {
                        let vis = [];
                        if (msg.message.imageMessage) {
                            const tmp = path.join(__dirname, `tmp_w_${Date.now()}.jpg`);
                            try {
                                await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, tmp);
                                const u = await uploadImgBB(tmp);
                                if (u) vis.push(u);
                                if (fs.existsSync(tmp)) fs.unlinkSync(tmp);
                            } catch (e) {}
                        }

                        const input = body || "[image]";
                        State.addHist(sess, 'User', input);
                        
                        const prompt = State.buildPrompt(sess.gem, sess.history, input);
                        
                        // Fake typing delay for realism
                        const delay = Math.min(input.length * 40, 3500) + 500;
                        await sleep(delay);
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch (_) {}

                        const { text, err } = await askAI(prompt, vis);
                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch (_) {}

                        if (!err) {
                            State.addHist(sess, 'AI', text);
                            await Gifted.sendMessage(chatId, { text }, { quoted: msg });
                        }
                    } catch (err) { console.error('[AIGems] Watcher Error:', err.message); }
                });
            } catch (err) { console.error('[AIGems] Watcher Critical:', err.message); }
        }
    });
    console.log('[AIGems] Neural Watcher Attached to Stream.');
};

// ==============================================================================
// 40. LIFECYCLE MANAGEMENT
// ==============================================================================

/**
 * Attaches the watcher globally when the socket is ready.
 */
const _rebindAI = () => {
    const G = global.conn || global.client;
    if (G) attachWatcher(G);
};

setInterval(_rebindAI, 15000);
setTimeout(_rebindAI, 5000);

console.log('[AIGems] Phase 9 Complete: AI Intelligence & Automation Suite Online.');
