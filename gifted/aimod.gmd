}, async (from, Gifted, conText) => {
    return conText.reply(`🤖 *AI COMMAND CENTER*\n\n` +
        `• \`.gem\` — Manage AI personas (gen, analyze, remix)\n` +
        `• \`.gai\` — One-shot ask & Auto-reply control\n` +
        `• \`.img\` — Generate AI artwork\n` +
        `• \`.aitranslate <lang> <text>\` — Translate content\n` +
        `• \`.aiwrite <type> <topic>\` — Creative drafting\n` +
        `• \`.aidecode\` — Analyze images/text in-depth\n` +
        `• \`.apimon\` — View API health & usage\n` +
        `• \`.autoenhance on/off\` — Fix your messages automatically`);
});

// Bootstrapper
setTimeout(() => { if (global.conn) attachWatcher(global.conn); }, 5000);
// ==============================================================================
// 15. ADVANCED IMAGE SUITE — INFIP API OPTIMIZATION
// ==============================================================================

/**
 * @command .img
 * @description Advanced image generation suite with Chaos, Surprise, and Model switching.
 */
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'genimg', 'art'],
    category: 'ai',
    desc: 'Advanced Image Generation. .img help for sub-commands.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase() || 'help';
    const rest = parts.slice(1).join(' ');

    // ── CONFIGURATION & MODELS ──
    if (cmd === 'models' || cmd === 'list') {
        const lines = Object.entries(CFG.IMG_MDLS).map(([id, m]) => 
            `${m.tier === 'pro' ? '👑' : '🆓'} \`${id}\` — ${m.desc}`
        ).join('\n');
        return reply(`📋 *Available Models*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\`\n*Switch:* \`.img set <model>\``);
    }

    if (cmd === 'set' || cmd === 'config') {
        const newModel = parts[1]?.toLowerCase();
        if (!newModel || !CFG.IMG_MDLS[newModel]) return reply(`📝 \`.img set <model_id>\`\n_Models:_ \`${Object.keys(CFG.IMG_MDLS).join(', ')}\``);
        CFG.IMG_MODEL = newModel;
        if (parts[2]) CFG.IMG_SIZE = parts[2];
        return reply(`✅ *Default Config Updated*\nModel: \`${CFG.IMG_MODEL}\`\nSize: \`${CFG.IMG_SIZE}\``);
    }

    // ── GENERATION MODES ──
    if (cmd === 'surprise') {
        const stub = await thinking(Gifted, from, mek, '🎲 _Dreaming up something wild..._');
        const { text: dream, err } = await askAI(`Generate a highly creative, vivid, and detailed image generation prompt. It should be visually stunning and unique. Return ONLY the prompt text.`);
        if (err) return editMsg(Gifted, stub, `❌ ${dream}`);
        await editMsg(Gifted, stub, `🎨 _Visualizing Dream:_ "${dream.slice(0, 100)}..."`);
        const urls = await generateImage(dream);
        if (!urls.length) return editMsg(Gifted, stub, '❌ *Generation failed.*');
        await del(Gifted, stub.key);
        return sendImg(Gifted, from, urls[0], `🎲 *Surprise Generation*\n\n*Prompt:* _${dream}_\n*Model:* \`${CFG.IMG_MODEL}\``, mek);
    }

    if (cmd === 'chaos') {
        const models = Object.keys(CFG.IMG_MDLS);
        const randomModel = models[Math.floor(Math.random() * models.length)];
        const randomSize = ['1024x1024', '1792x1024', '1024x1792'][Math.floor(Math.random() * 3)];
        const stub = await thinking(Gifted, from, mek, `🌪️ *CHAOS MODE* — Using \`${randomModel}\`...`);
        const { text: chaosPrompt } = await askAI("Generate a bizarre, surreal, and abstract prompt. Return ONLY text.");
        const urls = await generateImage(chaosPrompt || 'surreal entropy', { model: randomModel, size: randomSize });
        if (!urls.length) return editMsg(Gifted, stub, '❌ *Chaos engine failed.*');
        await del(Gifted, stub.key);
        return sendImg(Gifted, from, urls[0], `🌪️ *CHAOS MODE*\n\n*Prompt:* _${chaosPrompt}_\n*Model:* \`${randomModel}\`\n*Size:* \`${randomSize}\``, mek);
    }

    if (cmd === 'enhance') {
        if (!rest) return reply('📝 `.img enhance <simple_prompt>`');
        const stub = await thinking(Gifted, from, mek, '🧠 _Expanding prompt..._');
        const { text: enhanced, err } = await askAI(`Expand this simple image prompt into a professional masterwork prompt with details on lighting, texture, camera lens, and atmosphere: "${rest}". Return ONLY the enhanced prompt.`);
        if (err) return editMsg(Gifted, stub, `❌ ${enhanced}`);
        return editMsg(Gifted, stub, `✨ *Enhanced Prompt:*\n\n${enhanced}\n\n_Generate with:_ \`.img gen ${enhanced}\``);
    }

    if (cmd === 'gen' || (cmd && !['help', 'setup'].includes(cmd))) {
        const prompt = cmd === 'gen' ? rest : q;
        if (!prompt) return reply('📝 `.img gen <prompt>`');
        await react('⏳');
        const stub = await thinking(Gifted, from, mek, '🎨 _Processing..._');
        const urls = await generateImage(prompt);
        if (!urls.length) return editMsg(Gifted, stub, '❌ *Failed.* Check `.img setup`');
        await del(Gifted, stub.key);
        await react('✨');
        return sendImg(Gifted, from, urls[0], `🎨 *AI Art*\n\n*Prompt:* _${prompt}_\n*Model:* \`${CFG.IMG_MODEL}\``, mek);
    }

    return reply(
        `🎨 *IMAGE GENERATION SUITE*\n\n` +
        `• \`.img <prompt>\` — Quick generate\n` +
        `• \`.img surprise\` — Random AI-dreamed art\n` +
        `• \`.img chaos\` — Random parameters & prompt\n` +
        `• \`.img enhance <text>\` — Expand basic prompt\n` +
        `• \`.img models\` — List available AI models\n` +
        `• \`.img set <id>\` — Change default model\n` +
        `• \`.img setup\` — Test API keys`
    );
});

// ==============================================================================
// 16. MASTER AI CONTROL — .GAI EXTENSIONS (STALK, WIPE, SUMMARY)
// ==============================================================================

/**
 * @command .gai
 * @description Advanced auto-reply controls and stalker logic.
 */
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain'],
    category: 'ai',
    desc: 'AI Assistant & Automation Control.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase();
    const targetNum = parts[1]?.replace(/[^0-9]/g, '');

    if (cmd === 'stalk') {
        if (!targetNum) return reply('📝 `.gai stalk <number> [gem_name]`');
        const jid = targetNum + '@s.whatsapp.net';
        const gem = parts[2] || 'default';
        const persona = (gem !== 'default' ? Gems.get(gem) : null) || State.PERSONA;
        State.stalkers.set(jid, { gem: persona, history: [], gemName: gem });
        return reply(`🕵️ *Global Stalker Active*\nUser: @${targetNum}\nGem: \`${gem}\`\nAI will reply to this user in EVERY chat.`, { mentions: [jid] });
    }

    if (cmd === 'target') {
        if (!targetNum) return reply('📝 `.gai target <number> [gem_name]`');
        const jid = targetNum + '@s.whatsapp.net';
        const gem = parts[2] || 'default';
        const persona = (gem !== 'default' ? Gems.get(gem) : null) || State.PERSONA;
        State.targets.set(jid, { gem: persona, history: [], chatId: from, gemName: gem });
        return reply(`🤖 *Target Locked*\nUser: @${targetNum}\nGem: \`${gem}\`\nAI will reply to this user in THIS chat only.`, { mentions: [jid] });
    }

    if (cmd === 'stop') {
        const type = parts[1]?.toLowerCase();
        if (type === 'all') {
            State.stalkers.clear(); State.targets.clear(); State.chats.delete(from); State.dmActive = false;
            return reply('☢️ *All AI automations terminated.*');
        }
        if (targetNum) {
            const jid = targetNum + '@s.whatsapp.net';
            State.stalkers.delete(jid); State.targets.delete(jid);
            return reply(`✅ Stopped tracking @${targetNum}`, { mentions: [jid] });
        }
        State.chats.delete(from);
        return reply('🛑 AI disabled in this chat.');
    }

    if (cmd === 'wipe') {
        const sess = State.chats.get(from) || State.dmSessions.get(from);
        if (sess) { sess.history = []; return reply('🧠 *Session memory wiped.*'); }
        return reply('❌ No active session here.');
    }

    if (cmd === 'summary') {
        const sess = State.chats.get(from);
        if (!sess || sess.history.length < 4) return reply('ℹ️ Not enough history to summarize.');
        const stub = await thinking(Gifted, from, mek, '📝 _Summarizing..._');
        const { text, err } = await askAI(`Provide a concise summary of the following conversation history in bullet points:\n\n${sess.history.join('\n')}`);
        return editMsg(Gifted, stub, err ? `❌ ${text}` : `📝 *Chat Summary*\n\n${text}`);
    }

    if (cmd === 'status') {
        const s = Limiter.stats();
        return reply(`📊 *AI System Status*\n\n• *DMs:* ${State.dmActive ? '✅' : '❌'}\n• *Stalkers:* ${State.stalkers.size}\n• *Targets:* ${State.targets.size}\n• *Active Chats:* ${State.chats.size}\n• *Daily AI:* ${s.ai}\n• *Daily Img:* ${s.img}\n• *Errors:* ${s.err}\n• *Circuit:* ${CB.open() ? '🔴 OPEN' : '🟢 CLOSED'}`);
    }

    // Default: Ask AI
    if (q) {
        const stub = await thinking(Gifted, from, mek, '🧠 _Thinking..._');
        const { text, err } = await askAI(q);
        return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
    }

    return reply(`🧠 *GAI CONTROL HELP*\n\n.gai stalk <num>\n.gai target <num>\n.gai stop [all|num]\n.gai wipe\n.gai summary\n.gai status\n.gai <question>`);
});

// ==============================================================================
// 17. API MONITORING & DIAGNOSTICS
// ==============================================================================

gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    category: 'ai',
    desc: 'Deep API health check and diagnostic tool.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const stats = Limiter.stats();
    const circuit = CB.open() ? '⚠️ *TRIPPED* (Cooldown active)' : '✅ *STABLE*';
    
    let infipHealth = 'Testing...';
    try { 
        await ensureInfip();
        infipHealth = _iOk ? '✅ *Connected*' : '❌ *Failed*';
    } catch(e) { infipHealth = '❌ *Error*'; }

    let quillHealth = 'Testing...';
    try {
        const { err } = await askAI('Ping');
        quillHealth = !err ? '✅ *Online*' : '❌ *Auth/Cookie Error*';
    } catch(e) { quillHealth = '❌ *Timed Out*'; }

    return reply(
        `🛰️ *AI DIAGNOSTIC REPORT*\n\n` +
        `*System Circuit:* ${circuit}\n` +
        `*QuillBot API:* ${quillHealth}\n` +
        `*Infip API:* ${infipHealth}\n\n` +
        `*Usage Metrics:*\n` +
        `• Requests/Min: ${stats.rpm}/${CFG.MAX_RPM}\n` +
        `• Requests/Hour: ${stats.rph}/${CFG.MAX_RPH}\n` +
        `• Today's Success: ${stats.ai + stats.img}\n` +
        `• Today's Failures: ${stats.err}\n\n` +
        `*Active Key:* \`${_iKey.slice(0, 15)}...\``
    );
});

// ==============================================================================
// 18. RE-ATTACH WATCHER (Fixes for potential runtime drops)
// ==============================================================================
const rebindWatcher = () => {
    const Gifted = global.conn || global.client;
    if (Gifted) {
        // Prevent duplicate listeners by checking if a custom flag exists
        if (!Gifted._atassaWatcherSet) {
            attachWatcher(Gifted);
            Gifted._atassaWatcherSet = true;
            console.log('[AIGems] Neural Watcher bound to global connection.');
        }
    }
};

// Periodic health check for the watcher
setInterval(rebindWatcher, 30000);
rebindWatcher();

