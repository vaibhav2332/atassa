gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['tr', 'translate', 'aitr'],
    category: 'ai',
    desc: 'Translate text to any language using AI reasoning.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Owner access required.*');

    const parts = q.trim().split(/\s+/);
    const targetLang = parts[0];
    let sourceText = parts.slice(1).join(' ');

    // Check for quoted message if source text is missing
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (!sourceText && quoted) {
        sourceText = quoted.conversation || quoted.extendedTextMessage?.text;
    }

    if (!targetLang || !sourceText) {
        return reply('*📝 Usage:* `.aitranslate <language> <text>` or reply to a message with `.aitranslate <language>`');
    }

    const stub = await thinking(Gifted, from, mek, `*🌐 Translating to ${targetLang}...*`);
    
    const prompt = `Translate this text into ${targetLang}. 
    Maintain the original slang, tone, and formatting. 
    Use WhatsApp Markdown for the output. 
    Return ONLY the translated text without any conversational filler or quotes.
    
    Text: "${sourceText}"`;

    const { text, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `*❌ Translation Error:* ${text}`);

    return editMsg(Gifted, stub, `*🌐 AI TRANSLATION [${targetLang.toUpperCase()}]*\n\n${text}`);
});

// ==============================================================================
// 16. .aiwrite — CREATIVE DRAFTING ENGINE (PHASE 8)
// ==============================================================================
gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'draft', 'writer'],
    category: 'ai',
    desc: 'Generate creative content using specialized prompt templates.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Owner access required.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const templates = {
        'roast':   "Write a savage, witty, and hilarious WhatsApp roast about: {topic}. Use emojis and bold text for emphasis. Ensure it sounds like a real person, not a bot.",
        'story':   "Write a short, engaging 2-paragraph story about: {topic}. Focus on vivid imagery and a punchy ending. Use _italics_ for internal monologue.",
        'code':    "Write clean, optimized, and modern code for: {topic}. Include comments explaining logic. Use ```code blocks``` for the result.",
        'caption': "Generate 5 unique and catchy social media captions for: {topic}. Include relevant emojis and a mix of formal/informal styles.",
        'email':   "Draft a professional email regarding: {topic}. Use *bold* for key dates or subject lines. Keep it concise.",
        'lyrics':  "Write song lyrics about: {topic} in the style of a modern rap or pop artist. Use [Verse] and [Chorus] tags.",
        'bio':     "Write 3 different WhatsApp/Instagram bio options for: {topic}. Use creative symbols and short phrases."
    };

    if (!templates[type]) {
        return reply(
            `*✍️ AI WRITER MENU*\n\n` +
            `*Usage:* \`.aiwrite <type> <topic>\`\n\n` +
            `*Available Types:*\n` +
            `• \`roast\` — Savage humor\n` +
            `• \`story\` — Short fiction\n` +
            `• \`code\` — Scripting/Coding\n` +
            `• \`caption\` — Social media\n` +
            `• \`email\` — Professional drafts\n` +
            `• \`lyrics\` — Songwriting\n` +
            `• \`bio\` — Profile descriptions\n\n` +
            `_Example: .aiwrite roast my bad luck_`
        );
    }

    if (!topic) return reply(`*⚠️ Please provide a topic for the ${type.toUpperCase()}.*`);

    const stub = await thinking(Gifted, from, mek, `*✍️ Composing ${type}...*`);
    const prompt = templates[type].replace('{topic}', topic) + "\n\n*IMPORTANT*: Always use WhatsApp Markdown. No LaTeX. No markdown headers (###).";

    const { text, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `*❌ Writing Error:* ${text}`);

    return editMsg(Gifted, stub, `*✨ AI ${type.toUpperCase()}*\n\n${text}`);
});

