// ==============================================================================
// 18. EVENT WATCHER — THE AUTO-PILOT & REACTIVE ENGINE
// ==============================================================================

/**
 * @section Reactive Watcher
 * @description Background listener for stalking, auto-reply, and auto-enhance.
 */

let _watchDone = false;

// Inject Markdown Enforcement into Global Persona
State.PERSONA += "\n\n*STRICT FORMATTING RULE*: You MUST use WhatsApp markdown for EVERY response. Use *bold* for emphasis, _italics_ for tone, ~strikethrough~ for corrections, and ```code blocks``` for technical data or lists. Keep your responses punchy and visually structured.";

/**
 * Attaches the main message listener to the Gifted instance.
 * @param {Object} Gifted - The Baileys/Gifted client socket.
 */
const attachWatcher = (Gifted) => {
    if (_watchDone || !Gifted?.ev) return;
    _watchDone = true;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        // Only process new incoming messages or appended ones
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                // Ignore messages without content or from system bots (BAE5...)
                if (!msg.message || msg.key.id.startsWith('BAE5')) continue;

                const fromMe = msg.key.fromMe;
                const chatId = msg.key.remoteJid || '';
                const sender = (msg.key.participant || msg.key.remoteJid || '').split(':')[0].split('@')[0] + '@s.whatsapp.net';
                const isGrp = chatId.endsWith('@g.us');
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                // ----------------------------------------------------------
                // 1. AUTO-ENHANCE: IMPROVE OWNER'S OUTGOING MESSAGES
                // ----------------------------------------------------------
                if (fromMe && State.autoEnhance && body.length > 8 && !body.startsWith('.')) {
                    // Execute in separate thread-like context to avoid blocking
                    setImmediate(async () => {
                        try {
                            const enhancementPrompt = `Act as a master of linguistics and WhatsApp communication. Rewrite the following message to be more effective, professional yet natural, and grammatically perfect. Use WhatsApp markdown. Return ONLY the enhanced text:\n\n"${body}"`;
                            const { text: enhanced, err } = await askAI(enhancementPrompt);
                            
                            if (!err && enhanced && enhanced.trim().toLowerCase() !== body.trim().toLowerCase()) {
                                // Subtle delay to simulate 'thinking' before editing
                                await sleep(1200);
                                await Gifted.sendMessage(chatId, { text: enhanced.trim(), edit: msg.key });
                            }
                        } catch (e) { /* Fail silently to not disrupt owner flow */ }
                    });
                    continue;
                }

                // Ignore further logic if message is from self or a command
                if (fromMe || body.startsWith('.')) continue;

                // ----------------------------------------------------------
                // 2. PRIORITY SESSION RESOLVER
                // ----------------------------------------------------------
                let activeSession = null;

                // Priority 1: Global Stalkers (Monitor user across all chats)
                if (State.stalkers.has(sender)) {
                    activeSession = State.stalkers.get(sender);
                } 
                // Priority 2: Targeted Users (Specific users in specific chats)
                else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (!targetData.chatId || targetData.chatId === chatId) {
                        activeSession = targetData;
                    }
                } 
                // Priority 3: Active Chat AI (Everyone in a specific group/chat)
                else if (State.chats.has(chatId)) {
                    activeSession = State.chats.get(chatId);
                } 
                // Priority 4: DM Auto-Pilot (Global private message responder)
                else if (!isGrp && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, {
                            gem: State.dmGem || State.PERSONA,
                            history: [],
                            gemName: 'auto_pilot_dm'
                        });
                    }
                    activeSession = State.dmSessions.get(sender);
                }

                if (!activeSession) continue;

                // ----------------------------------------------------------
                // 3. NEURAL PROCESSING & RESPONSE
                // ----------------------------------------------------------
                setImmediate(async () => {
                    try {
                        let attachedImages = [];
                        
                        // Handle vision if message contains an image
                        if (msg.message.imageMessage) {
                            const tempPath = path.join(__dirname, `tmp_watch_${Date.now()}.jpg`);
                            try {
                                const buffer = await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage, tempPath);
                                const imageUrl = await uploadImgBB(tempPath);
                                if (imageUrl) attachedImages.push(imageUrl);
                                if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);
                            } catch (imgErr) {
                                console.error('[AIGems] Vision Stalking Error:', imgErr.message);
                            }
                        }

                        // Build conversation context
                        const userInput = body || (msg.message.imageMessage ? "[Sent an Image]" : "[Unknown Media]");
                        State.addHist(activeSession, 'User', userInput);

                        const finalPrompt = State.buildPrompt(
                            activeSession.gem + "\n\n*REMINDER*: Use full WhatsApp markdown (*bold*, _italics_, `code`).",
                            activeSession.history,
                            userInput
                        );

                        // Simulate human response time based on complexity
                        const typingDelay = Math.min(userInput.length * 30, 3500) + 800;
                        await sleep(typingDelay);
                        
                        // Set "composing" status for realism
                        try { await Gifted.sendPresenceUpdate('composing', chatId); } catch(_) {}

                        const { text: response, err: aiError } = await askAI(finalPrompt, attachedImages);
                        
                        // Clear presence status
                        try { await Gifted.sendPresenceUpdate('paused', chatId); } catch(_) {}

                        if (aiError && CB.open()) return; // Circuit breaker active

                        const cleanResponse = response.trim();
                        State.addHist(activeSession, 'AI', cleanResponse);

                        // Ensure response is properly quoted for context
                        const quotedOptions = {
                            quoted: {
                                key: msg.key,
                                message: msg.message
                            }
                        };

                        await Gifted.sendMessage(chatId, { text: cleanResponse }, quotedOptions);

                    } catch (innerErr) {
                        console.error('[AIGems] Watcher Processing Error:', innerErr.message);
                    }
                });

            } catch (outerErr) {
                console.error('[AIGems] Critical Watcher Loop Failure:', outerErr.message);
            }
        }
    });

    console.log('[AIGems] ⚡ Reactive Watcher Engine Online (Stalking/DM/Enhance active)');
};

/**
 * Bootstrapper: Locates the global connection and attaches the watcher.
 * Retries every 8 seconds if connection is not yet initialized.
 */
const _bootWatcher = setInterval(() => {
    const activeClient = global.conn || global.client;
    if (activeClient) {
        attachWatcher(activeClient);
        clearInterval(_bootWatcher);
    }
}, 8000);

// Immediate check on load
setTimeout(() => {
    const activeClient = global.conn || global.client;
    if (activeClient) {
        attachWatcher(activeClient);
        clearInterval(_bootWatcher);
    }
}, 2000);

