// ═══════════════════════════════════════════════════════════════════════════
//  .code — AI CODE HELPER
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'code',
        aliases : ['aicode', 'codegen', 'aidev'],
        category: 'ai',
        react   : '💻',
        desc    : 'AI code generation and explanation',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        if (!q) return editOrReply(Gifted, from, mek, 'Usage: *.code <task or code snippet>*');

        // Include quoted code snippet if present
        const quotedText = mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage?.conversation
            || mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage?.extendedTextMessage?.text || '';
        const prompt = quotedText
            ? `Context/Code being discussed:\n\`\`\`\n${quotedText}\n\`\`\`\n\nUser request: ${q}`
            : q;

        await editOrReply(Gifted, from, mek, '💻 *Coding...*');
        const r = await smartAI(
            `You are an expert programmer. Help with this coding request:\n\n${prompt}\n\nIf generating code, provide it with a brief explanation. Use proper formatting.`,
            [], conText
        );
        return editOrReply(Gifted, from, mek, r);
    }
);

// ═══════════════════════════════════════════════════════════════════════════
//  .vision — IMAGE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'vision',
        aliases : ['aiimg', 'describe', 'analyse', 'seethis'],
        category: 'ai',
        react   : '👁️',
        desc    : 'AI vision — analyse and describe a quoted or URL image',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;
        await editOrReply(Gifted, from, mek, '👁️ *Processing image...*');

        let imgUrl = q?.startsWith('http') ? q : null;

        // Try quoted image
        if (!imgUrl) {
            imgUrl = await getQuotedImageUrl(mek, Gifted);
        }

        if (!imgUrl)
            return editOrReply(Gifted, from, mek, '❌ Please quote an image or provide an image URL.');

        const userPrompt = (q && !q.startsWith('http')) ? q
            : 'Describe this image in detail. Note all elements, colours, mood, text, and any interesting details.';

        const r = await qbRequest(userPrompt, [imgUrl]);
        return editOrReply(Gifted, from, mek, `👁️ *Vision Analysis*\n\n${r}`);
    }
);

