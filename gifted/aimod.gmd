gmd({
    pattern: 'forget',
    cmdname: 'forget',
    category: 'ai',
    desc: 'Clear the AI memory for the current session.',
    react: '🧹'
}, async (from, Gifted, conText) => {
    const { isSuperUser, reply } = conText;
    if (!isSuperUser) return;

    if (State.sessions.has(from)) {
        State.sessions.get(from).history = [];
        return reply('🧹 *Memory Purged:* The AI has forgotten previous context for this chat.');
    }
    
    // Check if there is a target session here
    let found = false;
    State.targets.forEach((val, key) => {
        if (val.chatId === from) {
            val.history = [];
            found = true;
        }
    });

    if (found) return reply('🧹 *Memory Purged:* Target history for this chat cleared.');
    return reply('ℹ️ No active AI session found in this chat.');
});

gmd({
    pattern: 'aisettings',
    cmdname: 'aisettings',
    category: 'ai',
    desc: 'Configure global AI behavior.',
    react: '⚙️'
}, async (from, Gifted, conText) => {
    const { q, isSuperUser, reply } = conText;
    if (!isSuperUser) return;

    const [opt, val] = q.toLowerCase().split(' ');
