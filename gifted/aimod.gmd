gmd({
    pattern: 'fixgrammar',
    cmdname: 'fixgrammar',
    aliases: ['fix', 'correct', 'grammar'],
    category: 'ai',
    desc: 'Fix grammar and spelling in a text.',
    react: '📖',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    let text = q.trim();
    if (!text) {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        text = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    }

    if (!text) return reply('*📝 Usage:* Reply to text or type `.fixgrammar <text>`');

    const stub = await thinking(Gifted, from, mek, '*📖 Proofreading...*');
    const { text: result, err } = await askAI(`Act as a professional editor. Correct all grammar, spelling, and punctuation errors in the following text. Maintain the original language. Return ONLY the corrected text:\n\n"${text}"`);

    if (err) return editMsg(Gifted, stub, `*❌ Error:* ${result}`);
    
    if (result.trim().toLowerCase() === text.trim().toLowerCase()) {
        return editMsg(Gifted, stub, '*✅ Text is already grammatically perfect.*');
    }

    return editMsg(Gifted, stub, `*📖 Corrected Text:*\n\n${result}`);
});

gmd({
    pattern: 'paraphrase',
    cmdname: 'paraphrase',
    aliases: ['rewrite', 'rephrase'],
    category: 'ai',
    desc: 'Rewrite text in a specified style (Formal, Casual, Creative).',
    react: '🔄',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const parts = q.trim().split(/\s+/);
    const style = parts[0]?.toLowerCase();
    const text = parts.slice(1).join(' ');

    const validStyles = ['formal', 'casual', 'creative', 'short', 'expanded'];
    if (!validStyles.includes(style) || !text) {
        return reply(`*🔄 Paraphraser*\n\n*Usage:* \`.paraphrase <style> <text\`\n*Styles:* \`${validStyles.join('`, `')}\``);
    }

    const stub = await thinking(Gifted, from, mek, `*🔄 Rephrasing (${style})...*`);
    const prompt = `Rewrite the following text in a ${style} style. Keep the meaning identical but change the structure and vocabulary. Return ONLY the rewritten text:\n\n"${text}"`;

    const { text: result, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `*❌ Error:* ${result}`);

    return editMsg(Gifted, stub, `*🔄 Rephrased (${style.toUpperCase()}):*\n\n${result}`);
});

// ==============================================================================
// 24. LIFECYCLE & EXPORTS
// ==============================================================================

setInterval(() => {
    const now = Date.now();
    const expiry = 3600000 * 2; 

    State.dmSessions.forEach((sess, jid) => {
        if (sess.lastActive && (now - sess.lastActive > expiry)) {
            State.dmSessions.delete(jid);
        }
    });

    _iCache.forEach((data, key) => {
        if (now - data.ts > 3600000) {
            _iCache.delete(key);
        }
    });

    if (CB.fails > 0 && (now - CB.lastFail > CB.TTL)) {
        CB.reset();
        console.log('[AIGems] Circuit breaker automatically reset.');
    }
}, 1800000);

process.on('SIGINT', () => {
    console.log('[AIGems] Shutting down AI module...');
    if (db) db.close();
    process.exit(0);
});

module.exports = {
    askAI,
    generateImage,
    State,
    Gems,
    Limiter,
    CB,
    CFG,
    attachWatcher
};

console.log('[AIGems] AI Controller successfully loaded.');
// ==============================================================================
// 25. .gem — ADVANCED VAULT UTILITIES (EXPORT, IMPORT, BACKUP)
// ==============================================================================

/**
 * @command .gembackup
 * @description Exports the entire persona database into a single JSON file.
 */
gmd({
    pattern: 'gembackup',
    cmdname: 'gembackup',
    category: 'ai',
    desc: 'Export all saved personas to a backup file.',
    react: '💾',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const list = Gems.list();
    if (!list.length) return reply('❌ *Vault is empty.*');

    const backup = {};
    list.forEach(name => {
        backup[name] = Gems.get(name);
    });

    const filePath = path.join(__dirname, `gems_backup_${Date.now()}.json`);
    fs.writeFileSync(filePath, JSON.stringify(backup, null, 2));

    await Gifted.sendMessage(from, { 
        document: fs.readFileSync(filePath), 
        mimetype: 'application/json', 
        fileName: `atassa_gems_${new Date().toISOString().split('T')[0]}.json`,
        caption: `💎 *Atassa Persona Vault Backup*\n\n*Total Gems:* ${list.length}\n*Date:* ${new Date().toLocaleString()}`
    });

    return fs.unlinkSync(filePath);
});

/**
 * @command .gemrestore
 * @description Restores gems from a quoted JSON file.
 */
gmd({
    pattern: 'gemrestore',
    cmdname: 'gemrestore',
    category: 'ai',
    desc: 'Restore personas from a backup JSON file.',
    react: '📥',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (!quoted?.documentMessage) return reply('📝 *Reply to a valid gems_backup.json file.*');

    const stub = await thinking(Gifted, from, mek, '📥 _Restoring vault..._');
    try {
        const filePath = await Gifted.downloadAndSaveMediaMessage(quoted.documentMessage, `restore_${Date.now()}`);
        const data = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
        
        let count = 0;
        Object.entries(data).forEach(([name, content]) => {
            if (Gems.save(name, content)) count++;
        });

        fs.unlinkSync(filePath);
        return editMsg(Gifted, stub, `✅ *Vault Restored*\n\nSuccessfully imported \`${count}\` personas into the database.`);
    } catch (e) {
        return editMsg(Gifted, stub, `❌ *Restore Failed:* ${e.message}`);
    }
});

/**
 * @command .gemshare
 * @description Generates a Base64 string for sharing a specific persona.
 */
gmd({
    pattern: 'gemshare',
    cmdname: 'gemshare',
    category: 'ai',
    desc: 'Generate a shareable code for a persona.',
    react: '🔗',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const name = q.trim().toLowerCase();
    const content = Gems.get(name);
    if (!content) return reply(`❌ *Gem \`${name}\` not found.*`);

    const shareCode = Buffer.from(JSON.stringify({ n: name, c: content })).toString('base64');
    return reply(`🔗 *Share Code for \`${name}\`:*\n\n\`\`\`${shareCode}\`\`\`\n\n_Use \`.gemimport <code>\` to add this to another bot._`);
});

/**
 * @command .gemimport
 * @description Imports a persona from a Base64 share code.
 */
gmd({
    pattern: 'gemimport',
    cmdname: 'gemimport',
    category: 'ai',
    desc: 'Import a persona from a share code.',
    react: '📥',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    try {
        const decoded = JSON.parse(Buffer.from(q.trim(), 'base64').toString('utf-8'));
        if (!decoded.n || !decoded.c) throw new Error('Invalid code');

        if (Gems.save(decoded.n, decoded.c)) {
            return reply(`✅ *Persona Imported:* \`${decoded.n}\``);
        }
    } catch (e) {
        return reply('❌ *Import Failed:* Invalid share code provided.');
    }
});

// ==============================================================================
// 26. .gem — METADATA & STATS
// ==============================================================================

/**
 * @command .gemstats
 * @description View usage statistics for personas.
 */
gmd({
    pattern: 'gemstats',
    cmdname: 'gemstats',
    category: 'ai',
    desc: 'View usage statistics for personas.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const gems = Gems.list();
    let stalkersCount = 0;
    State.stalkers.forEach(() => stalkersCount++);

    let report = `📊 *VAULT STATISTICS*\n\n` +
                 `• *Stored Personas:* ${gems.length}\n` +
                 `• *Active Stalkers:* ${State.stalkers.size}\n` +
                 `• *Active Targets:* ${State.targets.size}\n` +
                 `• *Active Chats:* ${State.chats.size}\n\n` +
                 `*Most Used (Session):*\n`;

    const usage = {};
    State.chats.forEach(s => { if(s.gemName) usage[s.gemName] = (usage[s.gemName]||0) + 1; });
    State.targets.forEach(s => { if(s.gemName) usage[s.gemName] = (usage[s.gemName]||0) + 1; });
    State.stalkers.forEach(s => { if(s.gemName) usage[s.gemName] = (usage[s.gemName]||0) + 1; });

    Object.entries(usage).sort((a,b) => b[1] - a[1]).forEach(([name, count]) => {
        report += `• \`${name}\`: ${count} instances\n`;
    });

    return reply(report);
});

// ==============================================================================
// 27. AUTO-PILOT ENHANCEMENTS (SMART TRIGGERS)
// ==============================================================================

/**
 * @command .gemtrigger
 * @description Sets a keyword trigger to activate a persona.
 */
const _triggers = new Map();

gmd({
    pattern: 'gemtrigger',
    cmdname: 'gemtrigger',
    category: 'ai',
    desc: 'Set a keyword to automatically activate a gem in a chat.',
    react: '⚡',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/);
    const keyword = parts[0]?.toLowerCase();
    const gemName = parts[1]?.toLowerCase();

    if (!keyword || !gemName) return reply('📝 *Usage:* \`.gemtrigger <keyword> <gem_name>\`');
    if (!Gems.get(gemName)) return reply(`❌ *Gem \`${gemName}\` not found.*`);

    _triggers.set(keyword, gemName);
    return reply(`✅ *Trigger Set:* Whenever someone says \`${keyword}\`, AI will activate \`${gemName}\` in that chat.`);
});

// ==============================================================================
// 28. RE-INJECTION OF WATCHER LOGIC (SAFETY)
// ==============================================================================

/**
 * Extra validation to prevent 'sleep' redeclaration while ensuring availability.
 * The 'sleep' function is used in the watcher but already defined in Section 5.
 */
const safeWatcherUpdate = (Gifted) => {
    if (!Gifted?._atassaEventsBound) {
        Gifted._atassaEventsBound = true;
        
        Gifted.ev.on('messages.upsert', async ({ messages }) => {
            for (const msg of messages) {
                if (!msg.message || msg.key.fromMe) continue;
                const body = (msg.message.conversation || msg.message.extendedTextMessage?.text || '').toLowerCase();
                
                // Check triggers
                for (const [kw, gem] of _triggers.entries()) {
                    if (body.includes(kw)) {
                        const persona = Gems.get(gem);
                        if (persona) {
                            State.chats.set(msg.key.remoteJid, { 
                                gem: persona, 
                                history: [], 
                                gemName: gem,
                                lastActive: Date.now()
                            });
                        }
                    }
                }
            }
        });
    }
};

// ==============================================================================
// 29. SYSTEM RECOVERY & PERSISTENCE
// ==============================================================================

/**
 * Saves current AI session states to the database to survive restarts.
 * (Future proofing for Phase 7: Session Persistence)
 */
const persistState = () => {
    try {
        const data = {
            stalkers: Array.from(State.stalkers.entries()),
            targets: Array.from(State.targets.entries()),
            dmActive: State.dmActive,
            dmGemName: State.dmGem ? 'active' : null
        };
        // Logic to write to a 'system_state' table in gems_ai.db
    } catch(e) {}
};

