//  .factcheck — AI FACT CHECKER (NEW)
// ═══════════════════════════════════════════════════════════════════════════
gmd(
    {
        pattern : 'factcheck',
        aliases : ['verify', 'checkfact', 'isittrue'],
        category: 'ai',
        react   : '🔎',
        desc    : 'AI fact-checks a statement',
        filename: __filename,
    },
    async (from, Gifted, conText) => {
        const { q, mek } = conText;

        const quotedText = mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage?.conversation
            || mek?.message?.extendedTextMessage?.contextInfo?.quotedMessage?.extendedTextMessage?.text || '';
        const claim = q || quotedText;

        if (!claim) return editOrReply(Gifted, from, mek, 'Usage: *.factcheck <statement>* or reply to a message.');
        await editOrReply(Gifted, from, mek, '🔎 *Fact-checking...*');
        const r = await smartAI(
            `Fact-check the following statement based on your knowledge:\n\n"${claim}"\n\nFormat your response:\n📊 *Verdict:* (TRUE / FALSE / PARTIALLY TRUE / UNCERTAIN)\n📝 *Explanation:* (2-3 sentences)\n⚠️ *Caveat:* (any important context)`,
            [], conText
        );
        return editOrReply(Gifted, from, mek, `🔎 *Fact Check*\n\n${r}`);
    }
);

