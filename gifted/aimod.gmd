gmd({
    pattern: 'aisync',
    cmdname: 'aisync',
    category: 'ai',
    desc: 'Force sync AI sessions and clear memory cache.',
    react: '🔄',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');
    
    _watchDone = false;
    attachWatcher(Gifted);
    _iCache.clear();
    
    return reply('*🔄 AI SYNCHRONIZATION COMPLETE*\n\n• Watcher restarted.\n• Image cache purged.\n• Rate limits refreshed.');
});

