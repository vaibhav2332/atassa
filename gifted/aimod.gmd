gmd({
    pattern:'aidecode', cmdname:'aidecode', aliases:['vision'], category:'ai', desc:'Analyze image/text.', react:'🔍', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const quoted=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    let imgUrls=[];
    if(quoted?.imageMessage){
        const tp=await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage,`tmp_dec_${Date.now()}`);
        if(tp){ const url=await uploadImgBB(tp); if(url) imgUrls.push(url); try{fs.unlinkSync(tp);}catch(_){} }
    }
    const ctx=quoted?.conversation||quoted?.extendedTextMessage?.text||'';
    const prompt=imgUrls.length?`Analyze image. ${q||'What is this?'}`:(`Analyze text: "${ctx||q}"`);
    const stub=await thinking(Gifted,from,mek,'🔍 _Analysing…_');
    const {text,err}=await askAI(prompt + " Use WhatsApp Markdown. No LaTeX.",imgUrls);
    return editMsg(Gifted,stub,err?`❌ ${text}`:`🔍 *AI Analysis*\n\n${text}`);
});

// ==============================================================================
// 18.  EVENT WATCHER — AUTO-REPLY + AUTO-ENHANCE
// ==============================================================================
let _watchDone=false;
const attachWatcher=(Gifted)=>{
    if(_watchDone||!Gifted?.ev) return;
    _watchDone=true;
    Gifted.ev.on('messages.upsert', async({messages,type})=>{
        if(type!=='append' && type!=='notify') return;
        for(const msg of messages){
            try{
                if(!msg.message) continue;
                const fromMe=msg.key.fromMe, chatId=msg.key.remoteJid||'', body=msg.message.conversation||msg.message.extendedTextMessage?.text||'';
                if(fromMe&&State.autoEnhance&&body.length>10&&!body.startsWith('.')){
                    setTimeout(async()=>{
                        const{text:fixed,err}=await askAI(`Fix grammar/spelling. No LaTeX. Return ONLY corrected text.\n\nText: ${body}`);
                        if(!err&&fixed.trim().toLowerCase()!==body.trim().toLowerCase()) await Gifted.sendMessage(chatId,{text:fixed.trim(),edit:msg.key});
                    },800);
                    continue;
                }
                if(fromMe||body.startsWith('.')) continue;
                const sender=msg.key.participant||msg.key.remoteJid||'';
                let sess=null;
                if(State.stalkers.has(sender)) sess=State.stalkers.get(sender);
                else if(State.targets.has(sender)){
                    const t=State.targets.get(sender); if(!t.chatId||t.chatId===chatId) sess=t;
                }
                else if(State.chats.has(chatId)) sess=State.chats.get(chatId);
                else if(!chatId.endsWith('@g.us')&&State.dmActive){
                    if(!State.dmSessions.has(sender)) State.dmSessions.set(sender,{gem:State.dmGem||State.PERSONA,history:[]});
                    sess=State.dmSessions.get(sender);
                }
                if(!sess) continue;
                setImmediate(async()=>{
                    State.addHist(sess,'User',body);
                    const{text:rep,err}=await askAI(State.buildPrompt(sess.gem,sess.history,body));
                    if(!err){ State.addHist(sess,'AI',rep); await Gifted.sendMessage(chatId,{text:rep},{quoted:msg}); }
                });
            }catch(e){}
        }
    });
};

const _boot = setInterval(() => { 
    const G = global.conn || global.client; 
    if (G) { attachWatcher(G); clearInterval(_boot); } 
}, 5000);

// Finalizing Module Exports
module.exports = {
    askAI, uploadImgBB, generateImage, State, attachWatcher
};
// ==============================================================================
// 8. RUNTIME STATE
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    chats: new Map(),
    targets: new Map(),
    stalkers: new Map(),
    dmSessions: new Map(),
    autoEnhance: false,
    PERSONA: 'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Never say you are an AI. Use conversation history to stay consistent. Always use WhatsApp Markdown: *bold* for emphasis, _italics_ for notes, and structured bullet points. Strictly avoid LaTeX formatting (no backslashes or mathematical notation).',
    
    addHist(ctx, role, txt) {
        if (!ctx.history) ctx.history = [];
        const t = new Date().toLocaleTimeString('en', { hour12: false, hour: '2-digit', minute: '2-digit' });
        ctx.history.push(`[${t}] ${role}: ${txt}`);
        if (ctx.history.length > CFG.MAX_HIST) ctx.history = ctx.history.slice(-CFG.MAX_HIST);
    },
    
    buildPrompt(sys, hist, input) {
        return `SYSTEM:\n${sys}\n\n--- HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nREPLY:`;
    }
};

// ==============================================================================
// 9. MESSAGE HELPERS
// ==============================================================================

/**
 * Sends a temporary "thinking" label to provide user feedback.
 */
const thinking = async (Gifted, from, mek, label = '⏳ _thinking…_') => {
    try {
        return await Gifted.sendMessage(from, { text: label }, { quoted: mek });
    } catch (e) {
        return null;
    }
};

/**
 * Edits an existing message if possible, or falls back to delete/resend.
 */
const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText, edit: sentMsg.key });
        return;
    } catch (e) {}
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { delete: sentMsg.key });
    } catch (e) {}
    await sleep(400);
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText });
    } catch (e) {
        console.error('[AIGems] editMsg Error:', e.message);
    }
};

/**
 * Deletes a message by its key.
 */
const del = async (Gifted, key) => {
    try {
        await Gifted.sendMessage(key.remoteJid, { delete: key });
    } catch (_) {}
};

/**
 * Sends an image via URL; provides text link fallback on failure.
 */
const sendImg = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { image: { url }, caption }, { quoted: mek });
        return true;
    } catch (e) {
        try {
            await Gifted.sendMessage(from, { text: `🎨 ${caption}\n\n🔗 ${url}` }, { quoted: mek });
        } catch (_) {}
        return false;
    }
};

// ==============================================================================
// 10. .gem — PERSONA VAULT SYSTEM
// ==============================================================================
gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['gems', 'persona'],
    category: 'ai',
    desc: 'AI persona vault. .gem help for all sub-commands.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only command.*');
    const parts = q.trim().split(/\s+/),
        cmd = parts[0]?.toLowerCase() || 'help',
        rest = parts.slice(1);

    if (cmd === 'create') {
        if (rest.length < 2) return reply('📝 `.gem create <name> <persona prompt>`');
        const [name, ...pArr] = rest, content = pArr.join(' ');
        return Gems.save(name, content) ?
            reply(`💎 *Gem Saved*\n\n*Name:* \`${name}\`\n*Preview:* _${content.slice(0, 120)}_`) :
            reply('❌ *Database error.*');
    }
    if (cmd === 'gen') {
        const topic = rest.join(' ');
        if (!topic) return reply('📝 `.gem gen <topic>`  e.g. `.gem gen sarcastic gamer`');
        const stub = await thinking(Gifted, from, mek, `🔮 _Forging "${topic}"…_`);
        const { text, err } = await askAI(`Create a detailed WhatsApp persona system prompt for: ${topic}.\nInclude personality, speaking style, slang, emoji habits.\nInstructions: Always use WhatsApp Markdown (*bold*, _italics_). Return ONLY the raw system prompt. Avoid LaTeX.`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const name = (rest[0] || 'gem').toLowerCase().slice(0, 12) + '_ai';
        Gems.save(name, text);
        return editMsg(Gifted, stub, `✨ *Gem Created*\n\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0, 150)}_\n\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd === 'analyze') {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!quoted) return reply('📝 *Reply to a message* then run `.gem analyze`');
        const sample = quoted.conversation || quoted.extendedTextMessage?.text || '[no text]';
        const stub = await thinking(Gifted, from, mek, '🕵️ _Cloning style…_');
        const { text, err } = await askAI(`Analyze this WhatsApp message and build a system prompt to clone this style exactly:\n"${sample}"\nEnsure the persona uses WhatsApp markdown. Return ONLY the system prompt. Avoid LaTeX.`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const name = `clone_${Date.now().toString(36)}`;
        Gems.save(name, text);
        return editMsg(Gifted, stub, `🧬 *Clone Created*\n\n*Name:* \`${name}\`\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd === 'remix') {
        const [gemName, ...tw] = rest;
        const tweak = tw.join(' ');
        if (!gemName || !tweak) return reply('📝 `.gem remix <name> <modification>`');
        const base = Gems.get(gemName);
        if (!base) return reply(`❌ Gem \`${gemName}\` not found.`);
        const stub = await thinking(Gifted, from, mek, `🔀 _Remixing "${gemName}"…_`);
        const { text, err } = await askAI(`Modify this system prompt per the instruction. Keep the core but apply the change. Return ONLY the updated prompt.\n\nOriginal:\n${base}\n\nChange: ${tweak}`);
        if (err) return editMsg(Gifted, stub, `❌ ${text}`);
        const newName = `${gemName}_remix`;
        Gems.save(newName, text);
        return editMsg(Gifted, stub, `🔀 *Remixed*\n\n\`${gemName}\` → \`${newName}\``);
    }
    if (cmd === 'list') {
        const list = Gems.list();
        if (!list.length) return reply('📚 *No gems yet.*\n`.gem gen <topic>` or `.gem create <n> <prompt>`');
        return reply(`📚 *Gems Vault (${list.length})*\n\n${list.map((g, i) => `${i + 1}. 💎 \`${g}\``).join('\n')}\n\n_Use_ \`.gem use <n>\``);
    }
    if (cmd === 'view') {
        const c = Gems.get(rest[0] || '');
        if (!rest[0]) return reply('📝 `.gem view <name>`');
        if (!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        return reply(`💎 *${rest[0].toUpperCase()}*\n\n${c}`);
    }
    if (cmd === 'use') {
        if (!rest[0]) return reply('📝 `.gem use <name>`');
        const c = Gems.get(rest[0]);
        if (!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        State.dmGem = c;
        return reply(`✅ *DM Persona set to:* \`${rest[0]}\`\nEnable with \`.gai dm on\``);
    }
    if (cmd === 'delete' || cmd === 'del') {
        if (!rest[0]) return reply('📝 `.gem delete <name>`');
        return Gems.del(rest[0]) ? reply(`🗑️ Gem \`${rest[0]}\` deleted.`) : reply(`❌ Not found.`);
    }
    return reply(
        `💎 *GEM — Persona Vault Management*\n\n` +
        `• \`.gem create <n> <prompt>\` — Save manual persona\n` +
        `• \`.gem gen <topic>\` — AI generates persona\n` +
        `• \`.gem analyze\` — Clone from replied message\n` +
        `• \`.gem remix <n> <tweak>\` — Edit existing persona\n` +
        `• \`.gem list\` — Show all saved gems\n` +
        `• \`.gem view <n>\` — View persona prompt\n` +
        `• \`.gem use <n>\` — Set as active DM persona\n` +
        `• \`.gem delete <n>\` — Remove a gem\n\n` +
        `*Tip:* Use \`.gai dm on\` after selecting a gem.`
    );
});
// ==============================================================================
// 11.  .gai  — MASTER AI CONTROL & AUTOMATION
// ==============================================================================
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain', 'ask'],
    category: 'ai',
    desc: 'AI Master Control. .gai help for automation modes.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner access required.*');

    const parts = q.trim().split(/\s+/),
        cmd = parts[0]?.toLowerCase() || '',
        rest = parts.slice(1),
        val = rest[0]?.toLowerCase() || '';

    // --- Sub-command: DM Auto-Pilot ---
    if (cmd === 'dm') {
        if (val === 'on') {
            State.dmActive = true;
            return reply(`📨 *DM Auto-Pilot:* ✅ *ON*\n*Persona:* ${State.dmGem ? 'Custom' : 'Default'}`);
        }
        if (val === 'off') {
            State.dmActive = false;
            return reply('📨 *DM Auto-Pilot:* ❌ *OFF*');
        }
        return reply(`📨 *DM Auto-Pilot:* ${State.dmActive ? '✅ ON' : '❌ OFF'}`);
    }

    // --- Sub-command: Chat AI Activation ---
    if (cmd === 'chat') {
        const gemName = val || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.chats.set(from, { gem: persona, history: [], gemName, lastActive: Date.now() });
        return reply(`⚔️ *Chat AI Activated*\n*Gem:* \`${gemName}\`\nAI will respond to all messages in this chat.`);
    }

    // --- Sub-command: Targeted Response ---
    if (cmd === 'target' || cmd === 'bot') {
        const num = rest[0]?.replace(/\D/g, '');
        if (!num) return reply('📝 *Usage:* `.gai target <number> [gem]`');
        const jid = num + '@s.whatsapp.net', gemName = rest[1] || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.targets.set(jid, { gem: persona, history: [], chatId: from, gemName });
        return reply(`🤖 *Target Locked:* @${num}\n*Gem:* \`${gemName}\`\nAI will reply only to this user here.`, { mentions: [jid] });
    }

    // --- Sub-command: Global Stalking ---
    if (cmd === 'stalk') {
        const num = rest[0]?.replace(/\D/g, '');
        if (!num) return reply('📝 *Usage:* `.gai stalk <number> [gem]`');
        const jid = num + '@s.whatsapp.net', gemName = rest[1] || 'default';
        const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
        State.stalkers.set(jid, { gem: persona, history: [], gemName });
        return reply(`🕵️ *Stalker Active:* @${num}\n*Gem:* \`${gemName}\`\nAI will shadow this user in all chats.`, { mentions: [jid] });
    }

    // --- Sub-command: Session Termination ---
    if (cmd === 'stop') {
        if (val === 'all') {
            State.dmActive = false; State.chats.clear(); State.targets.clear(); State.stalkers.clear(); State.dmSessions.clear();
            return reply('☢️ *All AI automations terminated.*');
        }
        State.chats.delete(from);
        return reply('🛑 *AI disabled for this chat.*');
    }

    // --- Sub-command: Memory Wipe ---
    if (cmd === 'wipe') {
        const sess = State.chats.get(from) || State.dmSessions.get(from);
        if (sess) { sess.history = []; return reply('🧠 *Session memory purged.*'); }
        return reply('ℹ️ No active session here.');
    }

    // --- Sub-command: Chat Summary ---
    if (cmd === 'summary') {
        const sess = State.chats.get(from);
        if (!sess || sess.history.length < 2) return reply('ℹ️ Not enough history to summarize.');
        const stub = await thinking(Gifted, from, mek, '📝 _Summarizing..._');
        const { text, err } = await askAI(`Summarize this chat history into key bullet points. Identify the main topics discussed. Use WhatsApp Markdown:\n\n${sess.history.join('\n')}`);
        return editMsg(Gifted, stub, err ? `❌ ${text}` : `📝 *Chat Summary*\n\n${text}`);
    }

    // --- Sub-command: System Status ---
    if (cmd === 'status') {
        const s = Limiter.stats(), cb = CB.open() ? '🔴 *TRIPPED*' : '🟢 *OK*';
        return reply(
            `📊 *AI SYSTEM STATUS*\n\n` +
            `• *DM Auto:* ${State.dmActive ? '✅' : '❌'}\n` +
            `• *Groups:* ${State.chats.size}\n` +
            `• *Targets:* ${State.targets.size}\n` +
            `• *Stalkers:* ${State.stalkers.size}\n\n` +
            `• *RPM:* ${s.rpm}/${CFG.MAX_RPM}\n` +
            `• *Circuit:* ${cb}`
        );
    }

    // --- Help Menu ---
    if (cmd === 'help' || !q.trim()) {
        return reply(
            `🧠 *GAI — AI MASTER CONTROL*\n\n` +
            `*Modes:*\n` +
            `• \`.gai dm on/off\` — AI in DMs\n` +
            `• \`.gai chat [gem]\` — AI for this chat\n` +
            `• \`.gai target <num> [gem]\` — AI for user here\n` +
            `• \`.gai stalk <num> [gem]\` — AI for user everywhere\n\n` +
            `*Tools:*\n` +
            `• \`.gai <question>\` — Quick AI query\n` +
            `• \`.gai summary\` — Chat key points\n` +
            `• \`.gai status\` — API metrics\n` +
            `• \`.gai stop [all]\` — End sessions\n` +
            `• \`.gai wipe\` — Clear memory`
        );
    }

    // --- Default: One-shot Question ---
    await react('🧠');
    const stub = await thinking(Gifted, from, mek, '🧠 _thinking…_');
    let imgUrls = [];
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quoted?.imageMessage) {
        try {
            const tp = await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage, `tmp_gai_${Date.now()}`);
            const url = await uploadImgBB(tp);
            if (url) imgUrls.push(url);
            if (fs.existsSync(tp)) fs.unlinkSync(tp);
        } catch (e) {}
    }

    const contextText = quoted?.conversation || quoted?.extendedTextMessage?.text;
    const prompt = contextText ? `Context: "${contextText}"\n\nQuestion: ${q}` : q;
    const { text, err } = await askAI(prompt, imgUrls);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
});

