// ==============================================================================
// 3. DATABASE INITIALIZATION (GEM PERSONA VAULT)
// ==============================================================================
let db = null;
if (Database) {
    try {
        // Ensure directory exists
        const dbDir = path.dirname(CFG.DB_PATH);
        if (!fs.existsSync(dbDir)) fs.mkdirSync(dbDir, { recursive: true });

        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        
        // Table for AI Personas
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);

        // Table for Stalk/Target Logic Persistence
        db.exec(`
            CREATE TABLE IF NOT EXISTS ai_sessions (
                id TEXT PRIMARY KEY,
                type TEXT NOT NULL, -- 'stalk', 'target', 'chat'
                gem_name TEXT,
                chat_id TEXT,
                target_jid TEXT,
                is_active INTEGER DEFAULT 1
            );
        `);

        console.log('[AIGems] SQLite Database initialized at:', CFG.DB_PATH);
    } catch (e) {
        console.error('[AIGems] Database setup failed:', e.message);
        db = null;
    }
}

/**
 * Gems Interface - CRUD for AI Personas
 */
const Gems = {
    get: (name) => {
        try {
            if (!db) return null;
            const res = db.prepare('SELECT content FROM gems WHERE name = ?').get(name.toLowerCase().trim());
            return res ? res.content : null;
        } catch (e) { return null; }
    },
    save: (name, content) => {
        try {
            if (!db) return false;
            const stmt = db.prepare('INSERT OR REPLACE INTO gems (name, content) VALUES (?, ?)');
            return !!stmt.run(name.toLowerCase().trim(), content).changes;
        } catch (e) { return false; }
    },
    del: (name) => {
        try {
            if (!db) return false;
            return db.prepare('DELETE FROM gems WHERE name = ?').run(name.toLowerCase().trim()).changes > 0;
        } catch (e) { return false; }
    },
    list: () => {
        try {
            if (!db) return [];
            return db.prepare('SELECT name FROM gems ORDER BY name ASC').all().map(r => r.name);
        } catch (e) { return []; }
    }
};

// ==============================================================================
// 4. RATE LIMITER & CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q: [], 
    hr_q: [], 
    daily: { ai: 0, img: 0, err: 0, day: new Date().toDateString() },

    check() {
        const now = Date.now();
        this.min_q = this.min_q.filter(t => now - t < 60000);
        this.hr_q = this.hr_q.filter(t => now - t < 3600000);
        return this.min_q.length < CFG.MAX_RPM && this.hr_q.length < CFG.MAX_RPH;
    },

    hit(type = 'ai') {
        const now = Date.now();
        this.min_q.push(now);
        this.hr_q.push(now);
        const today = new Date().toDateString();
        if (today !== this.daily.day) {
            this.daily = { ai: 0, img: 0, err: 0, day: today };
        }
        if (type === 'ai') this.daily.ai++;
        if (type === 'img') this.daily.img++;
    },

    err() { this.daily.err++; },

    stats() {
        const now = Date.now();
        return {
            rpm: this.min_q.filter(t => now - t < 60000).length,
            rph: this.hr_q.filter(t => now - t < 3600000).length,
            ...this.daily
        };
    }
};

const CB = {
    fails: 0, 
    lastFail: 0, 
    THRESH: 5, 
    TTL: 300000, // 5 minutes cool-down

    open() {
        return this.fails >= this.THRESH && (Date.now() - this.lastFail < this.TTL);
    },

    fail() {
        this.fails++;
        this.lastFail = Date.now();
        Limiter.err();
    },

    ok() {
        this.fails = 0;
    },

    reset() {
        this.fails = 0;
        this.lastFail = 0;
    },

    msg() {
        const lines = [
            'neural pathways congested... one sec',
            'api link hiccupped, trying to reconnect',
            'brain.exe encountered a minor glitch',
            'signal weak, retrying the neural handshake'
        ];
        return `_*${lines[Math.floor(Math.random() * lines.length)]}*_`;
    }
};

// ==============================================================================
// 5. RUNTIME STATE (STALK/TARGET CORE)
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    autoEnhance: false,
    
    // Active session maps
    chats: new Map(),     // Active in specific group/chat
    targets: new Map(),   // Responding to specific user in specific chat
    stalkers: new Map(),  // Responding to specific user EVERYWHERE
    dmSessions: new Map(), // One-on-one DM sessions
    
    // Default Persona
    PERSONA: 'You are an elite, sharp-witted assistant. Keep replies concise and extremely helpful. ' +
             'Do not identify as an AI. Use current history to remain consistent.',

    /**
     * History Management
     */
    addHist(ctx, role, txt) {
        if (!ctx.history) ctx.history = [];
        const time = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit' });
        ctx.history.push(`[${time}] ${role}: ${txt}`);
        if (ctx.history.length > CFG.MAX_HIST) {
            ctx.history = ctx.history.slice(-CFG.MAX_HIST);
        }
    },

    /**
     * Build system prompt with Markdown Injection
     */
    buildPrompt(sys, hist, input) {
        return `CONTEXT_RULES:\n${CFG.MARKDOWN_RULE}\n\nUSER_PERSONA:\n${sys}\n\n` +
               `--- CONVERSATION LOG ---\n${hist.join('\n')}\n---\n` +
               `LATEST_INPUT: ${input}\nREPLY:`;
    }
};
// ==============================================================================
// 6. CORE AI ENGINE — QuillBot SSE Streaming & Reliable Recovery
// ==============================================================================

/**
 * Clean AI responses for WhatsApp Markdown
 * Removes LaTeX wrappers and problematic escaping
 */
const cleanResponse = (raw) => {
    if (!raw) return '';
    return raw
        .replace(/\\\(|\\\)/g, '') // Remove \( \)
        .replace(/\\\[|\\\]/g, '') // Remove \[ \]
        .replace(/\\n/g, '\n')     // Fix escaped newlines
        .replace(/\\"/g, '"')      // Fix escaped quotes
        .replace(/\*\*/g, '*')     // Convert Bold to WA format
        .replace(/###\s*(.*)/g, '*$1*') // Headers to Bold
        .replace(/##\s*(.*)/g, '*$1*')
        .replace(/#\s*(.*)/g, '*$1*')
        .replace(/\\([_!#*~`])/g, '$1') // Unescape MD chars
        .trim();
};

/**
 * Main AI Interaction Logic
 */
const askAI = async (prompt, imgUrls = []) => {
    // 1. Circuit Breaker & Rate Limiter Check
    if (CB.open()) return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: '_*Rate limit reached. Cooling down...*_', err: true };

    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: prompt,
            files: imgUrls.map(u => ({
                url: u,
                mimeType: 'image/jpeg',
                name: 'attachment.jpg'
            }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat' },
        tools: []
    };

    const cookieHeader = Object.entries(CFG.QB_COOKIES)
        .map(([k, v]) => `${k}=${v}`)
        .join('; ');

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');
            
            const response = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { 
                        ...CFG.QB_HEADERS, 
                        'Cookie': cookieHeader 
                    },
                    timeout: CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            let fullContent = '';
            
            // Process SSE Stream
            const streamData = await new Promise((resolve, reject) => {
                let buffer = '';
                const timeoutId = setTimeout(() => resolve(buffer), CFG.TIMEOUT - 2000);

                response.data.on('data', (chunk) => {
                    const raw = chunk.toString();
                    const lines = raw.split('\n');
                    
                    for (const line of lines) {
                        const trimmed = line.trim();
                        if (!trimmed || !trimmed.startsWith('data: ')) continue;
                        
                        try {
                            const jsonStr = trimmed.slice(6);
                            if (jsonStr === '[DONE]') continue;
                            
                            const parsed = JSON.parse(jsonStr);
                            if (parsed.chunk) {
                                fullContent += parsed.chunk;
                            }
                        } catch (e) {
                            // Non-critical parsing error for partial chunks
                        }
                    }
                });

                response.data.on('end', () => {
                    clearTimeout(timeoutId);
                    resolve(fullContent);
                });

                response.data.on('error', (err) => {
                    clearTimeout(timeoutId);
                    reject(err);
                });
            });

            if (!streamData || streamData.trim().length === 0) {
                if (attempt < CFG.RETRIES - 1) {
                    await new Promise(r => setTimeout(r, 2000));
                    continue;
                }
                throw new Error('Empty AI response');
            }

            CB.ok();
            return { 
                text: cleanResponse(streamData), 
                err: false 
            };

        } catch (error) {
            console.error(`[AIGems] AI Attempt ${attempt + 1} Failed:`, error.message);
            Limiter.err();
            
            if (attempt === CFG.RETRIES - 1) {
                CB.fail();
                return { 
                    text: `_*Connection error: ${error.message}. Please try again later.*_`, 
                    err: true 
                };
            }
            await new Promise(r => setTimeout(r, 1500 * (attempt + 1)));
        }
    }
};

// ==============================================================================
// 7. MEDIA HANDLING — Vision & Uploads
// ==============================================================================

const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    const FormData = require('form-data');
    const form = new FormData();
    form.append('image', fs.createReadStream(filePath));

    try {
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form,
            { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url || null;
    } catch (e) {
        console.error('[AIGems] ImgBB Upload Error:', e.message);
        return null;
    }
};

// ==============================================================================
// 8. IMAGE GENERATION — Infip High-Speed Pipeline
// ==============================================================================

let _activeInfipKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
let _infipValidated = false;

const rotateInfipKey = () => {
    _activeInfipKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
    _infipValidated = false;
};

const ensureInfip = async () => {
    if (_infipValidated) return true;
    try {
        const check = await axios.get(`${CFG.INFIP_URL}/v1/models`, {
            headers: { Authorization: `Bearer ${_activeInfipKey}` },
            timeout: 5000
        });
        if (check.status === 200) {
            _infipValidated = true;
            return true;
        }
    } catch (e) {
        rotateInfipKey();
    }
    return false;
};

const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;
    const count = Math.min(opts.count || CFG.IMG_COUNT, 4);

    if (!Limiter.check()) return [];
    await ensureInfip();
    Limiter.hit('img');

    try {
        const res = await axios.post(
            `${CFG.INFIP_URL}/v1/images/generations`,
            {
                model,
                prompt,
                n: count,
                size: size,
                response_format: 'url',
                quality: opts.quality || CFG.IMG_QUALITY,
                style: opts.style || CFG.IMG_STYLE
            },
            {
                headers: { 
                    Authorization: `Bearer ${_activeInfipKey}`,
                    'Content-Type': 'application/json'
                },
                timeout: CFG.TIMEOUT
            }
        );

        if (res.status === 200 && res.data?.data) {
            return res.data.data.map(d => d.url);
        }
    } catch (e) {
        console.error('[AIGems] Image Gen Error:', e.message);
        Limiter.err();
    }
    return [];
};

// ==============================================================================
// 9. MESSAGE HELPERS — UX & Edits
// ==============================================================================

const UI = {
    /** Show typing/thinking state */
    async think(Gifted, from, mek, msg = '⏳ _brainstorming..._') {
        try {
            return await Gifted.sendMessage(from, { text: msg }, { quoted: mek });
        } catch (e) { return null; }
    },

    /** Update existing message or resend if failed */
    async update(Gifted, targetMsg, newText) {
        if (!targetMsg?.key) return;
        try {
            await Gifted.sendMessage(targetMsg.key.remoteJid, { 
                text: newText, 
                edit: targetMsg.key 
            });
        } catch (e) {
            try {
                await Gifted.sendMessage(targetMsg.key.remoteJid, { text: newText });
            } catch (err) {}
        }
    },

    /** Delete message */
    async delete(Gifted, key) {
        try {
            await Gifted.sendMessage(key.remoteJid, { delete: key });
        } catch (e) {}
    },

    /** Robust Image Dispatch */
    async sendArt(Gifted, from, url, caption, quoted) {
        try {
            await Gifted.sendMessage(from, { 
                image: { url }, 
                caption: caption 
            }, { quoted });
            return true;
        } catch (e) {
            await Gifted.sendMessage(from, { 
                text: `🎨 *Generation Success*\n\nPrompt: ${caption}\n\nLink: ${url}` 
            }, { quoted });
            return false;
        }
    }
};

// ==============================================================================
// 10. BOT COMMANDS — .gai (Control & Direct Interaction)
// ==============================================================================

gmd({
    pattern: 'gai',
    cmdname: 'gai',
    category: 'ai',
    desc: 'Master AI control and querying.',
    react: '🧠'
}, async (from, Gifted, context) => {
    const { mek, q, reply, isSuperUser, react } = context;
    if (!isSuperUser) return reply('❌ *Access Denied.* Restricted to Bot Admin.');

    const input = q.trim();
    if (!input) return reply('❓ *Usage:*\n.gai <ask anything>\n.gai chat (start AI in this group)\n.gai stop (stop AI here)\n.gai status (view metrics)');

    const args = input.split(' ');
    const subCmd = args[0].toLowerCase();

    // -- MODE: CHAT (Group-wide AI)
    if (subCmd === 'chat') {
        const gemName = args[1] || 'default';
        const gemContent = Gems.get(gemName) || State.PERSONA;
        State.chats.set(from, {
            gem: gemContent,
            history: [],
            gemName: gemName
        });
        return reply(`⚔️ *AI Mode: ACTIVE*\nGroup: ${from}\nPersona: \`${gemName}\`\n\n_I will now respond to every message in this chat._`);
    }

    // -- MODE: TARGET (Single User in current chat)
    if (subCmd === 'target') {
        const targetNum = args[1]?.replace(/[^0-9]/g, '');
        if (!targetNum) return reply('📝 `.gai target <number> [gem]`');
        const jid = targetNum + '@s.whatsapp.net';
        const gemName = args[2] || 'default';
        State.targets.set(jid, {
            gem: Gems.get(gemName) || State.PERSONA,
            history: [],
            chatId: from,
            gemName: gemName
        });
        return reply(`🎯 *Target Locked: @${targetNum}*\nI will only respond to this user in this group.`);
    }

    // -- MODE: STALK (Global User Tracking)
    if (subCmd === 'stalk') {
        const stalkNum = args[1]?.replace(/[^0-9]/g, '');
        if (!stalkNum) return reply('📝 `.gai stalk <number> [gem]`');
        const jid = stalkNum + '@s.whatsapp.net';
        const gemName = args[2] || 'default';
        State.stalkers.set(jid, {
            gem: Gems.get(gemName) || State.PERSONA,
            history: [],
            gemName: gemName
        });
        return reply(`🕵️ *Global Stalk: @${stalkNum}*\nI will follow this user into any group we share.`);
    }

    // -- MODE: STOP
    if (subCmd === 'stop') {
        if (args[1] === 'all') {
            State.chats.clear();
            State.targets.clear();
            State.stalkers.clear();
            return reply('🛑 *System Halted.* All active AI sessions cleared.');
        }
        State.chats.delete(from);
        return reply('📴 *AI Disabled* for this chat.');
    }

    // -- MODE: STATUS
    if (subCmd === 'status') {
        const stats = Limiter.stats();
        const cbStatus = CB.open() ? '🔴 TRIPPED' : '🟢 CLOSED';
        return reply(`📊 *AI Engine Status*\n\n` +
            `• *Rate Limit:* ${stats.rpm}/${CFG.MAX_RPM} RPM\n` +
            `• *Daily Total:* ${stats.ai} calls\n` +
            `• *Error Rate:* ${stats.err}\n` +
            `• *Circuit:* ${cbStatus}\n` +
            `• *Active Chats:* ${State.chats.size}\n` +
            `• *Targets:* ${State.targets.size}\n` +
            `• *Stalkers:* ${State.stalkers.size}`);
    }

    // -- MODE: ONE-SHOT ASK
    await react('🧠');
    const thinkingMsg = await UI.think(Gifted, from, mek);
    
    // Handle quoted context or images
    let promptFinal = input;
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const contextText = quoted?.conversation || quoted?.extendedTextMessage?.text;
    if (contextText) promptFinal = `Reference Context:\n"${contextText}"\n\nUser Question: ${input}`;

    const { text, err } = await askAI(promptFinal);
    return await UI.update(Gifted, thinkingMsg, text);
});

// ==============================================================================
// 11. IMAGE COMMANDS — .img (Creative Generation)
// ==============================================================================

gmd({
    pattern: 'img',
    cmdname: 'img',
    category: 'ai',
    desc: 'AI image generator.',
    react: '🎨'
}, async (from, Gifted, context) => {
    const { mek, q, reply, isSuperUser, react } = context;
    if (!isSuperUser) return reply('❌ *Owner Only.*');

    const prompt = q.trim();
    if (!prompt) return reply('🎨 *Example:* `.img a neon cyberpunk cat in rain`');

    await react('🎨');
    const loader = await UI.think(Gifted, from, mek, '🎨 _Painting your imagination..._');
    
    const urls = await generateImage(prompt);
    if (!urls || urls.length === 0) {
        return await UI.update(Gifted, loader, '❌ *Generation Failed.* API busy or prompt blocked.');
    }

    await UI.delete(Gifted, loader.key);
    for (let i = 0; i < urls.length; i++) {
        await UI.sendArt(Gifted, from, urls[i], i === 0 ? prompt : `Variation ${i+1}`, mek);
    }
});

// ==============================================================================
// 12. MESSAGE WATCHER — The Engine Room (Stalk/Target Logic)
// ==============================================================================

const initWatcher = (Gifted) => {
    if (!Gifted?.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;

                const chatId = msg.key.remoteJid;
                const sender = msg.key.participant || msg.key.remoteJid;
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                if (body.startsWith('.') || body.startsWith('!')) continue;

                // Determine Session Priority
                let session = null;
                
                // 1. Stalker (Global priority)
                if (State.stalkers.has(sender)) {
                    session = State.stalkers.get(sender);
                } 
                // 2. Target (Specific chat priority)
                else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (targetData.chatId === chatId) session = targetData;
                }
                // 3. Chat-wide AI
                else if (State.chats.has(chatId)) {
                    session = State.chats.get(chatId);
                }
                // 4. DM Auto-reply
                else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, {
                            gem: State.dmGem || State.PERSONA,
                            history: [],
                            gemName: 'dm'
                        });
                    }
                    session = State.dmSessions.get(sender);
                }

                if (!session) continue;

                // Execute Response Pipeline
                (async () => {
                    try {
                        State.addHist(session, 'User', body);
                        const finalPrompt = State.buildPrompt(session.gem, session.history, body);
                        
                        await Gifted.sendPresenceUpdate('composing', chatId);
                        const { text, err } = await askAI(finalPrompt);
                        await Gifted.sendPresenceUpdate('paused', chatId);

                        if (!err) {
                            State.addHist(session, 'AI', text);
                            await Gifted.sendMessage(chatId, { text }, { quoted: msg });
                        }
                    } catch (err) {
                        console.error('[Watcher Pipeline Error]:', err.message);
                    }
                })();
            } catch (e) {
                console.error('[Watcher Main Loop Error]:', e.message);
            }
        }
    });
};

// Auto-bootstrap the watcher when global conn is available
const checkConn = setInterval(() => {
    const conn = global.conn || global.client;
    if (conn) {
        initWatcher(conn);
        clearInterval(checkConn);
        console.log('✅ [AIGems] Neural Watcher initialized.');
    }
}, 5000);
/**
 * @section Image Processing & Generation Utilities
 * @description ImgBB integration, Infip Key-Rotator, and Media Fallback Systems
 */

/**
 * Uploads a local file to ImgBB for vision processing tasks.
 * @param {string} filePath - Path to the temporary image file.
 * @returns {Promise<string|null>} - Public URL or null.
 */
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, 
            { 
                headers: form.getHeaders(), 
                timeout: 30000 
            }
        );
        return res.data?.data?.url ?? null;
    } catch (e) {
        console.error('[AIGems] ImgBB Upload Error:', e.message);
        return null;
    }
};

/**
 * Generates an image using Infip API with automatic key rotation and caching.
 * @param {string} prompt - The visual description.
 * @param {Object} opts - Model, size, and quality settings.
 */
const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;
    const cacheKey = `img:${model}:${size}:${prompt.toLowerCase().trim().slice(0, 50)}`;

    // Check Latency-Reduction Cache
    const cached = _iCache.get(cacheKey);
    if (cached && (Date.now() - cached.ts < 3600000)) return cached.urls;

    if (!Limiter.check()) return [];
    
    // Automatic Key Rotation
    const rotateKey = () => {
        _iKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('img');
            const response = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`, {
                model,
                prompt,
                n: Math.min(opts.count || CFG.IMG_COUNT, 4),
                size,
                response_format: 'url',
                quality: opts.quality || CFG.IMG_QUALITY,
                style: opts.style || CFG.IMG_STYLE
            }, { 
                headers: { 
                    'Authorization': `Bearer ${_iKey}`,
                    'Content-Type': 'application/json'
                }, 
                timeout: CFG.TIMEOUT 
            });

            if (response.data?.data?.length) {
                const urls = response.data.data.map(d => d.url);
                _iCache.set(cacheKey, { urls, ts: Date.now() });
                return urls;
            }
        } catch (e) {
            Limiter.err();
            rotateKey(); // Rotate key on failure
            if (attempt === CFG.RETRIES - 1) console.error('[AIGems] Image Gen Exhausted:', e.message);
            await new Promise(r => setTimeout(r, 1000 * (attempt + 1)));
        }
    }
    return [];
};

/**
 * Sends image with a text-fallback if media upload fails.
 */
const sendImg = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { 
            image: { url }, 
            caption: caption 
        }, { quoted: mek });
        return true;
    } catch (err) {
        // Fallback: Send URL as text if WhatsApp media server rejects
        await Gifted.sendMessage(from, { 
            text: `🎨 *Image Generation Success*\n\n*Prompt:* ${caption}\n\n🔗 *Direct Link:* ${url}\n\n_Note: Media display failed, use the link above._`
        }, { quoted: mek });
        return false;
    }
};

