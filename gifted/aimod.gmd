});

gmd({
    pattern: 'vision',
    cmdname: 'vision',
    category: 'ai',
    desc: 'Analyze images using ImgBB + AI Neural Decode.',
    react: '👁️'
}, async (from, Gifted, context) => {
    const { mek, q, reply, react } = context;
    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const isImage = quoted?.imageMessage || mek.message?.imageMessage;

    if (!isImage) return reply('❌ *Error:* Reply to an image or send an image with `.vision`');

    await react('👁️');
    const stub = await Gifted.sendMessage(from, { text: '🔍 _Uploading to neural bridge..._' }, { quoted: mek });

    try {
        const media = quoted?.imageMessage || mek.message.imageMessage;
        const localPath = await Gifted.downloadAndSaveMediaMessage(media, `vision_${Date.now()}`);
        const remoteUrl = await uploadImgBB(localPath);
        
        if (fs.existsSync(localPath)) fs.unlinkSync(localPath);

        if (!remoteUrl) return await editMsg(Gifted, stub, '❌ *Network Error:* ImgBB link failed.');

        await editMsg(Gifted, stub, '🧠 _Decoding visual patterns..._');
        
        const visionPrompt = q || "Explain this image in high detail. If there is text, transcribe it. If there are people, describe their actions.";
        const { text, err } = await askAI(visionPrompt, [remoteUrl]);

        return await editMsg(Gifted, stub, err ? `❌ *AI Error:* ${text}` : `🧐 *Visual Interpretation*\n\n${text}`);
    } catch (e) {
        return await editMsg(Gifted, stub, `❌ *System Failure:* ${e.message}`);
    }
});

