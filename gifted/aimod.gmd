    if (!isSuperUser) return reply('❌ *Owner only.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    let imgUrls = [];
    if (quoted?.imageMessage) {
        const tp = await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage, `tmp_dec_${Date.now()}`);
        const url = await uploadImgBB(tp);
        if (url) imgUrls.push(url);
        if (fs.existsSync(tp)) fs.unlinkSync(tp);
    }

    const textCtx = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    if (!textCtx && !imgUrls.length && !q.trim()) return reply('📝 *Reply to an image or text block.*');

    const stub = await thinking(Gifted, from, mek, '🔍 _Analyzing..._');
    const prompt = imgUrls.length ? `Analyze image. ${q || 'What is this?'}` : `Deep analysis of: "${textCtx || q}"`;
    const { text, err } = await askAI(prompt + "\n\nFormat using WhatsApp Markdown. Avoid LaTeX.", imgUrls);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : `🔍 *AI ANALYSIS*\n\n${text}`);
});

