// ==============================================================================
// 38. CORE UTILITIES — ATASSA BULLETPROOF INTEGRATION
// ==============================================================================

/**
 * Deep Argument Hunter: Finds the true socket and message object across bot forks.
 * Used for deep context resolution in auto-reply watchers.
 */
resolveContext = (arg1, args = []) => {
    let sock = global.conn || global.client || arg1.bot || arg1.client;
    let m = arg1;
    const allArgs = [arg1, ...args];
    allArgs.forEach(arg => {
        if (arg && typeof arg === 'object' && !Array.isArray(arg)) {
            if (typeof arg.sendMessage === 'function') sock = arg;
            else if (arg.sock && typeof arg.sock.sendMessage === 'function') sock = arg.sock;
            else if (arg.bot && typeof arg.bot.sendMessage === 'function') sock = arg.bot;
            if (arg.chat || arg.from || arg.jid || (arg.key && arg.key.remoteJid)) m = arg;
        }
    });
    return { m, sock };
};

/**
 * Deep Quote Sanitizer: Prevents Baileys crashes during AI automated replies.
 */
buildSafeQuote = (m) => {
    if (!m || !m.key || !m.key.remoteJid || !m.key.id) return {};
    const cleanKey = {
        remoteJid: String(m.key.remoteJid),
        fromMe: Boolean(m.key.fromMe),
        id: String(m.key.id)
    };
    if (m.key.participant) cleanKey.participant = String(m.key.participant);
    return { quoted: { key: cleanKey, message: m.message || {} } };
};

// ==============================================================================
// 39. STALK & TARGET LOGIC REFINEMENT (Production Stability)
// ==============================================================================

/**
 * Enhanced Stalker Handler: Intercepts messages to provide automated AI tracking.
 * Ensures all AI responses follow the WhatsApp Markdown protocol.
 */
const processStalkLogic = async (msg, Gifted) => {
    const { m, sock } = resolveContext(msg);
    const sender = m.key.participant || m.key.remoteJid;
    const isGroup = m.key.remoteJid.endsWith('@g.us');
    
    // Hierarchy check: Stalker (Global) > Target (Local) > Chat Mode
    const session = State.resolveSession(sender, m.key.remoteJid, isGroup);
    if (!session) return;

    // Ignore command triggers
    const body = m.message?.conversation || m.message?.extendedTextMessage?.text || '';
    if (['.', '/', '!', '+', '#'].includes(body[0])) return;

    // Circuit Breaker / Rate Limit Check
    if (CB.open() || !Limiter.check()) return;

    try {
        await Gifted.sendPresenceUpdate('composing', m.key.remoteJid);
        
        State.addHist(session, 'User', body);
        const prompt = State.buildPrompt(session, body);
        const { text, err } = await askAI(prompt);

        if (err) return;

        const formatted = markdownHelper.applyFormatting(text, 'whatsapp');
        const options = buildSafeQuote(m);
        
        await Gifted.sendMessage(m.key.remoteJid, { text: formatted }, options);
        State.addHist(session, 'AI', text);

    } catch (e) {
        console.error(`[AIGems.Stalk] Error processing @${sender}:`, e.message);
    }
};

// ==============================================================================
// 40. DYNAMIC REGISTRAR WRAPPER
// ==============================================================================

let commandRegister;
try {
    const cmdSys = require('../gift/gmdCmds');
    commandRegister = cmdSys.gifted || cmdSys.gmd || cmdSys.cmd || cmdSys.smd || cmdSys.Module || cmdSys;
} catch (err) {
    // Fallback to internal registry if external mapping fails
    commandRegister = gmd;
}

/**
 * Module Finalization
 * Registers the system watchers and provides final exports for the bot environment.
 */
if (typeof commandRegister === 'function') {
    // Integration logic for non-command triggered events
    const client = global.conn || global.client;
    if (client && client.ev) {
        client.ev.on('messages.upsert', async ({ messages, type }) => {
            if (type !== 'notify') return;
            for (const msg of messages) {
                await processStalkLogic(msg, client);
            }
        });
    }
}

