/**
 * @command .imgbatch
 * @description Quick variations generator.
 */
gmd({
    pattern: 'imgbatch',
    cmdname: 'imgbatch',
    category: 'ai',
    desc: 'Generate 4 variations of a prompt at once.',
    react: '🎴',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');
    if (!q.trim()) return reply('📝 *Usage:* \`.imgbatch <prompt>\`');

    const stub = await thinking(Gifted, from, mek, '🎴 _Processing batch (4 variations)..._');
    const oldC = CFG.IMG_COUNT;
    CFG.IMG_COUNT = 4;
    
    const urls = await generateImage(q.trim());
    CFG.IMG_COUNT = oldC;

    if (!urls.length) return editMsg(Gifted, stub, '❌ *Batch failed.*');
    
    await del(Gifted, stub.key);
    for (let i = 0; i < urls.length; i++) {
        await sendImg(Gifted, from, urls[i], `*🎴 Batch [${i+1}/4]*`, mek);
        await sleep(600);
    }
});

/**
 * @command .imgvariation
 * @description Uses AI to reimagine a quoted message as an image.
 */
gmd({
    pattern: 'imgvariation',
    cmdname: 'imgvariation',
    aliases: ['imgvary', 'reimagine'],
    category: 'ai',
    desc: 'Reimagine a quoted prompt or text as a new AI image.',
    react: '🌀',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    let source = q.trim();
    if (!source) {
        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        source = quoted?.conversation || quoted?.extendedTextMessage?.text || '';
    }

    if (!source) return reply('📝 *Usage:* Reply to a prompt or text with \`.imgvariation\`');

    const stub = await thinking(Gifted, from, mek, '🌀 _Reimagining..._');
    const { text: newP, err } = await askAI(`Rewrite this prompt into a unique artistic variation with a different style (e.g. oil painting, synthwave, 3D render). Keep the core subject. Return ONLY the new prompt: "${source}"`);
    
    if (err) return editMsg(Gifted, stub, `❌ ${newP}`);
    
    await editMsg(Gifted, stub, `🎨 _Visualizing Variation:_ "${newP.slice(0, 80)}..."`);
    const urls = await generateImage(newP);
    
    if (!urls.length) return editMsg(Gifted, stub, '❌ *Variation failed.*');
    
    await del(Gifted, stub.key);
    return sendImg(Gifted, from, urls[0], `🌀 *VARIATION*\n\n*Style:* _${newP}_\n*Original:* _${source.slice(0, 50)}..._`, mek);
});

