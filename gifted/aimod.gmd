gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['aitr', 'translate', 'tr'],
    category: 'ai',
    desc: 'AI-powered translation into any language.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/);
    const lang = parts[0];
    const text = parts.slice(1).join(' ');

    if (!lang || !text) {
        return reply('📝 *Usage:* `.aitranslate <language> <text>`\n_Example: .aitranslate Japanese Good morning friend_');
    }

    const stub = await thinking(Gifted, from, mek, `🌐 _Translating to ${lang}..._`);
    const prompt = `Translate the following to ${lang}. Keep the tone natural for a chat application. Return ONLY the translated text.\n\nText: "${text}"`;

    const { text: result, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `❌ *Translation Error:* ${result}`);

    return editMsg(Gifted, stub, `🌐 *AI TRANSLATION*\n\n*Target Language:* ${lang}\n\n*Original:* _${text}_\n*Result:* ${result}`);
});

// ==============================================================================
// 16.  .aiwrite — CREATIVE GENERATOR
// ==============================================================================

gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'draft', 'aiwriter'],
    category: 'ai',
    desc: 'Generate creative content using AI prompts.',
    react: '📝',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const styleMap = {
        'roast': 'Write a savage but witty roast about {topic}. Use emojis.',
        'caption': 'Generate 3 creative Instagram captions for {topic}. Use hashtags.',
        'email': 'Write a professional email about {topic}. Include subject line.',
        'code': 'Write a clean, documented code snippet for {topic}. Use markdown.',
        'story': 'Write a short gripping story about {topic} in under 200 words.',
        'lyrics': 'Write 8 bars of song lyrics in the style of Drake about {topic}.',
        'formal': 'Rewrite this as formal professional text: {topic}',
        'slang': 'Rewrite this using heavy Gen-Z slang: {topic}'
    };

    if (!styleMap[type]) {
        return reply(
            `📝 *AI WRITER FACTORY*\n\n` +
            `*Available Styles:*\n` +
            `• \`roast\`, \`caption\`, \`email\`, \`code\`, \`story\`, \`lyrics\`, \`formal\`, \`slang\`\n\n` +
            `*Usage:* \`.aiwrite <style> <topic/text>\`\n` +
            `_Example: .aiwrite roast my coding skills_`
        );
    }

    if (!topic) return reply(`⚠️ Please provide a topic/text for the \`${type}\` style.`);

    const stub = await thinking(Gifted, from, mek, `📝 _Composing ${type}..._`);
    const finalPrompt = styleMap[type].replace('{topic}', topic);

    const { text, err } = await askAI(finalPrompt + "\n\nFormat output strictly with WhatsApp markdown.");
    if (err) return editMsg(Gifted, stub, `❌ *Writing Error:* ${text}`);

    return editMsg(Gifted, stub, `✨ *AI ${type.toUpperCase()}*\n\n${text}`);
});

// ==============================================================================
// 17.  .aidecode — MULTIMODAL VISION ANALYSIS
// ==============================================================================

gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'analyze'],
    category: 'ai',
    desc: 'Analyze a quoted image and explain its contents.',
    react: '👁️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImg = quoted?.imageMessage || mek.message?.imageMessage;

    if (!hasImg) return reply('🖼️ *Please reply to an image or send one with .aidecode to analyze it.*');

    const stub = await thinking(Gifted, from, mek, '👁️ _Analyzing Visual Data..._');
    let imgUrl = null;

    try {
        const target = quoted?.imageMessage ? quoted.imageMessage : mek.message.imageMessage;
        const tmpFile = path.join(__dirname, `tmp_vis_${Date.now()}.jpg`);
        await Gifted.downloadAndSaveMediaMessage(target, tmpFile);
        imgUrl = await uploadImgBB(tmpFile);
        if (fs.existsSync(tmpFile)) fs.unlinkSync(tmpFile);
    } catch (e) {
        return editMsg(Gifted, stub, `❌ *Image Processing Failed:* ${e.message}`);
    }

    if (!imgUrl) return editMsg(Gifted, stub, '❌ *Upload Failed:* Could not generate analysis URL.');

    const instruction = q.trim() || 'Describe this image in detail. Identify objects, text, and overall context.';
    const { text, err } = await askAI(instruction + "\n\nUse WhatsApp Markdown for the analysis report.", [imgUrl]);

    if (err) return editMsg(Gifted, stub, `❌ *Vision API Error:* ${text}`);

    return editMsg(Gifted, stub, `👁️ *VISION DECODER*\n\n${text}`);
});

