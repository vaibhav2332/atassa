// 17.  .aidecode  — VISION INTEGRATION
// ==============================================================================
gmd({
    pattern:'aidecode', cmdname:'aidecode', aliases:['vision'], category:'ai', desc:'Analyze image/text.', react:'🔍', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const quoted=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    let imgUrls=[];
    if(quoted?.imageMessage){
        const tp=await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage,`tmp_dec_${Date.now()}`);
        if(tp){ const url=await uploadImgBB(tp); if(url) imgUrls.push(url); try{fs.unlinkSync(tp);}catch(_){} }
    }
    const ctx=quoted?.conversation||quoted?.extendedTextMessage?.text||'';
    const prompt=imgUrls.length?`Analyze image. ${q||'What is this?'}`:(`Analyze text: "${ctx||q}"`);
    const stub=await thinking(Gifted,from,mek,'🔍 _Analysing…_');
    const {text,err}=await askAI(prompt,imgUrls);
    return editMsg(Gifted,stub,err?`❌ ${text}`:`🔍 *AI Analysis*\n\n${text}`);
});

// ==============================================================================
// 18.  EVENT WATCHER — AUTO-REPLY + AUTO-ENHANCE
// ==============================================================================
let _watchDone=false;
const attachWatcher=(Gifted)=>{
    if(_watchDone||!Gifted?.ev) return;
    _watchDone=true;
    Gifted.ev.on('messages.upsert', async({messages,type})=>{
        if(type!=='append' && type!=='notify') return;
        for(const msg of messages){
            try{
                if(!msg.message) continue;
                const fromMe=msg.key.fromMe, chatId=msg.key.remoteJid||'', body=msg.message.conversation||msg.message.extendedTextMessage?.text||'';
                if(fromMe&&State.autoEnhance&&body.length>10&&!body.startsWith('.')){
                    setTimeout(async()=>{
                        const{text:fixed,err}=await askAI(`Fix grammar/spelling. Return ONLY corrected text.\n\nText: ${body}`);
                        if(!err&&fixed.trim().toLowerCase()!==body.trim().toLowerCase()) await Gifted.sendMessage(chatId,{text:fixed.trim(),edit:msg.key});
                    },800);
                    continue;
                }
                if(fromMe||body.startsWith('.')) continue;
                const sender=msg.key.participant||msg.key.remoteJid||'';
                let sess=null;
                if(State.stalkers.has(sender)) sess=State.stalkers.get(sender);
                else if(State.targets.has(sender)){
                    const t=State.targets.get(sender); if(!t.chatId||t.chatId===chatId) sess=t;
                }
                else if(State.chats.has(chatId)) sess=State.chats.get(chatId);
                else if(!chatId.endsWith('@g.us')&&State.dmActive){
                    if(!State.dmSessions.has(sender)) State.dmSessions.set(sender,{gem:State.dmGem||State.PERSONA,history:[]});
                    sess=State.dmSessions.get(sender);
                }
                if(!sess) continue;
                setImmediate(async()=>{
                    State.addHist(sess,'User',body);
                    const{text:rep,err}=await askAI(State.buildPrompt(sess.gem,sess.history,body));
                    if(!err){ State.addHist(sess,'AI',rep); await Gifted.sendMessage(chatId,{text:rep},{quoted:msg}); }
                });
            }catch(e){}
        }
    });
};
const _boot=setInterval(()=>{ const G=global.conn||global.client; if(G){attachWatcher(G);clearInterval(_boot);} },5000);
// ==============================================================================
// 19. ADVANCED CREATIVE SUITE (ROBUST)
// ==============================================================================

gmd({
    pattern: 'aitranslate',
    cmdname: 'aitranslate',
    aliases: ['aitr', 'translate', 'tr'],
    category: 'ai',
    desc: 'Translate text into any language with AI context.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Permission Denied.*');
    
    const input = q.trim();
    if (!input) return reply('*📝 Usage:* `.aitranslate <lang> <text>`\n_Example: .aitranslate french How are you today?_');

    const [targetLang, ...textArr] = input.split(' ');
    const textToTranslate = textArr.join(' ');

    if (!textToTranslate) return reply('*⚠️ Please provide the text to be translated.*');

    const stub = await thinking(Gifted, from, mek, `*🌐 Translating to ${targetLang}...*`);
    
    const prompt = `Translate the following text to ${targetLang}. 
    Maintain the original tone (formal/informal). 
    If there are multiple ways to say it, provide the most natural one for WhatsApp.
    Return ONLY the translation using WhatsApp Markdown for emphasis if needed.
    
    Text: "${textToTranslate}"`;

    const { text, err } = await askAI(prompt);
    
    if (err) return editMsg(Gifted, stub, `*❌ Translation failed:* ${text}`);
    
    const response = `*🌐 AI TRANSLATION [${targetLang.toUpperCase()}]*\n\n` +
                     `*Original:* _${textToTranslate}_\n` +
                     `*Result:* ${text}`;
                     
    return editMsg(Gifted, stub, response);
});

gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'draft', 'writer'],
    category: 'ai',
    desc: 'Generate creative content (roasts, captions, stories, code).',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const styles = {
        roast:   "Write a savage but funny WhatsApp roast about: {topic}. Use emojis and bold text.",
        caption: "Generate 5 catchy WhatsApp/Instagram captions for: {topic}. Include hashtags and emojis.",
        code:    "Write clean, optimized {topic} code. Use markdown code blocks and add brief comments.",
        story:   "Write a short, engaging 2-paragraph story about: {topic}.",
        email:   "Draft a professional email regarding: {topic}. Use bold for subject lines.",
        lyrics:  "Write song lyrics in the style of a modern rap/pop artist about: {topic}.",
        pickup:  "Write 3 smooth or funny pickup lines related to: {topic}."
    };

    if (!styles[type]) {
        return reply(`*✍️ AI WRITER MENU*\n\n` +
                     `*Usage:* \`.aiwrite <type> <topic>\`\n\n` +
                     `*Types:* \`roast\`, \`caption\`, \`code\`, \`story\`, \`email\`, \`lyrics\`, \`pickup\`\n\n` +
                     `_Example: .aiwrite roast my friend who sleeps in class_`);
    }

    if (!topic) return reply(`*⚠️ Please provide a topic for the ${type}.*`);

    const stub = await thinking(Gifted, from, mek, `*✍️ Drafting your ${type}...*`);
    const prompt = styles[type].replace('{topic}', topic) + "\n\nEnsure the output uses WhatsApp Markdown (*bold*, _italics_, \`code\`).";

    const { text, err } = await askAI(prompt);
    if (err) return editMsg(Gifted, stub, `*❌ Writing Error:* ${text}`);

    return editMsg(Gifted, stub, `*✨ AI ${type.toUpperCase()}*\n\n${text}`);
});

gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['vision', 'explain', 'whatis'],
    category: 'ai',
    desc: 'Analyze a quoted image and explain its contents.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const hasImage = quoted?.imageMessage || mek.message?.imageMessage;

    if (!hasImage) return reply('*🖼️ Please reply to an image or send an image with .aidecode*');

    const stub = await thinking(Gifted, from, mek, '*🔍 Analyzing visual data...*');
    
    let imgUrl = null;
    try {
        const targetMsg = quoted?.imageMessage ? quoted.imageMessage : mek.message.imageMessage;
        const localPath = path.join(__dirname, `vision_${Date.now()}.jpg`);
        await Gifted.downloadAndSaveMediaMessage(targetMsg, localPath);
        imgUrl = await uploadImgBB(localPath);
        if (fs.existsSync(localPath)) fs.unlinkSync(localPath);
    } catch (e) {
        return editMsg(Gifted, stub, '*❌ Failed to process image.*');
    }

    if (!imgUrl) return editMsg(Gifted, stub, '*❌ Failed to upload image for analysis.*');

    const prompt = q.trim() || "Analyze this image in detail. Identify objects, text, and the overall context.";
    const { text, err } = await askAI(prompt + " Response must be in WhatsApp Markdown.", [imgUrl]);

    if (err) return editMsg(Gifted, stub, `*❌ Vision Error:* ${text}`);

    return editMsg(Gifted, stub, `*👁️ VISION ANALYSIS*\n\n${text}`);
});

gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    aliases: ['status', 'health', 'sysmon'],
    category: 'ai',
    desc: 'Check AI system health, rate limits, and API status.',
    react: '📊',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const start = Date.now();
    const stats = Limiter.stats();
    const circuitStatus = CB.open() ? '*🔴 TRIPPED*' : '*🟢 CLOSED (Healthy)*';
    
    let latency = 'N/A';
    try {
        await axios.get('https://quillbot.com/api/raven/quill-chat/health', { timeout: 5000 });
        latency = `${Date.now() - start}ms`;
    } catch(e) { latency = '*Error*'; }

    const report = `*📊 AI SYSTEM MONITOR*\n\n` +
                   `*System Status:* ${circuitStatus}\n` +
                   `*API Latency:* \`${latency}\`\n\n` +
                   `*Rate Limiting (1m):* \`${stats.rpm}/${CFG.MAX_RPM}\` requests\n` +
                   `*Rate Limiting (1h):* \`${stats.rph}/${CFG.MAX_RPH}\` requests\n\n` +
                   `*Daily Usage:* \n` +
                   ` 🧠 AI Queries: \`${stats.ai}\` \n` +
                   ` 🎨 Image Gens: \`${stats.img}\` \n` +
                   ` ⚠️ Total Errors: \`${stats.err}\` \n\n` +
                   `*Active Sessions:* \`${State.chats.size}\` chats\n` +
                   `*Targeted Bots:* \`${State.targets.size}\` numbers\n` +
                   `*Global Stalkers:* \`${State.stalkers.size}\` active\n\n` +
                   `_Last reset: ${stats.day}_`;

    return reply(report);
});

// ==============================================================================
// 20. STALKER SYSTEM FIX & REGISTRATION
// ==============================================================================

gmd({
    pattern: 'stalk',
    cmdname: 'stalk',
    category: 'ai',
    desc: 'Force the AI to reply to a specific user across all chats.',
    react: '🕵️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser, mek } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const input = q.trim().split(/\s+/);
    const target = input[0]?.replace(/[^0-9]/g, '');
    const gemName = input[1] || 'default';

    if (!target) return reply('*📝 Usage:* `.stalk <number> [gem_name]`');

    const jid = `${target}@s.whatsapp.net`;
    const persona = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;

    if (gemName !== 'default' && !Gems.get(gemName)) {
        return reply(`*⚠️ Gem \`${gemName}\` not found. Using default persona.*`);
    }

    State.stalkers.set(jid, {
        gem: persona,
        history: [],
        gemName: gemName,
        startTime: Date.now()
    });

    return reply(`*🕵️ STALKER ACTIVATED*\n\n*Target:* @${target}\n*Persona:* \`${gemName}\`\n*Scope:* Global (All Chats)\n\n_I will now shadow this user's every message._`, { mentions: [jid] });
});

gmd({
    pattern: 'unstalk',
    cmdname: 'unstalk',
    category: 'ai',
    desc: 'Remove an AI stalker from a user.',
    react: '🔓',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*❌ Access Denied.*');

    const target = q.trim().replace(/[^0-9]/g, '');
    if (!target) return reply('*📝 Usage:* `.unstalk <number>`');

    const jid = `${target}@s.whatsapp.net`;
    if (State.stalkers.has(jid)) {
        State.stalkers.delete(jid);
        return reply(`*🔓 UNSTALKED:* @${target} is now free.`, { mentions: [jid] });
    } else {
        return reply(`*⚠️ User @${target} was not being stalked.*`, { mentions: [jid] });
    }
});

