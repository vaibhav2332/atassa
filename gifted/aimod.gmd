// ==============================================================================
// 3. DATABASE
// ==============================================================================
let db = null;
if (Database) {
    try {
        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        console.log('[AIGems] Database ready');
    } catch(e) { console.error('[AIGems] DB error:', e.message); db = null; }
}

const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT content FROM gems WHERE name=?').get(n.toLowerCase().trim())?.content ?? null; } catch(e){ return null; } },
    save : (n, c) => { try { return !!db?.prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(n.toLowerCase().trim(), c)?.changes; } catch(e){ return false; } },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};
// ==============================================================================
// 4. RATE LIMITER + CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q:[], hr_q:[], daily:{ai:0,img:0,err:0,day:new Date().toDateString()},
    check() {
        const n=Date.now();
        this.min_q=this.min_q.filter(t=>n-t<60000);
        this.hr_q=this.hr_q.filter(t=>n-t<3600000);
        return this.min_q.length<CFG.MAX_RPM && this.hr_q.length<CFG.MAX_RPH;
    },
    hit(type='ai'){
        const n=Date.now(); this.min_q.push(n); this.hr_q.push(n);
        const d=new Date().toDateString();
        if(d!==this.daily.day) this.daily={ai:0,img:0,err:0,day:d};
        if(type==='ai') this.daily.ai++;
        if(type==='img') this.daily.img++;
    },
    err(){ this.daily.err++; },
    stats(){
        const n=Date.now();
        return {rpm:this.min_q.filter(t=>n-t<60000).length, rph:this.hr_q.filter(t=>n-t<3600000).length, ...this.daily};
    }
};

const CB = {
    fails:0, lastFail:0, THRESH:5, TTL:300000,
    open()  { return this.fails>=this.THRESH && Date.now()-this.lastFail<this.TTL; },
    fail()  { this.fails++; this.lastFail=Date.now(); Limiter.err(); },
    ok()    { this.fails=0; },
    reset() { this.fails=0; this.lastFail=0; },
    msg()   { return ['neural link glitchy rn','signal weak on my end','connection hiccupped','brain.exe crashed lol'][Math.floor(Math.random()*4)]; }
};

// ==============================================================================
// 5. CORE AI ŌĆö QuillBot SSE streaming (responseType: 'stream' for proper SSE)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit ŌĆö wait a moment', err: true };

    // ENFORCE WHATSAPP MARKDOWN VIA SYSTEM PREAMBLE
    const markdownPreamble = "SYSTEM: You must format your response using WhatsApp Markdown (*bold*, _italic_, ~strikethrough~, ```code block```). Use bullet points for lists. Be concise.\n\n";

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: markdownPreamble + prompt,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            // Collect SSE chunks into full text
            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            // Parse SSE: extract all "chunk" values from the data stream
            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { 
                        const o = JSON.parse(l.slice(6)); 
                        if (o.chunk) full += o.chunk; 
                    } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1200*(attempt+1)); continue; }
                CB.fail();
                return { text: 'empty response ŌĆö session may be expired', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] askAI attempt ${attempt+1}:`, e.message);
            if (attempt < CFG.RETRIES - 1) await sleep(1200*(attempt+1));
            else { CB.fail(); return { text: `API unreachable ŌĆö ${e.message}`, err: true }; }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 6. IMGBB UPLOADER
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch(e) { console.error('[AIGems] ImgBB:', e.message); return null; }
};

// ==============================================================================
// 7. IMAGE GENERATOR ŌĆö Infip API (key pool)
// ==============================================================================
let _iKey = CFG.INFIP_POOL[Math.floor(Math.random()*CFG.INFIP_POOL.length)];
let _iOk  = false;
const _iCache = new Map();
const _iHdr = () => ({ Authorization:`Bearer ${_iKey}`, 'Content-Type':'application/json' });

const ensureInfip = async () => {
    if (_iOk) return true;
    try { 
        const r = await axios.get(`${CFG.INFIP_URL}/v1/models`, {headers:_iHdr(), timeout:10000}); 
        if(r.status === 200){ _iOk = true; return true; } 
    } catch(e){}
    try { 
        const r = await axios.post(`${CFG.INFIP_URL}/v1/api-keys`, {}, {timeout:10000}); 
        if(r.data?.api_key){ _iKey = r.data.api_key; _iOk = true; return true; } 
    } catch(e){}
    _iOk = true; return false;
};

const generateImage = async (prompt, opts={}) => {
    const model = opts.model || CFG.IMG_MODEL, 
          size = opts.size || CFG.IMG_SIZE,
          n = Math.min(opts.count || CFG.IMG_COUNT, 4), 
          quality = opts.quality || CFG.IMG_QUALITY, 
          style = opts.style || CFG.IMG_STYLE;
          
    const ck = `${model}|${size}|${prompt.slice(0,60)}`;
    const hit = _iCache.get(ck);
    if(hit && Date.now() - hit.ts < 3600000) return hit.urls;
    if(!Limiter.check()) return [];
    
    await ensureInfip(); 
    Limiter.hit('img');
    
    for(let i=0; i<CFG.RETRIES; i++){
        try{
            const r = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`,
                { model, prompt, n, size, response_format:'url', quality, style },
                { headers:_iHdr(), timeout:CFG.TIMEOUT }
            );
            if(r.status === 200 && r.data?.data?.length){ 
                const urls = r.data.data.map(d => d.url); 
                _iCache.set(ck, {urls, ts:Date.now()}); 
                return urls; 
            }
        }catch(e){ 
            Limiter.err(); 
            if(i < CFG.RETRIES-1) await sleep(1000*(i+1)); 
        }
    }
    return [];
};
// ==============================================================================
// 8. RUNTIME STATE
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    chats: new Map(),
    targets: new Map(),
    stalkers: new Map(),
    dmSessions: new Map(),
    autoEnhance: false,
    PERSONA: 'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Always use WhatsApp markdown (*bold*, _italic_, ~strike~, ```code```) for emphasis and structure. Never say you are an AI. Use conversation history to stay consistent.',
    
    /** Normalizes JIDs to fix the stalk/target matching issue by removing device IDs and ensuring standard domain */
    norm(jid) {
        if (!jid || typeof jid !== 'string') return '';
        return jid.split(':')[0].split('@')[0] + '@s.whatsapp.net';
    },

    addHist(ctx, role, txt) {
        if (!ctx.history) ctx.history = [];
        const t = new Date().toLocaleTimeString('en', { hour12: false, hour: '2-digit', minute: '2-digit' });
        ctx.history.push(`[${t}] ${role}: ${txt}`);
        if (ctx.history.length > CFG.MAX_HIST) ctx.history = ctx.history.slice(-CFG.MAX_HIST);
    },

    buildPrompt(sys, hist, input) {
        return `SYSTEM:\n${sys}\n\n--- HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nREPLY (Format with WhatsApp markdown):`;
    }
};

// ==============================================================================
// 9. MESSAGE HELPERS
// ==============================================================================

/** Send quoted thinking stub, return sent msg for later edit */
const thinking = async (Gifted, from, mek, label = 'ŌÅ│ _thinkingŌĆ”_') => {
    try {
        return await Gifted.sendMessage(from, { text: label }, { quoted: mek });
    } catch (e) {
        return null;
    }
};

/** Edit a message with fallback: delete + resend */
const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    const remoteJid = sentMsg.key.remoteJid;
    try {
        // Attempt native WhatsApp message edit
        await Gifted.sendMessage(remoteJid, { text: newText, edit: sentMsg.key });
        return;
    } catch (e1) {}
    
    // Fallback strategy: delete old ŌåÆ wait ŌåÆ send fresh message
    try {
        await Gifted.sendMessage(remoteJid, { delete: sentMsg.key });
    } catch (e) {}
    await sleep(300);
    try {
        await Gifted.sendMessage(remoteJid, { text: newText });
    } catch (e2) {
        console.error('[AIGems] editMsg failed:', e2.message);
    }
};

/** Delete message silently */
const del = async (Gifted, key) => {
    try {
        if (key && key.remoteJid) {
            await Gifted.sendMessage(key.remoteJid, { delete: key });
        }
    } catch (_) {}
};

/** Send image with URL-text fallback in case of media upload failure */
const sendImg = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { image: { url }, caption }, { quoted: mek });
        return true;
    } catch (e) {
        try {
            await Gifted.sendMessage(from, { text: `­¤Ä© ${caption}\n\n­¤öŚ ${url}` }, { quoted: mek });
        } catch (_) {}
        return false;
    }
};

// ==============================================================================
// 10.  .gem  ŌĆö PERSONA SYSTEM
// ==============================================================================
gmd({
    pattern:'gem', cmdname:'gem', aliases:['gems','persona'],
    category:'ai', desc:'AI persona vault. .gem help for all sub-commands.', react:'­¤ÆÄ', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('ŌØī Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'help', rest=parts.slice(1);

    if (cmd==='create') {
        if(rest.length<2) return reply('­¤ōØ Usage: `.gem create <name> <persona prompt>`');
        const [name,...pArr]=rest, content=pArr.join(' ');
        return Gems.save(name,content)
            ? reply(`­¤ÆÄ *Gem Saved*\n*Name:* \`${name}\`\n*Preview:* _${content.slice(0,120)}_`)
            : reply('ŌØī Database write error.');
    }
    if (cmd==='gen') {
        const topic=rest.join(' ');
        if(!topic) return reply('­¤ōØ Usage: `.gem gen <topic>`  e.g. `.gem gen sarcastic gamer`');
        const stub=await thinking(Gifted,from,mek,`­¤ö« _Forging "${topic}" personaŌĆ”_`);
        const {text,err}=await askAI(`Create a detailed WhatsApp persona system prompt for: ${topic}.\nInclude personality, speaking style, slang, emoji habits.\nReturn ONLY the raw system prompt text.`);
        if(err) return editMsg(Gifted,stub,`ŌØī ${text}`);
        const name=(rest[0]||'gem').toLowerCase().slice(0,12)+'_ai';
        Gems.save(name,text);
        return editMsg(Gifted,stub,`Ō£© *Gem Created*\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0,150)}_\n\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd==='analyze') {
        const quoted=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if(!quoted) return reply('­¤ōØ *Reply to a message* then run `.gem analyze`');
        const sample=quoted.conversation||quoted.extendedTextMessage?.text||'[no text]';
        const stub=await thinking(Gifted,from,mek,'­¤ĢĄ’ĖÅ _Cloning writing styleŌĆ”_');
        const {text,err}=await askAI(`Analyze this WhatsApp message and build a system prompt to clone this exact style and tone:\n"${sample}"\nReturn ONLY the system prompt.`);
        if(err) return editMsg(Gifted,stub,`ŌØī ${text}`);
        const name=`clone_${Date.now().toString(36)}`;
        Gems.save(name,text);
        return editMsg(Gifted,stub,`­¤¦¼ *Clone Created*\n*Name:* \`${name}\`\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd==='remix') {
        const [gemName,...tw]=rest; const tweak=tw.join(' ');
        if(!gemName||!tweak) return reply('­¤ōØ Usage: `.gem remix <name> <modification instruction>`');
        const base=Gems.get(gemName);
        if(!base) return reply(`ŌØī Gem \`${gemName}\` not found.`);
        const stub=await thinking(Gifted,from,mek,`­¤öĆ _Remixing "${gemName}"ŌĆ”_`);
        const {text,err}=await askAI(`Modify this system prompt per the instruction. Return ONLY the updated prompt.\n\nOriginal:\n${base}\n\nInstruction: ${tweak}`);
        if(err) return editMsg(Gifted,stub,`ŌØī ${text}`);
        const newName=`${gemName}_remix`;
        Gems.save(newName,text);
        return editMsg(Gifted,stub,`­¤öĆ *Remixed*\n\`${gemName}\` ŌåÆ \`${newName}\``);
    }
    if (cmd==='list') {
        const list=Gems.list();
        if(!list.length) return reply('­¤ōÜ No gems found.\n`.gem gen <topic>` or `.gem create <n> <prompt>`');
        return reply(`­¤ōÜ *Gems Vault (${list.length})*\n\n${list.map((g,i)=>`${i+1}. ­¤ÆÄ \`${g}\``).join('\n')}\n\n_Use_ \`.gem use <name>\``);
    }
    if (cmd==='view') {
        const c=Gems.get(rest[0]||'');
        if(!rest[0]) return reply('­¤ōØ Usage: `.gem view <name>`');
        if(!c) return reply(`ŌØī Gem \`${rest[0]}\` not found.`);
        return reply(`­¤ÆÄ *PERSONA: ${rest[0].toUpperCase()}*\n\n${c}`);
    }
    if (cmd==='use') {
        if(!rest[0]) return reply('­¤ōØ Usage: `.gem use <name>`');
        const c=Gems.get(rest[0]);
        if(!c) return reply(`ŌØī Gem \`${rest[0]}\` not found.`);
        State.dmGem=c;
        return reply(`Ō£ģ *DM Persona set to:* \`${rest[0]}\`\nEnable AI with \`.gai dm on\``);
    }
    if (cmd==='delete'||cmd==='del') {
        if(!rest[0]) return reply('­¤ōØ Usage: `.gem delete <name>`');
        return Gems.del(rest[0]) ? reply(`­¤Śæ’ĖÅ Gem \`${rest[0]}\` deleted.`) : reply(`ŌØī Not found.`);
    }
    return reply(
        `­¤ÆÄ *GEM ŌĆö Persona Vault*\n\n`+
        `ŌĆó \`.gem create <n> <prompt>\` - Manual save\n`+
        `ŌĆó \`.gem gen <topic>\` ŌĆö AI creates persona\n`+
        `ŌĆó \`.gem analyze\` ŌĆö Clone from quoted msg\n`+
        `ŌĆó \`.gem remix <n> <tweak>\` - Modify existing\n`+
        `ŌĆó \`.gem list\` - View all gems\n`+
        `ŌĆó \`.gem view <n>\` - Read prompt\n`+
        `ŌĆó \`.gem use <n>\` - Set as active DM persona\n`+
        `ŌĆó \`.gem delete <n>\` - Remove gem`
    );
});
// ==============================================================================
// 11.  .gai  ŌĆö ONE-SHOT AI + AUTO-REPLY CONTROL
// ==============================================================================
gmd({
    pattern:'gai', cmdname:'gai', aliases:['ai','ask','brain'],
    category:'ai', desc:'AI assistant & auto-reply control. .gai help', react:'­¤¦Ā', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('ŌØī Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'', rest=parts.slice(1), second=rest[0]?.toLowerCase()||'';

    if (cmd==='dm') {
        if(second==='on')  { State.dmActive=true;  return reply(`­¤ō© *DM Auto-Pilot: Ō£ģ ON*\nPersona: ${State.dmGem?'Custom gem':'Default'}`); }
        if(second==='off') { State.dmActive=false; return reply('­¤ō© *DM Auto-Pilot: ŌØī OFF*'); }
        return reply(`­¤ō© DM Auto-Pilot: ${State.dmActive?'Ō£ģ ON':'ŌØī OFF'}`);
    }
    if (cmd==='chat') {
        const gemName=second||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.chats.set(from,{gem:gemTxt,history:[],gemName});
        return reply(`ŌÜö’ĖÅ *Chat AI Active*\nGem: *${gemName}* ŌĆö replying to everyone here.`);
    }
    if (cmd==='target'||cmd==='bot') {
        const num=rest[0]?.replace(/[^0-9]/g,'');
        if(!num) return reply('­¤ōØ `.gai target <number> [gem]`');
        const tjid=num+'@s.whatsapp.net', gemName=rest[1]||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.targets.set(tjid,{gem:gemTxt,history:[],chatId:from,gemName});
        return reply(`­¤ż¢ *Target Locked*\n@${num} | Gem: *${gemName}*`);
    }
    if (cmd==='stalk') {
        const num=rest[0]?.replace(/[^0-9]/g,'');
        if(!num) return reply('­¤ōØ `.gai stalk <number> [gem]`');
        const tjid=num+'@s.whatsapp.net', gemName=rest[1]||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.stalkers.set(tjid,{gem:gemTxt,history:[],gemName});
        return reply(`­¤īŹ *Global Stalker*\n@${num} everywhere | Gem: *${gemName}*`);
    }
    if (cmd==='stop') {
        if(second==='all'){
            State.dmActive=false; State.chats.clear(); State.targets.clear();
            State.stalkers.clear(); State.dmSessions.clear();
            return reply('Ōśó’ĖÅ *ALL AI OFF*\nDM: OFF | Chats: 0 | Targets: 0 | Stalkers: 0');
        }
        State.chats.delete(from);
        return reply('­¤øæ AI stopped here.\n_Stop all:_ `.gai stop all`');
    }
    if (cmd==='wipe') {
        const sess=State.chats.get(from);
        if(sess){ sess.history=[]; return reply('­¤¦Ā _Memory wiped!_'); }
        return reply('Ōä╣’ĖÅ No active session here.');
    }
    if (cmd==='status') {
        const s=Limiter.stats(), cb=CB.open()?`­¤ö┤ TRIPPED (${CB.fails}/${CB.THRESH})`:`­¤¤ó OK`;
        let out=`­¤ōŖ *AI STATUS*\nDM:${State.dmActive?'Ō£ģ':'ŌØī'} Chats:${State.chats.size} Targets:${State.targets.size} Stalkers:${State.stalkers.size}\n${s.rpm}rpm ${s.rph}rph | AI:${s.ai} Img:${s.img} Err:${s.err}\nCircuit: ${cb}`;
        if(State.chats.size){ out+='\n*Sessions:*'; State.chats.forEach((d,c)=>{out+=`\nŌĆó ${c.split('@')[0]}: ${d.history.length}t (${d.gemName})`;}); }
        return reply(out);
    }
    if (cmd==='summary') {
        const sess=State.chats.get(from);
        if(!sess?.history?.length) return reply('Ōä╣’ĖÅ No history here. Start a session with `.gai chat` first.');
        const stub=await thinking(Gifted,from,mek,'­¤ōØ _SummarisingŌĆ”_');
        const {text,err}=await askAI(`Summarise this WhatsApp chat in bullet points:\n\n${sess.history.join('\n')}`);
        return editMsg(Gifted,stub,err?`ŌØī ${text}`:`­¤ōØ *Summary*\n\n${text}`);
    }
    if (cmd==='help') {
        return reply(
            `­¤¦Ā *GAI ŌĆö AI CONTROL*\n\n`+
            `*Quick ask:* \`.gai <question>\`\n\n`+
            `*Modes:*\nŌĆó \`.gai dm on/off\` - Auto reply in DMs\nŌĆó \`.gai chat [gem]\` - Reply to everyone in this chat\nŌĆó \`.gai target <num> [gem]\` - Reply to num in this chat\nŌĆó \`.gai stalk <num> [gem]\` - Reply to num globally\n\n`+
            `*Control:*\nŌĆó \`.gai stop\` / \`.gai stop all\`\nŌĆó \`.gai wipe\` - Reset chat memory\nŌĆó \`.gai summary\` - Recap history\nŌĆó \`.gai status\` - Performance metrics`
        );
    }

    // ŌöĆŌöĆ ONE-SHOT ASK ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
    const question = q.trim();
    if (!question) return reply('­¤ōØ `.gai <question>`  or  `.gai help`');

    let imgUrls=[];
    const quotedMsg=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quotedMsg?.imageMessage) {
        await react('­¤æü’ĖÅ');
        try {
            const tp=await Gifted.downloadAndSaveMediaMessage(quotedMsg.imageMessage,`tmp_gai_${Date.now()}`);
            if(tp){ const url=await uploadImgBB(tp); if(url) imgUrls.push(url); try{fs.unlinkSync(tp);}catch(_){} }
        } catch(e){ console.error('[AIGems] vision:', e.message); }
    }

    const stub=await thinking(Gifted,from,mek,'­¤¦Ā _thinkingŌĆ”_');
    let finalPrompt=question;
    const ctx=quotedMsg?.conversation||quotedMsg?.extendedTextMessage?.text;
    if(ctx) finalPrompt=`Context:\n"${ctx}"\n\nQuestion: ${question}`;
    const {text,err}=await askAI(finalPrompt,imgUrls);
    return editMsg(Gifted,stub, err?`ŌØī ${text}`:text);
});

// ==============================================================================
// 12.  .img  ŌĆö IMAGE GENERATION
// ==============================================================================
gmd({
    pattern:'img', cmdname:'img', aliases:['imagine','genimg','drawai'],
    category:'ai', desc:'AI image generation. .img help for sub-commands.', react:'­¤Ä©', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('ŌØī Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'help', rest=parts.slice(1);
    const KNOWN=['gen','surprise','chaos','models','config','enhance','setup','random','cache','help'];

    const doGen=async(prompt,stub)=>{
        const urls=await generateImage(prompt);
        if(!urls.length) return editMsg(Gifted,stub,'ŌØī Generation failed. Try `.img setup` or `.img config <model>`.');
        await del(Gifted,stub.key);
        await sendImg(Gifted,from,urls[0],`­¤Ä© _${prompt.slice(0,200)}_\n­¤ż¢ \`${CFG.IMG_MODEL}\``,mek);
        for(const u of urls.slice(1)) await sendImg(Gifted,from,u,'­¤Ä© _Variation_',mek);
    };

    if(cmd==='gen'||(!KNOWN.includes(cmd)&&q)){
        const prompt=cmd==='gen'?rest.join(' '):q;
        if(!prompt.trim()) return reply('­¤ōØ `.img gen <prompt>`');
        await react('­¤Ä©');
        return doGen(prompt, await thinking(Gifted,from,mek,'­¤Ä© _GeneratingŌĆ”_'));
    }
    if(cmd==='surprise'){
        const hint=rest.join(' ');
        const stub=await thinking(Gifted,from,mek,`­¤Ä▓ _Dreaming${hint?` (${hint})`:''}ŌĆ”_`);
        const {text:dreamt,err}=await askAI(`Generate a highly detailed creative image prompt${hint?` themed: "${hint}"`:''}.\nReturn ONLY the prompt.`);
        if(err) return editMsg(Gifted,stub,`ŌØī ${dreamt}`);
        await editMsg(Gifted,stub,`­¤Ä▓ _Visualising:_ "${dreamt.slice(0,80)}ŌĆ”"`);
        const urls=await generateImage(dreamt);
        if(!urls.length) return editMsg(Gifted,stub,'ŌØī Failed. Retry.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`­¤Ä▓ *Surprise!*\n­¤ÆŁ _${dreamt.slice(0,200)}_`,mek);
    }
    if(cmd==='chaos'){
        const free=Object.keys(CFG.IMG_MDLS).filter(k=>CFG.IMG_MDLS[k].tier==='free');
        CFG.IMG_MODEL=free[Math.floor(Math.random()*free.length)];
        CFG.IMG_SIZE=['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        CFG.IMG_QUALITY=Math.random()>.5?'hd':'standard'; CFG.IMG_STYLE=Math.random()>.5?'vivid':'natural';
        const stub=await thinking(Gifted,from,mek,`­¤ī¬’ĖÅ *CHAOS* ŌĆö ${CFG.IMG_MODEL} | ${CFG.IMG_SIZE}`);
        const {text:chaos}=await askAI(['Generate a bizarre surreal image prompt defying logic. Return ONLY prompt.','Create an absurd scene with impossible physics. Return ONLY prompt.','Describe the most chaotic image imaginable. Return ONLY prompt.'][Math.floor(Math.random()*3)]);
        const fp=chaos||'melting clocks cybernetic forest neon rain 8k';
        const urls=await generateImage(fp);
        if(!urls.length) return editMsg(Gifted,stub,'ŌØī Chaos failed. Retry.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`­¤ī¬’ĖÅ *CHAOS*\n­¤ÆŁ _${fp.slice(0,200)}_\nŌÜÖ’ĖÅ \`${CFG.IMG_MODEL}\` \`${CFG.IMG_SIZE}\``,mek);
    }
    if(cmd==='models'){
        const lines=Object.entries(CFG.IMG_MDLS).map(([id,m])=>`${m.tier==='pro'?'­¤ææ':'­¤åō'} \`${id}\` ŌĆö ${m.desc}`).join('\n');
        return reply(`­¤ōŗ *Models*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\`\nSwitch: \`.img config <model>\``);
    }
    if(cmd==='config'){
        if(!rest[0]) return reply(`ŌÜÖ’ĖÅ *Config*\nModel:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Count:${CFG.IMG_COUNT} Quality:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\`\n\n­¤ōØ \`.img config <model> [size] [n] [quality] [style]\``);
        const [model,size,count,quality,style]=rest;
        if(model&&!CFG.IMG_MDLS[model]) return reply(`ŌØī Model \`${model}\` unknown. Run \`.img models\``);
        if(model) CFG.IMG_MODEL=model; if(size) CFG.IMG_SIZE=size;
        if(count) CFG.IMG_COUNT=Math.min(parseInt(count)||1,4);
        if(quality) CFG.IMG_QUALITY=quality; if(style) CFG.IMG_STYLE=style;
        return reply(`Ō£ģ Model:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Q:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\``);
    }
    if(cmd==='enhance'){
        const p=rest.join(' '); if(!p) return reply('­¤ōØ `.img enhance <prompt>`');
        const stub=await thinking(Gifted,from,mek,'­¤¦Ā _EnhancingŌĆ”_');
        const {text,err}=await askAI(`Enhance this image prompt ŌĆö richer details, same intent. Return ONLY the prompt.\n\n${p}`);
        return editMsg(Gifted,stub,err?`ŌØī ${text}`:`Ō£© *Enhanced*\n\n*Original:* ${p}\n\n*Enhanced:* ${text}`);
    }
    if(cmd==='random'){
        const free=Object.keys(CFG.IMG_MDLS).filter(k=>CFG.IMG_MDLS[k].tier==='free');
        CFG.IMG_MODEL=free[Math.floor(Math.random()*free.length)];
        CFG.IMG_SIZE=['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        CFG.IMG_QUALITY=Math.random()>.5?'hd':'standard'; CFG.IMG_STYLE=Math.random()>.5?'vivid':'natural';
        return reply(`­¤Ä▓ *Randomized*\nModel:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Q:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\``);
    }
    if(cmd==='setup'){
        const stub=await thinking(Gifted,from,mek,'­¤ö¦ _Validating InfipŌĆ”_');
        _iOk=false; const ok=await ensureInfip();
        return editMsg(Gifted,stub,ok?`Ō£ģ *Infip Ready*\nKey: \`${_iKey.slice(0,20)}ŌĆ”\``:`ŌØī *Setup Failed* ŌĆö all keys invalid`);
    }
    if(cmd==='cache'){ _iCache.clear(); return reply('­¤Śæ’ĖÅ Cache cleared.'); }
    return reply(`­¤Ä© *IMG COMMANDS*\nŌĆó \`.img gen <prompt>\`\nŌĆó \`.img surprise [topic]\`\nŌĆó \`.img chaos\`\nŌĆó \`.img enhance <prompt>\`\nŌĆó \`.img models\`\nŌĆó \`.img config [model] [size] [n] [quality] [style]\`\nŌĆó \`.img random\`\nŌĆó \`.img setup\`\nŌĆó \`.img cache\`\n\n*Active:* \`${CFG.IMG_MODEL}\` @ \`${CFG.IMG_SIZE}\``);
});

// ==============================================================================
// 13.  .apimon  ŌĆö API MONITOR
// ==============================================================================
gmd({
    pattern:'apimon', cmdname:'apimon', aliases:['apistat','aihealth'],
    category:'ai', desc:'AI API usage, health check and circuit breaker.', react:'­¤ōŖ', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('ŌØī Owner only.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'status';
    if(cmd==='status'||!q.trim()){
        const s=Limiter.stats(), cb=CB.open()?'­¤ö┤ TRIPPED':`­¤¤ó OK (${CB.fails}/${CB.THRESH})`;
        const bar=(v,max,l=12)=>'Ō¢ł'.repeat(Math.min(l,Math.round(v/max*l)))+'Ō¢æ'.repeat(Math.max(0,l-Math.round(v/max*l)));
        return reply(`­¤ōŖ *API Status*\n1m: \`${bar(s.rpm,CFG.MAX_RPM)}\` ${s.rpm}/${CFG.MAX_RPM}\n1h: \`${bar(s.rph,CFG.MAX_RPH)}\` ${s.rph}/${CFG.MAX_RPH}\nToday: AI:${s.ai} Img:${s.img} Err:${s.err}\nCircuit: ${cb}`);
    }
    if(cmd==='health'){
        const stub=await thinking(Gifted,from,mek,'­¤öŹ _Health checkŌĆ”_');
        const lines=[];
        const {text:tr,err:te}=await askAI('Reply ONLY with the word: HEALTH_OK');
        lines.push((!te&&tr.includes('HEALTH_OK'))?'Ō£ģ QuillBot: Healthy':`ŌÜĀ’ĖÅ QuillBot: ${te?'Error':'Unexpected'} ŌĆö ${tr.slice(0,60)}`);
        lines.push(CB.open()?'­¤ö┤ Circuit: TRIPPED':'Ō£ģ Circuit: Closed');
        lines.push(Limiter.check()?'Ō£ģ Rate Limit: Clear':'ŌÜĀ’ĖÅ Rate Limit: Active');
        lines.push(_iOk?'Ō£ģ Infip: Validated':'ŌÜĀ’ĖÅ Infip: Not tested');
        try{Gems.list();lines.push('Ō£ģ DB: OK');}catch(e){lines.push('ŌØī DB: Error');}
        return editMsg(Gifted,stub,`­¤öŹ *Health Check*\n\n${lines.join('\n')}`);
    }
    if(cmd==='reset'){
        const type=parts[1]?.toLowerCase();
        if(type==='circuit'){ CB.reset(); return reply('Ō£ģ Circuit breaker reset.'); }
        if(type==='daily'){ Limiter.daily={ai:0,img:0,err:0,day:new Date().toDateString()}; return reply('Ō£ģ Daily stats reset.'); }
        return reply('­¤ōØ `.apimon reset <circuit|daily>`');
    }
    return reply(`­¤ōŖ *API Monitor*\nŌĆó \`.apimon status\`\nŌĆó \`.apimon health\`\nŌĆó \`.apimon reset <circuit|daily>\``);
});

