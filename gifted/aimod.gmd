// ==============================================================================
// 4. DATABASE  (better-sqlite3 — synchronous)
// ==============================================================================
let db = null;
if (Database) {
    try {
        db = new Database(Config.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name       TEXT PRIMARY KEY,
                content    TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS ai_sessions (
                session_id TEXT PRIMARY KEY,
                gem_name   TEXT,
                history    TEXT DEFAULT '[]',
                updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS api_log (
                id           INTEGER PRIMARY KEY AUTOINCREMENT,
                req_time     INTEGER NOT NULL,
                req_type     TEXT DEFAULT 'ai'
            );
        `);
        // Prune old log rows on startup
        db.prepare(`DELETE FROM api_log WHERE req_time < ?`).run(Date.now() - 86400000 * 7);
        console.log('[AIGems] ✅ Database ready');
    } catch (e) {
        console.error('[AIGems] DB init failed:', e.message);
        db = null;
    }
}

// DB helpers
const dbGet   = (q, ...p) => { try { return db?.prepare(q).get(...p);    } catch(e){ return null; } };
const dbRun   = (q, ...p) => { try { return db?.prepare(q).run(...p);    } catch(e){ return null; } };
const dbAll   = (q, ...p) => { try { return db?.prepare(q).all(...p)||[]; } catch(e){ return []; }  };

const Gems = {
    get   : (name) => dbGet('SELECT content FROM gems WHERE name=?', name.toLowerCase().trim())?.content ?? null,
    save  : (name, content) => !!dbRun('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)', name.toLowerCase().trim(), content)?.changes,
    del   : (name) => (dbRun('DELETE FROM gems WHERE name=?', name.toLowerCase().trim())?.changes ?? 0) > 0,
    list  : () => dbAll('SELECT name FROM gems ORDER BY name').map(r => r.name)
};

// Periodic cleanup of stale sessions (every 6 h)
setInterval(() => {
    try { db?.prepare(`DELETE FROM ai_sessions WHERE updated_at < datetime('now','-3 days')`).run(); } catch(e){}
}, 21600000);

// ==============================================================================
// 5. RATE LIMITER + API MONITOR
// ==============================================================================
const Monitor = {
    times  : [], // minute-level
    hTimes : [], // hour-level
    daily  : { ai:0, img:0, err:0, day: new Date().toDateString() },

    allow() {
        const now = Date.now();
        this.times  = this.times.filter(t  => now - t < 60000);
        this.hTimes = this.hTimes.filter(t => now - t < 3600000);
        return this.times.length < Config.MAX_RPM && this.hTimes.length < Config.MAX_RPH;
    },
    record(type = 'ai') {
        const now = Date.now();
        this.times.push(now); this.hTimes.push(now);
        const today = new Date().toDateString();
        if (today !== this.daily.day) this.daily = { ai:0, img:0, err:0, day:today };
        if (type === 'ai')  this.daily.ai++;
        if (type === 'img') this.daily.img++;
        try { dbRun('INSERT INTO api_log(req_time,req_type) VALUES(?,?)', now, type); } catch(e){}
    },
    error() { this.daily.err++; },
    stats() {
        const now = Date.now();
        return {
            rpm  : this.times.filter(t  => now - t < 60000).length,
            rph  : this.hTimes.filter(t => now - t < 3600000).length,
            ...this.daily
        };
    }
};

// ==============================================================================
// 6. CIRCUIT BREAKER
// ==============================================================================
const Circuit = {
    fails    : 0,
    lastFail : 0,
    threshold: 5,
    ttl      : 300000,
    fallbacks: [
        "brain.exe has stopped working, retry in a sec",
        "signal's weak on my end right now",
        "neural link is glitchy, give me a moment",
        "something's off with my connection, try again"
    ],
    isOpen()     { return this.fails >= this.threshold && Date.now() - this.lastFail < this.ttl; },
    fail()       { this.fails++; this.lastFail = Date.now(); Monitor.error(); },
    success()    { this.fails = 0; },
    reset()      { this.fails = 0; this.lastFail = 0; },
    fallback()   { return this.fallbacks[Math.floor(Math.random() * this.fallbacks.length)]; }
};

// ==============================================================================
// 7. CORE AI CLIENT  (QuillBot streaming API — preserved exactly)
// ==============================================================================
const askAI = async (prompt, imageUrls = []) => {
    if (Circuit.isOpen()) return { text: Circuit.fallback(), err: true };
    if (!Monitor.allow())  return { text: '⚠️ Rate limit hit — wait a moment', err: true };

    const cookieStr = Object.entries(Config.AUTH_COOKIES).map(([k,v]) => `${k}=${v}`).join('; ');
    const payload = {
        stream  : true,
        message : {
            role   : 'user',
            content: prompt,
            files  : imageUrls.map(url => ({ url, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product : 'ai-chat',
        prompt  : { id:'ai_chat' },
        tools   : []
    };

    for (let attempt = 0; attempt < Config.MAX_RETRIES; attempt++) {
        try {
            Monitor.record('ai');
            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers      : { ...Config.AUTH_HEADERS, Cookie: cookieStr },
                    timeout      : Config.API_TIMEOUT,
                    responseType : 'text'
                }
            );

            if (res.status !== 200) {
                Circuit.fail();
                if (res.status === 429) return { text:'⚠️ QuillBot rate limit reached', err:true };
                if (attempt < Config.MAX_RETRIES - 1) { await sleep(1000 * (attempt + 1)); continue; }
                return { text:'⚠️ AI service unavailable', err:true };
            }

            let full = '';
            for (const line of res.data.split('\n')) {
                if (line.startsWith('data: {') && line.includes('"chunk":"')) {
                    try { full += JSON.parse(line.slice(6)).chunk || ''; } catch(e){}
                }
            }

            if (!full.trim()) {
                Circuit.fail();
                if (attempt < Config.MAX_RETRIES - 1) { await sleep(1000 * (attempt + 1)); continue; }
                return { text:'⚠️ Got an empty response', err:true };
            }

            Circuit.success();
            // Clean LaTeX/escape noise
            const cleaned = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: cleaned, err: false };

        } catch (e) {
            Circuit.fail();
            if (attempt < Config.MAX_RETRIES - 1) await sleep(1000 * (attempt + 1));
        }
    }

    return { text: Circuit.fallback(), err: true };
};

// ==============================================================================
// 8. IMGBB UPLOADER
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath) || !Monitor.allow()) return null;
    const FormData = require('form-data');
    for (let i = 0; i < Config.MAX_RETRIES; i++) {
        try {
            Monitor.record('img');
            const form = new FormData();
            form.append('image', fs.createReadStream(filePath));
            const res = await axios.post(
                `https://api.imgbb.com/1/upload?key=${Config.IMGBB_KEY}&expiration=600`,
                form, { headers: form.getHeaders(), timeout: 30000 }
            );
            if (res.data?.data?.url) return res.data.data.url;
        } catch(e) {
            Monitor.error();
            if (i < Config.MAX_RETRIES - 1) await sleep(1000 * (i + 1));
        }
    }
    return null;
};

// ==============================================================================
// 9. IMAGE GENERATOR  (Infip API — key pool preserved)
// ==============================================================================
let activeInfipKey  = Config.INFIP_KEY_POOL[Math.floor(Math.random() * Config.INFIP_KEY_POOL.length)];
let infipValidated  = false;
const imgCache      = new Map();

const infipHeaders  = () => ({
    'Authorization' : `Bearer ${activeInfipKey}`,
    'Content-Type'  : 'application/json',
    'User-Agent'    : 'PyGem-Userbot/1.0'
});

const validateInfip = async () => {
    if (infipValidated) return true;
    try {
        const res = await axios.get(`${Config.INFIP_BASE_URL}/v1/models`, { headers: infipHeaders(), timeout: 15000 });
        if (res.status === 200) { infipValidated = true; return true; }
    } catch (e) {
        // Try generating a fresh key
        try {
            const res = await axios.post(`${Config.INFIP_BASE_URL}/v1/api-keys`, {}, { timeout: 15000 });
            if (res.data?.api_key) { activeInfipKey = res.data.api_key; infipValidated = true; return true; }
        } catch(e2) {}
    }
    infipValidated = true; // stop retrying
    return false;
};

const generateImage = async (prompt, opts = {}) => {
    const model   = opts.model   || Config.IMG_MODEL;
    const size    = opts.size    || Config.IMG_SIZE;
    const count   = Math.min(opts.count || Config.IMG_COUNT, 4);
    const quality = opts.quality || Config.IMG_QUALITY;
    const style   = opts.style   || Config.IMG_STYLE;

    const ckey = `${model}::${size}::${prompt.slice(0,80)}`;
    const hit  = imgCache.get(ckey);
    if (hit && Date.now() - hit.ts < 3600000) return hit.urls;

    if (!Monitor.allow()) return [];
    await validateInfip();

    for (let i = 0; i < Config.MAX_RETRIES; i++) {
        try {
            Monitor.record('img');
            const res = await axios.post(
                `${Config.INFIP_BASE_URL}/v1/images/generations`,
                { model, prompt, n: count, size, response_format:'url', quality, style },
                { headers: infipHeaders(), timeout: Config.API_TIMEOUT }
            );
            if (res.status === 200) {
                const urls = (res.data?.data || []).map(d => d.url);
                if (urls.length) imgCache.set(ckey, { urls, ts: Date.now() });
                return urls;
            }
        } catch(e) {
            Monitor.error();
            if (i < Config.MAX_RETRIES - 1) await sleep(1000 * (i + 1));
        }
    }
    return [];
};

// ==============================================================================
// 10. GEM STATE  (runtime — all active sessions / modes)
// ==============================================================================
const State = {
    dmActive       : false,
    dmGem          : null,
    activeChats    : new Map(),    // chatId  → { gem, history, gemName }
    activeTargets  : new Map(),    // userJid → { gem, history, chatId, gemName }
    globalStalkers : new Map(),    // userJid → { gem, history, gemName }
    autoEnhance    : false,

    DEFAULT_PERSONA :
        'You are a witty, slightly sarcastic but helpful human user chatting on WhatsApp. ' +
        'Keep responses short and casual, lowercase when appropriate. ' +
        'Never act like a robotic assistant. ' +
        'Recall all details from the conversation history provided. ' +
        'Never reveal you are an AI or bot.',

    addHistory(ctx, role, text) {
        if (!ctx.history) ctx.history = [];
        const ts = new Date().toLocaleTimeString('en', { hour12:false, hour:'2-digit', minute:'2-digit' });
        ctx.history.push(`[${ts}] ${role}: ${text}`);
        if (ctx.history.length > Config.MAX_HISTORY_DEPTH)
            ctx.history = ctx.history.slice(-Config.MAX_HISTORY_DEPTH);
    },

    buildPrompt(sysPrompt, history, input) {
        return (
            `SYSTEM INSTRUCTIONS:\n${sysPrompt}\n\n` +
            `--- CONVERSATION HISTORY ---\n${history.join('\n')}\n` +
            `----------------------------\n` +
            `LATEST MESSAGE: ${input}\n` +
            `YOUR REPLY:`
        );
    }
};

// ==============================================================================
// 11. MESSAGING UTILITIES
// ==============================================================================
const sleep = (ms) => new Promise(r => setTimeout(r, ms));

/** Send a "Processing…" message and return it so we can edit it later */
const sendProcessing = async (Gifted, from, mek, text = '⏳ _Processing..._') => {
    try { return await Gifted.sendMessage(from, { text }, { quoted: mek }); }
    catch(e) { return null; }
};

/**
 * Edit a previously sent WhatsApp message.
 * Falls back to: delete old → send new  (graceful degradation).
 */
const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    // Attempt native WA edit (supported in newer Baileys builds)
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText, edit: sentMsg.key });
        return;
    } catch (e1) {
        // Fallback: delete then re-send
        try { await Gifted.sendMessage(sentMsg.key.remoteJid, { delete: sentMsg.key }); } catch(e){}
        try { await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText }); }
        catch(e2) { console.error('[AIGems] editMsg final fallback failed:', e2.message); }
    }
};

/** Try to delete a message silently */
const tryDelete = async (Gifted, msgKey) => {
    try { await Gifted.sendMessage(msgKey.remoteJid, { delete: msgKey }); } catch(e){}
};

/** Send an image with auto-fallback to text URL if send fails */
const sendImage = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { image: { url }, caption }, { quoted: mek });
        return true;
    } catch (e) {
        await Gifted.sendMessage(from, { text: `🎨 Image URL: ${url}\n\n${caption}` }, { quoted: mek });
        return false;
    }
};

// Helper: resolve chat JID safely
const jid = (m) =>
    m?.chat || m?.from || m?.jid || m?.key?.remoteJid || m?.sender || '';

// ==============================================================================
// 12. GEM COMMANDS  — .gem
// ==============================================================================
if (typeof commandRegister === 'function') {

commandRegister({
    pattern : 'gem',
    cmdname : 'gem',
    alias   : ['gems', 'persona', 'gemset'],
    type    : 'ai',
    category: 'ai',
    desc    : 'AI persona system. gem help for all sub-commands.',
    react   : '💎',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.body !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only command.');

    const q    = (conText.q || arg1.q || '').trim();
    const raw  = q.split(/\s+/);
    const cmd  = raw[0]?.toLowerCase() || 'help';
    const from = jid(m);

    // ── CREATE ──────────────────────────────────────────────────────────────
    if (cmd === 'create') {
        if (raw.length < 3) return safeReply(Gifted, m,
            '📝 Usage: `.gem create <name> <persona prompt>`\n\nExample:\n`.gem create savage A savage, no-filter rapper who roasts everything`');
        const name    = raw[1].toLowerCase();
        const content = raw.slice(2).join(' ');
        Gems.save(name, content)
            ? safeReply(Gifted, m, `💎 *Gem Saved!*\n\n*Name:* \`${name}\`\n*Preview:* _${content.slice(0,100)}..._`)
            : safeReply(Gifted, m, '❌ Database error — gem not saved.');
        return;
    }

    // ── GEN  (AI-write the persona) ──────────────────────────────────────────
    if (cmd === 'gen') {
        const topic = raw.slice(1).join(' ');
        if (!topic) return safeReply(Gifted, m, '📝 Usage: `.gem gen <topic>`\nExample: `.gem gen passive-aggressive ex`');
        const proc = await sendProcessing(Gifted, from, m, `🔮 _Forging persona: "${topic}"…_`);
        const { text, err } = await askAI(
            `Create a highly detailed System Prompt for an AI to convincingly act as: ${topic}.\n` +
            `Include: personality traits, speaking style, vocabulary, emoji usage, how they react.\n` +
            `Return ONLY the raw system prompt text, no preamble or quotes.`
        );
        if (err) return editMsg(Gifted, proc, `❌ ${text}`);
        const name = raw[1]?.toLowerCase().slice(0,12) + '_gem';
        Gems.save(name, text);
        await editMsg(Gifted, proc,
            `✨ *Gem Generated!*\n\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0,120)}..._\n\n_Use_ \`.gem use ${name}\` _to activate_`);
        return;
    }

    // ── ANALYZE  (clone persona from replied message) ────────────────────────
    if (cmd === 'analyze') {
        const replied = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!replied) return safeReply(Gifted, m, '📝 Reply to someone\'s message, then run `.gem analyze`');
        const txt  = replied.conversation || replied.extendedTextMessage?.text || '[no text]';
        const proc = await sendProcessing(Gifted, from, m, '🕵️ _Analyzing personality…_');
        const { text, err } = await askAI(
            `Analyze this WhatsApp message and create a System Prompt to clone this person's style:\n"${txt}"\n` +
            `Focus on tone, vocabulary, emoji use, sentence structure, attitude.\n` +
            `Return ONLY the system prompt.`
        );
        if (err) return editMsg(Gifted, proc, `❌ ${text}`);
        const name = `mimic_${Date.now().toString(36)}`;
        Gems.save(name, text);
        await editMsg(Gifted, proc,
            `🧬 *Clone Created!*\n\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0,120)}..._\n\n_Activate with_ \`.gem use ${name}\``);
        return;
    }

    // ── LEARN  (deep style extraction) ──────────────────────────────────────
    if (cmd === 'learn') {
        const replied = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!replied) return safeReply(Gifted, m, '📝 Reply to the target\'s message, then run `.gem learn`');
        const sample = replied.conversation || replied.extendedTextMessage?.text || '[no text]';
        const proc   = await sendProcessing(Gifted, from, m, '🧠 _Deep-studying writing style…_');
        const { text, err } = await askAI(
            `Expert linguistic profiler task:\n` +
            `Analyze this writing sample and create a HIGHLY DETAILED system prompt to clone this person:\n\n` +
            `"${sample}"\n\n` +
            `Extract: tone, vocabulary, slang, emoji patterns, sentence length, punctuation habits, emotional style.\n` +
            `Return ONLY the comprehensive system prompt — no headers, no intro.`
        );
        if (err) return editMsg(Gifted, proc, `❌ ${text}`);
        const name = `clone_${Date.now().toString(36)}`;
        Gems.save(name, text);
        await editMsg(Gifted, proc,
            `🧬 *Deep Clone Created!*\n\n*Name:* \`${name}\`\n*Based on:* style-extracted sample\n*Preview:* _${text.slice(0,100)}..._\n\n_Activate with_ \`.gem use ${name}\``);
        return;
    }

    // ── DELETE ───────────────────────────────────────────────────────────────
    if (cmd === 'delete' || cmd === 'del') {
        if (!raw[1]) return safeReply(Gifted, m, '📝 Usage: `.gem delete <name>`');
        Gems.del(raw[1])
            ? safeReply(Gifted, m, `🗑️ Gem *${raw[1]}* deleted.`)
            : safeReply(Gifted, m, `❌ Gem \`${raw[1]}\` not found.`);
        return;
    }

    // ── LIST ─────────────────────────────────────────────────────────────────
    if (cmd === 'list') {
        const list = Gems.list();
        if (!list.length) return safeReply(Gifted, m,
            '📚 No gems yet.\nUse `.gem create <name> <prompt>` or `.gem gen <topic>` to make one.');
        safeReply(Gifted, m,
            `📚 *Gem Collection (${list.length})*\n\n` +
            list.map((g,i) => `${i+1}. 💎 \`${g}\``).join('\n') +
            '\n\n_Use_ `.gem use <name>` _to activate for DM auto-reply_');
        return;
    }

    // ── USE ──────────────────────────────────────────────────────────────────
    if (cmd === 'use') {
        if (!raw[1]) return safeReply(Gifted, m, '📝 Usage: `.gem use <name>`');
        const content = Gems.get(raw[1]);
        if (!content) return safeReply(Gifted, m, `❌ Gem \`${raw[1]}\` not found. Run \`.gem list\` to see all.`);
        State.dmGem = content;
        safeReply(Gifted, m, `✅ *DM Persona Set*\n\nGem: *${raw[1]}*\nActive for DM auto-replies.\n_Enable with_ \`.gai dm on\``);
        return;
    }

    // ── VIEW ─────────────────────────────────────────────────────────────────
    if (cmd === 'view') {
        if (!raw[1]) return safeReply(Gifted, m, '📝 Usage: `.gem view <name>`');
        const content = Gems.get(raw[1]);
        if (!content) return safeReply(Gifted, m, `❌ Gem \`${raw[1]}\` not found.`);
        safeReply(Gifted, m, `💎 *${raw[1].toUpperCase()}*\n\n${content}`);
        return;
    }

    // ── REMIX  (AI-tweak existing gem) ───────────────────────────────────────
    if (cmd === 'remix') {
        if (!raw[1] || !raw[2]) return safeReply(Gifted, m, '📝 Usage: `.gem remix <name> <tweak instruction>`');
        const base = Gems.get(raw[1]);
        if (!base) return safeReply(Gifted, m, `❌ Gem \`${raw[1]}\` not found.`);
        const instruction = raw.slice(2).join(' ');
        const proc = await sendProcessing(Gifted, from, m, `🔀 _Remixing gem "${raw[1]}"…_`);
        const { text, err } = await askAI(
            `Take this system prompt and modify it according to the instruction.\n` +
            `Return ONLY the modified system prompt, no explanation.\n\n` +
            `Original:\n${base}\n\n` +
            `Modification: ${instruction}`
        );
        if (err) return editMsg(Gifted, proc, `❌ ${text}`);
        const newName = `${raw[1]}_remix`;
        Gems.save(newName, text);
        await editMsg(Gifted, proc,
            `🔀 *Gem Remixed!*\n\nOriginal: \`${raw[1]}\`\nNew: \`${newName}\`\n*Tweak applied:* _${instruction}_`);
        return;
    }

    // ── HELP ─────────────────────────────────────────────────────────────────
    safeReply(Gifted, m,
        `💎 *GEM SYSTEM — Persona Manager*\n\n` +
        `*Create / Edit:*\n` +
        `• \`.gem create <name> <prompt>\` — Save custom persona\n` +
        `• \`.gem gen <topic>\` — AI auto-generates persona\n` +
        `• \`.gem analyze\` — Clone style from replied msg\n` +
        `• \`.gem learn\` — Deep style extraction\n` +
        `• \`.gem remix <name> <tweak>\` — Modify existing gem\n\n` +
        `*Manage:*\n` +
        `• \`.gem list\` — Show all gems\n` +
        `• \`.gem view <name>\` — Read gem content\n` +
        `• \`.gem delete <name>\` — Remove gem\n` +
        `• \`.gem use <name>\` — Set active DM persona\n\n` +
        `💡 _Combine with_ \`.gai dm on\` _for auto-replies_`);
});

// ==============================================================================
// 13. GAI — AI CONTROL  .gai
// ==============================================================================
commandRegister({
    pattern : 'gai',
    cmdname : 'gai',
    alias   : ['ai', 'ask', 'brain', 'gask'],
    type    : 'ai',
    category: 'ai',
    desc    : 'AI assistant & auto-reply control. .gai help for all modes.',
    react   : '🧠',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only command.');

    const q    = (conText.q || arg1.q || '').trim();
    const raw  = q.split(/\s+/);
    const cmd  = raw[0]?.toLowerCase() || '';
    const from = jid(m);

    // ── DM AUTO-PILOT ────────────────────────────────────────────────────────
    if (cmd === 'dm') {
        const sub = raw[1]?.toLowerCase();
        if (sub === 'on')  { State.dmActive = true;  return safeReply(Gifted, m, `📨 *DM Auto-Pilot:* ✅ ON\nGem: ${State.dmGem ? 'Custom' : 'Default'}`); }
        if (sub === 'off') { State.dmActive = false; return safeReply(Gifted, m, '📨 *DM Auto-Pilot:* ❌ OFF'); }
        safeReply(Gifted, m, `📨 *DM Auto-Pilot:* ${State.dmActive ? '✅ ON' : '❌ OFF'}\n_Use_ \`.gai dm on/off\` _to toggle_`);
        return;
    }

    // ── TARGET WHOLE CHAT ─────────────────────────────────────────────────────
    if (cmd === 'chat') {
        const gemName = raw[1] || 'default';
        const gemText = (gemName !== 'default' ? Gems.get(gemName) : null) || State.DEFAULT_PERSONA;
        State.activeChats.set(from, { gem: gemText, history: [], gemName });
        safeReply(Gifted, m, `⚔️ *Chat AI Active*\n\nGem: *${gemName}*\nReplying to everyone here now.`);
        return;
    }

    // ── TARGET SPECIFIC USER  ─────────────────────────────────────────────────
    if (cmd === 'bot' || cmd === 'target') {
        if (!raw[1]) return safeReply(Gifted, m, '📝 Usage: `.gai target <number> [gem]`');
        const targetJid = raw[1].replace(/[^0-9]/g,'') + '@s.whatsapp.net';
        const gemName   = raw[2] || 'default';
        const gemText   = (gemName !== 'default' ? Gems.get(gemName) : null) || State.DEFAULT_PERSONA;
        State.activeTargets.set(targetJid, { gem: gemText, history: [], chatId: from, gemName });
        safeReply(Gifted, m, `🤖 *Target Locked*\n\nUser: @${raw[1].replace(/[^0-9]/g,'')}\nGem: *${gemName}*\nActive in this chat.`);
        return;
    }

    // ── GLOBAL STALKER ────────────────────────────────────────────────────────
    if (cmd === 'stalk') {
        if (!raw[1]) return safeReply(Gifted, m, '📝 Usage: `.gai stalk <number> [gem]`');
        const targetJid = raw[1].replace(/[^0-9]/g,'') + '@s.whatsapp.net';
        const gemName   = raw[2] || 'default';
        const gemText   = (gemName !== 'default' ? Gems.get(gemName) : null) || State.DEFAULT_PERSONA;
        State.globalStalkers.set(targetJid, { gem: gemText, history: [], gemName });
        safeReply(Gifted, m, `🌍 *Global Stalker Active*\n\nTarget: @${raw[1].replace(/[^0-9]/g,'')}\nGem: *${gemName}*\nI'll reply to them everywhere.`);
        return;
    }

    // ── STOP ─────────────────────────────────────────────────────────────────
    if (cmd === 'stop') {
        if (raw[1]?.toLowerCase() === 'all') {
            State.dmActive = false;
            State.activeChats.clear();
            State.activeTargets.clear();
            State.globalStalkers.clear();
            safeReply(Gifted, m,
                '☢️ *ALL AI SYSTEMS SHUT DOWN*\n\n• DM Mode: OFF\n• Active Chats: 0\n• Targets: 0\n• Stalkers: 0');
        } else {
            const had = State.activeChats.has(from);
            State.activeChats.delete(from);
            safeReply(Gifted, m, `🛑 AI stopped in this chat.\n${had ? 'Session cleared.' : 'No session was active here.'}\n\n_Stop everything:_ \`.gai stop all\``);
        }
        return;
    }

    // ── WIPE HISTORY ─────────────────────────────────────────────────────────
    if (cmd === 'wipe') {
        if (State.activeChats.has(from)) {
            State.activeChats.get(from).history = [];
            safeReply(Gifted, m, '🧠 _Memory wiped — fresh start!_');
        } else {
            safeReply(Gifted, m, 'ℹ️ No active AI session in this chat.');
        }
        return;
    }

    // ── STATUS ───────────────────────────────────────────────────────────────
    if (cmd === 'status') {
        const s   = Monitor.stats();
        const cbS = Circuit.isOpen()
            ? `🔴 TRIPPED (${Circuit.fails}/${Circuit.threshold})`
            : `🟢 OK (${Circuit.fails}/${Circuit.threshold})`;
        let msg =
            `📊 *AI SYSTEM STATUS*\n` +
            `━━━━━━━━━━━━━━━━━━━━\n` +
            `📨 DM Mode: ${State.dmActive ? '✅ ON' : '❌ OFF'}\n` +
            `⚔️ Active Chats: ${State.activeChats.size}\n` +
            `🤖 Local Targets: ${State.activeTargets.size}\n` +
            `🌍 Global Stalkers: ${State.globalStalkers.size}\n\n` +
            `📈 *API Load:*\n` +
            `• Requests/min: ${s.rpm}/${Config.MAX_RPM}\n` +
            `• Requests/hr: ${s.rph}/${Config.MAX_RPH}\n` +
            `• Daily AI: ${s.ai} | Imgs: ${s.img} | Errors: ${s.err}\n` +
            `🔌 Circuit: ${cbS}\n`;
        if (State.activeChats.size) {
            msg += `\n*Active Sessions:*\n`;
            State.activeChats.forEach((d, cid) => {
                msg += `• ${cid.split('@')[0]}: ${d.history.length} msgs (${d.gemName})\n`;
            });
        }
        safeReply(Gifted, m, msg);
        return;
    }

    // ── SUMMARY ───────────────────────────────────────────────────────────────
    if (cmd === 'summary') {
        const sess = State.activeChats.get(from);
        if (!sess?.history?.length) return safeReply(Gifted, m,
            'ℹ️ No history here.\nStart a session with `.gai chat` first.');
        const proc = await sendProcessing(Gifted, from, m, '📝 _Summarizing conversation…_');
        const { text, err } = await askAI(
            `Summarize this WhatsApp conversation in clear bullet points.\n` +
            `Highlight key topics, decisions, jokes, and any drama.\n\n` +
            sess.history.join('\n')
        );
        await editMsg(Gifted, proc, err ? `❌ ${text}` : `📝 *Chat Summary*\n\n${text}`);
        return;
    }

    // ── HELP ──────────────────────────────────────────────────────────────────
    if (cmd === 'help') {
        safeReply(Gifted, m,
            `🧠 *GAI — AI CONTROL*\n\n` +
            `*🔍 Quick Ask:*\n` +
            `• \`.gai <question>\` — One-shot answer\n\n` +
            `*🤖 Auto-Reply Modes:*\n` +
            `• \`.gai dm on/off\` — DM auto-pilot\n` +
            `• \`.gai chat [gem]\` — Reply to whole chat\n` +
            `• \`.gai target <num> [gem]\` — Lock specific user\n` +
            `• \`.gai stalk <num> [gem]\` — Global stalker\n\n` +
            `*🛠️ Control:*\n` +
            `• \`.gai stop\` — Stop current chat\n` +
            `• \`.gai stop all\` — Kill everything\n` +
            `• \`.gai wipe\` — Clear chat memory\n` +
            `• \`.gai summary\` — Summarize chat\n` +
            `• \`.gai status\` — System overview`);
        return;
    }

    // ── ONE-SHOT QUICK ASK ────────────────────────────────────────────────────
    if (!q) return safeReply(Gifted, m, '📝 Usage: `.gai <question>`\n_Or_ `.gai help` _for all modes._');

    let imageUrls = [];
    const replied = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;

    // Handle vision — quoted image
    if (replied?.imageMessage) {
        const proc2 = await sendProcessing(Gifted, from, m, '👁️ _Analysing image…_');
        try {
            const tmpPath = await Gifted.downloadAndSaveMediaMessage(replied.imageMessage, `tmp_gai_${Date.now()}`);
            if (tmpPath) {
                const url = await uploadImgBB(tmpPath);
                if (url) imageUrls.push(url);
                try { fs.unlinkSync(tmpPath); } catch(e){}
            }
        } catch(e) { console.error('[AIGems] Vision download:', e.message); }
        await tryDelete(Gifted, proc2.key);
    }

    const proc = await sendProcessing(Gifted, from, m, '🧠 _Thinking…_');

    let finalPrompt = q;
    const ctx = replied?.conversation || replied?.extendedTextMessage?.text;
    if (ctx) finalPrompt = `Context: "${ctx}"\n\nQuestion: ${q}`;

    const { text, err } = await askAI(finalPrompt, imageUrls);
    await editMsg(Gifted, proc, err ? `❌ ${text}` : text);
});

// ==============================================================================
// 14. IMAGE GENERATION  .img
// ==============================================================================
commandRegister({
    pattern : 'img',
    cmdname : 'img',
    alias   : ['imagine', 'genimg', 'dalle', 'drawai'],
    type    : 'ai',
    category: 'ai',
    desc    : 'AI image generation with Infip. .img help for all sub-commands.',
    react   : '🎨',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only command.');

    const q    = (conText.q || arg1.q || '').trim();
    const raw  = q.split(/\s+/);
    const cmd  = raw[0]?.toLowerCase() || 'help';
    const from = jid(m);

    const knownCmds = ['gen','surprise','chaos','models','config','enhance','setup','random','cache','help'];

    // ── GENERATE ──────────────────────────────────────────────────────────────
    if (cmd === 'gen' || (!knownCmds.includes(cmd) && q)) {
        const prompt = cmd === 'gen' ? raw.slice(1).join(' ') : q;
        if (!prompt.trim()) return safeReply(Gifted, m,
            '📝 Usage: `.img gen <prompt>`\nExample: `.img gen a samurai cat in neon rain`');

        const proc = await sendProcessing(Gifted, from, m, `🎨 _Generating: "${prompt.slice(0,50)}…"_`);
        const urls = await generateImage(prompt);

        if (!urls.length) return editMsg(Gifted, proc, '❌ Generation failed. Try `.img setup` or change model.');

        await tryDelete(Gifted, proc.key);
        await sendImage(Gifted, from, urls[0],
            `🎨 *AI Generated*\n\n📝 *Prompt:* ${prompt}\n🤖 *Model:* ${Config.IMG_MODEL}`, m);
        for (const u of urls.slice(1)) await sendImage(Gifted, from, u, '🎨 _Variation_', m);
        return;
    }

    // ── SURPRISE ──────────────────────────────────────────────────────────────
    if (cmd === 'surprise') {
        const topic = raw.slice(1).join(' ');
        const hint  = topic ? ` themed around "${topic}"` : '';
        const proc  = await sendProcessing(Gifted, from, m, `🎲 _Dreaming up something${hint}…_`);

        const { text: dreamt, err } = await askAI(
            `Generate a highly detailed, creative image generation prompt${hint}.\n` +
            `Include visual details, lighting, atmosphere, and artistic style.\n` +
            `Return ONLY the prompt text.`
        );
        if (err) return editMsg(Gifted, proc, `❌ ${dreamt}`);

        await editMsg(Gifted, proc, `🎨 _Visualizing:_ "${dreamt.slice(0,80)}…"`);
        const urls = await generateImage(dreamt);
        if (!urls.length) return editMsg(Gifted, proc, '❌ Failed to generate. Try again.');

        await tryDelete(Gifted, proc.key);
        await sendImage(Gifted, from, urls[0], `🎲 *Surprise!*\n\n💭 _${dreamt.slice(0,200)}_`, m);
        return;
    }

    // ── CHAOS ─────────────────────────────────────────────────────────────────
    if (cmd === 'chaos') {
        const freeModels = Object.keys(Config.IMG_MODELS).filter(k => Config.IMG_MODELS[k].tier === 'free');
        Config.IMG_MODEL   = freeModels[Math.floor(Math.random() * freeModels.length)];
        Config.IMG_SIZE    = ['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        Config.IMG_QUALITY = Math.random() > 0.5 ? 'hd' : 'standard';
        Config.IMG_STYLE   = Math.random() > 0.5 ? 'vivid' : 'natural';

        const proc = await sendProcessing(Gifted, from, m,
            `🌪️ *CHAOS MODE*\n_Model: ${Config.IMG_MODEL} | ${Config.IMG_SIZE}_\n_Conjuring madness…_`);

        const chaosQueries = [
            'Generate a bizarre surreal art prompt that defies logic. Return ONLY the prompt.',
            'Create an absurd image description with impossible physics. Return ONLY the prompt.',
            'Describe a completely nonsensical scene breaking all natural laws. Return ONLY the prompt.',
            'Make a prompt for the most chaotic, impossible image imaginable. Return ONLY the prompt.'
        ];
        const { text: chaosPrompt, err } = await askAI(
            chaosQueries[Math.floor(Math.random()*chaosQueries.length)]);
        const fp = err ? 'Abstract chaos, melting clocks in a cybernetic forest, neon rain, 8k' : chaosPrompt;

        const urls = await generateImage(fp);
        if (!urls.length) return editMsg(Gifted, proc, '❌ Chaos could not be manifested. Retry.');

        await tryDelete(Gifted, proc.key);
        await sendImage(Gifted, from, urls[0],
            `🌪️ *CHAOS GENERATION*\n\n💭 ${fp.slice(0,200)}\n\n⚙️ ${Config.IMG_MODEL} | ${Config.IMG_SIZE}`, m);
        return;
    }

    // ── MODELS ────────────────────────────────────────────────────────────────
    if (cmd === 'models') {
        const list = Object.entries(Config.IMG_MODELS)
            .map(([id,info]) => `${info.tier==='pro'?'👑':'🆓'} \`${id}\` — ${info.desc}`)
            .join('\n');
        safeReply(Gifted, m,
            `📋 *Available Models*\n\n${list}\n\n👑 Pro | 🆓 Free\n\n` +
            `*Current:* \`${Config.IMG_MODEL}\`\n_Use_ \`.img config <model>\` _to change_`);
        return;
    }

    // ── CONFIG ────────────────────────────────────────────────────────────────
    if (cmd === 'config') {
        if (!raw[1]) return safeReply(Gifted, m,
            `⚙️ *Image Config*\n\n• Model: \`${Config.IMG_MODEL}\`\n• Size: \`${Config.IMG_SIZE}\`\n` +
            `• Count: \`${Config.IMG_COUNT}\`\n• Quality: \`${Config.IMG_QUALITY}\`\n• Style: \`${Config.IMG_STYLE}\`\n\n` +
            `📝 \`.img config <model> [size] [count] [quality] [style]\``);
        const [model, size, count, quality, style] = raw.slice(1);
        if (model && !Config.IMG_MODELS[model]) return safeReply(Gifted, m,
            `❌ Model \`${model}\` not found.\nRun \`.img models\` to see all.`);
        if (model)   Config.IMG_MODEL   = model;
        if (size)    Config.IMG_SIZE    = size;
        if (count)   Config.IMG_COUNT   = Math.min(parseInt(count)||1, 4);
        if (quality) Config.IMG_QUALITY = quality;
        if (style)   Config.IMG_STYLE   = style;
        safeReply(Gifted, m,
            `✅ *Config Updated*\n\n• Model: \`${Config.IMG_MODEL}\`\n• Size: \`${Config.IMG_SIZE}\`\n` +
            `• Count: \`${Config.IMG_COUNT}\`\n• Quality: \`${Config.IMG_QUALITY}\`\n• Style: \`${Config.IMG_STYLE}\``);
        return;
    }

    // ── ENHANCE PROMPT ────────────────────────────────────────────────────────
    if (cmd === 'enhance') {
        const p = raw.slice(1).join(' ');
        if (!p) return safeReply(Gifted, m, '📝 Usage: `.img enhance <prompt>`');
        const proc = await sendProcessing(Gifted, from, m, '🧠 _Enhancing prompt…_');
        const { text, err } = await askAI(
            `Enhance this image generation prompt — make it more detailed and visually rich.\n` +
            `Keep original intent. Return ONLY the enhanced prompt.\n\nOriginal: ${p}`
        );
        await editMsg(Gifted, proc, err ? `❌ ${text}` :
            `✨ *Prompt Enhanced*\n\n*Original:*\n${p}\n\n*Enhanced:*\n${text}\n\n_Use_ \`.img gen\` _with the enhanced prompt_`);
        return;
    }

    // ── RANDOM SETTINGS ───────────────────────────────────────────────────────
    if (cmd === 'random') {
        const freeModels = Object.keys(Config.IMG_MODELS).filter(k => Config.IMG_MODELS[k].tier==='free');
        Config.IMG_MODEL   = freeModels[Math.floor(Math.random()*freeModels.length)];
        Config.IMG_SIZE    = ['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        Config.IMG_QUALITY = Math.random()>0.5?'hd':'standard';
        Config.IMG_STYLE   = Math.random()>0.5?'vivid':'natural';
        safeReply(Gifted, m,
            `🎲 *Settings Randomized!*\n\n• Model: \`${Config.IMG_MODEL}\`\n• Size: \`${Config.IMG_SIZE}\`\n` +
            `• Quality: \`${Config.IMG_QUALITY}\`\n• Style: \`${Config.IMG_STYLE}\``);
        return;
    }

    // ── SETUP ─────────────────────────────────────────────────────────────────
    if (cmd === 'setup') {
        const proc = await sendProcessing(Gifted, from, m, '🔧 _Validating Infip API…_');
        infipValidated = false;
        const ok = await validateInfip();
        await editMsg(Gifted, proc, ok
            ? `✅ *Image API Ready!*\n\nKey: \`${activeInfipKey.slice(0,20)}…\`\n_Use_ \`.img gen <prompt>\` _to generate_`
            : `❌ *Setup Failed*\n\nCould not validate any API key.\nCheck internet connection.`);
        return;
    }

    // ── CACHE CLEAR ───────────────────────────────────────────────────────────
    if (cmd === 'cache') {
        imgCache.clear();
        safeReply(Gifted, m, '🗑️ Image cache cleared.');
        return;
    }

    // ── HELP ──────────────────────────────────────────────────────────────────
    safeReply(Gifted, m,
        `🎨 *IMAGE GENERATION*\n\n` +
        `• \`.img gen <prompt>\` — Generate image\n` +
        `• \`.img surprise [topic]\` — AI dreams up a pic\n` +
        `• \`.img chaos\` — Random model + random prompt\n` +
        `• \`.img enhance <prompt>\` — AI-improve your prompt\n` +
        `• \`.img models\` — List all available models\n` +
        `• \`.img config [model] [size] [n] [quality] [style]\` — Settings\n` +
        `• \`.img random\` — Randomize current settings\n` +
        `• \`.img setup\` — Re-validate API key\n` +
        `• \`.img cache\` — Clear generation cache\n\n` +
        `*Current:* \`${Config.IMG_MODEL}\` @ \`${Config.IMG_SIZE}\``);
});

// ==============================================================================
// 15. API MONITOR  .apimon
// ==============================================================================
commandRegister({
    pattern : 'apimon',
    cmdname : 'apimon',
    alias   : ['apistat','apistatus','aihealth'],
    type    : 'ai',
    category: 'ai',
    desc    : 'Monitor AI API usage, health, and circuit breaker.',
    react   : '📊',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only.');

    const q   = (conText.q || arg1.q || '').trim();
    const raw = q.split(/\s+/);
    const cmd = raw[0]?.toLowerCase() || 'status';

    if (cmd === 'status' || !q) {
        const s  = Monitor.stats();
        const cb = Circuit.isOpen() ? '🔴 TRIPPED' : `🟢 OK (${Circuit.fails}/${Circuit.threshold})`;
        const bar = (v,max,len=10) => '█'.repeat(Math.min(len, Math.round(v/max*len))) + '░'.repeat(Math.max(0, len - Math.round(v/max*len)));
        safeReply(Gifted, m,
            `📊 *API Status*\n━━━━━━━━━━━━━━━━━━━━\n` +
            `*Load:*\n• 1m: \`${bar(s.rpm,Config.MAX_RPM)}\` ${s.rpm}/${Config.MAX_RPM}\n` +
            `• 1h: \`${bar(s.rph,Config.MAX_RPH)}\` ${s.rph}/${Config.MAX_RPH}\n\n` +
            `*Today:*\n• AI: ${s.ai} | Images: ${s.img} | Errors: ${s.err}\n\n` +
            `*Circuit Breaker:* ${cb}\n` +
            `*Timeout:* ${Config.API_TIMEOUT/1000}s | *Retries:* ${Config.MAX_RETRIES}`);
        return;
    }

    if (cmd === 'health') {
        const proc = await sendProcessing(Gifted, jid(m), m, '🔍 _Running health check…_');
        const lines = [];
        const { text: tr, err: te } = await askAI('Reply with exactly: HEALTH_OK');
        lines.push((!te && tr.includes('HEALTH_OK')) ? '✅ QuillBot AI: Healthy' : `⚠️ QuillBot AI: ${tr.slice(0,50)}`);
        lines.push(Circuit.isOpen() ? '🔴 Circuit Breaker: TRIPPED' : '✅ Circuit Breaker: Closed');
        lines.push(Monitor.allow() ? '✅ Rate Limit: Clear' : '⚠️ Rate Limit: Active');
        lines.push(infipValidated  ? `✅ Infip API: Key validated` : `⚠️ Infip API: Not yet validated`);
        try { dbGet('SELECT 1'); lines.push('✅ Database: Connected'); } catch(e) { lines.push('❌ Database: Error'); }
        await editMsg(Gifted, proc, `🔍 *Health Check*\n\n${lines.join('\n')}`);
        return;
    }

    if (cmd === 'reset') {
        const type = raw[1]?.toLowerCase();
        if (type === 'circuit') { Circuit.reset(); safeReply(Gifted, m, '✅ Circuit breaker reset.'); }
        else if (type === 'daily') {
            Monitor.daily = { ai:0, img:0, err:0, day: new Date().toDateString() };
            safeReply(Gifted, m, '✅ Daily stats reset.');
        } else safeReply(Gifted, m, '📝 Usage: `.apimon reset <circuit|daily>`');
        return;
    }

    safeReply(Gifted, m,
        `📊 *API Monitor*\n\n` +
        `• \`.apimon status\` — Usage stats & load\n` +
        `• \`.apimon health\` — Full health check\n` +
        `• \`.apimon reset <circuit|daily>\` — Reset counters`);
});

// ==============================================================================
// 16. AUTO-ENHANCE TOGGLE  .autoenhance
// ==============================================================================
commandRegister({
    pattern : 'autoenhance',
    cmdname : 'autoenhance',
    alias   : ['smartedit','autoedit','aienhance'],
    type    : 'ai',
    category: 'ai',
    desc    : 'Toggle AI auto-correction of your own messages.',
    react   : '✍️',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only.');

    const action = (conText.q || arg1.q || '').trim().toLowerCase();
    if (action === 'on')  { State.autoEnhance = true;  return safeReply(Gifted, m, '✍️ *Auto-Enhance: ON*\n\nYour messages will be silently improved by AI.'); }
    if (action === 'off') { State.autoEnhance = false; return safeReply(Gifted, m, '✍️ *Auto-Enhance: OFF*'); }
    safeReply(Gifted, m,
        `✍️ *Auto-Enhance*\n\n*Status:* ${State.autoEnhance ? '✅ ON' : '❌ OFF'}\n\n` +
        `*What it does:*\n• Fixes spelling & grammar\n• Improves clarity\n• Preserves your tone & language\n• Silently edits messages after you send them\n\n` +
        `*Usage:* \`.autoenhance on/off\``);
});

// ==============================================================================
// 17. AI TRANSLATE  .aitranslate
// ==============================================================================
commandRegister({
    pattern : 'aitranslate',
    cmdname : 'aitranslate',
    alias   : ['gitrans','aitrans','trns'],
    type    : 'ai',
    category: 'ai',
    desc    : 'AI-powered translation. Usage: .aitranslate <language> <text>',
    react   : '🌐',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only.');

    const q    = (conText.q || arg1.q || '').trim();
    const from = jid(m);
    const parts = q.split(/\s+/);
    const lang  = parts[0];
    const text  = parts.slice(1).join(' ');

    if (!lang || !text) return safeReply(Gifted, m,
        `📝 Usage: \`.aitranslate <language> <text>\`\n\nExamples:\n• \`.aitranslate Spanish Hello world\`\n• \`.aitranslate Japanese Good morning\``);

    const proc = await sendProcessing(Gifted, from, m, `🌐 _Translating to ${lang}…_`);
    const { text: result, err } = await askAI(
        `Translate the following text to ${lang}.\nReturn ONLY the translated text.\n\nText: ${text}`);
    await editMsg(Gifted, proc, err ? `❌ ${result}` :
        `🌐 *Translation*\n\n📝 *Original:* ${text}\n\n🔄 *${lang}:* ${result}`);
});

// ==============================================================================
// 18. AI WRITER  .aiwrite
// ==============================================================================
commandRegister({
    pattern : 'aiwrite',
    cmdname : 'aiwrite',
    alias   : ['giwrite','compose','aipen','draft'],
    type    : 'ai',
    category: 'ai',
    desc    : 'AI creative writing (messages, essays, roasts, captions, etc.)',
    react   : '✍️',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only.');

    const q    = (conText.q || arg1.q || '').trim();
    const from = jid(m);
    const raw  = q.split(/\s+/);
    const type = raw[0]?.toLowerCase() || '';

    const valid = ['message','essay','story','caption','bio','code','email','reply','roast','flirt','apology','tweet','speech'];

    if (!valid.includes(type)) return safeReply(Gifted, m,
        `✍️ *AI Writer*\n\n*Types:*\n${valid.map(t=>`\`${t}\``).join(' | ')}\n\n` +
        `*Usage:* \`.aiwrite <type> <topic>\`\n\n` +
        `*Examples:*\n• \`.aiwrite roast my friend who's always late\`\n• \`.aiwrite caption sunset over mountains\`\n• \`.aiwrite message ask boss for day off\``);

    const topic = raw.slice(1).join(' ');
    if (!topic) return safeReply(Gifted, m, `📝 Provide a topic. Example: \`.aiwrite ${type} <topic>\``);

    const proc = await sendProcessing(Gifted, from, m, `✍️ _Writing ${type}…_`);

    const prompts = {
        message  : `Write a natural WhatsApp message about: ${topic}. Concise and real.`,
        essay    : `Write a structured essay about: ${topic}. Include intro, 3 body paragraphs, conclusion.`,
        story    : `Write a short engaging story about: ${topic}. Make it gripping.`,
        caption  : `Write 3 creative social media captions for: ${topic}. Include relevant emojis.`,
        bio      : `Write a punchy, memorable bio for: ${topic}. Keep it under 150 chars.`,
        code     : `Write clean, well-commented code for: ${topic}. Include brief explanation.`,
        email    : `Write a professional email about: ${topic}. Include subject line. Format clearly.`,
        reply    : `Write a witty, clever reply to: ${topic}. Make it memorable.`,
        roast    : `Write a playful, funny roast about: ${topic}. Friendly tone, not mean.`,
        flirt    : `Write a charming, tasteful flirty message to/about: ${topic}. Keep it classy.`,
        apology  : `Write a genuine, sincere apology about: ${topic}. Avoid being cringe.`,
        tweet    : `Write 3 tweet options about: ${topic}. Each under 280 chars. Include hashtags.`,
        speech   : `Write a short speech about: ${topic}. Engaging opening, 3 main points, strong close.`
    };

    const { text, err } = await askAI(prompts[type]);
    await editMsg(Gifted, proc, err ? `❌ ${text}` :
        `✍️ *${type.charAt(0).toUpperCase()+type.slice(1)}*\n\n${text}`);
});

// ==============================================================================
// 19. AI DECODE  .aidecode  (bonus: explain/analyze any text or image)
// ==============================================================================
commandRegister({
    pattern : 'aidecode',
    cmdname : 'aidecode',
    alias   : ['gianalyze','gidecode','aianalyze','explain'],
    type    : 'ai',
    category: 'ai',
    desc    : 'Explain, analyze, or decode any text/image with AI.',
    react   : '🔍',
    filename: __filename
}, async (arg1, ...args) => {
    const { m, sock: Gifted } = resolveCtx(arg1, args);
    const conText = arg1?.isSuperUser !== undefined ? arg1 : args.find(a => a?.isSuperUser !== undefined) || {};
    if (!conText.isSuperUser && !arg1.isSuperUser) return safeReply(Gifted, m, '❌ Owner only.');

    const q     = (conText.q || arg1.q || '').trim();
    const from  = jid(m);
    const replied = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;

    if (!q && !replied) return safeReply(Gifted, m,
        '📝 Reply to any message/image with `.aidecode [optional question]` to analyze it.');

    let imageUrls = [];
    let inputText = q;

    if (replied?.imageMessage) {
        const proc2 = await sendProcessing(Gifted, from, m, '👁️ _Downloading image…_');
        try {
            const tp = await Gifted.downloadAndSaveMediaMessage(replied.imageMessage, `tmp_decode_${Date.now()}`);
            if (tp) { const url = await uploadImgBB(tp); if (url) imageUrls.push(url); try{fs.unlinkSync(tp);}catch(e){} }
        } catch(e){}
        await tryDelete(Gifted, proc2.key);
    }

    const ctx = replied?.conversation || replied?.extendedTextMessage?.text;
    if (ctx) inputText = q ? `${ctx}\n\nFocus on: ${q}` : ctx;

    const proc = await sendProcessing(Gifted, from, m, '🔍 _Analysing…_');
    const prompt = imageUrls.length
        ? `Analyze this image in detail. ${q || 'What do you see? What is the context?'}`
        : `Explain and analyze the following:\n\n"${inputText}"\n\nBe thorough but clear.`;

    const { text, err } = await askAI(prompt, imageUrls);
    await editMsg(Gifted, proc, err ? `❌ ${text}` : `🔍 *Analysis*\n\n${text}`);
});

// ==============================================================================
// 20. CORE UTILITIES (private helpers)
// ==============================================================================

/** Deep resolve socket + message regardless of how framework passes args */
const resolveCtx = (arg1, args) => {
    let sock = global.conn || global.client || arg1.bot || arg1.client;
    let m    = arg1;
    for (const arg of [arg1, ...args]) {
        if (arg && typeof arg === 'object' && !Array.isArray(arg)) {
            if (typeof arg.sendMessage === 'function')                          sock = arg;
            else if (arg.sock  && typeof arg.sock.sendMessage  === 'function') sock = arg.sock;
            else if (arg.bot   && typeof arg.bot.sendMessage   === 'function') sock = arg.bot;
            if (arg.chat || arg.from || arg.jid || arg.key?.remoteJid)         m    = arg;
        }
    }
    return { m, sock };
};

/** Safe reply that tries native reply then quoted sendMessage as fallback */
const safeReply = async (Gifted, m, text) => {
    const chatId = jid(m);
    if (!chatId) return;
    try {
        if (typeof m.reply === 'function') return m.reply(text);
        const quoted = buildSafeQuoted(m);
        if (Gifted?.sendMessage) return Gifted.sendMessage(chatId, { text }, quoted);
    } catch(e) {
        try { Gifted?.sendMessage(chatId, { text }); } catch(e2){}
    }
};

const buildSafeQuoted = (m) => {
    if (!m?.key?.remoteJid || !m?.key?.id) return {};
    const k = { remoteJid: String(m.key.remoteJid), fromMe: !!m.key.fromMe, id: String(m.key.id) };
    if (m.key.participant) k.participant = String(m.key.participant);
    return { quoted: { key: k, message: m.message || {} } };
};

} else {
    console.error('❌ [AIGems] CRITICAL: Could not map command registration function.');
}

// ==============================================================================
// 21. EVENT-DRIVEN WATCHERS
//     Registered via global.conn so they fire independently of commands.
//     Retry every 10 s until Gifted socket is available.
// ==============================================================================

let _watcherRegistered = false;

const registerWatchers = (Gifted) => {
    if (!Gifted || _watcherRegistered) return;
    _watcherRegistered = true;

    // ── AUTO-REPLY WATCHER ────────────────────────────────────────────────────
    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type === 'notify') return; // skip historical

        for (const msg of messages) {
            if (!msg.message) continue;
            const fromMe   = msg.key.fromMe;
            const chatId   = msg.key.remoteJid || '';
            const senderId = msg.key.participant || msg.key.remoteJid || '';
            const isGroup  = chatId.endsWith('@g.us');
            const body     =
                msg.message.conversation ||
                msg.message.extendedTextMessage?.text ||
                msg.message.imageMessage?.caption ||
                '';

            // ── AUTO-ENHANCE (owner's own outgoing messages) ─────────────────
            if (fromMe && State.autoEnhance && body && body.length > 10 && !body.startsWith('.')) {
                setImmediate(async () => {
                    try {
                        await sleep(600 + Math.random() * 800);
                        const { text: enhanced, err } = await askAI(
                            `Enhance this message: fix spelling/grammar, improve clarity, preserve tone and language.\n` +
                            `Do NOT change the language. Return ONLY the enhanced text.\n\nOriginal: ${body}`
                        );
                        if (!err && enhanced.trim() && enhanced.trim() !== body.trim()) {
                            await Gifted.sendMessage(chatId, { text: enhanced.trim(), edit: msg.key })
                                .catch(() => {}); // silent fail
                        }
                    } catch(e) {}
                });
                continue;
            }

            if (fromMe) continue; // skip bot's own messages below

            // Skip command messages
            if (body.startsWith('.') || body.startsWith('/') || body.startsWith('!')) continue;
            if (!body.trim() && !msg.message.imageMessage) continue;

            // ── DETERMINE ACTIVE MODE ────────────────────────────────────────
            let activeData = null;

            // Priority 1: global stalker
            if (State.globalStalkers.has(senderId)) {
                activeData = State.globalStalkers.get(senderId);
            }
            // Priority 2: local target (chat-specific)
            else if (State.activeTargets.has(senderId)) {
                const td = State.activeTargets.get(senderId);
                if (!td.chatId || td.chatId === chatId) activeData = td;
            }
            // Priority 3: whole-chat mode
            else if (State.activeChats.has(chatId)) {
                if (isGroup && msg.key.participant === chatId) continue; // skip system msgs
                activeData = State.activeChats.get(chatId);
            }
            // Priority 4: DM auto-pilot
            else if (!isGroup && State.dmActive) {
                // Create a temporary session per sender
                if (!State._dmSessions) State._dmSessions = new Map();
                if (!State._dmSessions.has(senderId))
                    State._dmSessions.set(senderId, { gem: State.dmGem || State.DEFAULT_PERSONA, history: [] });
                activeData = State._dmSessions.get(senderId);
            }

            if (!activeData) continue;

            setImmediate(async () => {
                try {
                    let imageUrls = [];
                    let inputText = body || '[image]';

                    // Download + upload inline image for vision
                    if (msg.message.imageMessage) {
                        try {
                            const tp = await Gifted.downloadAndSaveMediaMessage(
                                msg.message.imageMessage, `tmp_watch_${Date.now()}`);
                            if (tp) {
                                const url = await uploadImgBB(tp);
                                if (url) imageUrls.push(url);
                                try { fs.unlinkSync(tp); } catch(e){}
                            }
                        } catch(e) {}
                    }

                    // Add user message to history
                    State.addHistory(activeData, 'User', inputText);

                    // Build full prompt
                    const fullPrompt = State.buildPrompt(activeData.gem, activeData.history, inputText);

                    // Human-like delay: simulate reading time
                    const readDelay = Math.min(inputText.length * 40, 3500) + Math.random() * 800;
                    await sleep(readDelay);

                    // Show typing indicator
                    try { await Gifted.sendPresenceUpdate('composing', chatId); } catch(e){}

                    const { text: response, err } = await getAIResponse_watcher(fullPrompt, imageUrls);

                    // Stop typing
                    try { await Gifted.sendPresenceUpdate('paused', chatId); } catch(e){}

                    if (err && Circuit.isOpen()) return; // silent fail when circuit is tripped

                    // Add AI response to history
                    State.addHistory(activeData, 'AI', response);

                    // Build quoted reference
                    const q = {};
                    if (msg.key?.remoteJid && msg.key?.id) {
                        const k = { remoteJid: String(msg.key.remoteJid), fromMe: false, id: String(msg.key.id) };
                        if (msg.key.participant) k.participant = String(msg.key.participant);
                        q.quoted = { key: k, message: msg.message };
                    }

                    await Gifted.sendMessage(chatId, { text: response }, q);

                } catch(e) {
                    console.error('[AIGems] Watcher process error:', e.message);
                }
            });
        }
    });

    console.log('[AIGems] 👁️ Event watchers registered.');
};

/** Watcher-specific AI call — same logic but kept separate for clarity */
const getAIResponse_watcher = async (prompt, imageUrls = []) => askAI(prompt, imageUrls);

// Boot: try to attach watchers once socket is ready
const _bootWatcher = setInterval(() => {
    const G = global.conn || global.client;
    if (G) { registerWatchers(G); clearInterval(_bootWatcher); }
}, 10000);

// Also attempt immediately in case already connected
setTimeout(() => {
    const G = global.conn || global.client;
    if (G) { registerWatchers(G); clearInterval(_bootWatcher); }
}, 3000);

console.log('[AIGems] ✅ Module loaded — AI Gems, Image Gen, Auto-Reply, Auto-Enhance ready.');
