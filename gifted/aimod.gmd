/**
 * @command .aicookies
 * @description Update QuillBot session cookies on the fly.
 */
gmd({
    pattern: 'aicookies',
    cmdname: 'aicookies',
    category: 'ai',
    desc: 'Update AI session cookies (Owner only).',
    react: '🍪',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only.*');
    
    if (!q.includes('connect.sid')) return reply('📝 *Usage:* `.aicookies <raw_cookie_string>`\n_Must contain connect.sid_');

    const lines = q.split(';').map(v => v.split('='));
    lines.forEach(([k, v]) => {
        const key = k.trim();
        if (CFG.QB_COOKIES[key] !== undefined) CFG.QB_COOKIES[key] = (v || '').trim();
    });

    return reply('✅ *Cookies Updated.* AI engine refreshed.');
});

/**
 * @command .aihistory
 * @description View current conversation context stored in RAM.
 */
gmd({
    pattern: 'aihistory',
    cmdname: 'aihistory',
    category: 'ai',
    desc: 'View current chat history context.',
    react: '📜',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner Only.*');

    const sess = State.chats.get(from) || State.dmSessions.get(from);
    if (!sess || !sess.history.length) return reply('📚 *No active history in this chat.*');

    const histText = sess.history.map(h => `• ${h}`).join('\n');
    return reply(`📜 *AI CONTEXT HISTORY*\n\n${histText}\n\n*Limit:* ${CFG.MAX_HIST} messages.`);
});

