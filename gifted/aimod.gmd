// --- CHUNK: The Watcher: Event-Driven Logic and Auto-Enhance ---
// ==============================================================================
// 19. CHUNK 11: THE WATCHER — Event-Driven Logic & Auto-Enhance
// ==============================================================================

/**
 * @function calculateHumanDelay
 * @description Simulates realistic typing speed based on message length.
 * @param {string} text - The content being "typed".
 * @returns {number} Delay in milliseconds.
 */
const calculateHumanDelay = (text) => {
    const wpm = 60; // Average typing speed
    const cps = (wpm * 5) / 60; // Characters per second
    const baseDelay = (text.length / cps) * 1000;
    // Add jitter (randomness) and cap at 7 seconds to prevent lag feel
    const jitter = Math.random() * 1500;
    return Math.min(baseDelay + jitter, 7000);
};

/**
 * @function coreWatcher
 * @description The central event listener managing all passive AI interactions.
 */
const coreWatcher = (Gifted) => {
    if (!Gifted?.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        // We handle 'notify' for real-time incoming and 'append' for synced messages
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.remoteJid === 'status@broadcast') continue;

                const chatId = msg.key.remoteJid;
                const sender = msg.key.participant || msg.key.remoteJid;
                const fromMe = msg.key.fromMe;
                const isGrp = chatId.endsWith('@g.us');
                
                // Extract body text across different message types
                const body = (
                    msg.message.conversation || 
                    msg.message.extendedTextMessage?.text || 
                    msg.message.imageMessage?.caption || 
                    msg.message.videoMessage?.caption || 
                    ''
                ).trim();

                // ── 1. AUTO-ENHANCE (OWNER MESSAGES) ──
                if (fromMe && State.autoEnhance && body.length > 5 && !['.', '!', '/', '#'].includes(body[0])) {
                    // Execute correction in background to not block UI
                    setImmediate(async () => {
                        try {
                            const correctionPrompt = `You are a silent AI grammar assistant. Fix spelling, grammar, and punctuation for this WhatsApp message. Keep the tone, language, and any emojis exactly as they are. If the message is already perfect, return the exact same text. Return ONLY the corrected text. 
                            Text: ${body}`;
                            
                            const { text: fixed, err } = await askAI(correctionPrompt);
                            if (!err && fixed && fixed.trim().toLowerCase() !== body.toLowerCase()) {
                                await sleep(1000); // Small delay so the original message "lands" first
                                await Gifted.sendMessage(chatId, { text: fixed.trim(), edit: msg.key });
                            }
                        } catch (e) { /* Silent fail for auto-enhance */ }
                    });
                    continue; // Don't trigger AI response to our own enhanced messages
                }

                if (fromMe) continue;

                // ── 2. TARGETING LOGIC (STALKER / TARGET / CHAT / DM) ──
                const targetHit = State.isTargeted(sender, chatId);
                let activeSess = null;

                if (targetHit) {
                    activeSess = targetHit.sess;
                } else if (!isGrp && State.dmActive) {
                    // DM Auto-Pilot
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, { 
                            gem: State.dmGem || State.PERSONA, 
                            history: [], 
                            gemName: 'dm_auto' 
                        });
                    }
                    activeSess = State.dmSessions.get(sender);
                }

                // If no active session logic applies, ignore message
                if (!activeSess) continue;

                // Ignore commands for passive logic
                if (['.', '!', '/', '#'].includes(body[0])) continue;

                // ── 3. AI RESPONSE EXECUTION ──
                setImmediate(async () => {
                    try {
                        let mediaUrls = [];
                        
                        // Handle Vision if image is present
                        if (msg.message.imageMessage) {
                            const tempPath = path.join(__dirname, `../gift/temp/v_${Date.now()}.jpg`);
                            try {
                                const buffer = await require('@whiskeysockets/baileys').downloadContentFromMessage(msg.message.imageMessage, 'image');
                                let fullBuffer = Buffer.from([]);
                                for await (const chunk of buffer) fullBuffer = Buffer.concat([fullBuffer, chunk]);
                                fs.writeFileSync(tempPath, fullBuffer);
                                
                                const remoteUrl = await uploadImgBB(tempPath);
                                if (remoteUrl) mediaUrls.push(remoteUrl);
                                if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);
                            } catch (e) { console.error('[Watcher] Vision Download Error:', e.message); }
                        }

                        // Add user input to history
                        const displayInput = body || (msg.message.imageMessage ? '[Image Sent]' : '[Media]');
                        State.addHist(activeSess, 'User', displayInput);

                        // Build persona-aware prompt
                        const finalSystemPrompt = `${activeSess.gem}\n\nIMPORTANT: You are chatting on WhatsApp. Always use WhatsApp Markdown: *bold* for emphasis, _italics_ for tone, ~strikethrough~ for corrections, and \`\`\`code\`\`\` for technical bits. Use emojis naturally but don't overdo it. Keep responses concise and engaging.`;
                        const fullPrompt = State.buildPrompt(finalSystemPrompt, activeSess.history, displayInput);

                        // Initial "Thinking" delay
                        await sleep(800 + Math.random() * 1200);
                        
                        // Set presence to 'composing'
                        await Gifted.sendPresenceUpdate('composing', chatId);

                        const { text: aiResponse, err } = await askAI(fullPrompt, mediaUrls);
                        
                        if (err) {
                            await Gifted.sendPresenceUpdate('paused', chatId);
                            if (!CB.open()) {
                                // Optional: Notify of temporary glitch if not circuit-broken
                                // await Gifted.sendMessage(chatId, { text: "_System hiccup, try again in a sec..._" });
                            }
                            return;
                        }

                        // Calculate Typing Speed Delay
                        const typingDelay = calculateHumanDelay(aiResponse);
                        await sleep(typingDelay);

                        // Stop presence
                        await Gifted.sendPresenceUpdate('paused', chatId);

                        // Update History
                        State.addHist(activeSess, 'AI', aiResponse);

                        // Construct Quoted Message Object
                        const quotedMek = {
                            key: {
                                remoteJid: chatId,
                                fromMe: false,
                                id: msg.key.id,
                                participant: msg.key.participant || sender
                            },
                            message: msg.message
                        };

                        // Send Final Message
                        await Gifted.sendMessage(chatId, { 
                            text: aiResponse.trim() 
                        }, { quoted: quotedMek });

                    } catch (err) {
                        console.error('[AIGems] Watcher Fatal:', err);
                    }
                });

            } catch (loopErr) {
                console.error('[AIGems] Watcher Loop Err:', loopErr);
            }
        }
    });

    console.log('[AIGems] Watcher Engine: Synchronized & Event-Driven');
};

// Initialize Watcher on boot
const _watcherInterval = setInterval(() => {
    const activeClient = global.conn || global.client;
    if (activeClient?.ev) {
        coreWatcher(activeClient);
        clearInterval(_watcherInterval);
    }
}, 5000);

/**
 * End of Chunk 11: The Watcher.
 * Features: Auto-Enhance, Stalker Logic, DM Auto-Pilot, Human-like Typing Simulation.
 */

// --- CHUNK: Monitoring, Health, and Boot Initialization ---
// ==============================================================================
// 19.  BOOTSTRAP & INITIALIZATION SEQUENCE
// ==============================================================================

/**
 * @function bootstrap
 * @description Ensures the environment is ready: DB migrations, API pre-validation, and circuit check.
 */
const bootstrap = async () => {
    console.log('------------------------------------------------------------');
    console.log('[AIGems] Initializing Bootstrap Sequence...');
    
    const results = {
        database: false,
        quillbot: false,
        infip:    false
    };

    // 1. Database Migration & Integrity Check
    if (db) {
        try {
            db.prepare('SELECT count(*) FROM gems').get();
            // Ensure WAL mode for high-concurrency WhatsApp environments
            db.pragma('journal_mode = WAL');
            db.pragma('synchronous = NORMAL');
            results.database = true;
            console.log('[AIGems] [BOOT] Database: 🟢 INTEGRITY_OK');
        } catch (e) {
            console.error('[AIGems] [BOOT] Database: 🔴 FAILED -', e.message);
        }
    } else {
        console.warn('[AIGems] [BOOT] Database: 🟡 DISABLED (better-sqlite3 missing)');
    }

    // 2. API Pool Pre-Validation (Infip)
    try {
        const infipStatus = await ensureInfip();
        results.infip = infipStatus;
        console.log(`[AIGems] [BOOT] Infip API: ${infipStatus ? '🟢 POOL_READY' : '🔴 AUTH_FAILED'}`);
    } catch (e) {
        console.error('[AIGems] [BOOT] Infip API: 🔴 FATAL -', e.message);
    }

    // 3. QuillBot Connectivity & Cookie Warmup
    try {
        const testRequest = await askAI('System: Boot check. Reply only "READY"');
        if (!testRequest.err && testRequest.text.toUpperCase().includes('READY')) {
            results.quillbot = true;
            console.log('[AIGems] [BOOT] QuillBot AI: 🟢 SESSION_ACTIVE');
        } else {
            console.warn('[AIGems] [BOOT] QuillBot AI: 🟡 DEGRADED -', testRequest.text);
        }
    } catch (e) {
        console.error('[AIGems] [BOOT] QuillBot AI: 🔴 UNREACHABLE');
    }

    console.log('[AIGems] Bootstrap Complete.');
    console.log('------------------------------------------------------------');
    return results;
};

// ==============================================================================
// 20.  .apimon — ADVANCED MONITORING & HEALTH (Re-Implementation)
// ==============================================================================

gmd({
    pattern: 'apimon',
    cmdname: 'apimon',
    aliases: ['aihealth', 'mon', 'sysstat'],
    category: 'ai',
    desc: 'Monitor AI health, test APIs, and manage circuit breakers.',
    react: '🩺',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied:* Elite clearance required.');

    const args = q.trim().toLowerCase().split(/\s+/);
    const sub = args[0] || 'status';

    // Helper: Progress Bar for UI
    const getBar = (current, max) => {
        const size = 10;
        const progress = Math.min(size, Math.round((current / max) * size));
        return '▢'.repeat(progress) + ' ' + '⬚'.repeat(size - progress);
    };

    if (sub === 'status' || sub === 'stats') {
        const s = Limiter.stats();
        const cbStatus = CB.open() ? '🔴 *TRIPPED* (Open)' : '🟢 *STABLE* (Closed)';
        
        let report = `📊 *SYSTEM MONITOR* 📊\n\n`;
        report += `*Circuit Breaker:* ${cbStatus}\n`;
        report += `*Fails:* \`${CB.fails}/${CB.THRESH}\` (Last: ${CB.lastFail ? new Date(CB.lastFail).toLocaleTimeString() : 'N/A'})\n\n`;
        
        report += `*Rate Limits (Requests)*\n`;
        report += `1m: \`[${getBar(s.rpm, CFG.MAX_RPM)}]\` (${s.rpm}/${CFG.MAX_RPM})\n`;
        report += `1h: \`[${getBar(s.rph, CFG.MAX_RPH)}]\` (${s.rph}/${CFG.MAX_RPH})\n\n`;
        
        report += `*Daily Throughput (Today)*\n`;
        report += `• AI Calls: \`${s.ai}\` msgs\n`;
        report += `• Images:  \`${s.img}\` imgs\n`;
        report += `• Errors:  \`${s.err}\` total\n\n`;
        
        report += `*Active Threads*\n`;
        report += `• Stalkers: \`${State.stalkers.size}\` users\n`;
        report += `• Targets:  \`${State.targets.size}\` users\n`;
        report += `• Chats:    \`${State.chats.size}\` groups\n`;
        report += `• DMs:      \`${State.dmActive ? 'Active' : 'Idle'}\``;

        return reply(report);
    }

    if (sub === 'health' || sub === 'test') {
        const stub = await thinking(Gifted, from, mek, '🔍 *Running Diagnostic...*');
        
        const checks = await Promise.allSettled([
            askAI('Ping. Reply only "PONG"'), // AI check
            ensureInfip(),                   // Image API check
            Promise.resolve(db ? db.prepare('SELECT 1').get() : null) // DB check
        ]);

        const ai = checks[0].status === 'fulfilled' && !checks[0].value.err && checks[0].value.text.includes('PONG');
        const img = checks[1].status === 'fulfilled' && checks[1].value === true;
        const storage = checks[2].status === 'fulfilled' && checks[2].value !== null;

        let res = `🛡️ *HEALTH DIAGNOSTIC* 🛡️\n\n`;
        res += `• *QuillBot AI:* ${ai ? '🟢 `READY`' : '🔴 `FAULT`'}\n`;
        res += `• *Infip Pool:* ${img ? '🟢 `AUTHENTICATED`' : '🔴 `UNAUTHORIZED`'}\n`;
        res += `• *SQLite DB:*  ${storage ? '🟢 `CONNECTED`' : '🔴 `ERROR`'}\n`;
        res += `• *Circuits:*   ${CB.open() ? '⚠️ `TRIPPED`' : '✅ `CLOSED`'}\n\n`;
        
        res += `_Current Token:_ \`${_iKey.slice(0, 12)}...${_iKey.slice(-4)}\`\n`;
        res += `_DB Path:_ \`${CFG.DB_PATH.split(path.sep).pop()}\``;

        return editMsg(Gifted, stub, res);
    }

    if (sub === 'reset') {
        const target = args[1];
        if (target === 'circuit' || target === 'cb') {
            CB.reset();
            return reply('⚡ *System Instruction:* Circuit Breaker has been manual-reset. Flows restored.');
        }
        if (target === 'daily' || target === 'limits') {
            Limiter.daily = { ai: 0, img: 0, err: 0, day: new Date().toDateString() };
            return reply('♻️ *System Instruction:* Daily request counters have been zeroed out.');
        }
        return reply('📝 *Usage:* `.apimon reset <circuit|daily>`');
    }

    if (sub === 'debug') {
        const stalkerList = Array.from(State.stalkers.keys()).map(k => `• @${k.split('@')[0]}`).join('\n');
        return reply(`🕵️ *STALKER REGISTRY*\n\n${stalkerList || '_None active_'}`);
    }

    return reply(`❌ *Invalid Sub-command.*\n_Try:_ \`status\`, \`health\`, \`reset\`, \`debug\``);
});

// ==============================================================================
// 21.  LIFECYCLE: ATTACHMENT & GLOBAL HOOKS
// ==============================================================================

/**
 * @description Primary Watchdog. Attaches the AI Event Watcher to the 
 * active connection object (Gifted/Baileys).
 */
const initWatcher = async () => {
    let attempts = 0;
    const maxAttempts = 20;

    const finder = setInterval(async () => {
        // Detect common global object names used in WhatsApp Bot Frameworks
        const conn = global.conn || global.client || global.Gifted;

        if (conn && typeof conn.ev === 'object') {
            console.log('[AIGems] [INIT] Global connection detected.');
            clearInterval(finder);
            
            // Run pre-start validation
            await bootstrap();
            
            // Attach the AI processing logic to the live stream
            // coreWatcher is defined in Chunk 11
            if (typeof coreWatcher === 'function') {
                coreWatcher(conn);
                console.log('[AIGems] [INIT] AI Watcher attached successfully.');
            } else if (typeof attachWatcher === 'function') {
                // Fallback for earlier versions
                attachWatcher(conn);
                console.log('[AIGems] [INIT] AI Watcher attached (Legacy Hook).');
            }
        } else {
            attempts++;
            if (attempts % 5 === 0) {
                console.log(`[AIGems] [INIT] Searching for connection object... (Attempt ${attempts})`);
            }
            if (attempts >= maxAttempts) {
                console.error('[AIGems] [INIT] Failed to find global connection object. AI Watcher disabled.');
                clearInterval(finder);
            }
        }
    }, 5000);
};

// Start the search process
initWatcher();

// ==============================================================================
// 22.  EXPORT & FINALIZATION
// ==============================================================================

module.exports = {
    Gems,
    State,
    askAI,
    generateImage,
    Limiter,
    CB,
    bootstrap
};

console.log('[AIGems] Final Chunk (12/12) Loaded. System is Robust.');
