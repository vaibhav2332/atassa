/**
 * Periodically cleans up dead sessions to prevent memory leaks in the global State.
 */
setInterval(() => {
    const now = Date.now();
    State.dmSessions.forEach((sess, key) => {
        if (sess.lastActive && (now - sess.lastActive > 3600000)) { // 1 hour inactivity
            State.dmSessions.delete(key);
        }
    });
}, 600000); // Check every 10 minutes
/**
 * .aitranslate: High-precision multi-language translation
 */
gmd({
    pattern: "aitranslate",
    cmdname: "aitranslate",
    alias: ["translate", "tr", "aitr"],
    category: "ai",
    desc: "Translate text to any language using AI context awareness.",
    react: "🌐",
    filename: __filename
}, async (from, sock, context) => {
    const { q, reply, mek, isSuperUser } = context;
    if (!isSuperUser) return reply("❌ Owner only.");
    
    const parts = q.split("|");
    const targetLang = parts[0]?.trim();
