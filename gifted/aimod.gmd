// ==============================================================================
// 3. DATABASE
// ==============================================================================
let db = null;
if (Database) {
    try {
        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        console.log('[AIGems] Database ready');
    } catch(e) { console.error('[AIGems] DB error:', e.message); db = null; }
}

const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT content FROM gems WHERE name=?').get(n.toLowerCase().trim())?.content ?? null; } catch(e){ return null; } },
    save : (n, c) => { try { return !!db?.prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(n.toLowerCase().trim(), c)?.changes; } catch(e){ return false; } },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};

// ==============================================================================
// 4. RATE LIMITER + CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q:[], hr_q:[], daily:{ai:0,img:0,err:0,day:new Date().toDateString()},
    check() {
        const n=Date.now();
        this.min_q=this.min_q.filter(t=>n-t<60000);
        this.hr_q=this.hr_q.filter(t=>n-t<3600000);
        return this.min_q.length<CFG.MAX_RPM && this.hr_q.length<CFG.MAX_RPH;
    },
    hit(type='ai'){
        const n=Date.now(); this.min_q.push(n); this.hr_q.push(n);
        const d=new Date().toDateString();
        if(d!==this.daily.day) this.daily={ai:0,img:0,err:0,day:d};
        if(type==='ai') this.daily.ai++;
        if(type==='img') this.daily.img++;
    },
    err(){ this.daily.err++; },
    stats(){
        const n=Date.now();
        return {rpm:this.min_q.filter(t=>n-t<60000).length, rph:this.hr_q.filter(t=>n-t<3600000).length, ...this.daily};
    }
};

const CB = {
    fails:0, lastFail:0, THRESH:5, TTL:300000,
    open()  { return this.fails>=this.THRESH && Date.now()-this.lastFail<this.TTL; },
    fail()  { this.fails++; this.lastFail=Date.now(); Limiter.err(); },
    ok()    { this.fails=0; },
    reset() { this.fails=0; this.lastFail=0; },
    msg()   { return ['neural link glitchy rn','signal weak on my end','connection hiccupped','brain.exe crashed lol'][Math.floor(Math.random()*4)]; }
};

// ==============================================================================
// 5. CORE AI — QuillBot SSE streaming (responseType: 'stream' for proper SSE)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: prompt,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'        // ← key fix: stream not text
                }
            );

            // Collect SSE chunks into full text
            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            // Parse SSE: extract all "chunk" values
            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { const o = JSON.parse(l.slice(6)); if (o.chunk) full += o.chunk; } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1200*(attempt+1)); continue; }
                CB.fail();
                return { text: 'empty response — cookies may need refreshing', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            console.error(`[AIGems] askAI attempt ${attempt+1}:`, e.message);
            if (attempt < CFG.RETRIES - 1) await sleep(1200*(attempt+1));
            else { CB.fail(); return { text: `API unreachable — ${e.message}`, err: true }; }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 6. IMGBB UPLOADER
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch(e) { console.error('[AIGems] ImgBB:', e.message); return null; }
};

// ==============================================================================
// 7. IMAGE GENERATOR — Infip API (key pool)
// ==============================================================================
let _iKey = CFG.INFIP_POOL[Math.floor(Math.random()*CFG.INFIP_POOL.length)];
let _iOk  = false;
const _iCache = new Map();
const _iHdr = () => ({ Authorization:`Bearer ${_iKey}`, 'Content-Type':'application/json' });

const ensureInfip = async () => {
    if (_iOk) return true;
    try { const r=await axios.get(`${CFG.INFIP_URL}/v1/models`,{headers:_iHdr(),timeout:10000}); if(r.status===200){_iOk=true;return true;} } catch(e){}
    try { const r=await axios.post(`${CFG.INFIP_URL}/v1/api-keys`,{},{timeout:10000}); if(r.data?.api_key){_iKey=r.data.api_key;_iOk=true;return true;} } catch(e){}
    _iOk=true; return false;
};

const generateImage = async (prompt, opts={}) => {
    const model=opts.model||CFG.IMG_MODEL, size=opts.size||CFG.IMG_SIZE,
          n=Math.min(opts.count||CFG.IMG_COUNT,4), quality=opts.quality||CFG.IMG_QUALITY, style=opts.style||CFG.IMG_STYLE;
    const ck=`${model}|${size}|${prompt.slice(0,60)}`;
    const hit=_iCache.get(ck);
    if(hit&&Date.now()-hit.ts<3600000) return hit.urls;
    if(!Limiter.check()) return [];
    await ensureInfip(); Limiter.hit('img');
    for(let i=0;i<CFG.RETRIES;i++){
        try{
            const r=await axios.post(`${CFG.INFIP_URL}/v1/images/generations`,
                {model,prompt,n,size,response_format:'url',quality,style},{headers:_iHdr(),timeout:CFG.TIMEOUT});
            if(r.status===200&&r.data?.data?.length){ const urls=r.data.data.map(d=>d.url); _iCache.set(ck,{urls,ts:Date.now()}); return urls; }
        }catch(e){ Limiter.err(); if(i<CFG.RETRIES-1) await sleep(1000*(i+1)); }
    }
    return [];
};

// ==============================================================================
// 8. RUNTIME STATE
// ==============================================================================
const State = {
    dmActive:false, dmGem:null,
    chats:new Map(), targets:new Map(), stalkers:new Map(), dmSessions:new Map(),
    autoEnhance:false,
    PERSONA:'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Never say you are an AI. Use conversation history to stay consistent.',
    addHist(ctx,role,txt){ if(!ctx.history)ctx.history=[]; const t=new Date().toLocaleTimeString('en',{hour12:false,hour:'2-digit',minute:'2-digit'}); ctx.history.push(`[${t}] ${role}: ${txt}`); if(ctx.history.length>CFG.MAX_HIST)ctx.history=ctx.history.slice(-CFG.MAX_HIST); },
    buildPrompt(sys,hist,input){ return `SYSTEM:\n${sys}\n\n--- HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nREPLY:`; }
};

// ==============================================================================
// 9. MESSAGE HELPERS
// ==============================================================================

/** Send quoted thinking stub, return sent msg for later edit */
const thinking = async (Gifted, from, mek, label='⏳ _thinking…_') => {
    try { return await Gifted.sendMessage(from, { text:label }, { quoted:mek }); } catch(e){ return null; }
};

/** Edit a message with fallback: delete + resend */
const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    // Attempt native WA message edit
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text:newText, edit:sentMsg.key });
        return;
    } catch(e1) {}
    // Fallback: delete old → send fresh
    try { await Gifted.sendMessage(sentMsg.key.remoteJid, { delete:sentMsg.key }); } catch(e){}
    await sleep(300);
    try { await Gifted.sendMessage(sentMsg.key.remoteJid, { text:newText }); } catch(e2) {
        console.error('[AIGems] editMsg failed:', e2.message);
    }
};

/** Delete message silently */
const del = async (Gifted, key) => { try { await Gifted.sendMessage(key.remoteJid,{delete:key}); } catch(_){} };

/** Send image with URL-text fallback */
const sendImg = async (Gifted, from, url, caption, mek) => {
    try { await Gifted.sendMessage(from, { image:{url}, caption }, {quoted:mek}); return true; }
    catch(e) { try { await Gifted.sendMessage(from, {text:`🎨 ${caption}\n\n🔗 ${url}`},{quoted:mek}); } catch(_){} return false; }
};

// ==============================================================================
// 10.  .gem  — PERSONA SYSTEM
// ==============================================================================
gmd({
    pattern:'gem', cmdname:'gem', aliases:['gems','persona'],
    category:'ai', desc:'AI persona vault. .gem help for all sub-commands.', react:'💎', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'help', rest=parts.slice(1);

    if (cmd==='create') {
        if(rest.length<2) return reply('📝 `.gem create <name> <persona prompt>`');
        const [name,...pArr]=rest, content=pArr.join(' ');
        return Gems.save(name,content)
            ? reply(`💎 *Gem Saved*\n*Name:* \`${name}\`\n*Preview:* _${content.slice(0,120)}_`)
            : reply('❌ DB error.');
    }
    if (cmd==='gen') {
        const topic=rest.join(' ');
        if(!topic) return reply('📝 `.gem gen <topic>`  e.g. `.gem gen sarcastic gamer`');
        const stub=await thinking(Gifted,from,mek,`🔮 _Forging "${topic}"…_`);
        const {text,err}=await askAI(`Create a detailed WhatsApp persona system prompt for: ${topic}.\nInclude personality, speaking style, slang, emoji habits.\nReturn ONLY the raw system prompt.`);
        if(err) return editMsg(Gifted,stub,`❌ ${text}`);
        const name=(rest[0]||'gem').toLowerCase().slice(0,12)+'_ai';
        Gems.save(name,text);
        return editMsg(Gifted,stub,`✨ *Gem Created*\n*Name:* \`${name}\`\n*Preview:* _${text.slice(0,150)}_\n\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd==='analyze') {
        const quoted=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if(!quoted) return reply('📝 *Reply to a message* then run `.gem analyze`');
        const sample=quoted.conversation||quoted.extendedTextMessage?.text||'[no text]';
        const stub=await thinking(Gifted,from,mek,'🕵️ _Cloning style…_');
        const {text,err}=await askAI(`Analyze this WhatsApp message and build a system prompt to clone this style:\n"${sample}"\nReturn ONLY the system prompt.`);
        if(err) return editMsg(Gifted,stub,`❌ ${text}`);
        const name=`clone_${Date.now().toString(36)}`;
        Gems.save(name,text);
        return editMsg(Gifted,stub,`🧬 *Clone Created*\n*Name:* \`${name}\`\n_Activate:_ \`.gem use ${name}\``);
    }
    if (cmd==='remix') {
        const [gemName,...tw]=rest; const tweak=tw.join(' ');
        if(!gemName||!tweak) return reply('📝 `.gem remix <name> <modification>`');
        const base=Gems.get(gemName);
        if(!base) return reply(`❌ Gem \`${gemName}\` not found.`);
        const stub=await thinking(Gifted,from,mek,`🔀 _Remixing "${gemName}"…_`);
        const {text,err}=await askAI(`Modify this system prompt per the instruction. Return ONLY the updated prompt.\n\nOriginal:\n${base}\n\nChange: ${tweak}`);
        if(err) return editMsg(Gifted,stub,`❌ ${text}`);
        const newName=`${gemName}_remix`;
        Gems.save(newName,text);
        return editMsg(Gifted,stub,`🔀 *Remixed*\n\`${gemName}\` → \`${newName}\``);
    }
    if (cmd==='list') {
        const list=Gems.list();
        if(!list.length) return reply('📚 No gems yet.\n`.gem gen <topic>` or `.gem create <n> <prompt>`');
        return reply(`📚 *Gems (${list.length})*\n\n${list.map((g,i)=>`${i+1}. 💎 \`${g}\``).join('\n')}\n\n_Use_ \`.gem use <n>\``);
    }
    if (cmd==='view') {
        const c=Gems.get(rest[0]||'');
        if(!rest[0]) return reply('📝 `.gem view <name>`');
        if(!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        return reply(`💎 *${rest[0].toUpperCase()}*\n\n${c}`);
    }
    if (cmd==='use') {
        if(!rest[0]) return reply('📝 `.gem use <name>`');
        const c=Gems.get(rest[0]);
        if(!c) return reply(`❌ Gem \`${rest[0]}\` not found.`);
        State.dmGem=c;
        return reply(`✅ *DM Persona:* \`${rest[0]}\`\nEnable with \`.gai dm on\``);
    }
    if (cmd==='delete'||cmd==='del') {
        if(!rest[0]) return reply('📝 `.gem delete <name>`');
        return Gems.del(rest[0]) ? reply(`🗑️ \`${rest[0]}\` deleted.`) : reply(`❌ Not found.`);
    }
    return reply(
        `💎 *GEM — Persona Vault*\n\n`+
        `• \`.gem create <n> <prompt>\`\n• \`.gem gen <topic>\` — AI generates\n`+
        `• \`.gem analyze\` — Clone from replied msg\n• \`.gem remix <n> <tweak>\`\n`+
        `• \`.gem list\` | \`.gem view <n>\` | \`.gem use <n>\` | \`.gem delete <n>\``
    );
});

// ==============================================================================
// 11.  .gai  — ONE-SHOT AI + AUTO-REPLY CONTROL
// ==============================================================================
gmd({
    pattern:'gai', cmdname:'gai', aliases:['ai','ask','brain'],
    category:'ai', desc:'AI assistant & auto-reply control. .gai help', react:'🧠', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'', rest=parts.slice(1), second=rest[0]?.toLowerCase()||'';

    if (cmd==='dm') {
        if(second==='on')  { State.dmActive=true;  return reply(`📨 *DM Auto-Pilot: ✅ ON*\nPersona: ${State.dmGem?'Custom gem':'Default'}`); }
        if(second==='off') { State.dmActive=false; return reply('📨 *DM Auto-Pilot: ❌ OFF*'); }
        return reply(`📨 DM Auto-Pilot: ${State.dmActive?'✅ ON':'❌ OFF'}`);
    }
    if (cmd==='chat') {
        const gemName=second||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.chats.set(from,{gem:gemTxt,history:[],gemName});
        return reply(`⚔️ *Chat AI Active*\nGem: *${gemName}* — replying to everyone here.`);
    }
    if (cmd==='target'||cmd==='bot') {
        const num=rest[0]?.replace(/[^0-9]/g,'');
        if(!num) return reply('📝 `.gai target <number> [gem]`');
        const tjid=num+'@s.whatsapp.net', gemName=rest[1]||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.targets.set(tjid,{gem:gemTxt,history:[],chatId:from,gemName});
        return reply(`🤖 *Target Locked*\n@${num} | Gem: *${gemName}*`);
    }
    if (cmd==='stalk') {
        const num=rest[0]?.replace(/[^0-9]/g,'');
        if(!num) return reply('📝 `.gai stalk <number> [gem]`');
        const tjid=num+'@s.whatsapp.net', gemName=rest[1]||'default';
        const gemTxt=(gemName!=='default'?Gems.get(gemName):null)||State.PERSONA;
        State.stalkers.set(tjid,{gem:gemTxt,history:[],gemName});
        return reply(`🌍 *Global Stalker*\n@${num} everywhere | Gem: *${gemName}*`);
    }
    if (cmd==='stop') {
        if(second==='all'){
            State.dmActive=false; State.chats.clear(); State.targets.clear();
            State.stalkers.clear(); State.dmSessions.clear();
            return reply('☢️ *ALL AI OFF*\nDM: OFF | Chats: 0 | Targets: 0 | Stalkers: 0');
        }
        State.chats.delete(from);
        return reply('🛑 AI stopped here.\n_Stop all:_ `.gai stop all`');
    }
    if (cmd==='wipe') {
        const sess=State.chats.get(from);
        if(sess){ sess.history=[]; return reply('🧠 _Memory wiped!_'); }
        return reply('ℹ️ No active session here.');
    }
    if (cmd==='status') {
        const s=Limiter.stats(), cb=CB.open()?`🔴 TRIPPED (${CB.fails}/${CB.THRESH})`:`🟢 OK`;
        let out=`📊 *AI STATUS*\nDM:${State.dmActive?'✅':'❌'} Chats:${State.chats.size} Targets:${State.targets.size} Stalkers:${State.stalkers.size}\n${s.rpm}rpm ${s.rph}rph | AI:${s.ai} Img:${s.img} Err:${s.err}\nCircuit: ${cb}`;
        if(State.chats.size){ out+='\n*Sessions:*'; State.chats.forEach((d,c)=>{out+=`\n• ${c.split('@')[0]}: ${d.history.length}t (${d.gemName})`;}); }
        return reply(out);
    }
    if (cmd==='summary') {
        const sess=State.chats.get(from);
        if(!sess?.history?.length) return reply('ℹ️ No history here. Start a session with `.gai chat` first.');
        const stub=await thinking(Gifted,from,mek,'📝 _Summarising…_');
        const {text,err}=await askAI(`Summarise this WhatsApp chat in bullet points:\n\n${sess.history.join('\n')}`);
        return editMsg(Gifted,stub,err?`❌ ${text}`:`📝 *Summary*\n\n${text}`);
    }
    if (cmd==='help') {
        return reply(
            `🧠 *GAI — AI CONTROL*\n\n`+
            `*Quick ask:* \`.gai <question>\`\n\n`+
            `*Modes:*\n• \`.gai dm on/off\`\n• \`.gai chat [gem]\`\n• \`.gai target <num> [gem]\`\n• \`.gai stalk <num> [gem]\`\n\n`+
            `*Control:*\n• \`.gai stop\` / \`.gai stop all\`\n• \`.gai wipe\`\n• \`.gai summary\`\n• \`.gai status\``
        );
    }

    // ── ONE-SHOT ASK ──────────────────────────────────────────────────────────
    // q contains the full text including cmd (which is the question itself)
    const question = q.trim();
    if (!question) return reply('📝 `.gai <question>`  or  `.gai help`');

    let imgUrls=[];
    const quotedMsg=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if (quotedMsg?.imageMessage) {
        await react('👁️');
        try {
            const tp=await Gifted.downloadAndSaveMediaMessage(quotedMsg.imageMessage,`tmp_gai_${Date.now()}`);
            if(tp){ const url=await uploadImgBB(tp); if(url) imgUrls.push(url); try{fs.unlinkSync(tp);}catch(_){} }
        } catch(e){ console.error('[AIGems] vision:', e.message); }
    }

    const stub=await thinking(Gifted,from,mek,'🧠 _thinking…_');
    let finalPrompt=question;
    const ctx=quotedMsg?.conversation||quotedMsg?.extendedTextMessage?.text;
    if(ctx) finalPrompt=`Context:\n"${ctx}"\n\nQuestion: ${question}`;
    const {text,err}=await askAI(finalPrompt,imgUrls);
    return editMsg(Gifted,stub, err?`❌ ${text}`:text);
});

// ==============================================================================
// 12.  .img  — IMAGE GENERATION
// ==============================================================================
gmd({
    pattern:'img', cmdname:'img', aliases:['imagine','genimg','drawai'],
    category:'ai', desc:'AI image generation. .img help for sub-commands.', react:'🎨', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only command.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'help', rest=parts.slice(1);
    const KNOWN=['gen','surprise','chaos','models','config','enhance','setup','random','cache','help'];

    const doGen=async(prompt,stub)=>{
        const urls=await generateImage(prompt);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Generation failed. Try `.img setup` or `.img config <model>`.');
        await del(Gifted,stub.key);
        await sendImg(Gifted,from,urls[0],`🎨 _${prompt.slice(0,200)}_\n🤖 \`${CFG.IMG_MODEL}\``,mek);
        for(const u of urls.slice(1)) await sendImg(Gifted,from,u,'🎨 _Variation_',mek);
    };

    if(cmd==='gen'||(!KNOWN.includes(cmd)&&q)){
        const prompt=cmd==='gen'?rest.join(' '):q;
        if(!prompt.trim()) return reply('📝 `.img gen <prompt>`');
        await react('🎨');
        return doGen(prompt, await thinking(Gifted,from,mek,'🎨 _Generating…_'));
    }
    if(cmd==='surprise'){
        const hint=rest.join(' ');
        const stub=await thinking(Gifted,from,mek,`🎲 _Dreaming${hint?` (${hint})`:''}…_`);
        const {text:dreamt,err}=await askAI(`Generate a highly detailed creative image prompt${hint?` themed: "${hint}"`:''}.\nReturn ONLY the prompt.`);
        if(err) return editMsg(Gifted,stub,`❌ ${dreamt}`);
        await editMsg(Gifted,stub,`🎲 _Visualising:_ "${dreamt.slice(0,80)}…"`);
        const urls=await generateImage(dreamt);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Failed. Retry.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`🎲 *Surprise!*\n💭 _${dreamt.slice(0,200)}_`,mek);
    }
    if(cmd==='chaos'){
        const free=Object.keys(CFG.IMG_MDLS).filter(k=>CFG.IMG_MDLS[k].tier==='free');
        CFG.IMG_MODEL=free[Math.floor(Math.random()*free.length)];
        CFG.IMG_SIZE=['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        CFG.IMG_QUALITY=Math.random()>.5?'hd':'standard'; CFG.IMG_STYLE=Math.random()>.5?'vivid':'natural';
        const stub=await thinking(Gifted,from,mek,`🌪️ *CHAOS* — ${CFG.IMG_MODEL} | ${CFG.IMG_SIZE}`);
        const {text:chaos}=await askAI(['Generate a bizarre surreal image prompt defying logic. Return ONLY prompt.','Create an absurd scene with impossible physics. Return ONLY prompt.','Describe the most chaotic image imaginable. Return ONLY prompt.'][Math.floor(Math.random()*3)]);
        const fp=chaos||'melting clocks cybernetic forest neon rain 8k';
        const urls=await generateImage(fp);
        if(!urls.length) return editMsg(Gifted,stub,'❌ Chaos failed. Retry.');
        await del(Gifted,stub.key);
        return sendImg(Gifted,from,urls[0],`🌪️ *CHAOS*\n💭 _${fp.slice(0,200)}_\n⚙️ \`${CFG.IMG_MODEL}\` \`${CFG.IMG_SIZE}\``,mek);
    }
    if(cmd==='models'){
        const lines=Object.entries(CFG.IMG_MDLS).map(([id,m])=>`${m.tier==='pro'?'👑':'🆓'} \`${id}\` — ${m.desc}`).join('\n');
        return reply(`📋 *Models*\n\n${lines}\n\n*Active:* \`${CFG.IMG_MODEL}\`\nSwitch: \`.img config <model>\``);
    }
    if(cmd==='config'){
        if(!rest[0]) return reply(`⚙️ *Config*\nModel:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Count:${CFG.IMG_COUNT} Quality:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\`\n\n📝 \`.img config <model> [size] [n] [quality] [style]\``);
        const [model,size,count,quality,style]=rest;
        if(model&&!CFG.IMG_MDLS[model]) return reply(`❌ Model \`${model}\` unknown. Run \`.img models\``);
        if(model) CFG.IMG_MODEL=model; if(size) CFG.IMG_SIZE=size;
        if(count) CFG.IMG_COUNT=Math.min(parseInt(count)||1,4);
        if(quality) CFG.IMG_QUALITY=quality; if(style) CFG.IMG_STYLE=style;
        return reply(`✅ Model:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Q:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\``);
    }
    if(cmd==='enhance'){
        const p=rest.join(' '); if(!p) return reply('📝 `.img enhance <prompt>`');
        const stub=await thinking(Gifted,from,mek,'🧠 _Enhancing…_');
        const {text,err}=await askAI(`Enhance this image prompt — richer details, same intent. Return ONLY the prompt.\n\n${p}`);
        return editMsg(Gifted,stub,err?`❌ ${text}`:`✨ *Enhanced*\n\n*Original:* ${p}\n\n*Enhanced:* ${text}`);
    }
    if(cmd==='random'){
        const free=Object.keys(CFG.IMG_MDLS).filter(k=>CFG.IMG_MDLS[k].tier==='free');
        CFG.IMG_MODEL=free[Math.floor(Math.random()*free.length)];
        CFG.IMG_SIZE=['1024x1024','1792x1024','1024x1792'][Math.floor(Math.random()*3)];
        CFG.IMG_QUALITY=Math.random()>.5?'hd':'standard'; CFG.IMG_STYLE=Math.random()>.5?'vivid':'natural';
        return reply(`🎲 *Randomized*\nModel:\`${CFG.IMG_MODEL}\` Size:\`${CFG.IMG_SIZE}\` Q:\`${CFG.IMG_QUALITY}\` Style:\`${CFG.IMG_STYLE}\``);
    }
    if(cmd==='setup'){
        const stub=await thinking(Gifted,from,mek,'🔧 _Validating Infip…_');
        _iOk=false; const ok=await ensureInfip();
        return editMsg(Gifted,stub,ok?`✅ *Infip Ready*\nKey: \`${_iKey.slice(0,20)}…\``:`❌ *Setup Failed* — all keys invalid`);
    }
    if(cmd==='cache'){ _iCache.clear(); return reply('🗑️ Cache cleared.'); }
    return reply(`🎨 *IMG COMMANDS*\n• \`.img gen <prompt>\`\n• \`.img surprise [topic]\`\n• \`.img chaos\`\n• \`.img enhance <prompt>\`\n• \`.img models\`\n• \`.img config [model] [size] [n] [quality] [style]\`\n• \`.img random\`\n• \`.img setup\`\n• \`.img cache\`\n\n*Active:* \`${CFG.IMG_MODEL}\` @ \`${CFG.IMG_SIZE}\``);
});

// ==============================================================================
// 13.  .apimon  — API MONITOR
// ==============================================================================
gmd({
    pattern:'apimon', cmdname:'apimon', aliases:['apistat','aihealth'],
    category:'ai', desc:'AI API usage, health check and circuit breaker.', react:'📊', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const parts=q.trim().split(/\s+/), cmd=parts[0]?.toLowerCase()||'status';
    if(cmd==='status'||!q.trim()){
        const s=Limiter.stats(), cb=CB.open()?'🔴 TRIPPED':`🟢 OK (${CB.fails}/${CB.THRESH})`;
        const bar=(v,max,l=12)=>'█'.repeat(Math.min(l,Math.round(v/max*l)))+'░'.repeat(Math.max(0,l-Math.round(v/max*l)));
        return reply(`📊 *API Status*\n1m: \`${bar(s.rpm,CFG.MAX_RPM)}\` ${s.rpm}/${CFG.MAX_RPM}\n1h: \`${bar(s.rph,CFG.MAX_RPH)}\` ${s.rph}/${CFG.MAX_RPH}\nToday: AI:${s.ai} Img:${s.img} Err:${s.err}\nCircuit: ${cb}`);
    }
    if(cmd==='health'){
        const stub=await thinking(Gifted,from,mek,'🔍 _Health check…_');
        const lines=[];
        const {text:tr,err:te}=await askAI('Reply ONLY with the word: HEALTH_OK');
        lines.push((!te&&tr.includes('HEALTH_OK'))?'✅ QuillBot: Healthy':`⚠️ QuillBot: ${te?'Error':'Unexpected'} — ${tr.slice(0,60)}`);
        lines.push(CB.open()?'🔴 Circuit: TRIPPED':'✅ Circuit: Closed');
        lines.push(Limiter.check()?'✅ Rate Limit: Clear':'⚠️ Rate Limit: Active');
        lines.push(_iOk?'✅ Infip: Validated':'⚠️ Infip: Not tested');
        try{Gems.list();lines.push('✅ DB: OK');}catch(e){lines.push('❌ DB: Error');}
        return editMsg(Gifted,stub,`🔍 *Health Check*\n\n${lines.join('\n')}`);
    }
    if(cmd==='reset'){
        const type=parts[1]?.toLowerCase();
        if(type==='circuit'){ CB.reset(); return reply('✅ Circuit breaker reset.'); }
        if(type==='daily'){ Limiter.daily={ai:0,img:0,err:0,day:new Date().toDateString()}; return reply('✅ Daily stats reset.'); }
        return reply('📝 `.apimon reset <circuit|daily>`');
    }
    return reply(`📊 *API Monitor*\n• \`.apimon status\`\n• \`.apimon health\`\n• \`.apimon reset <circuit|daily>\``);
});

// ==============================================================================
// 14.  .autoenhance  — TOGGLE AUTO-CORRECTION
// ==============================================================================
gmd({
    pattern:'autoenhance', cmdname:'autoenhance', aliases:['smartedit','autoedit'],
    category:'ai', desc:'Toggle AI auto-correction of your outgoing messages.', react:'✍️', filename:__filename
}, async (from, Gifted, conText) => {
    const { q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const a=q.trim().toLowerCase();
    if(a==='on')  { State.autoEnhance=true;  return reply('✍️ *Auto-Enhance: ON*\nYour messages will be silently AI-improved.'); }
    if(a==='off') { State.autoEnhance=false; return reply('✍️ *Auto-Enhance: OFF*'); }
    return reply(`✍️ *Auto-Enhance:* ${State.autoEnhance?'✅ ON':'❌ OFF'}\n\nFixes grammar/spelling silently after you send.\n\n• \`.autoenhance on\`\n• \`.autoenhance off\``);
});

// ==============================================================================
// 15.  .aitranslate  — TRANSLATION
// ==============================================================================
gmd({
    pattern:'aitranslate', cmdname:'aitranslate', aliases:['gitrans','aitrans'],
    category:'ai', desc:'AI translation. Usage: .aitranslate <language> <text>', react:'🌐', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const parts=q.trim().split(/\s+/), lang=parts[0], text=parts.slice(1).join(' ');
    if(!lang||!text) return reply('📝 `.aitranslate <language> <text>`\nExample: `.aitranslate Spanish Good morning`');
    const stub=await thinking(Gifted,from,mek,`🌐 _Translating to ${lang}…_`);
    const {text:out,err}=await askAI(`Translate to ${lang}. Return ONLY the translated text.\n\nText: ${text}`);
    return editMsg(Gifted,stub,err?`❌ ${out}`:`🌐 *→ ${lang}*\n\n📝 ${text}\n\n🔄 ${out}`);
});

// ==============================================================================
// 16.  .aiwrite  — CREATIVE WRITING
// ==============================================================================
gmd({
    pattern:'aiwrite', cmdname:'aiwrite', aliases:['giwrite','compose','draft'],
    category:'ai', desc:'AI creative writing (roast, caption, story, email, etc.)', react:'✍️', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const parts=q.trim().split(/\s+/), type=parts[0]?.toLowerCase()||'', topic=parts.slice(1).join(' ');
    const TYPES={
        message:`Write a natural short WhatsApp message about: ${topic}.`,
        roast  :`Write a playful funny roast about: ${topic}. Friendly tone.`,
        caption:`Write 3 creative captions with emojis for: ${topic}.`,
        essay  :`Write a structured essay about: ${topic}.`,
        story  :`Write a gripping short story about: ${topic}.`,
        bio    :`Write a punchy memorable bio for: ${topic}. Under 150 chars.`,
        email  :`Write a professional email about: ${topic}. Include subject line.`,
        reply  :`Write a witty clever reply to: ${topic}.`,
        flirt  :`Write a charming tasteful message about: ${topic}. Keep classy.`,
        apology:`Write a genuine sincere apology about: ${topic}.`,
        tweet  :`Write 3 tweet options about: ${topic}. Under 280 chars each with hashtags.`,
        speech :`Write a short speech about: ${topic}. Strong opening, 3 points, memorable close.`,
        code   :`Write clean commented code for: ${topic}. Include brief explanation.`
    };
    if(!TYPES[type]) return reply(`✍️ *AI Writer — Types:*\n${Object.keys(TYPES).map(t=>`\`${t}\``).join(' | ')}\n\n*Usage:* \`.aiwrite <type> <topic>\`\n*Example:* \`.aiwrite roast my friend who is always late\``);
    if(!topic) return reply(`📝 \`.aiwrite ${type} <topic>\``);
    const stub=await thinking(Gifted,from,mek,`✍️ _Writing ${type}…_`);
    const {text,err}=await askAI(TYPES[type]);
    return editMsg(Gifted,stub,err?`❌ ${text}`:`✍️ *${type.charAt(0).toUpperCase()+type.slice(1)}*\n\n${text}`);
});

// ==============================================================================
// 17.  .aidecode  — EXPLAIN / ANALYZE ANYTHING
// ==============================================================================
gmd({
    pattern:'aidecode', cmdname:'aidecode', aliases:['gianalyze','explain','aianalyze'],
    category:'ai', desc:'Explain or analyze any quoted text or image with AI.', react:'🔍', filename:__filename
}, async (from, Gifted, conText) => {
    const { mek, q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ Owner only.');
    const quoted=mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    if(!q.trim()&&!quoted) return reply('📝 Reply to any message/image with `.aidecode [optional focus]`');
    let imgUrls=[];
    if(quoted?.imageMessage){
        try{
            const tp=await Gifted.downloadAndSaveMediaMessage(quoted.imageMessage,`tmp_dec_${Date.now()}`);
            if(tp){ const url=await uploadImgBB(tp); if(url) imgUrls.push(url); try{fs.unlinkSync(tp);}catch(_){} }
        }catch(e){}
    }
    const ctx=quoted?.conversation||quoted?.extendedTextMessage?.text||'';
    let prompt=imgUrls.length?`Analyse this image in detail. ${q||'What do you see?'}`:(`Explain and analyse:\n"${ctx||q}"\nBe thorough but clear.`);
    if(ctx&&q) prompt=`Text: "${ctx}"\n\nFocus on: ${q}`;
    const stub=await thinking(Gifted,from,mek,'🔍 _Analysing…_');
    const {text,err}=await askAI(prompt,imgUrls);
    return editMsg(Gifted,stub,err?`❌ ${text}`:`🔍 *Analysis*\n\n${text}`);
});

// ==============================================================================
// 18.  EVENT WATCHER — auto-reply + auto-enhance
// ==============================================================================
let _watchDone=false;

const attachWatcher=(Gifted)=>{
    if(_watchDone||!Gifted?.ev) return;
    _watchDone=true;

    Gifted.ev.on('messages.upsert', async({messages,type})=>{
        if(type!=='append') return;
        for(const msg of messages){
            try{
                if(!msg.message) continue;
                const fromMe=msg.key.fromMe, chatId=msg.key.remoteJid||'';
                const sender=msg.key.participant||msg.key.remoteJid||'';
                const isGrp=chatId.endsWith('@g.us');
                const body=msg.message.conversation||msg.message.extendedTextMessage?.text||msg.message.imageMessage?.caption||'';

                // Auto-enhance own messages
                if(fromMe&&State.autoEnhance&&body.length>10&&!body.startsWith('.')){
                    setTimeout(async()=>{
                        try{
                            await sleep(700+Math.random()*600);
                            const{text:fixed,err}=await askAI(`Fix grammar/spelling only. Preserve tone and language. Return ONLY corrected text.\n\nText: ${body}`);
                            if(!err&&fixed.trim()&&fixed.trim()!==body.trim())
                                await Gifted.sendMessage(chatId,{text:fixed.trim(),edit:msg.key}).catch(()=>{});
                        }catch(e){}
                    },0);
                    continue;
                }
                if(fromMe) continue;
                if(['.','/','+','!'].includes(body[0])) continue;
                if(!body.trim()&&!msg.message.imageMessage) continue;

                let sess=null;
                if(State.stalkers.has(sender)) sess=State.stalkers.get(sender);
                else if(State.targets.has(sender)&&(!State.targets.get(sender).chatId||State.targets.get(sender).chatId===chatId)) sess=State.targets.get(sender);
                else if(State.chats.has(chatId)) sess=State.chats.get(chatId);
                else if(!isGrp&&State.dmActive){
                    if(!State.dmSessions.has(sender)) State.dmSessions.set(sender,{gem:State.dmGem||State.PERSONA,history:[],gemName:'dm'});
                    sess=State.dmSessions.get(sender);
                }
                if(!sess) continue;

                setImmediate(async()=>{
                    try{
                        let imgUrls=[], input=body||'[image]';
                        if(msg.message.imageMessage){
                            try{
                                const tp=await Gifted.downloadAndSaveMediaMessage(msg.message.imageMessage,`tmp_w_${Date.now()}`);
                                if(tp){const u=await uploadImgBB(tp);if(u)imgUrls.push(u);try{fs.unlinkSync(tp);}catch(_){}}
                            }catch(e){}
                        }
                        State.addHist(sess,'User',input);
                        const prompt=State.buildPrompt(sess.gem,sess.history,input);
                        await sleep(Math.min(input.length*35,3000)+Math.random()*700);
                        try{await Gifted.sendPresenceUpdate('composing',chatId);}catch(_){}
                        const{text:rep,err}=await askAI(prompt,imgUrls);
                        try{await Gifted.sendPresenceUpdate('paused',chatId);}catch(_){}
                        if(err&&CB.open()) return;
                        State.addHist(sess,'AI',rep);
                        const q={};
                        if(msg.key?.remoteJid&&msg.key?.id){
                            const k={remoteJid:String(msg.key.remoteJid),fromMe:false,id:String(msg.key.id)};
                            if(msg.key.participant)k.participant=String(msg.key.participant);
                            q.quoted={key:k,message:msg.message};
                        }
                        await Gifted.sendMessage(chatId,{text:rep},q);
                    }catch(e){console.error('[AIGems] watcher reply:',e.message);}
                });
            }catch(e){console.error('[AIGems] watcher loop:',e.message);}
        }
    });
    console.log('[AIGems] Watcher active');
};

const _boot=setInterval(()=>{ const G=global.conn||global.client; if(G){attachWatcher(G);clearInterval(_boot);} },8000);
setTimeout(()=>{ const G=global.conn||global.client; if(G){attachWatcher(G);clearInterval(_boot);} },2000);

console.log('[AIGems] Module loaded');
