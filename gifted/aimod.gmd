 */
if (typeof gmd === 'function') {
    gmd({
        pattern: "aitranslate",
        cmdname: "aitranslate",
        alias: ["trans", "translate"],
        category: "ai",
        desc: "Neural translation to any language.",
        react: "🌐",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ Owner only.");
        const [lang, ...txtParts] = q.trim().split(/\s+/);
        const text = txtParts.join(" ");
        if (!lang || !text) return reply("📝 *Usage:* `.trans <language> <text>`");

        const stub = await sock.sendMessage(from, { text: "🌐 *Translating...*" }, { quoted: mek });
        const { text: result, err } = await askAI(`Translate the following to ${lang}. Return ONLY the translation:\n\n${text}`);
        return sock.sendMessage(from, { text: err ? `❌ Error: ${result}` : `🌐 *Translation (${lang})*\n\n${result}`, edit: stub.key });
    });

    /**
     * .autoenhance: Self-correction toggle
     */
    gmd({
        pattern: "autoenhance",
        cmdname: "autoenhance",
        alias: ["smartedit"],
        category: "ai",
        desc: "Auto-correct your outgoing messages for grammar/tone.",
        react: "✍️",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ Owner only.");
        const mode = q.trim().toLowerCase();
        if (mode === "on") { State.autoEnhance = true; return reply("✍️ *Auto-Enhance:* Enabled. Your outgoing messages will be polished."); }
        if (mode === "off") { State.autoEnhance = false; return reply("✍️ *Auto-Enhance:* Disabled."); }
        return reply(`✍️ *Auto-Enhance status:* ${State.autoEnhance ? "ON" : "OFF"}\n_Use \`.autoenhance on/off\`_`);
    });
}
if (typeof gmd === 'function') {

    /**
     * .gai: Master AI Control (Targeting, Stalking, & Status)
     * Phase 5 Rewrite: Enhanced JID parsing, Global Mapping, and Memory Wiping.
     */
    gmd({
        pattern: "gai",
        cmdname: "gai",
        alias: ["brain", "control", "target", "stalk"],
        category: "ai",
        desc: "Advanced AI targeting and stalking suite for session-based interactions.",
        react: "🎯",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser, sender } = context;
        if (!isSuperUser) return reply("❌ *Access Denied:* Master permissions required for targeting protocols.");

        const args = q.trim().split(/\s+/);
        const cmd = args[0]?.toLowerCase();
        const rawTarget = args[1];
        const gemName = args[2] || "default";

        /**
         * Enhanced JID Resolver: 
         * Safely converts phone numbers into valid WhatsApp JIDs for State mapping.
         */
        const resolveJID = (input) => {
            if (!input) return null;
            let clean = input.replace(/[^0-9]/g, "");
            if (clean.length < 7) return null;
            return `${clean}@s.whatsapp.net`;
        };

        // Standard markdown enforcement for all AI responses
        const MD_REQ = "\n\n*Formatting:* Use WhatsApp Markdown (bold, italic, code). Ensure technical terms are monospaced.";

        switch (cmd) {
            case "target": {
                const jid = resolveJID(rawTarget);
                if (!jid) return reply("📝 *Usage:* `.gai target <number> [gem]`\n_Example: .gai target 1234567890 dark_");
                
                const persona = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;
                State.targets.set(jid, {
                    gem: persona + MD_REQ,
                    history: [],
                    chatId: from,
                    gemName: gemName
                });
                return reply(`🤖 *Target Locked:* @${jid.split("@")[0]}\n💎 *Persona:* \`${gemName}\`\n📍 *Constraint:* Local (Replying in this chat only).`);
            }

            case "stalk": {
                const jid = resolveJID(rawTarget);
                if (!jid) return reply("📝 *Usage:* `.gai stalk <number> [gem]`\n_Example: .gai stalk 1234567890 spy_");

                const persona = (gemName !== "default" ? Gems.get(gemName) : null) || State.PERSONA;
                State.stalkers.set(jid, {
                    gem: persona + MD_REQ,
                    history: [],
                    gemName: gemName
                });
                return reply(`👁️ *Global Stalker Engaged:* @${jid.split("@")[0]}\n💎 *Persona:* \`${gemName}\`\n🌍 *Constraint:* Global (Active across all chats).`);
            }

            case "stop": {
                if (rawTarget === "all") {
                    State.targets.clear();
                    State.stalkers.clear();
                    State.chats.delete(from);
                    State.dmSessions.clear();
                    return reply("☢️ *Global Termination:* All AI session objects and trackers have been purged.");
                }
                const jid = resolveJID(rawTarget);
                if (jid && (State.targets.has(jid) || State.stalkers.has(jid))) {
                    State.targets.delete(jid);
                    State.stalkers.delete(jid);
                    return reply(`✅ *Purged:* Tracker for @${jid.split("@")[0]} removed from State.`);
                }
                State.chats.delete(from);
                return reply("🛑 *Local Stop:* Chat-wide AI deactivated.");
            }

            case "wipe": {
                const targetJid = resolveJID(rawTarget) || from;
                let found = false;
                [State.targets, State.stalkers, State.chats, State.dmSessions].forEach(sessionMap => {
                    if (sessionMap.has(targetJid)) {
                        sessionMap.get(targetJid).history = [];
                        found = true;
                    }
                });
                return reply(found ? `🧠 *Memory Wiped:* Contextual history for @${targetJid.split("@")[0]} is now blank.` : "❌ *Error:* No active session found to wipe.");
            }

            case "status": {
                let statusMsg = "🛰️ *AI SYSTEM STATUS MONITOR*\n\n";
                statusMsg += `🎯 *Active Targets:* ${State.targets.size}\n`;
                State.targets.forEach((v, k) => statusMsg += `  ◦ @${k.split("@")[0]} (\`${v.gemName}\`)\n`);
                
                statusMsg += `\n👁️ *Active Stalkers:* ${State.stalkers.size}\n`;
                State.stalkers.forEach((v, k) => statusMsg += `  ◦ @${k.split("@")[0]} (\`${v.gemName}\`)\n`);

                const isLocal = State.chats.has(from);
                statusMsg += `\n📍 *Local Chat AI:* ${isLocal ? "✅ ONLINE" : "❌ OFFLINE"}`;
                if (isLocal) statusMsg += ` (\`${State.chats.get(from).gemName}\`)`;

                return reply(statusMsg);
            }

            case "chat": {
                const persona = (rawTarget && rawTarget !== "default" ? Gems.get(rawTarget) : null) || State.PERSONA;
                State.chats.set(from, {
                    gem: persona + MD_REQ,
                    history: [],
                    gemName: rawTarget || "default"
                });
                return reply(`⚔️ *Chat AI Deployed:* Persona \`${rawTarget || "default"}\` is now monitoring all incoming traffic.`);
            }

            case "help":
            default: {
                if (!q) return reply(`🧠 *GAI COMMANDS:*\n\n• \`.gai target <num> [gem]\` - Target specific user here\n• \`.gai stalk <num> [gem]\` - Target user in all chats\n• \`.gai stop [num/all]\` - Terminate session\n• \`.gai wipe [num]\` - Clear AI memory\n• \`.gai status\` - View active sessions\n• \`.gai chat [gem]\` - AI mode for everyone here\n\n_Example: .gai Hello how are you? (One-shot)_`);
                
                // One-shot AI request
                const stub = await sock.sendMessage(from, { text: "⏳ *Processing neural link...*" }, { quoted: mek });
                const { text, err } = await askAI(q + MD_REQ);
                return sock.sendMessage(from, { text: err ? `⚠️ *API Error:* ${text}` : text, edit: stub.key });
            }
        }
    });

    /**
     * .aidecode: Explain or analyze quoted content
     */
    gmd({
        pattern: "aidecode",
        cmdname: "aidecode",
        alias: ["analyze", "explain", "vision"],
        category: "ai",
        desc: "Explain quoted text or images using high-level reasoning.",
        react: "🔍",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ Owner only.");

        const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage || mek.message?.imageMessage;
        let imgUrls = [];

        if (quoted?.imageMessage || mek.message?.imageMessage) {
            try {
                const imgMsg = quoted?.imageMessage || mek.message?.imageMessage;
                const localPath = await sock.downloadAndSaveMediaMessage(imgMsg, `tmp_v_${Date.now()}`);
                const remoteUrl = await uploadImgBB(localPath);
                if (remoteUrl) imgUrls.push(remoteUrl);
                if (fs.existsSync(localPath)) fs.unlinkSync(localPath);
            } catch (e) { console.error("[AIGems] Vision upload failed:", e.message); }
        }

        const promptText = q || (imgUrls.length ? "Analyze this image in detail and describe its contents." : "Analyze the quoted text above.");
        const stub = await sock.sendMessage(from, { text: "🔍 *Decoding...*" }, { quoted: mek });
        const { text, err } = await askAI(promptText + "\n\n*Format:* Use WhatsApp Markdown bold for headings.", imgUrls);
        
        return sock.sendMessage(from, { text: err ? `⚠️ *Analysis Failure:* ${text}` : `🔍 *DECODED ANALYSIS*\n\n${text}`, edit: stub.key });
    });

    /**
     * .aiwrite: Draft professional or creative content
     */
    gmd({
        pattern: "aiwrite",
        cmdname: "aiwrite",
        alias: ["draft", "compose"],
        category: "ai",
        desc: "Draft content (emails, stories, scripts, etc.)",
        react: "✍️",
        filename: __filename
    }, async (from, sock, context) => {
        const { q, reply, mek, isSuperUser } = context;
        if (!isSuperUser) return reply("❌ Owner only.");
        if (!q) return reply("📝 *Usage:* `.aiwrite <description of what to write>`");

        const stub = await sock.sendMessage(from, { text: "✍️ *Drafting content...*" }, { quoted: mek });
        const { text, err } = await askAI(`Write the following content with a professional flair: ${q}\n\n*Constraint:* Return the result in pure WhatsApp Markdown.`);
        
        return sock.sendMessage(from, { text: err ? `❌ *Writing Error:* ${text}` : `✍️ *AI DRAFT*\n\n${text}`, edit: stub.key });
    });

}

