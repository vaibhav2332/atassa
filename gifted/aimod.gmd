// ==============================================================================
// 4. DATABASE & PERSISTENCE
// ==============================================================================
let db = null;
if (Database) {
    try {
        const dbDir = path.dirname(CFG.DB_PATH);
        if (!fs.existsSync(dbDir)) fs.mkdirSync(dbDir, { recursive: true });
        db = new Database(CFG.DB_PATH);
        db.pragma('journal_mode = WAL');
        db.exec(`
            CREATE TABLE IF NOT EXISTS gems (
                name TEXT PRIMARY KEY,
                content TEXT NOT NULL,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            );
        `);
        console.log('[AIGems] Database ready at:', CFG.DB_PATH);
    } catch(e) { console.error('[AIGems] DB error:', e.message); db = null; }
}

const Gems = {
    get  : (n) => { try { return db?.prepare('SELECT content FROM gems WHERE name=?').get(n.toLowerCase().trim())?.content ?? null; } catch(e){ return null; } },
    save : (n, c) => { try { return !!db?.prepare('INSERT OR REPLACE INTO gems(name,content) VALUES(?,?)').run(n.toLowerCase().trim(), c)?.changes; } catch(e){ return false; } },
    del  : (n) => { try { return (db?.prepare('DELETE FROM gems WHERE name=?').run(n.toLowerCase().trim())?.changes??0)>0; } catch(e){ return false; } },
    list : () => { try { return db?.prepare('SELECT name FROM gems ORDER BY name').all().map(r=>r.name)??[]; } catch(e){ return []; } }
};

// ==============================================================================
// 5. RATE LIMITER & CIRCUIT BREAKER
// ==============================================================================
const Limiter = {
    min_q:[], hr_q:[], daily:{ai:0,img:0,err:0,day:new Date().toDateString()},
    check() {
        const n=Date.now();
        this.min_q=this.min_q.filter(t=>n-t<60000);
        this.hr_q=this.hr_q.filter(t=>n-t<3600000);
        return this.min_q.length<CFG.MAX_RPM && this.hr_q.length<CFG.MAX_RPH;
    },
    hit(type='ai'){
        const n=Date.now(); this.min_q.push(n); this.hr_q.push(n);
        const d=new Date().toDateString();
        if(d!==this.daily.day) this.daily={ai:0,img:0,err:0,day:d};
        if(type==='ai') this.daily.ai++;
        if(type==='img') this.daily.img++;
    },
    err(){ this.daily.err++; },
    stats(){
        const n=Date.now();
        return {rpm:this.min_q.filter(t=>n-t<60000).length, rph:this.hr_q.filter(t=>n-t<3600000).length, ...this.daily};
    }
};

const CB = {
    fails:0, lastFail:0, THRESH:5, TTL:300000,
    open()  { return this.fails>=this.THRESH && Date.now()-this.lastFail<this.TTL; },
    fail()  { this.fails++; this.lastFail=Date.now(); Limiter.err(); },
    ok()    { this.fails=0; },
    reset() { this.fails=0; this.lastFail=0; },
    msg()   { return ['neural link glitchy rn','signal weak on my end','connection hiccupped','brain.exe crashed lol'][Math.floor(Math.random()*4)]; }
};

// ==============================================================================
// 6. CORE AI — QuillBot SSE Streaming
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: prompt + CFG.MARKDOWN_REQ,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };
};

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { 
                        const o = JSON.parse(l.slice(6)); 
                        if (o.chunk) full += o.chunk; 
                    } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1500 * (attempt + 1)); continue; }
                CB.fail();
                return { text: '_[Internal Error: Empty Stream]_', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1')
                .replace(/\*\*(.*?)\*\*/g, '*$1*') // Convert MD bold to WA bold
                .trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            if (attempt < CFG.RETRIES - 1) await sleep(2000 * (attempt + 1));
            else { 
                CB.fail(); 
                return { text: `_Signal lost:_ ${e.message}`, err: true }; 
            }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 7. IMAGE HANDLING UTILITIES
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch(e) { 
        console.error('[AIGems] ImgBB Upload Failed:', e.message); 
        return null; 
    }
};

const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;
    const n = Math.min(opts.count || CFG.IMG_COUNT, 4);
    
    if (!Limiter.check()) return [];
    
    Limiter.hit('img');
    const _iKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
    
    for (let i = 0; i < CFG.RETRIES; i++) {
        try {
            const r = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`, {
                model, prompt, n, size, response_format: 'url'
            }, {
                headers: { 
                    'Authorization': `Bearer ${_iKey}`,
                    'Content-Type': 'application/json' 
                },
                timeout: CFG.TIMEOUT
            });
            if (r.status === 200 && r.data?.data?.length) {
                return r.data.data.map(d => d.url);
            }
        } catch(e) { 
            Limiter.err(); 
            if (i < CFG.RETRIES - 1) await sleep(1500 * (i + 1)); 
        }
    }
    return [];
};

// ==============================================================================
// 8. SESSION & TRACKING STATE
// ==============================================================================
const State = {
    dmActive: false,
    dmGem: null,
    chats: new Map(),     // Active AI in specific group
    targets: new Map(),   // Target user in specific chat
    stalkers: new Map(),  // Target user globally
    autoEnhance: false,
    DEFAULT_PROMPT: "You are a helpful and witty AI assistant. Keep responses concise and use WhatsApp markdown formatting.",
    
    addHist(ctx, role, txt) {
        if (!ctx.history) ctx.history = [];
        const timestamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        ctx.history.push(`[${timestamp}] ${role}: ${txt}`);
        if (ctx.history.length > CFG.MAX_HIST) ctx.history.shift();
    },

    getPrompt(sys, hist, input) {
        return `SYSTEM_INSTRUCTION:\n${sys}\n\nCHAT_HISTORY:\n${hist.join('\n')}\n\nCURRENT_MESSAGE:\n${input}\n\nRESPONSE:`;
    }
};

// ==============================================================================
// 9. MODULEBASE HELPERS
// ==============================================================================
const resolveContext = (arg1, args) => {
    let sock = global.conn || global.client || arg1.bot || arg1.client;
    let m = arg1;
    const allArgs = [arg1, ...args];
    allArgs.forEach(arg => {
        if (arg && typeof arg === 'object' && !Array.isArray(arg)) {
            if (typeof arg.sendMessage === 'function') sock = arg;
            if (arg.key && arg.key.remoteJid) m = arg;
        }
    });
    return { m, sock };
};

const buildSafeQuote = (m) => {
    if (!m || !m.key) return {};
    return {
        quoted: {
            key: {
                remoteJid: m.key.remoteJid,
                fromMe: m.key.fromMe,
                id: m.key.id,
                participant: m.key.participant || m.participant
            },
            message: m.message
        }
    };
};

const thinking = async (sock, jid, m, text = '⏳ _thinking..._') => {
    try {
        return await sock.sendMessage(jid, { text }, buildSafeQuote(m));
    } catch (e) { return null; }
};

const editMsg = async (sock, jid, targetMsg, newText) => {
    try {
        if (!targetMsg || !targetMsg.key) return;
        await sock.sendMessage(jid, { text: newText, edit: targetMsg.key });
    } catch (e) {
        await sock.sendMessage(jid, { text: newText }, buildSafeQuote(targetMsg));
    }
};

// ==============================================================================
// 10. COMMAND REGISTRATION
// ==============================================================================
if (typeof commandRegister === 'function') {

    // --- PERSONA MANAGEMENT (.gem) ---
    commandRegister({
        pattern: "gem",
        cmdname: "gem",
        alias: ["persona", "gems"],
        category: "ai",
        desc: "Gem persona vault management.",
        react: "💎",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const text = (m.body || m.text || "").split(/\s+/).slice(1).join(" ").trim();
        const parts = text.split(" ");
        const sub = parts[0]?.toLowerCase();

        if (sub === 'save' || sub === 'create') {
            const name = parts[1]?.toLowerCase();
            const content = parts.slice(2).join(" ");
            if (!name || !content) return sock.sendMessage(jid, { text: "📝 *.gem save <name> <prompt>*" }, buildSafeQuote(m));
            Gems.save(name, content);
            return sock.sendMessage(jid, { text: `✅ Gem *${name}* stored in vault.` }, buildSafeQuote(m));
        }

        if (sub === 'list') {
            const list = Gems.list();
            if (!list.length) return sock.sendMessage(jid, { text: "📭 Vault is empty." }, buildSafeQuote(m));
            return sock.sendMessage(jid, { text: `📚 *Gem Vault:*\n\n${list.map(g => `• \`${g}\``).join('\n')}` }, buildSafeQuote(m));
        }

        if (sub === 'delete' || sub === 'del') {
            const name = parts[1]?.toLowerCase();
            if (Gems.del(name)) return sock.sendMessage(jid, { text: `🗑️ Gem *${name}* removed.` }, buildSafeQuote(m));
            return sock.sendMessage(jid, { text: "❌ Gem not found." }, buildSafeQuote(m));
        }

        sock.sendMessage(jid, { 
            text: "💎 *Gem Vault Commands*\n\n• *.gem save <name> <prompt>*\n• *.gem list*\n• *.gem delete <name>*\n• *.gem info <name>*" 
        }, buildSafeQuote(m));
    });

    // --- AI TRACKING (.stalk / .target) ---
    commandRegister({
        pattern: "stalk",
        cmdname: "stalk",
        alias: ["watch"],
        category: "ai",
        desc: "Auto-reply to a user globally.",
        react: "👁️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = (m.body || m.text || "").split(/\s+/).slice(1).join(" ").trim();
        const parts = q.split(" ");
        const target = parts[0]?.replace(/[^0-9]/g, '') + "@s.whatsapp.net";
        const gemName = parts[1]?.toLowerCase();

        if (!parts[0]) return sock.sendMessage(jid, { text: "📝 *.stalk <number> [gem_name]*" }, buildSafeQuote(m));
        
        const persona = gemName ? (Gems.get(gemName) || State.DEFAULT_PROMPT) : State.DEFAULT_PROMPT;
        State.stalkers.set(target, { gem: persona, history: [], gemName: gemName || 'default' });
        
        sock.sendMessage(jid, { text: `👁️ *Global Stalk Active*\nTarget: @${parts[0]}\nGem: *${gemName || 'Default'}*`, mentions: [target] }, buildSafeQuote(m));
    });

    commandRegister({
        pattern: "target",
        cmdname: "target",
        alias: ["botuser"],
        category: "ai",
        desc: "Auto-reply to a user in this chat only.",
        react: "🎯",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = (m.body || m.text || "").split(/\s+/).slice(1).join(" ").trim();
        const parts = q.split(" ");
        const target = parts[0]?.replace(/[^0-9]/g, '') + "@s.whatsapp.net";
        const gemName = parts[1]?.toLowerCase();

        if (!parts[0]) return sock.sendMessage(jid, { text: "📝 *.target <number> [gem_name]*" }, buildSafeQuote(m));

        const persona = gemName ? (Gems.get(gemName) || State.DEFAULT_PROMPT) : State.DEFAULT_PROMPT;
        State.targets.set(target, { gem: persona, history: [], chatId: jid, gemName: gemName || 'default' });

        sock.sendMessage(jid, { text: `🎯 *Chat Target Locked*\nTarget: @${parts[0]}\nGem: *${gemName || 'Default'}*`, mentions: [target] }, buildSafeQuote(m));
    });

    // --- STATUS MONITOR ---
    commandRegister({
        pattern: "apimon",
        cmdname: "apimon",
        alias: ["aistatus"],
        category: "ai",
        desc: "Monitor AI API health.",
        react: "📊",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const stats = Limiter.stats();
        const cbStatus = CB.open() ? "🔴 OPEN (Tripped)" : "🟢 CLOSED (Healthy)";

        const report = `📊 *AI Reliability Monitor*\n\n` +
            `*Circuit Breaker:* ${cbStatus}\n` +
            `*RPM (1m):* ${stats.rpm} / ${CFG.MAX_RPM}\n` +
            `*RPH (1h):* ${stats.rph} / ${CFG.MAX_RPH}\n\n` +
            `*Daily Totals:*\n` +
            `• AI Calls: ${stats.ai}\n` +
            `• Images: ${stats.img}\n` +
            `• Errors: ${stats.err}\n\n` +
            `_Date: ${stats.day}_`;

        sock.sendMessage(jid, { text: report }, buildSafeQuote(m));
    });

}

// ==============================================================================
// 11. EVENT LISTENER FOR AUTO-REPLY LOGIC
// ==============================================================================
const setupWatcher = (sock) => {
    if (!sock?.ev) return;
    
    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        const msg = messages[0];
        if (!msg.message || msg.key.fromMe) return;

        const sender = msg.key.participant || msg.key.remoteJid;
        const chatId = msg.key.remoteJid;
        const body = msg.message.conversation || msg.message.extendedTextMessage?.text || "";

        let activeSession = null;

        // Priority 1: Stalkers (Global)
        if (State.stalkers.has(sender)) {
            activeSession = State.stalkers.get(sender);
        }
        // Priority 2: Targets (Chat Specific)
        else if (State.targets.has(sender)) {
            const tgt = State.targets.get(sender);
            if (tgt.chatId === chatId) activeSession = tgt;
        }
        // Priority 3: Explicit Chat AI (.gai chat)
        else if (State.chats.has(chatId)) {
            activeSession = State.chats.get(chatId);
        }

        if (activeSession) {
            State.addHist(activeSession, "User", body);
            const prompt = State.getPrompt(activeSession.gem, activeSession.history, body);
            
            // Artificial delay for realism
            await sleep(1500 + Math.random() * 2000);
            await sock.sendPresenceUpdate('composing', chatId);

            const { text, err } = await askAI(prompt);
            
            if (!err) {
                State.addHist(activeSession, "AI", text);
                await sock.sendMessage(chatId, { text }, { quoted: msg });
            }
            await sock.sendPresenceUpdate('paused', chatId);
        }
    });
};

// Initialize watcher when bot connects
setTimeout(() => {
    const sock = global.conn || global.client;
    if (sock) setupWatcher(sock);
}, 10000);
// --- AITRANSLATE: TRANSLATION ---
if (typeof commandRegister === 'function') {
    commandRegister({
        pattern: "aitranslate",
        cmdname: "aitranslate",
        alias: ["gitrans", "aitrans", "translate"],
        category: "ai",
        desc: "AI translation with markdown formatting.",
        react: "🌐",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const text = args.join(" ");
        const parts = text.split(" ");
        const targetLang = parts[0];
        const query = parts.slice(1).join(" ");

        if (!targetLang || !query) {
            return sock.sendMessage(jid, { text: "📝 *Usage:* `.aitranslate <language> <text>`\nExample: `.aitranslate French Hello, how are you?`" }, buildSafeQuote(m));
        }

        const prompt = `Translate the following text to ${targetLang}. Provide the response in WhatsApp markdown. Ensure only the translation is returned.\n\nText: ${query}`;
        const { text: result, err } = await askAI(prompt);

        const response = err ? `❌ *Error:* ${result}` : `🌐 *Translation (${targetLang})*\n\n${result}`;
        await sock.sendMessage(jid, { text: response }, buildSafeQuote(m));
    });

    // --- AIWRITE: CREATIVE WRITING ---
    commandRegister({
        pattern: "aiwrite",
        cmdname: "aiwrite",
        alias: ["compose", "draft", "write"],
        category: "ai",
        desc: "AI creative writing tool.",
        react: "✍️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const input = args.join(" ");
        const parts = input.split(" ");
        const type = parts[0]?.toLowerCase();
        const topic = parts.slice(1).join(" ");

        const templates = {
            roast: `Write a savage but funny WhatsApp roast about: ${topic}. Use bolding for impact.`,
            bio: `Write a catchy WhatsApp bio for: ${topic}. Use emojis and italics.`,
            story: `Write a short, gripping story about: ${topic}. Use markdown for narrative structure.`,
            email: `Write a professional email regarding: ${topic}. Use monospacing for key details.`,
            caption: `Write 3 creative Instagram/WhatsApp captions for: ${topic}.`
        };

        if (!templates[type] || !topic) {
            return sock.sendMessage(jid, { text: `✍️ *AI Writer Modes:*\n${Object.keys(templates).map(t => `• \`${t}\``).join("\n")}\n\n*Usage:* \`.aiwrite <type> <topic>\`` }, buildSafeQuote(m));
        }

        const prompt = `${templates[type]}\n\nIMPORTANT: Respond using WhatsApp markdown formatting.`;
        const { text: result, err } = await askAI(prompt);

        const response = err ? `❌ *Error:* ${result}` : `✍️ *AI ${type.toUpperCase()}*\n\n${result}`;
        await sock.sendMessage(jid, { text: response }, buildSafeQuote(m));
    });

    // --- AIDECODE: VISION & ANALYSIS ---
    commandRegister({
        pattern: "aidecode",
        cmdname: "aidecode",
        alias: ["explain", "analyze", "inspect"],
        category: "ai",
        desc: "Explain quoted text or analyze images.",
        react: "🔍",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        const query = args.join(" ") || "Explain this in detail.";

        let imageUrls = [];
        if (quoted?.imageMessage) {
            try {
                const path = await sock.downloadAndSaveMediaMessage(quoted.imageMessage);
                const url = await uploadImgBB(path);
                if (url) imageUrls.push(url);
                if (fs.existsSync(path)) fs.unlinkSync(path);
            } catch (e) { console.error("[AIGems] Vision Error:", e); }
        }

        const contextText = quoted?.conversation || quoted?.extendedTextMessage?.text || "";
        const prompt = `Analyze the following context/image: "${contextText}".\nUser Query: ${query}\n\nRespond in clean WhatsApp markdown.`;

        const { text: result, err } = await askAI(prompt, imageUrls);
        const response = err ? `❌ *Analysis Failed:* ${result}` : `🔍 *AI Analysis*\n\n${result}`;
        await sock.sendMessage(jid, { text: response }, buildSafeQuote(m));
    });

    // --- AUTOENHANCE: SILENT SELF-CORRECTION ---
    commandRegister({
        pattern: "autoenhance",
        cmdname: "autoenhance",
        alias: ["smartedit"],
        category: "ai",
        desc: "Toggle silent AI correction of your own messages.",
        react: "✨",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const state = args[0]?.toLowerCase();

        if (state === "on") {
            State.autoEnhance = true;
            return sock.sendMessage(jid, { text: "✨ *Auto-Enhance:* ✅ ENABLED\nYour outgoing messages will be silently improved for grammar and clarity." }, buildSafeQuote(m));
        } else if (state === "off") {
            State.autoEnhance = false;
            return sock.sendMessage(jid, { text: "✨ *Auto-Enhance:* ❌ DISABLED" }, buildSafeQuote(m));
        }

        const current = State.autoEnhance ? "✅ ENABLED" : "❌ DISABLED";
        await sock.sendMessage(jid, { text: `✨ *Auto-Enhance Status:* ${current}\nUse \`.autoenhance on/off\` to toggle.` }, buildSafeQuote(m));
    });

    // --- STALK: GLOBAL SENDER TRACKING (CORRECTED) ---
    commandRegister({
        pattern: "stalk",
        cmdname: "stalk",
        alias: ["watch"],
        category: "ai",
        desc: "AI auto-replies to a specific user across all chats.",
        react: "👁️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const text = args.join(" ");
        const parts = text.split(" ");
        
        const num = parts[0]?.replace(/[^0-9]/g, "");
        const gemName = parts[1];

        if (!num) return sock.sendMessage(jid, { text: "📝 *Usage:* `.stalk <number> [gem_name]`" }, buildSafeQuote(m));

        const target = num + "@s.whatsapp.net";
        const persona = gemName ? (Gems.get(gemName) || State.DEFAULT_PROMPT) : State.DEFAULT_PROMPT;

        State.stalkers.set(target, { 
            gem: persona, 
            history: [], 
            gemName: gemName || "default" 
        });

        await sock.sendMessage(jid, { 
            text: `👁️ *Global Stalk Active*\nTarget: @${num}\nGem: *${gemName || "Default"}*\n\n_I will now respond to this user wherever they speak._`,
            mentions: [target]
        }, buildSafeQuote(m));
    });

    // --- STOP: ALL AI ACTIVITIES ---
    commandRegister({
        pattern: "aistop",
        cmdname: "aistop",
        alias: ["stopai", "clearai"],
        category: "ai",
        desc: "Kill all active AI sessions and stalkers.",
        react: "🛑",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;

        State.chats.clear();
        State.targets.clear();
        State.stalkers.clear();
        State.dmActive = false;

        await sock.sendMessage(jid, { text: "🛑 *AI Systems Offline*\nAll active sessions, targets, and stalkers have been cleared." }, buildSafeQuote(m));
    });
}

// ==============================================================================
// 12. ENHANCED WATCHER LOGIC (AUTO-ENHANCE + MARKDOWN)
// ==============================================================================
const startGlobalWatcher = (sock) => {
    if (!sock?.ev) return;

    sock.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        const m = messages[0];
        if (!m.message) return;

        const jid = m.key.remoteJid;
        const isMe = m.key.fromMe;
        const body = m.message.conversation || m.message.extendedTextMessage?.text || "";

        // 1. SILENT AUTO-ENHANCE (Outgoing)
        if (isMe && State.autoEnhance && body.length > 15 && !body.startsWith(".")) {
            const { text: enhanced, err } = await askAI(`Fix only the grammar, spelling, and flow of this message. Keep it natural. Respond in WhatsApp markdown. Return ONLY the text:\n\n${body}`);
            if (!err && enhanced.trim() !== body.trim()) {
                await sock.sendMessage(jid, { text: enhanced, edit: m.key });
            }
            return;
        }

        // 2. INCOMING AI RESPONSE LOGIC
        if (isMe) return;
        const sender = m.key.participant || m.key.remoteJid;
        let session = null;

        if (State.stalkers.has(sender)) session = State.stalkers.get(sender);
        else if (State.targets.has(sender) && State.targets.get(sender).chatId === jid) session = State.targets.get(sender);
        else if (State.chats.has(jid)) session = State.chats.get(jid);
        else if (!jid.endsWith('@g.us') && State.dmActive) {
            if (!State.dmSessions.has(sender)) State.dmSessions.set(sender, { gem: State.dmGem || State.DEFAULT_PROMPT, history: [], gemName: "dm" });
            session = State.dmSessions.get(sender);
        }

        if (session) {
            State.addHist(session, "User", body);
            const sysPrompt = `${session.gem}\n\nIMPORTANT: You are participating in a WhatsApp chat. Use WhatsApp markdown (bolding, italics). Keep it concise.`;
            const fullPrompt = State.getPrompt(sysPrompt, session.history, body);

            await sock.sendPresenceUpdate('composing', jid);
            const { text, err } = await askAI(fullPrompt);
            await sock.sendPresenceUpdate('paused', jid);

            if (!err) {
                State.addHist(session, "AI", text);
                await sock.sendMessage(jid, { text }, { quoted: m });
            }
        }
    });
};

// Auto-boot sequence for Atassa Framework
const initAtassa = () => {
    const sock = global.conn || global.client;
    if (sock) {
        startGlobalWatcher(sock);
        console.log("[AIGems] Atassa Framework Watcher Initialized.");
    } else {
        setTimeout(initAtassa, 5000);
    }
};

initAtassa();
// ==============================================================================
// 13. CORE AI ENGINE — QuillBot SSE Implementation
// ==============================================================================

/**
 * askAI: High-performance QuillBot SSE implementation.
 * @param {string} prompt - The user input or system-wrapped prompt.
 * @param {Array} imgUrls - List of image URLs for vision tasks.
 * @returns {Promise<{text: string, err: boolean}>}
 */
const askAI = async (prompt, imgUrls = []) => {
    // 1. Circuit Breaker & Rate Limit Check
    if (CB.open()) return { text: CB.msg(), err: true };
    if (!Limiter.check()) return { text: "_system: rate limit reached. try again in a minute._", err: true };

    // 2. Formatting Reinforcement (WhatsApp Markdown)
    const formattedPrompt = `
[SYSTEM INSTRUCTION]
Respond ONLY in WhatsApp Markdown:
- Use *bold* for emphasis, titles, or key points.
- Use _italics_ for quotes, side-notes, or actions.
- Use \`\`\`monospace\`\`\` for code blocks, technical data, or logs.
- Never use HTML tags or '#' headers.
- Keep the response concise and natural.
[/SYSTEM INSTRUCTION]

${prompt}`;

    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: formattedPrompt,
            files: imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'image.jpg' }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat' },
        tools: []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const response = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout: CFG.TIMEOUT,
                    responseType: 'stream' 
                }
            );

            // 3. SSE Stream Processing
            const resultText = await new Promise((resolve, reject) => {
                let accumulated = '';
                const timer = setTimeout(() => resolve(accumulated), CFG.TIMEOUT - 2000);
                
                response.data.on('data', chunk => {
                    const lines = chunk.toString().split('\n');
                    for (const line of lines) {
                        const trimmed = line.trim();
                        if (trimmed.startsWith('data: {') && trimmed.includes('"chunk"')) {
                            try {
                                const data = JSON.parse(trimmed.slice(6));
                                if (data.chunk) accumulated += data.chunk;
                            } catch (e) { /* silent parse fail */ }
                        }
                    }
                });

                response.data.on('end', () => {
                    clearTimeout(timer);
                    resolve(accumulated);
                });

                response.data.on('error', (err) => {
                    clearTimeout(timer);
                    reject(err);
                });
            });

            if (!resultText.trim()) {
                if (attempt < CFG.RETRIES - 1) {
                    await new Promise(r => setTimeout(r, 1500));
                    continue;
                }
                return { text: "_err: session timed out or returned empty response._", err: true };
            }

            CB.ok();
            // Sanitize potential AI artifacting (LaTeX leftovers)
            const cleanResponse = resultText
                .replace(/\\\(|\\\)/g, '')
                .replace(/\\\[|\\\]/g, '')
                .trim();

            return { text: cleanResponse, err: false };

        } catch (error) {
            Limiter.err();
            if (attempt === CFG.RETRIES - 1) {
                CB.fail();
                return { text: `_signal failure: ${error.message}_`, err: true };
            }
            await new Promise(r => setTimeout(r, 1000 * (attempt + 1)));
        }
    }
};

// ==============================================================================
// 14. ENHANCED STALK & TARGET COMMANDS (ModuleBase Registry)
// ==============================================================================

if (typeof commandRegister === 'function') {

    /**
     * Target Command: Locks the AI onto a specific user in the current chat.
     */
    commandRegister({
        pattern: "target",
        cmdname: "target",
        alias: ["lock", "botuser"],
        category: "ai",
        desc: "Force the AI to respond to every message from a specific user.",
        react: "🎯",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");
        
        let targetNum = m.message?.extendedTextMessage?.contextInfo?.participant || q.split(" ")[0];
        if (!targetNum) return sock.sendMessage(jid, { text: "❌ *Error:* Tag a user or provide a number.\nUsage: `.target @user [gem_name]`" }, buildSafeQuote(m));

        targetNum = targetNum.replace(/[^0-9]/g, "") + "@s.whatsapp.net";
        const gemName = q.split(" ")[1] || "default";
        const gemContent = (gemName !== "default" ? Gems.get(gemName) : null) || State.DEFAULT_PROMPT;

        State.targets.set(targetNum, {
            gem: gemContent,
            history: [],
            chatId: jid,
            gemName: gemName
        });

        await sock.sendMessage(jid, { 
            text: `🎯 *Target Locked*\n*User:* @${targetNum.split("@")[0]}\n*Persona:* \`${gemName}\`\n_AI will now intercept all their messages in this chat._`,
            mentions: [targetNum]
        }, buildSafeQuote(m));
    });

    /**
     * Stalk Command: Locks the AI onto a user globally (across all chats).
     */
    commandRegister({
        pattern: "stalk",
        cmdname: "stalk",
        alias: ["globalbot", "hunt"],
        category: "ai",
        desc: "Force the AI to follow and respond to a user in every chat they appear in.",
        react: "🕵️",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");

        let stalkNum = m.message?.extendedTextMessage?.contextInfo?.participant || q.split(" ")[0];
        if (!stalkNum) return sock.sendMessage(jid, { text: "❌ *Error:* Tag a user to stalk.\nUsage: `.stalk @user [gem_name]`" }, buildSafeQuote(m));

        stalkNum = stalkNum.replace(/[^0-9]/g, "") + "@s.whatsapp.net";
        const gemName = q.split(" ")[1] || "default";
        const gemContent = (gemName !== "default" ? Gems.get(gemName) : null) || State.DEFAULT_PROMPT;

        State.stalkers.set(stalkNum, {
            gem: gemContent,
            history: [],
            gemName: gemName
        });

        await sock.sendMessage(jid, {
            text: `🕵️ *Global Stalker Active*\n*Tracking:* @${stalkNum.split("@")[0]}\n*Persona:* \`${gemName}\`\n_AI will follow this user into every group and DM._`,
            mentions: [stalkNum]
        }, buildSafeQuote(m));
    });

    /**
     * Untarget / Unstalk
     */
    commandRegister({
        pattern: "untarget",
        cmdname: "untarget",
        alias: ["unstalk", "release"],
        category: "ai",
        desc: "Release a user from AI targeting/stalking.",
        react: "🔓",
        filename: __filename
    }, async (arg1, ...args) => {
        const { m, sock } = resolveContext(arg1, args);
        const jid = m.key.remoteJid;
        const q = args.join(" ");

        let num = m.message?.extendedTextMessage?.contextInfo?.participant || q.replace(/[^0-9]/g, "");
        if (!num) return sock.sendMessage(jid, { text: "❌ *Error:* Provide number or tag user." }, buildSafeQuote(m));
        
        num = num.includes("@") ? num : num + "@s.whatsapp.net";
        const removedTarget = State.targets.delete(num);
        const removedStalk = State.stalkers.delete(num);

        if (removedTarget || removedStalk) {
            await sock.sendMessage(jid, { text: `🔓 *Released:* @${num.split("@")[0]} is no longer being tracked.`, mentions: [num] }, buildSafeQuote(m));
        } else {
            await sock.sendMessage(jid, { text: `❌ *Error:* User was not being targeted.` }, buildSafeQuote(m));
        }
    });

}

// ==============================================================================
// 15. RUNTIME STATE HELPERS
// ==============================================================================

const State = {
    dmActive: false,
    dmGem: null,
    chats: new Map(),
    targets: new Map(),
    stalkers: new Map(),
    dmSessions: new Map(),
    autoEnhance: false,
    DEFAULT_PROMPT: "You are a helpful and witty WhatsApp assistant. Keep responses brief.",
    
    /**
     * addHist: Manages conversation memory limits.
     */
    addHist(ctx, role, txt) {
        if (!ctx.history) ctx.history = [];
        const timestamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
        ctx.history.push(`[${timestamp}] ${role}: ${txt}`);
        if (ctx.history.length > 20) ctx.history.shift();
    },

    /**
     * getPrompt: Constructs the final payload for the AI engine.
     */
    getPrompt(sys, hist, input) {
        return `SYSTEM:\n${sys}\n\nCONVERSATION_HISTORY:\n${hist.join('\n')}\n\nLATEST_USER_MESSAGE: ${input}\nAI_RESPONSE:`;
    }
};
// ==============================================================================
// 16. MEDIA INFRASTRUCTURE (ImgBB & Infip)
// ==============================================================================

/**
 * uploadImgBB: High-speed image hosting for vision-based AI tasks.
 * Uses the key from CFG and returns a direct JPG link.
 */
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch (e) { 
        console.error('[AIGems] ImgBB Upload Error:', e.message); 
        return null; 
    }
};

/**
 * Infip API Manager: Key pooling and model validation logic.
 */
let _iKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
let _iOk = false;
const _iCache = new Map();

const _iHdr = () => ({ 
    'Authorization': `Bearer ${_iKey}`, 
    'Content-Type': 'application/json' 
});

const ensureInfip = async () => {
    if (_iOk) return true;
    try { 
        const r = await axios.get(`${CFG.INFIP_URL}/v1/models`, { headers: _iHdr(), timeout: 10000 }); 
        if (r.status === 200) { _iOk = true; return true; } 
    } catch (e) { /* silent fail */ }
    try { 
        const r = await axios.post(`${CFG.INFIP_URL}/v1/api-keys`, {}, { timeout: 10000 }); 
        if (r.data?.api_key) { _iKey = r.data.api_key; _iOk = true; return true; } 
    } catch (e) { /* silent fail */ }
    return false;
};

/**
 * generateImage: Core engine for multi-model AI image generation.
 * Implements _iCache to prevent duplicate credit consumption for identical prompts.
 */
const generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size = opts.size || CFG.IMG_SIZE;
    const n = Math.min(opts.count || CFG.IMG_COUNT, 4);
    const quality = opts.quality || CFG.IMG_QUALITY;
    const style = opts.style || CFG.IMG_STYLE;

    const cacheId = `${model}|${size}|${prompt.substring(0, 80)}`;
    const hit = _iCache.get(cacheId);
    if (hit && (Date.now() - hit.ts < 3600000)) return hit.urls;

    await ensureInfip();
    for (let i = 0; i < CFG.RETRIES; i++) {
        try {
            const res = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`, {
                model, prompt, n, size, response_format: 'url', quality, style
            }, { headers: _iHdr(), timeout: CFG.TIMEOUT });

            if (res.status === 200 && res.data?.data?.length) {
                const urls = res.data.data.map(d => d.url);
                _iCache.set(cacheId, { urls, ts: Date.now() });
                return urls;
            }
        } catch (e) {
            if (i === CFG.RETRIES - 1) console.error('[AIGems] Gen Error:', e.message);
            await new Promise(r => setTimeout(r, 1500 * (i + 1)));
        }
    }
    return [];
};

// ==============================================================================
// 17. REFINED AI ENGINE (QuillBot SSE + Markdown)
// ==============================================================================

/**
 * askAI: Stream-parsed connection to QuillBot with vision and history support.
 * Forces response into WhatsApp Markdown format.
 */
const askAI = async (prompt, imgUrls = []) => {
    const payload = {
        stream: true,
        message: {
            role: 'user',
            content: `${prompt}\n\n*System Instruction:* ALWAYS format your output using WhatsApp Markdown (Bold for emphasis, lists for points, monospace for code/specs). Keep it clean.`,
            files: imgUrls.map(u => ({ url: u, mimeType: 'image/jpeg', name: 'input_vision.jpg' }))
        },
        product: 'ai-chat',
        prompt: { id: 'ai_chat' },
        tools: []
    };

    try {
        const res = await axios.post(
            'https://quillbot.com/api/raven/quill-chat/responses',
            payload,
            {
                headers: { ...CFG.QB_HEADERS, Cookie: Object.entries(CFG.QB_COOKIES).map(([k,v]) => `${k}=${v}`).join('; ') },
                timeout: CFG.TIMEOUT,
                responseType: 'stream'
            }
        );

        let output = '';
        return new Promise((resolve, reject) => {
            const timer = setTimeout(() => resolve({ text: output || 'Signal lost...', err: true }), CFG.TIMEOUT - 2000);
            res.data.on('data', chunk => {
                const lines = chunk.toString().split('\n');
                for (const line of lines) {
                    if (line.startsWith('data: {')) {
                        try {
                            const data = JSON.parse(line.slice(6));
                            if (data.chunk) output += data.chunk;
                        } catch (e) {}
                    }
                }
            });
            res.data.on('end', () => {
                clearTimeout(timer);
                const result = output.replace(/\\\(|\\\)/g, '').replace(/\\\[|\\\]/g, '').replace(/\\([a-zA-Z])/g, '$1').trim();
                resolve({ text: result, err: false });
            });
            res.data.on('error', e => { 
                clearTimeout(timer); 
                reject({ text: e.message, err: true }); 
            });
        });
    } catch (e) {
        return { text: `Neural link error: ${e.message}`, err: true };
    }
};

