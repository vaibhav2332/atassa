gmd({
    pattern: 'stalklist', cmdname: 'stalklist',
    category: 'ai', desc: 'Lists all globally stalked targets.', react: '­¤ōŗ', filename: __filename
}, async (from, Gifted, conText) => {
    const { isSuperUser, reply } = conText;
    if (!isSuperUser) return reply('ŌØī *Owner only.*');
    if (State.stalkers.size === 0) return reply('­¤ōŗ *No active stalkers.*');
    let listMsg = '­¤ōŗ *Active AI Stalking Targets:*\n\n';
    State.stalkers.forEach((data, jid) => {
        listMsg += `ŌĆó @${jid.split('@')[0]} (Gem: \`${data.gemName}\`)\n`;
    });
    return reply(listMsg);
});

gmd({
    pattern: 'stalkoff', cmdname: 'stalkoff',
    category: 'ai', desc: 'Remove a target from global stalking.', react: '­¤ō┤', filename: __filename
}, async (from, Gifted, conText) => {
    const { q, isSuperUser, reply } = conText;
    if (!isSuperUser) return reply('ŌØī *Owner only.*');
    const num = q.trim().replace(/[^0-9]/g, '');
    if (!num) return reply('­¤ōØ `.stalkoff <number>`');
    const jid = num + '@s.whatsapp.net';
    if (State.stalkers.delete(jid)) return reply(`Ō£ģ *Removed @${num} from stalking list.*`);
    return reply(`ŌØī *Target @${num} not found in stalker list.*`);
});

gmd({
    pattern: 'aireboot', cmdname: 'aireboot',
    category: 'ai', desc: 'Hard reset the AI system and watcher.', react: '­¤öä', filename: __filename
}, async (from, Gifted, conText) => {
    const { isSuperUser, reply } = conText;
    if (!isSuperUser) return reply('ŌØī *Owner only.*');
    _watchDone = false;
    const G = global.conn || global.client;
    if (G) attachWatcher(G);
    return reply('­¤öä *AI System rebooted and Watcher re-attached.*');
});

