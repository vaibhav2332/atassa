// ==============================================================================
// 23. FINAL BOOTLOADER & PROCESS LISTENERS
// ==============================================================================

/**
 * Automated Cache Maintenance.
 * Clears old image variations and inactive ephemeral sessions.
 */
setInterval(() => {
    const now = Date.now();
    // Flush image cache older than 3 hours
    for (const [key, val] of _iCache.entries()) {
        if (now - val.ts > 10800000) _iCache.delete(key);
    }
    // Prune empty ephemeral sessions
    State.dmSessions.forEach((sess, jid) => {
        if (sess.history.length === 0) State.dmSessions.delete(jid);
    });
}, 3600000);

/**
 * Critical Shutdown Handlers.
 * Ensures the SQLite database connection is finalized on process termination.
 */
const finalizeExit = () => {
    if (db) {
        try { 
            db.close(); 
            console.log('[AIGems] SQLite database connection closed safely.'); 
        } catch (err) {}
    }
};

process.on('SIGINT', () => { finalizeExit(); process.exit(0); });
process.on('SIGTERM', () => { finalizeExit(); process.exit(0); });

