        gem: State.dmGem || State.PERSONA,
        mood: 'natural',
        history: [],
        gemName: 'stalker-mode'
    });

    return reply(`👁️ *Stalk Protocol Active:* Intercepting all messages from @${target} across all chats.`, { mentions: [jid] });
});

gmd({
    pattern: 'target',
    cmdname: 'target',
    aliases: ['lock'],
    category: 'ai',
    desc: 'Track a user within this specific chat only.',
    react: '🎯',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused.*');

    let target = q.replace(/[^0-9]/g, '');
    const quoted = m.message?.extendedTextMessage?.contextInfo?.participant;
    if (!target && quoted) target = quoted.replace(/[^0-9]/g, '');

    if (!target) return reply('🎯 *Target Protocol:* Provide a number or reply to a message.');

    const jid = `${target}@s.whatsapp.net`;
    
    if (State.targets.has(jid)) {
        State.targets.delete(jid);
        return reply(`❌ *Target Released:* Ceased auto-replies for @${target} in this chat.`);
    }

    State.targets.set(jid, {
        gem: State.dmGem || State.PERSONA,
        mood: 'natural',
        history: [],
        chatId: from,
        gemName: 'target-mode'
    });

    return reply(`🎯 *Target Locked:* Auto-replying to @${target} exclusively in this thread.`, { mentions: [jid] });
});

// ==============================================================================
// 29. SYSTEM RE-INITIALIZATION FOR WATCHER
// ==============================================================================
// (Logic from previous chunk continues to handle the events)
// PHASE 6 COMPLETE. Moving to Phase 7: Productivity Tools & Admin AI.
// ==============================================================================
// 30. THE MASTER WATCHER (EVENT INTERCEPTOR)
// ==============================================================================

/**
 * @function Watchdog
 * @description The primary interceptor for real-time message analysis.
 *              Detects stalked users and active targets to trigger AI responses.
 */
const Watchdog = (Gifted) => {
    if (!Gifted || !Gifted.ev) return;

    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify' && type !== 'append') return;

        for (const msg of messages) {
            try {
                // 1. Basic Validation
                if (!msg.message || msg.key.fromMe || msg.key.remoteJid === 'status@broadcast') continue;

                const remoteJid = msg.key.remoteJid;
                const sender = msg.key.participant || remoteJid;
                const isGrp = remoteJid.endsWith('@g.us');
                
                // 2. Content Extraction (Supports Text & Image Captions)
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || 
                             msg.message.videoMessage?.caption || '';

                // Ignore command triggers to prevent recursive loops
                if (/^[.!#/\+]/.test(body)) continue;

                // 3. Resolve Session (Hierarchical Priority)
                let sess = null;
                let contextMode = '';

                // A. Stalker (Highest Priority - Global)
                if (State.stalkers.has(sender)) {
                    sess = State.stalkers.get(sender);
                    contextMode = 'STALK';
                } 
                // B. Target (Locked to Specific Chat)
                else if (State.targets.has(sender)) {
                    const targetData = State.targets.get(sender);
                    if (!targetData.chatId || targetData.chatId === remoteJid) {
                        sess = targetData;
                        contextMode = 'TARGET';
                    }
                } 
                // C. Active Chat Intelligence
                else if (isGrp && State.chats.has(remoteJid)) {
                    sess = State.chats.get(remoteJid);
                    contextMode = 'CHAT';
                } 
                // D. DM Auto-Pilot
                else if (!isGrp && State.dmActive) {
                    if (!State.dmSessions.has(sender)) {
                        State.dmSessions.set(sender, {
                            gem: State.dmGem || State.PERSONA,
                            history: [],
                            gemName: 'dm_pilot'
                        });
                    }
                    sess = State.dmSessions.get(sender);
                    contextMode = 'DM';
                }

                if (!sess) continue;

                // 4. Presence & Simulation Logic
                setImmediate(async () => {
                    try {
                        // Human typing simulation (30ms per character, capped at 4s)
                        const typingDelay = Math.min(body.length * 30, 4000) + 800;
                        await sleep(typingDelay);
                        
                        // Signal typing activity
                        try { await Gifted.sendPresenceUpdate('composing', remoteJid); } catch (_) {}

                        // Handle Visual Context for the Watcher
                        let visUrls = [];
                        if (msg.message.imageMessage) {
                            const tPath = path.join(__dirname, '..', 'gift', `wtch_${Date.now()}.jpg`);
                            const buffer = await Gifted.downloadMediaMessage({ message: msg.message });
                            fs.writeFileSync(tPath, buffer);
                            const url = await uploadImgBB(tPath);
                            if (url) visUrls.push(url);
                            if (fs.existsSync(tPath)) fs.unlinkSync(tPath);
                        }

                        // Update Conversation Memory
                        State.addHist(sess, 'User', body || '[Visual Input]');

                        // Construct Final Prompt with Markdown Enforcement
                        const systemDirective = `${sess.gem}\n\n[MODE: ${contextMode}]\n*RULE:* Use WhatsApp Markdown only.\n*RULE:* Keep responses under 200 words.\n*RULE:* Be human, witty, and contextual.`;
                        const finalPrompt = State.buildPrompt(systemDirective, sess.history, body);

                        const { text, err } = await askAI(finalPrompt, visUrls);
                        
                        try { await Gifted.sendPresenceUpdate('paused', remoteJid); } catch (_) {}

                        if (err || !text) return;

                        // Persist AI response in history
                        State.addHist(sess, 'AI', text);

                        // Send the response as a quoted reply
                        const replyOpt = {
                            quoted: {
                                key: {
                                    remoteJid: msg.key.remoteJid,
                                    fromMe: false,
                                    id: msg.key.id,
                                    participant: msg.key.participant
                                },
                                message: msg.message
                            }
                        };

                        await Gifted.sendMessage(remoteJid, { text: markdownHelper.applyFormatting(text) }, replyOpt);

                    } catch (watchErr) {
                        console.error(`[Watchdog.${contextMode}] Interaction Failure:`, watchErr.message);
                    }
                });

            } catch (globalErr) {
                console.error('[MasterWatcher] Fatal Error:', globalErr.message);
            }
        }
    });
};

// Initialize the watchdog on boot
const setupWatcher = () => {
    const client = global.conn || global.client;
    if (client) {
        Watchdog(client);
        console.log('🛡️ [AIGems] Master Watcher initialized.');
    } else {
        setTimeout(setupWatcher, 5000);
    }
};
setupWatcher();

// ==============================================================================
// 31. .aisearch — REAL-TIME KNOWLEDGE INJECTION
// ==============================================================================

gmd({
    pattern: 'aisearch',
    cmdname: 'aisearch',
    aliases: ['google', 'web', 'fetch'],
    category: 'ai',
    desc: 'Perform a web-aware AI search for current events and data.',
    react: '🌐',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied.*');

    if (!q) return reply('🌐 *Search Engine:* What do you want to find?');

    const stub = await thinking(Gifted, from, mek, '🌐 _Querying global knowledge graph..._');

    // Instruction to AI to simulate a search-based response
    const searchPrompt = `Act as a real-time information retrieval agent. Research and provide a detailed, well-formatted report on: "${q}". 
    Use headers, bullet points, and WhatsApp markdown. If current data is unavailable, provide the most relevant historical context.
    \n\nCRITICAL: Respond using *bold* for key facts and > for citations.`;

    const { text, err } = await askAI(searchPrompt);

    if (err) return Gifted.sendMessage(from, { text: `❌ *Search Failed:* ${text}`, edit: stub.key });

    const finalReport = `🌐 *INTELLIGENT SEARCH REPORT*\n\n${text}\n\n_— Data fetched via Neural Link —_`;
    return Gifted.sendMessage(from, { text: finalReport, edit: stub.key });
});

// ==============================================================================
// 32. .aisummarize — CONVERSATION RECAP
// ==============================================================================

gmd({
    pattern: 'aisummarize',
    cmdname: 'aisummarize',
    aliases: ['recap', 'tlm', 'summary'],
    category: 'ai',
    desc: 'Summarize the current AI session history for this chat.',
    react: '📝',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Access Denied.*');

    const sess = State.chats.get(from) || State.dmSessions.get(mek.key.remoteJid);
    if (!sess || !sess.history || sess.history.length === 0) {
        return reply('📝 *Summary Engine:* No conversation history found in active memory.');
    }

    const stub = await thinking(Gifted, from, mek, '📝 _Synthesizing history..._');
    
    const historyText = sess.history.join('\n');
    const summaryPrompt = `Analyze and summarize the following chat history into a concise, professional recap of the key topics discussed, decisions made, and the overall tone.
    \n\nHistory:\n${historyText}\n\nUse bullet points and WhatsApp markdown.`;

    const { text, err } = await askAI(summaryPrompt);

    if (err) return Gifted.sendMessage(from, { text: `❌ *Recap Error:* ${text}`, edit: stub.key });

    const output = `📝 *CONVERSATION RECAP*\n\n${text}\n\n_Memory Depth: ${sess.history.length} lines_`;
    return Gifted.sendMessage(from, { text: output, edit: stub.key });
});

