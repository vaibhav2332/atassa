    pattern: 'autoenhance',
    cmdname: 'autoenhance',
    aliases: ['smartfix', 'aiwriter'],
    category: 'ai',
    desc: 'Toggle AI-powered grammar/style enhancement for your sent messages.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const opt = q.trim().toLowerCase();
    if (opt === 'on' || opt === 'enable') {
        State.autoEnhance = true;
        return reply('✍️ *Auto-Enhance:* ✅ *ON*\n_The AI will now silently fix grammar and polish your outgoing messages._');
    }
    if (opt === 'off' || opt === 'disable') {
        State.autoEnhance = false;
        return reply('✍️ *Auto-Enhance:* ❌ *OFF*');
    }

    return reply(
        `✍️ *AUTO-ENHANCE SYSTEM*\n\n` +
        `Current Status: ${State.autoEnhance ? '✅ *ENABLED*' : '❌ *DISABLED*'}\n\n` +
        `• \`.autoenhance on\` — Enable correction\n` +
        `• \`.autoenhance off\` — Disable correction\n\n` +
        `*Note:* This only affects messages sent by YOU that are longer than 10 characters and not commands.`
    );
});

