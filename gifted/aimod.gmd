        image: { url: urls[0] }, 
        caption: `*🎨 PROMPT:* _${q}_\n*⚙️ ENGINE:* \`${CFG.IMG_MODEL}\`` 
    }, { quoted: m });
});

// ==============================================================================
// 18. ENHANCED COMMAND: .aiwrite (CONTENT ENGINE)
// ==============================================================================

gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['write', 'author', 'draft'],
    category: 'ai',
    desc: 'Professional writing engine for messages, emails, and scripts.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused.*');

    const parts = q.trim().split(/\s+/);
    const type = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    const MODES = {
        roast: 'Write a sharp, funny roast about: ',
        email: 'Write a professional email about: ',
        story: 'Write a 2-paragraph short story about: ',
        caption: 'Generate 3 catchy Instagram captions for: ',
        lyrics: 'Write song lyrics in the style of Eminem about: '
    };

    if (!MODES[type]) return reply(`✍️ *AI Authoring Engine*\n\n*Available Modes:*\n${Object.keys(MODES).map(k => `\`${k}\``).join(', ')}\n\n*Usage:* \`.aiwrite <mode> <topic>\``);
    if (!topic) return reply('📝 Please provide a topic.');

    const stub = await thinking(Gifted, from, m, `✍️ _Drafting ${type}..._`);
    const { text, err } = await askAI(`${MODES[type]} ${topic}`);
    
    if (err) return editMsg(Gifted, stub, `❌ *Drafting Error:* ${text}`);
    
    const formatted = `*✍️ AUTHORIZED ${type.toUpperCase()}*\n\n${text}\n\n_— Created via Gifted-AI —_`;
    return editMsg(Gifted, stub, formatted);
});

// ==============================================================================
// 19. MASTER WATCHER INTEGRATION (PHASE 4 FINALE)
// ==============================================================================

/**
 * Enhanced resolver that applies the hierarchy: 
 * Stalker (Global) > Target (Local) > Chat (Global) > DM
 */
State.resolveSession = (sender, from, isGrp) => {
    // 1. Check Global Stalkers
    if (State.stalkers.has(sender)) return State.stalkers.get(sender);
    
    // 2. Check Local Targets
    if (State.targets.has(sender)) {
        const target = State.targets.get(sender);
        if (target.chatId === from) return target;
    }
    
    // 3. Check Chat-Wide Intelligence
    if (isGrp && State.chats.has(from)) return State.chats.get(from);
    
    // 4. Check DM Auto-Pilot
    if (!isGrp && State.dmActive) {
        if (!State.dmSessions.has(sender)) {
            State.dmSessions.set(sender, {
                gem: State.dmGem || State.PERSONA,
                history: [],
                gemName: 'dm_pilot'
            });
        }
        return State.dmSessions.get(sender);
    }

    return null;
};

// ==============================================================================
// 20. EXPORTS (PHASE 4)
// ==============================================================================

module.exports = {
    Gems,
    State,
    Limiter,
    CB,
    askAI,
    generateImage,
    uploadImgBB,
    markdownHelper
};
// ==============================================================================
// 21. .gem — PERSONA VAULT (CREATE / CLONE / REMIX)
// ==============================================================================

gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['persona', 'vault', 'personality'],
    category: 'ai',
    desc: 'Advanced AI persona management system for forging and cloning identities.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused:* Master-level clearance required for Persona Vault operations.');

    const parts = q.trim().split(/\s+/);
    const action = parts[0]?.toLowerCase();
    const args = parts.slice(1);

    switch (action) {
        case 'create': {
            const name = args[0]?.toLowerCase();
            const content = args.slice(1).join(' ');
            if (!name || !content) return reply('📝 *Usage:* `.gem create <name> <instructions>`');
            const success = Gems.save(name, content);
            return reply(success ? `✅ *Gem Forged:* \`${name}\` has been successfully archived in the vault.` : '❌ *Error:* Vault database write failed.');
        }

        case 'list': {
            const list = Gems.list();
            if (!list.length) return reply('📂 *Vault Status:* Empty. No custom personas detected.');
            const listStr = list.map((n, i) => `*${i + 1}.* 💎 \`${n}\``).join('\n');
            return reply(`📂 *Persona Vault:*\n\n${listStr}\n\n_Use: .gem use <name> to activate._`);
        }

        case 'use': {
            const name = args[0]?.toLowerCase();
            const content = Gems.get(name);
            if (!content) return reply(`❌ *Error:* Persona \`${name}\` does not exist in the local vault.`);
            State.dmGem = content;
            return reply(`✅ *Identity Shift:* System auto-pilot now operating under \`${name}\` logic.`);
        }

        case 'del':
        case 'delete': {
            const name = args[0]?.toLowerCase();
            if (!name) return reply('📝 *Usage:* `.gem del <name>`');
            const done = Gems.del(name);
            return reply(done ? `🗑️ *Purged:* Persona \`${name}\` has been deleted.` : '❌ *Error:* target not found.');
        }

        case 'clone': {
            const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
            if (!quoted) return reply('📝 *Action:* Reply to a message to synthesize and clone the sender\'s style.');
            
            const sample = quoted.conversation || quoted.extendedTextMessage?.text || quoted.imageMessage?.caption;
            if (!sample) return reply('❌ *Error:* Quoted message contains no linguistic data.');

            const stub = await thinking(Gifted, from, m, '🧬 _Synthesizing linguistic DNA..._');
            const { text, err } = await askAI(`Analyze this message: "${sample}". Create a concise system prompt that replicates this exact tone, vocabulary, and sentence structure. Return ONLY the prompt text.`);
            
            if (err) return editMsg(Gifted, stub, `❌ *Synthesis Failed:* ${text}`);
            
            const cloneID = `clone_${Math.floor(1000 + Math.random() * 9000)}`;
            Gems.save(cloneID, text);
            return editMsg(Gifted, stub, `🧬 *Style Cloned:* \`${cloneID}\`\n\n_The vault has successfully replicated the target's cognitive patterns._`);
        }

        case 'remix': {
            const name = args[0]?.toLowerCase();
            const tweak = args.slice(1).join(' ');
            const base = Gems.get(name);
            if (!base || !tweak) return reply('📝 *Usage:* `.gem remix <name> <new_instructions>`');

            const stub = await thinking(Gifted, from, m, `🔀 _Refining persona logic for "${name}"..._`);
            const { text, err } = await askAI(`Update this AI persona prompt: "${base}" based on these new instructions: "${tweak}". Return ONLY the updated prompt.`);
            
            if (err) return editMsg(Gifted, stub, `❌ *Refinement Failed:* ${text}`);
            
            const remixID = `${name}_v2`;
            Gems.save(remixID, text);
            return editMsg(Gifted, stub, `🔀 *Persona Remixed:* \`${remixID}\` is now ready for deployment.`);
        }

        default:
            return reply(
                `💎 *PERSONA VAULT INTERFACE*\n\n` +
                `• \`.gem create <name> <prompt>\` - Manual forge\n` +
                `• \`.gem list\` - View all identities\n` +
                `• \`.gem use <name>\` - Set active logic\n` +
                `• \`.gem clone\` - (Reply) Clone a user style\n` +
                `• \`.gem remix <name> <tweak>\` - Edit persona\n` +
                `• \`.gem del <name>\` - Remove identity`
            );
    }
});

// ==============================================================================
// 22. .gai — AI CONTROL & ENHANCED TARGETING (STALK / TARGET / MOOD)
// ==============================================================================

gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai_control', 'bot_control', 'tracking'],
    category: 'ai',
    desc: 'Elite AI targeting system with stealth stalking and mood manipulation.',
    react: '🛰️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused:* Neural link access restricted to Elite developers.');

    const parts = q.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase();
    const args = parts.slice(1);

    const getTargetJid = () => {
        const quoted = m.message?.extendedTextMessage?.contextInfo?.participant;
        if (quoted) return quoted;
        const mentioned = m.message?.extendedTextMessage?.contextInfo?.mentionedJid?.[0];
        if (mentioned) return mentioned;
        const raw = args[0]?.replace(/[^0-9]/g, '');
        if (raw && raw.length > 5) return raw + '@s.whatsapp.net';
        return null;
    };

    switch (cmd) {
        case 'target': {
            const jid = getTargetJid();
            if (!jid) return reply('📝 *Usage:* `.gai target <number/tag/reply> [gem_name]`');
            
            const gemName = args[1] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.targets.set(jid, {
                gem: gemContent,
                chatId: from,
                history: [],
                mood: 'neutral',
                gemName: gemName
            });
            return reply(`🎯 *Target Locked:* AI will now intercept and respond to @${jid.split('@')[0]} in this specific chat.`);
        }

        case 'stalk': {
            const jid = getTargetJid();
            if (!jid) return reply('📝 *Usage:* `.gai stalk <number/tag/reply> [gem_name]`');
            
            const gemName = args[1] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.stalkers.set(jid, {
                gem: gemContent,
                history: [],
                mood: 'observant',
                gemName: gemName
            });
            return reply(`🛰️ *Global Stalker Active:* AI will now track and reply to @${jid.split('@')[0]} across ALL mutual groups.`);
        }

        case 'mood': {
            const targetMood = args.join(' ');
            const participant = m.key.participant || m.key.remoteJid;
            const session = State.resolveSession(participant, from, from.endsWith('@g.us'));
            
            if (!session) return reply('❌ *Error:* No active session detected in this context. Use `.gai chat` first.');
            session.mood = targetMood;
            return reply(`🎭 *Mood Shifted:* AI behavior updated to: \`${targetMood}\`.`);
        }

        case 'chat': {
            const gemName = args[0] || 'default';
            const gemContent = (gemName !== 'default' ? Gems.get(gemName) : null) || State.PERSONA;
            
            State.chats.set(from, {
                gem: gemContent,
                history: [],
                mood: 'natural',
                gemName: gemName
            });
            return reply(`⚔️ *Chat Hivemind:* AI intelligence activated for ALL users in this chat.`);
        }

        case 'stop': {
            const sub = args[0]?.toLowerCase();
            if (sub === 'all') {
                State.chats.clear();
                State.targets.clear();
                State.stalkers.clear();
                return reply('☢️ *System Purge:* All active AI sessions have been terminated.');
            }
            State.chats.delete(from);
            return reply('🛑 *Session Terminated:* Local chat AI deactivated.');
        }

        case 'dm': {
            const state = args[0]?.toLowerCase();
            if (state === 'on') {
                State.dmActive = true;
                return reply('📨 *DM Auto-Pilot:* [ENABLED]');
            }
            if (state === 'off') {
                State.dmActive = false;
                return reply('📨 *DM Auto-Pilot:* [DISABLED]');
            }
            return reply(`📨 *Auto-Pilot Status:* ${State.dmActive ? 'Online' : 'Offline'}`);
        }

        default: {
            const query = q.trim();
            if (!query) {
                return reply(
                    `🛰️ *AI CONTROL COMMANDS*\n\n` +
                    `• \`.gai chat [gem]\` - Enable for this chat\n` +
                    `• \`.gai target <user>\` - Local intercept\n` +
                    `• \`.gai stalk <user>\` - Global intercept\n` +
                    `• \`.gai mood <type>\` - Change AI vibe\n` +
                    `• \`.gai stop [all]\` - Terminate sessions\n` +
                    `• \`.gai dm <on/off>\` - Toggle private AI\n\n` +
                    `_Current Active Persona: ${State.dmGem ? 'Custom' : 'Default'}_`
                );
            }
            
            await react('🧠');
            const stub = await thinking(Gifted, from, m, '🧠 _Thinking..._');
            const { text, err } = await askAI(query);
            return editMsg(Gifted, stub, err ? `❌ *AI Error:* ${text}` : markdownHelper.applyFormatting(text));
        }
    }
});

// ==============================================================================
// 23. MASTER WATCHER: CORE AI INTERCEPTION LOGIC
// ==============================================================================

/**
 * Attaches the neural watcher to the Gifted client instance.
 * Rigorously handles Targeting, Stalking, and Group Chat AI.
 */
const attachNeuralWatcher = (client) => {
    client.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        
        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;
                
                const remoteJid = msg.key.remoteJid;
                const participant = msg.key.participant || remoteJid;
                const isGroup = remoteJid.endsWith('@g.us');
                
                // Content extraction
                const body = msg.message.conversation || 
                             msg.message.extendedTextMessage?.text || 
                             msg.message.imageMessage?.caption || '';

                // Hierarchy-based Session Resolution
                const session = State.resolveSession(participant, remoteJid, isGroup);
                if (!session) continue;

                // Prevention logic: Ignore commands and empty triggers
                if (['.', '/', '!', '#', '+'].includes(body[0]) || !body.trim()) continue;

                // Typing Simulation
                try {
                    await client.sendPresenceUpdate('composing', remoteJid);
                    const typingDelay = Math.min(body.length * 35, 4500) + 800;
                    await sleep(typingDelay);
                } catch (e) {}

                // Context & History Update
                State.addHist(session, 'User', body);

                // Neural Response Generation
                const systemPrompt = `${session.gem}\n\n*CURRENT MOOD:* ${session.mood || 'neutral'}\n*STRICT FORMATTING:* Use WhatsApp Markdown.`;
                const prompt = State.buildPrompt(systemPrompt, session.history, body);
                
                const { text, err } = await askAI(prompt);
                
                if (!err && text) {
                    State.addHist(session, 'AI', text);
                    const finalResponse = markdownHelper.applyFormatting(text);
                    await client.sendMessage(remoteJid, { text: finalResponse }, { quoted: msg });
                }

                try { await client.sendPresenceUpdate('paused', remoteJid); } catch (e) {}

            } catch (err) {
                console.error('[AIGems.NeuralWatcher] Execution Error:', err.message);
            }
        }
    });
};

// Auto-attach to global client if exists
if (global.conn) attachNeuralWatcher(global.conn);
else if (global.client) attachNeuralWatcher(global.client);

// ==============================================================================
// 24. RE-EXPORT & INITIALIZATION
// ==============================================================================

module.exports = {
    Gems,
    State,
    Limiter,
    CB,
    askAI,
    attachNeuralWatcher,
    markdownHelper,
    metadata: {
        phase: 5,
        target: 'Command Set Alpha',
        engine: 'QuillBot Raven'
    }
};
// ==============================================================================
// PHASE 6: COMMAND SET BETA — VISUAL GENERATION & ANALYSIS
// ==============================================================================

/**
 * @function uploadImgBB
 * @description Uploads a local buffer/file to ImgBB for AI Vision consumption.
 */
uploadImgBB = async (imagePath) => {
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(imagePath));
        
        const res = await axios.post(`https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}`, form, {
            headers: form.getHeaders(),
            timeout: 30000
        });
        
        return res.data?.data?.url || null;
    } catch (e) {
        console.error('[AIGems.ImgBB] Upload Failed:', e.message);
        return null;
    }
};

/**
 * @function generateImage
 * @description Interfaces with Infip API Pool to generate high-fidelity images.
 */
generateImage = async (prompt, opts = {}) => {
    const model = opts.model || CFG.IMG_MODEL;
    const size  = opts.size  || CFG.IMG_SIZE;
    
    // Rotate through API keys to avoid exhaustion
    const apiKey = CFG.INFIP_POOL[Math.floor(Math.random() * CFG.INFIP_POOL.length)];
    
    try {
        Limiter.hit('img');
        const res = await axios.post(`${CFG.INFIP_URL}/v1/images/generations`, {
            prompt: prompt,
            model: model,
            n: opts.count || 1,
            size: size,
            response_format: 'url'
        }, {
            headers: { 
                'Authorization': `Bearer ${apiKey}`,
                'Content-Type': 'application/json'
            },
            timeout: 120000 // Image gen can be slow
        });

        return res.data?.data?.map(img => img.url) || [];
    } catch (e) {
        console.error('[AIGems.Infip] Generation Failed:', e.response?.data || e.message);
        return [];
    }
};

// ==============================================================================
// 25. .img — CREATIVE VISION COMMAND
// ==============================================================================

gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['imagine', 'flux', 'phoenix', 'genimg'],
    category: 'ai',
    desc: 'Generate images using Phoenix or Flux models.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('*Refused:* Creative Suite requires High Clearance.');

    const parts = q.trim().split(/\s+/);
    const subCmd = parts[0]?.toLowerCase();

    // Configuration / Model Switching
    if (subCmd === 'set' || subCmd === 'config') {
        const newModel = parts[1]?.toLowerCase();
        if (!newModel || !CFG.IMG_MDLS[newModel]) {
            const list = Object.keys(CFG.IMG_MDLS).map(k => `• \`${k}\` (${CFG.IMG_MDLS[k].desc})`).join('\n');
            return reply(`🎨 *Available Models:*\n${list}\n\n*Usage:* \`.img set <model_name>\``);
        }
        CFG.IMG_MODEL = newModel;
        return reply(`✅ *Default Model Updated:* \`${newModel}\``);
    }

    if (!q) return reply(`🎨 *Image Generation Suite*\n\nUsage: \`.img <your prompt>\` or \`.img set <model>\` to change engines.\n\n*Active Engine:* \`${CFG.IMG_MODEL}\``);

    await react('⏳');
    const stub = await Gifted.sendMessage(from, { text: `🎨 _Synthesizing visual data using ${CFG.IMG_MODEL}..._` }, { quoted: m });

    try {
        const urls = await generateImage(q, { model: CFG.IMG_MODEL });

        if (!urls || urls.length === 0) {
            return Gifted.sendMessage(from, { text: `❌ *Generation Failed:* The neural engine returned an empty buffer. Try a different prompt or check \`.apimon health\`.`, edit: stub.key });
        }

        const caption = `🎨 *GENERATED IMAGE*\n\n*Prompt:* _${q}_\n*Model:* \`${CFG.IMG_MODEL}\`\n\n_Generated via Gifted Visual Engine_`;
        
        await Gifted.sendMessage(from, { delete: stub.key });
        return await Gifted.sendMessage(from, { 
            image: { url: urls[0] }, 
            caption: caption 
        }, { quoted: m });

    } catch (err) {
        return Gifted.sendMessage(from, { text: `❌ *Visual Logic Error:* ${err.message}`, edit: stub.key });
    }
});

// ==============================================================================
// 26. .aiwrite — SPECIALIZED WRITING MODES
// ==============================================================================

gmd({
    pattern: 'aiwrite',
    cmdname: 'aiwrite',
    aliases: ['compose', 'draft', 'author'],
    category: 'ai',
    desc: 'Specialized AI writing in 15+ modes.',
    react: '✍️',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('*Refused:* Writing module locked.');

    const MODES = {
        professional: 'formal business tone, corporate vocabulary, polite.',
        sarcastic: 'dripping with irony, witty, slightly mean but funny.',
        poetic: 'rhythmic, metaphorical, rich imagery, emotional.',
        slang: 'gen-z brainrot, heavy slang, very casual, chaotic.',
        pirate: 'talk like a high-seas buccaneer, arrr!',
        scientific: 'academic, precise, objective, data-focused.',
        romantic: 'sweet, affectionate, heartfelt, poetic.',
        villain: 'dramatic, menacing, ego-centric, theatrical.',
        coding: 'commented code-style explanation, logical, technical.',
        biblical: 'archaic language, "thou/thee", authoritative.',
        toddler: 'simple words, repetitive, innocent, hyper.',
        lawyer: 'legal jargon, dense, defensive, precise.',
        raindancer: 'mystical, ethereal, nature-focused, rhythmic.',
        storyteller: 'engaging narrative, suspenseful, descriptive.',
        roast: 'brutal, observational comedy, targeted insults (playful).'
    };

    const parts = q.trim().split(/\s+/);
    const mode = parts[0]?.toLowerCase();
    const topic = parts.slice(1).join(' ');

    if (!MODES[mode] || !topic) {
        const list = Object.keys(MODES).map(k => `\`${k}\``).join(', ');
        return reply(`✍️ *AI Writing Engine*\n\n*Modes:* ${list}\n\n*Usage:* \`.aiwrite <mode> <topic/text>\``);
    }

    const stub = await Gifted.sendMessage(from, { text: `✍️ _Authoring in ${mode} mode..._` }, { quoted: m });

    const prompt = `Act as a writer. Use a ${MODES[mode]} style. Write a response about: "${topic}".\n\nCRITICAL: You must use WhatsApp Markdown.`;
    const { text, err } = await askAI(prompt);

    if (err) return Gifted.sendMessage(from, { text: `❌ *Writing Error:* ${text}`, edit: stub.key });

    const formatted = `*┏━━━━━━━━━━━━━━━━━━━━┓*\n*┃ ✍️ AI ${mode.toUpperCase()} MODE*\n*┗━━━━━━━━━━━━━━━━━━━━┛*\n\n${markdownHelper.applyFormatting(text)}`;
    return Gifted.sendMessage(from, { text: formatted, edit: stub.key });
});

// ==============================================================================
// 27. .aidecode — AI VISION & OCR ANALYSIS
// ==============================================================================

gmd({
    pattern: 'aidecode',
    cmdname: 'aidecode',
    aliases: ['analyze', 'ocr', 'explain'],
    category: 'ai',
    desc: 'Extract text or analyze images using AI Vision.',
    react: '🔍',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { m, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('*Refused:* Vision analysis restricted.');

    const quoted = m.message?.extendedTextMessage?.contextInfo?.quotedMessage;
    const isImage = m.message?.imageMessage || quoted?.imageMessage;

    if (!isImage) return reply('📝 *Action Required:* Please reply to an image or send one with the command `.aidecode`.');

    await react('🔍');
    const stub = await Gifted.sendMessage(from, { text: '📸 _Processing image for neural analysis..._' }, { quoted: m });

    try {
        const media = m.message?.imageMessage ? m.message.imageMessage : quoted.imageMessage;
        const tmpPath = path.join(__dirname, '..', 'gift', `ocr_${Date.now()}.jpg`);
        
        // Download and Save
        const stream = await Gifted.downloadMediaMessage({ message: { imageMessage: media } });
        fs.writeFileSync(tmpPath, stream);
        
        // Upload to ImgBB
        const url = await uploadImgBB(tmpPath);
        if (fs.existsSync(tmpPath)) fs.unlinkSync(tmpPath);

        if (!url) return Gifted.sendMessage(from, { text: '❌ *Analysis Failed:* Could not generate temporary visual link.', edit: stub.key });

        // Analyze via askAI (Raven Vision)
        const prompt = q || 'Analyze this image in detail. Extract any text visible and describe the context.';
        const { text, err } = await askAI(prompt, [url]);

        if (err) return Gifted.sendMessage(from, { text: `❌ *Vision Error:* ${text}`, edit: stub.key });

        const output = `🔍 *VISUAL DECODE REPORT*\n\n${markdownHelper.applyFormatting(text)}\n\n_Analyzed via Gifted Vision Engine_`;
        return Gifted.sendMessage(from, { text: output, edit: stub.key });

    } catch (e) {
        return Gifted.sendMessage(from, { text: `❌ *Analysis Loop Error:* ${e.message}`, edit: stub.key });
    }
});

