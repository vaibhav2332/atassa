        info += `• *Mood:* \`${sess.mood || 'natural'}\`\n`;
        info += `• *Memory:* \`${sess.history?.length || 0}/${CFG.MAX_HIST}\` lines\n`;
    }

    return reply(info, { mentions: [jid] });
});

