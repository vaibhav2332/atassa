gmd({
    pattern:'autoenhance', cmdname:'autoenhance', aliases:['smartedit','autoedit'],
    category:'ai', desc:'Toggle AI auto-correction of your outgoing messages.', react:'Ō£Ź’ĖÅ', filename:__filename
}, async (from, Gifted, conText) => {
    const { q='', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('ŌØī Owner only.');
    const a=q.trim().toLowerCase();
    if(a==='on')  { State.autoEnhance=true;  return reply('Ō£Ź’ĖÅ *Auto-Enhance: ON*\nYour messages will be silently AI-improved.'); }
    if(a==='off') { State.autoEnhance=false; return reply('Ō£Ź’ĖÅ *Auto-Enhance: OFF*'); }
    return reply(`Ō£Ź’ĖÅ *Auto-Enhance:* ${State.autoEnhance?'Ō£ģ ON':'ŌØī OFF'}\n\nFixes grammar/spelling silently after you send.\n\nŌĆó \`.autoenhance on\`\nŌĆó \`.autoenhance off\``);
});
