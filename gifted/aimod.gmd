/**
 * DEBUG FIX:
 * The "Unexpected token '}'" error mentioned was located in Section 4 of the 
 * skeleton due to a trailing bracket. This continuation assumes the logic 
 * flow remains intact and provides the full remaining command set for 
 * production-level image generation and state tracking.
 */
// ==============================================================================
// 5. CORE AI — QuillBot SSE streaming (responseType: 'stream' for proper SSE)
// ==============================================================================
const sleep = ms => new Promise(r => setTimeout(r, ms));

/**
 * Communicates with QuillBot AI using the SSE stream endpoint.
 * Includes fixed SSE parsing logic to handle "chunk" extraction accurately.
 */
const askAI = async (prompt, imgUrls = []) => {
    if (CB.open())        return { text: CB.msg(),                          err: true };
    if (!Limiter.check()) return { text: 'rate limit hit — wait a moment', err: true };

    const systemInstruction = "Strictly adhere to WhatsApp Markdown in all outputs: use *bold* for emphasis, _italics_ for subtle notes, and structured bullet points with emojis where appropriate. Never use markdown headers (###).";
    const finalPrompt = `${systemInstruction}\n\nUser: ${prompt}`;

    const payload = {
        stream : true,
        message: {
            role   : 'user',
            content: finalPrompt,
            files  : imgUrls.map(u => ({ url:u, mimeType:'image/jpeg', name:'image.jpg' }))
        },
        product: 'ai-chat',
        prompt : { id:'ai_chat' },
        tools  : []
    };

    for (let attempt = 0; attempt < CFG.RETRIES; attempt++) {
        try {
            Limiter.hit('ai');

            const res = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers     : { ...CFG.QB_HEADERS, Cookie: COOKIE_STR },
                    timeout     : CFG.TIMEOUT,
                    responseType: 'stream'
                }
            );

            const rawText = await new Promise((resolve, reject) => {
                let buf = '';
                const timer = setTimeout(() => resolve(buf), CFG.TIMEOUT - 5000);
                res.data.on('data', chunk => { buf += chunk.toString(); });
                res.data.on('end',  () => { clearTimeout(timer); resolve(buf); });
                res.data.on('error', e => { clearTimeout(timer); reject(e); });
            });

            let full = '';
            for (const line of rawText.split('\n')) {
                const l = line.trim();
                if (l.startsWith('data: {') && l.includes('"chunk"')) {
                    try { 
                        const o = JSON.parse(l.slice(6)); 
                        if (o.chunk) full += o.chunk; 
                    } catch(e){}
                }
            }

            if (!full.trim()) {
                Limiter.err();
                if (attempt < CFG.RETRIES - 1) { await sleep(1500 * (attempt + 1)); continue; }
                CB.fail();
                return { text: 'empty response — api connection jittery', err: true };
            }

            CB.ok();
            const clean = full
                .replace(/\\\(|\\\)/g,'').replace(/\\\[|\\\]/g,'')
                .replace(/\\([a-zA-Z])/g,'$1').trim();
            return { text: clean, err: false };

        } catch(e) {
            Limiter.err();
            if (attempt < CFG.RETRIES - 1) await sleep(1500 * (attempt + 1));
            else { CB.fail(); return { text: `API unreachable — ${e.message}`, err: true }; }
        }
    }
    return { text: CB.msg(), err: true };
};

// ==============================================================================
// 6. IMGBB UPLOADER
// ==============================================================================
const uploadImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url ?? null;
    } catch(e) { return null; }
};

// ==============================================================================
// 7. IMAGE GENERATOR — Infip API (key pool)
// ==============================================================================
let _iKey = CFG.INFIP_POOL[Math.floor(Math.random()*CFG.INFIP_POOL.length)];
let _iOk  = false;
const _iCache = new Map();
const _iHdr = () => ({ Authorization:`Bearer ${_iKey}`, 'Content-Type':'application/json' });

const ensureInfip = async () => {
    if (_iOk) return true;
    try { const r=await axios.get(`${CFG.INFIP_URL}/v1/models`,{headers:_iHdr(),timeout:10000}); if(r.status===200){_iOk=true;return true;} } catch(e){}
    try { const r=await axios.post(`${CFG.INFIP_URL}/v1/api-keys`,{},{timeout:10000}); if(r.data?.api_key){_iKey=r.data.api_key;_iOk=true;return true;} } catch(e){}
    _iOk=true; return false;
};

const generateImage = async (prompt, opts={}) => {
    const model=opts.model||CFG.IMG_MODEL, size=opts.size||CFG.IMG_SIZE,
          n=Math.min(opts.count||CFG.IMG_COUNT,4), quality=opts.quality||CFG.IMG_QUALITY, style=opts.style||CFG.IMG_STYLE;
    const ck=`${model}|${size}|${prompt.slice(0,60)}`;
    const hit=_iCache.get(ck);
    if(hit&&Date.now()-hit.ts<3600000) return hit.urls;
    if(!Limiter.check()) return [];
    await ensureInfip(); Limiter.hit('img');
    for(let i=0;i<CFG.RETRIES;i++){
        try{
            const r=await axios.post(`${CFG.INFIP_URL}/v1/images/generations`,
                {model,prompt,n,size,response_format:'url',quality,style},{headers:_iHdr(),timeout:CFG.TIMEOUT});
            if(r.status===200&&r.data?.data?.length){ const urls=r.data.data.map(d=>d.url); _iCache.set(ck,{urls,ts:Date.now()}); return urls; }
        }catch(e){ Limiter.err(); if(i<CFG.RETRIES-1) await sleep(1000*(i+1)); }
    }
    return [];
};

// ==============================================================================
// 8. RUNTIME STATE
// ==============================================================================
const State = {
    dmActive:false, dmGem:null,
    chats:new Map(), targets:new Map(), stalkers:new Map(), dmSessions:new Map(),
    autoEnhance:false,
    PERSONA:'You are a witty, slightly sarcastic but genuinely helpful person on WhatsApp. Keep replies short and casual. Use conversation history. Always use WhatsApp Markdown: *bold*, _italics_, and structured lists.',
    addHist(ctx,role,txt){ 
        if(!ctx.history)ctx.history=[]; 
        const t=new Date().toLocaleTimeString('en',{hour12:false,hour:'2-digit',minute:'2-digit'}); 
        ctx.history.push(`[${t}] ${role}: ${txt}`); 
        if(ctx.history.length>CFG.MAX_HIST)ctx.history=ctx.history.slice(-CFG.MAX_HIST); 
        ctx.lastActive = Date.now();
    },
    buildPrompt(sys,hist,input){ return `SYSTEM:\n${sys}\n\n--- HISTORY ---\n${hist.join('\n')}\n---\nUSER: ${input}\nREPLY:`; }
};

// ==============================================================================
// 9. MESSAGE HELPERS
// ==============================================================================
const thinking = async (Gifted, from, mek, label = '⏳ _thinking…_') => {
    try { return await Gifted.sendMessage(from, { text: label }, { quoted: mek }); } catch (e) { return null; }
};

const editMsg = async (Gifted, sentMsg, newText) => {
    if (!sentMsg?.key) return;
    try {
        await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText, edit: sentMsg.key });
    } catch (e) {
        try { await Gifted.sendMessage(sentMsg.key.remoteJid, { text: newText }); } catch (e2) {}
    }
};

const del = async (Gifted, key) => {
    try { await Gifted.sendMessage(key.remoteJid, { delete: key }); } catch (_) {}
};

const sendImg = async (Gifted, from, url, caption, mek) => {
    try {
        await Gifted.sendMessage(from, { image: { url }, caption }, { quoted: mek });
        return true;
    } catch (e) {
        try { await Gifted.sendMessage(from, { text: `🎨 ${caption}\n\n🔗 ${url}` }, { quoted: mek }); } catch (_) {}
        return false;
    }
};

// ==============================================================================
// 10. .gem — PERSONA VAULT SUITE
// ==============================================================================
gmd({
    pattern: 'gem',
    cmdname: 'gem',
    aliases: ['persona', 'vault'],
    category: 'ai',
    desc: 'Advanced Persona Management.',
    react: '💎',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');
    
    const parts = q.trim().split(/\s+/), cmd = parts[0]?.toLowerCase() || 'help', rest = parts.slice(1);

    switch(cmd) {
        case 'create':
            if (rest.length < 2) return reply('📝 `.gem create <name> <prompt>`');
            return Gems.save(rest[0], rest.slice(1).join(' ')) ? reply(`✅ Gem \`${rest[0]}\` saved.`) : reply('❌ DB Error.');
        
        case 'gen':
            const topic = rest.join(' ');
            if (!topic) return reply('📝 `.gem gen <topic>`');
            const stubGen = await thinking(Gifted, from, mek, '🔮 _Forging..._');
            const { text: genP, err } = await askAI(`Generate a detailed WhatsApp persona prompt for: ${topic}. Return ONLY the prompt.`);
            if (err) return editMsg(Gifted, stubGen, `❌ ${genP}`);
            const gName = (rest[0] || 'gen').toLowerCase().slice(0,10) + '_' + Math.random().toString(36).slice(2,5);
            Gems.save(gName, genP);
            return editMsg(Gifted, stubGen, `✨ *Gem Generated*\n\n*Name:* \`${gName}\`\n*Prompt:* _${genP.slice(0, 150)}..._`);

        case 'analyze':
            const quoted = mek.message?.extendedTextMessage?.contextInfo?.quotedMessage;
            if (!quoted) return reply('📝 *Reply to a message to clone its style.*');
            const sample = quoted.conversation || quoted.extendedTextMessage?.text || '';
            const stubAn = await thinking(Gifted, from, mek, '🕵️ _Cloning..._');
            const { text: cloneP, err: anErr } = await askAI(`Analyze this message style and write a system prompt to mimic it perfectly:\n"${sample}"\nReturn ONLY the prompt.`);
            if (anErr) return editMsg(Gifted, stubAn, `❌ ${cloneP}`);
            const cName = `clone_${Math.random().toString(36).slice(2,6)}`;
            Gems.save(cName, cloneP);
            return editMsg(Gifted, stubAn, `🧬 *Clone Saved*\n\n*Name:* \`${cName}\``);

        case 'remix':
            if (rest.length < 2) return reply('📝 `.gem remix <name> <tweak>`');
            const base = Gems.get(rest[0]);
            if (!base) return reply('❌ Gem not found.');
            const stubRx = await thinking(Gifted, from, mek, '🔀 _Remixing..._');
            const { text: rxP, err: rxErr } = await askAI(`Modify this prompt: "${base}"\n\nAdjustment: ${rest.slice(1).join(' ')}\n\nReturn ONLY the prompt.`);
            if (rxErr) return editMsg(Gifted, stubRx, `❌ ${rxP}`);
            const rName = `${rest[0]}_v2`;
            Gems.save(rName, rxP);
            return editMsg(Gifted, stubRx, `🔀 *Remix Saved:* \`${rName}\``);

        case 'use':
            if (!rest[0]) return reply('📝 `.gem use <name>`');
            const uP = Gems.get(rest[0]);
            if (!uP) return reply('❌ Not found.');
            State.dmGem = uP;
            return reply(`✅ DM Persona set to: \`${rest[0]}\``);

        case 'list':
            const all = Gems.list();
            return reply(`📚 *Gems Vault*\n\n${all.map((g, i) => `${i+1}. 💎 \`${g}\``).join('\n')}`);

        case 'search':
            if (!rest[0]) return reply('📝 `.gem search <term>`');
            const matches = Gems.list().filter(n => n.includes(rest[0].toLowerCase()));
            return reply(`🔍 *Matches:* ${matches.length ? matches.map(m => `\`${m}\``).join(', ') : 'None'}`);

        case 'view':
            const vC = Gems.get(rest[0] || '');
            return vC ? reply(`💎 *${rest[0].toUpperCase()}*\n\n${vC}`) : reply('❌ Not found.');

        case 'del':
        case 'delete':
            return Gems.del(rest[0] || '') ? reply('🗑️ Deleted.') : reply('❌ Not found.');

        default:
            return reply(`💎 *GEM VAULT*\n\n• \`.gem list/view/del\`\n• \`.gem create/gen/remix\`\n• \`.gem analyze\` (reply)\n• \`.gem search <term>\`\n• \`.gem use <name>\``);
    }
});

// ==============================================================================
// 11. .gai — AI CONTROL & MODES
// ==============================================================================
gmd({
    pattern: 'gai',
    cmdname: 'gai',
    aliases: ['ai', 'brain'],
    category: 'ai',
    desc: 'Master AI Controller.',
    react: '🧠',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, isSuperUser, react } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');
    
    const parts = q.trim().split(/\s+/), cmd = parts[0]?.toLowerCase(), rest = parts.slice(1);

    if (cmd === 'dm') {
        const act = rest[0]?.toLowerCase();
        if (act === 'on') { State.dmActive = true; return reply('📨 *DM AI:* ✅ ON'); }
        if (act === 'off') { State.dmActive = false; return reply('📨 *DM AI:* ❌ OFF'); }
        return reply(`📨 *DM AI:* ${State.dmActive ? 'ON' : 'OFF'}`);
    }

    if (cmd === 'chat') {
        const gN = rest[0] || 'default';
        const gT = Gems.get(gN) || State.PERSONA;
        State.chats.set(from, { gem: gT, history: [], gemName: gN });
        return reply(`⚔️ *Chat AI Active:* \`${gN}\``);
    }

    if (cmd === 'target') {
        const num = rest[0]?.replace(/\D/g, '');
        if (!num) return reply('📝 `.gai target <number> [gem]`');
        const jid = num + '@s.whatsapp.net', gN = rest[1] || 'default';
        State.targets.set(jid, { gem: Gems.get(gN) || State.PERSONA, history: [], chatId: from, gemName: gN });
        return reply(`🤖 *Target:* @${num} (\`${gN}\`)`, { mentions: [jid] });
    }

    if (cmd === 'stop') {
        if (rest[0] === 'all') {
            State.chats.clear(); State.targets.clear(); State.stalkers.clear(); State.dmActive = false;
            return reply('☢️ *All AI stopped.*');
        }
        State.chats.delete(from);
        return reply('🛑 *AI stopped here.*');
    }

    if (cmd === 'status') {
        const s = Limiter.stats();
        return reply(`📊 *AI STATUS*\n\n• RPM: ${s.rpm}/${CFG.MAX_RPM}\n• Daily: ${s.ai} req / ${s.img} img\n• Sessions: ${State.chats.size} chats\n• Targets: ${State.targets.size}\n• Circuit: ${CB.open() ? '🔴' : '🟢'}`);
    }

    const prompt = q.trim();
    if (!prompt) return reply('📝 Usage: `.gai <question>` or `.gai help`');

    await react('🧠');
    const stub = await thinking(Gifted, from, mek);
    const { text, err } = await askAI(prompt);
    return editMsg(Gifted, stub, err ? `❌ ${text}` : text);
});

// ==============================================================================
// 12. .img — CREATIVE VISUALS
// ==============================================================================
gmd({
    pattern: 'img',
    cmdname: 'img',
    aliases: ['draw', 'imagine'],
    category: 'ai',
    desc: 'Image Generation.',
    react: '🎨',
    filename: __filename
}, async (from, Gifted, conText) => {
    const { mek, q = '', reply, react, isSuperUser } = conText;
    if (!isSuperUser) return reply('❌ *Owner only.*');

    const prompt = q.trim();
    if (!prompt) return reply('📝 `.img <prompt>`\nPresets: `.img config <model> <size>`');

    if (prompt.startsWith('config')) {
        const p = prompt.split(/\s+/);
        if (p[1]) CFG.IMG_MODEL = p[1];
        if (p[2]) CFG.IMG_SIZE = p[2];
        return reply(`✅ *Config:* \`${CFG.IMG_MODEL}\` | \`${CFG.IMG_SIZE}\``);
    }

    if (prompt === 'models') {
        return reply(`📋 *Models:*\n${Object.keys(CFG.IMG_MDLS).join(', ')}`);
    }

    await react('🎨');
    const stub = await thinking(Gifted, from, mek, '🎨 _Visualizing..._');
    const urls = await generateImage(prompt);
    
    if (!urls.length) return editMsg(Gifted, stub, '❌ Failed to generate.');
    
    await del(Gifted, stub.key);
    return sendImg(Gifted, from, urls[0], `🎨 _${prompt.slice(0, 50)}..._`, mek);
});

// ==============================================================================
// 13. WATCHER — AUTOMATION ENGINE
// ==============================================================================
const attachWatcher = (Gifted) => {
    if (!Gifted?.ev) return;
    
    Gifted.ev.on('messages.upsert', async ({ messages, type }) => {
        if (type !== 'notify') return;
        for (const msg of messages) {
            try {
                if (!msg.message || msg.key.fromMe) continue;
                const chatId = msg.key.remoteJid, sender = msg.key.participant || chatId;
                const body = msg.message.conversation || msg.message.extendedTextMessage?.text || '';
                
                let sess = null;
                if (State.stalkers.has(sender)) sess = State.stalkers.get(sender);
                else if (State.targets.has(sender)) {
                    const t = State.targets.get(sender);
                    if (t.chatId === chatId) sess = t;
                }
                else if (State.chats.has(chatId)) sess = State.chats.get(chatId);
                else if (!chatId.endsWith('@g.us') && State.dmActive) {
                    if (!State.dmSessions.has(chatId)) State.dmSessions.set(chatId, { gem: State.dmGem || State.PERSONA, history: [] });
                    sess = State.dmSessions.get(chatId);
                }

                if (!sess || body.startsWith('.')) continue;

                setImmediate(async () => {
                    State.addHist(sess, 'User', body);
                    const { text, err } = await askAI(State.buildPrompt(sess.gem, sess.history, body));
                    if (err) return;
                    State.addHist(sess, 'AI', text);
                    await Gifted.sendMessage(chatId, { text }, { quoted: msg });
                });
            } catch (e) {}
        }
    });
};

