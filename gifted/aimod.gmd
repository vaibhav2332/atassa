    },
    email: {
        emoji: '📧',
        prompt: (t) => `Draft a professional email about: ${t}. Structure it with Subject: and Body:. Use \`monospace\` for technical terms.`
    },
    code: {
        emoji: '💻',
        prompt: (t) => `Write clean, efficient code for: ${t}. Wrap code in triple backticks. Provide a brief *bold* explanation of logic.`
    },
    script: {
        emoji: '🎭',
        prompt: (t) => `Write a funny WhatsApp dialogue/script between two people about: ${t}. Use *NAME:* for speakers.`
