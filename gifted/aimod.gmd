// ==============================================================================
const STATE = {
    dmMode:       false,
    dmGem:        null,
    activeChats:  {},   // chatId → { gem, history[] }
    activeTargets:{},   // userId → { gem, history[] }
    stalkTargets: {},   // userId → { gem, history[] }
    autoEnhance:  true,
    autoProfile:  false,
    profileInterval: 3600 * 1000,
    _profileTimer: null,

    imgCache: {},       // prompt_key → { urls[], ts }
    apiRPM:   [],       // timestamps for rate limiting
    apiRPH:   [],
    apiStats: { ai:0, image:0, errors:0 }
};

const DEFAULT_PERSONA =
    'You are a witty, slightly sarcastic but helpful assistant. ' +
    'Keep responses short, casual. Recall details from Chat History provided.';

// ==============================================================================
// 7. RATE LIMITER
// ==============================================================================
const checkRate = () => {
    const now = Date.now();
    STATE.apiRPM = STATE.apiRPM.filter(t => now - t < 60000);
    STATE.apiRPH = STATE.apiRPH.filter(t => now - t < 3600000);
    return STATE.apiRPM.length < CFG.MAX_RPM && STATE.apiRPH.length < CFG.MAX_RPH;
};
const recordReq = (type='ai') => {
    const now = Date.now();
    STATE.apiRPM.push(now);
    STATE.apiRPH.push(now);
    STATE.apiStats[type] = (STATE.apiStats[type] || 0) + 1;
};

// ==============================================================================
// 8. QUILLBOT AI CLIENT
// ==============================================================================
const cookieStr = Object.entries(CFG.QB_COOKIES).map(([k,v])=>`${k}=${v}`).join('; ');

const cleanAIText = (text) => {
    if (!text) return '';
    return text
        .replace(/\\\(/g,'').replace(/\\\)/g,'')
        .replace(/\\\[/g,'').replace(/\\\]/g,'')
        .replace(/\\([a-zA-Z])/g,'$1')
        .trim();
};

const callAI = async (prompt, imageUrls=[]) => {
    if (!checkRate()) return '⚠️ Rate limit reached. Please wait a moment.';

    const filesPayload = imageUrls.map(url => ({
        url, mimeType:'image/jpeg', name:'image.jpg'
    }));

    const payload = {
        stream: true,
        message: { role:'user', content:prompt, files:filesPayload },
        product: 'ai-chat',
        prompt: { id:'ai_chat' },
        tools: []
    };

    for (let attempt = 0; attempt < CFG.MAX_RETRIES; attempt++) {
        try {
            recordReq('ai');
            const response = await axios.post(
                'https://quillbot.com/api/raven/quill-chat/responses',
                payload,
                {
                    headers: { ...CFG.QB_HEADERS, 'cookie': cookieStr },
                    responseType: 'stream',
                    timeout: CFG.TIMEOUT
                }
            );

            let fullText = '';
            await new Promise((resolve, reject) => {
                response.data.on('data', chunk => {
                    const lines = chunk.toString().split('\n');
                    for (const line of lines) {
                        if (line.startsWith('data: {') && line.includes('"chunk":"')) {
                            try {
                                const obj = JSON.parse(line.slice(6));
                                fullText += obj.chunk || '';
                            } catch(_) {}
                        }
                    }
                });
                response.data.on('end', resolve);
                response.data.on('error', reject);
            });

            if (!fullText.trim()) {
                STATE.apiStats.errors++;
                if (attempt < CFG.MAX_RETRIES - 1) { await delay(1000 * (attempt+1)); continue; }
                return '⚠️ Empty response from AI service.';
            }
            return cleanAIText(fullText);

        } catch (err) {
            STATE.apiStats.errors++;
            if (attempt < CFG.MAX_RETRIES - 1) { await delay(1000 * (2**attempt)); continue; }
            return `⚠️ Neural Link Severed — ${err.message}. Check cookies.`;
        }
    }
    return '⚠️ AI service unavailable after retries.';
};

// ==============================================================================
// 9. IMGBB UPLOADER (for vision)
// ==============================================================================
const uploadToImgBB = async (filePath) => {
    if (!fs.existsSync(filePath)) return null;
    try {
        const FormData = require('form-data');
        const form = new FormData();
        form.append('image', fs.createReadStream(filePath));
        const res = await axios.post(
            `https://api.imgbb.com/1/upload?key=${CFG.IMGBB_KEY}&expiration=600`,
            form, { headers: form.getHeaders(), timeout: 30000 }
        );
        return res.data?.data?.url || null;
    } catch(e) {
        STATE.apiStats.errors++;
        return null;
    }
};

// ==============================================================================
// 10. INFIP IMAGE GENERATOR
// ==============================================================================
let infipKey = CFG.INFIP_KEY;
let infipKeyTs = 0;

const ensureInfipKey = async () => {
    if (infipKey && (Date.now() - infipKeyTs < 300000)) return true;
    try {
        const res = await axios.post(`${CFG.INFIP_BASE}/v1/api-keys`, {}, { timeout:20000 });
        if (res.status === 200 && res.data?.api_key) {
            infipKey = res.data.api_key;
            infipKeyTs = Date.now();
            return true;
        }
    } catch(_) {}
    // Try with existing key
    try {
        const res = await axios.get(`${CFG.INFIP_BASE}/v1/models`, {
            headers: { Authorization: `Bearer ${infipKey}` }, timeout:15000
        });
        if (res.status === 200) { infipKeyTs = Date.now(); return true; }
    } catch(_) {}
    return false;
};

const generateImage = async (prompt, opts={}) => {
    if (!(await ensureInfipKey())) return [];
    if (!checkRate()) return [];

    // Cache check
    const cacheKey = `${prompt}_${opts.model||CFG.IMG_MODEL}_${opts.size||CFG.IMG_SIZE}`;
    const cached = STATE.imgCache[cacheKey];
    if (cached && (Date.now() - cached.ts < CFG.CACHE_TTL * 1000)) return cached.urls;

    const payload = {
        model:           opts.model   || CFG.IMG_MODEL,
        prompt,
        n:               Math.min(opts.count || CFG.IMG_COUNT, 4),
        size:            opts.size    || CFG.IMG_SIZE,
        response_format: 'url',
        quality:         opts.quality || CFG.IMG_QUALITY,
        style:           opts.style   || CFG.IMG_STYLE
    };

    try {
        recordReq('image');
        const res = await axios.post(`${CFG.INFIP_BASE}/v1/images/generations`, payload, {
            headers: {
                Authorization: `Bearer ${infipKey}`,
                'Content-Type': 'application/json'
            },
            timeout: CFG.TIMEOUT
        });
        const urls = (res.data?.data || []).map(d => d.url);
        if (urls.length) STATE.imgCache[cacheKey] = { urls, ts: Date.now() };
        return urls;
    } catch(e) {
        STATE.apiStats.errors++;
        return [];
    }
};

const enhancePrompt = async (prompt) => {
    const enhanced = await callAI(
        `Enhance this image generation prompt for better AI art results. ` +
        `More descriptive, same intent. Return ONLY the enhanced prompt:\n\n${prompt}`
    );
    return (enhanced && !enhanced.startsWith('⚠️')) ? enhanced : prompt;
};

// ==============================================================================
// 11. GEM / HISTORY HELPERS
// ==============================================================================
const addHistory = (ctx, role, content) => {
    if (!ctx.history) ctx.history = [];
    const ts = new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
    ctx.history.push(`[${ts}] ${role}: ${content}`);
    if (ctx.history.length > CFG.HISTORY_CAP)
        ctx.history = ctx.history.slice(-CFG.HISTORY_CAP);
};

const buildPrompt = (system, history, input) =>
    `SYSTEM INSTRUCTIONS:\n${system}\n\n` +
    `--- CONVERSATION MEMORY ---\n${history.join('\n')}\n` +
    `---------------------------\n` +
    `LATEST MESSAGE: ${input}\n` +
    `YOUR REPLY:`;

// ==============================================================================
// 12. HUMAN BEHAVIOUR SIMULATION (typing delay)
// ==============================================================================
const delay = (ms) => new Promise(r => setTimeout(r, ms));
const randomBetween = (a,b) => Math.random()*(b-a)+a;

const simulateTyping = async (sock, chatId, text) => {
    if (!text) return;
    const wpm   = randomBetween(5,9);
    const dur   = Math.min(text.length / wpm, 10);
    try {
        await sock.sendPresenceUpdate('composing', chatId);
        await delay(Math.max(dur * 1000, 1000));
        await sock.sendPresenceUpdate('paused', chatId);
    } catch(_) {}
};

// ==============================================================================
// 13. WHATSAPP PROFILE UPDATER
// ==============================================================================
const updateWAName = async (sock, name) => {
    try {
        await sock.updateProfileName(name);
        return true;
    } catch(e) {
        // Fallback IQ node approach (Baileys low-level)
        try {
            await sock.query({
                tag:'iq',
                attrs:{to:'s.whatsapp.net',type:'set',xmlns:'vcard'},
                content:[{
                    tag:'vcard',attrs:{},
                    content:Buffer.from(`BEGIN:VCARD\nVERSION:3.0\nFN:${name}\nEND:VCARD`)
                }]
            });
            return true;
        } catch(_){ return false; }
    }
};

const updateWABio = async (sock, bio) => {
    try {
        await sock.updateProfileStatus(bio);
        return true;
    } catch(e) { return false; }
};

const updateWAPFP = async (sock, imgPath) => {
    try {
        if (!fs.existsSync(imgPath)) return false;
        const buf = fs.readFileSync(imgPath);
        await sock.updateProfilePicture(sock.user.id, buf);
        return true;
    } catch(e) {
        // Secondary attempt via IQ node (like owner.gmd)
        try {
            const buf = fs.readFileSync(imgPath);
            const { Jimp } = require('jimp');
            const img = await Jimp.read(buf);
            img.scaleToFit({ w:720, h:720 });
            const processed = await img.getBuffer('image/jpeg');
            await sock.query({
                tag:'iq',
                attrs:{to:'s.whatsapp.net',type:'set',xmlns:'w:profile:picture'},
                content:[{tag:'picture',attrs:{type:'image'},content:processed}]
            });
            return true;
        } catch(_){ return false; }
    }
};

