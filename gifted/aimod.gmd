    let info = `👤 *AI SESSION PROFILE: @${jid.split('@')[0]}*\n\n`;
    
    const isStalked = State.stalkers.has(jid);
    const isTargeted = State.targets.has(jid);
    const sess = isStalked ? State.stalkers.get(jid) : (isTargeted ? State.targets.get(jid) : null);

    if (!sess) {
        info += `• *Status:* ⚪ Idle\n• *Mode:* No active tracking\n`;
    } else {
        info += `• *Status:* ${isStalked ? '🔴 STALKING' : '🎯 TARGETED'}\n`;
